Parameters!ApiUrl.Value+"/sharepoint/GetReportImageFile?system=T&amp;itemId="+
Fields!DefaultDriveItemId.Value+"&amp;fileName="+
Fields!DefaultFileName.Value+"&amp;lang=en&amp;t="+Parameters!token.Value,
Parameters!TrademarkFilePath.Value + Fields!Tmk_DefaultImage.Value
+"&amp;driveItemId="+Fields!DefaultDriveItemId.Value
)</Value>
                              <Sizing>FitProportional</Sizing>
                              <Height>1in</Height>
                              <Width>1.84375in</Width>
                              <Visibility>
                                <Hidden>=Fields!DATA_OrderOfEntry.Value&lt;&gt;1</Hidden>
