                    <TablixCell>
                      <CellContents>
                        <Textbox Name="Textbox29">
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>CountryApplicationsLabel</Label>
                                  <Value>=
IIF(Parameters!PrintPatentScore.Value, Parameters!LabelScore.Value + Parameters!SettingFieldDelimiter.Value+" ", "")+
IIF(Parameters!PrintEntireFamily.Value, Parameters!LabelCaseNumber.Value + Parameters!SettingFieldDelimiter.Value+" ", "")+
Parameters!LabelCountry.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelSubCase.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelCaseType.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelStatus.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelStatusDate.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelOtherReferenceNo.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelAppNumber.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelFilDate.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelPatNumber.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelIssDate.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelExpirationDate.Value+
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelAppTitle.Value+ 
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelOwner.Value+
	IIf(Parameters!PrintDesCtrys.Value=true,
	Parameters!SettingFieldDelimiter.Value+" "+
	Parameters!LabelDesignatedCountry.Value,"")+
	IIf(Parameters!PrintValCtrys.Value=true,
	Parameters!SettingFieldDelimiter.Value+" "+
	Parameters!LabelValidatedCountries.Value,"")+
IIf(Parameters!PrintInventors.Value=true,
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelInventors.Value,"")+
	IIf(Parameters!PrintProducts.Value=true,
	Parameters!SettingFieldDelimiter.Value+" "+
	Parameters!LabelProducts.Value,"")+
IIf(Parameters!PrintSubjectMatters.Value=true,
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelSubjectMatters.Value,"")+
	IIf(Parameters!PrintAssignments.Value=true,
	Parameters!SettingFieldDelimiter.Value+" "+
	Parameters!LabelAssignments.Value,"")+
IIf(Parameters!PrintRelatedCases.Value=true,
Parameters!SettingFieldDelimiter.Value+" "+
Parameters!LabelRelatedCases.Value,"")+
	IIf(Parameters!PrintLicensee.Value=true,
	Parameters!SettingFieldDelimiter.Value+" "+
	Parameters!LabelLicenses.Value,"")+
	
IIf(Parameters!PrintCustomFields.Value=true,
	Parameters!SettingFieldDelimiter.Value+" "+
	Fields!Ca_CustomFieldLabels.Value,"")+


Parameters!SettingRecordDelimiter.Value</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>Textbox29</rd:DefaultName>
                          <DataElementOutput>NoOutput</DataElementOutput>
                          <Style>
                            <Border>
                              <Color>LightGrey</Color>
                              <Style>Solid</Style>
                            </Border>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
