  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT [PositionId],[Position],[Description],[PositionA],[PositionB],[PositionC],[CreatedBy],[DateCreated],[UpdatedBy]"
+" ,[LastUpdate] FROM [tblPatIREmployeePosition]"
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(PositionId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="PositionId">
          <DataField>PositionId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Position">
