<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Arial Unicode MS</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>DB</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>d85cd161-118b-4257-993c-5836eb77635a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT  act.[ActionTypeID],[ActionType],act.[Country],c.CountryName,[FollowUpMsg]"
     +" ,[FollowUpMonth],[FollowUpDay],[FollowUpGen],act.[Remarks],[ResponsibleID], a.Attorney"
	 +" , a.AttorneyName,act.[CreatedBy],act.[UpdatedBy],act.[DateCreated],act.[LastUpdate]"
	 +" ,[ActionDue],[Yr],[Mo],[Dy],[Indicator]"
 +" FROM [tblGMActionType] act"
 +" LEFT JOIN [tblGMActionParameter] actp ON act.ActionTypeID=actp.ActionTypeID"
 +" LEFT JOIN [tblGMCountry] c ON act.Country=c.Country"
 +" LEFT JOIN [tblAttorney] a ON act.ResponsibleID = a.AttorneyID"
 +" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(act.[ActionTypeID] as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="ActionTypeID">
          <DataField>ActionTypeID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
