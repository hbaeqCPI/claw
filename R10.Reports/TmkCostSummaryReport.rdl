              <Height>0.3in</Height>
              <Width>3.5in</Width>
              <ZIndex>1</ZIndex>
              <Style>
                <Border>
                  <Style>None</Style>
                </Border>
              </Style>
            </Textbox>
            <Textbox Name="ExecutionTime">
              <CanGrow>true</CanGrow>
              <KeepTogether>true</KeepTogether>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Value>=Globals!ExecutionTime</Value>
                      <Style>
                        <FontSize>8pt</FontSize>
                        <Format>D</Format>
                      </Style>
                    </TextRun>
                  </TextRuns>
                  <Style>
                    <TextAlign>Right</TextAlign>
                  </Style>
                </Paragraph>
              </Paragraphs>
              <rd:DefaultName>ExecutionTime</rd:DefaultName>
              <Top>0.35833in</Top>
              <Left>5.7in</Left>
              <Height>0.15in</Height>
              <Width>2.2in</Width>
              <ZIndex>2</ZIndex>
              <Style>
                <Border>
                  <Style>None</Style>
                </Border>
              </Style>
            </Textbox>
            <Textbox Name="Pages">
              <CanGrow>true</CanGrow>
              <KeepTogether>true</KeepTogether>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Label>Page</Label>
                      <Value>="Page " &amp; Globals!PageNumber &amp; " of " &amp; Globals!TotalPages</Value>
                      <Style>
                        <FontSize>8pt</FontSize>
                      </Style>
                    </TextRun>
                  </TextRuns>
                  <Style>
                    <TextAlign>Right</TextAlign>
                  </Style>
                </Paragraph>
              </Paragraphs>
              <Top>0.1in</Top>
              <Left>5.7in</Left>
              <Height>0.15in</Height>
              <Width>2.2in</Width>
              <ZIndex>3</ZIndex>
              <Style>
                <Border>
                  <Style>None</Style>
                </Border>
              </Style>
            </Textbox>
            <Textbox Name="Textbox1">
              <CanGrow>true</CanGrow>
              <KeepTogether>true</KeepTogether>
              <Paragraphs>
                <Paragraph>
                  <TextRuns>
                    <TextRun>
                      <Label>FilterDateFromToLabel</Label>
                      <Value>=Switch(
Parameters!DateType.Value = 1, Parameters!LabelInvoiceDate.Value, 
Parameters!DateType.Value = 2, Parameters!LabelPaymentDate.Value, 
True, "") + " " &amp; 
Parameters!LabelFrom.Value+" " &amp; 
IIF(IsNothing(Parameters!FromDate.Value),"", Format(Parameters!FromDate.Value,Parameters!SettingDateFormat.Value))
&amp; " "+Parameters!LabelTo.Value+" " &amp; 
IIF(IsNothing(Parameters!ToDate.Value),"", Format(Parameters!ToDate.Value ,Parameters!SettingDateFormat.Value))</Value>
                      <Style>
                        <FontSize>11pt</FontSize>
                      </Style>
                    </TextRun>
                  </TextRuns>
                  <Style>
