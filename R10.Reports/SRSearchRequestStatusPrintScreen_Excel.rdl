  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT [ClearanceStatusId],[ClearanceStatus],[Description],[ActiveSwitch], [WorkflowOrder],[CreatedBy],[DateCreated],[UpdatedBy]"
+" ,[LastUpdate] FROM [tblTmcClearanceStatus]"
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(ClearanceStatusId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="ClearanceStatusId">
          <DataField>ClearanceStatusId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ClearanceStatus">
          <DataField>ClearanceStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
