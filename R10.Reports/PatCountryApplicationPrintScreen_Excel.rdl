                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Rectangle Name="Rectangle5">
                          <ReportItems>
                            <Image Name="Image7">
                              <Source>External</Source>
                              <Value>=IIF(Parameters!SettingIsSharePointIntegrationOn.Value = true,
Parameters!ApiUrl.Value+"/sharepoint/GetReportImageFile?system=P&amp;itemId="+
Fields!DefaultDriveItemId.Value+"&amp;fileName="+
Fields!DefaultFileName.Value+"&amp;lang=en&amp;t="+Parameters!token.Value,
Parameters!PatentFilePath.Value + Fields!CA_DefaultImage.Value
+"&amp;driveItemId="+Fields!DefaultDriveItemId.Value
)</Value>
                              <Sizing>FitProportional</Sizing>
                              <Height>0.6in</Height>
                              <Width>1.5in</Width>
                              <Visibility>
                                <Hidden>=IIF(Parameters!SettingIsSharePointIntegrationOn.Value, IsNothing(Fields!DefaultDriveItemId.Value), IsNothing(Fields!CA_DefaultImage.Value))</Hidden>
                              </Visibility>
                              <Style>
                                <Border>
                                  <Style>None</Style>
                                </Border>
                              </Style>
                            </Image>
                          </ReportItems>
                          <KeepTogether>true</KeepTogether>
                          <DataElementOutput>NoOutput</DataElementOutput>
                          <Style>
                            <Border>
                              <Color>Silver</Color>
                              <Style>Solid</Style>
                            </Border>
                          </Style>
                        </Rectangle>
                      </CellContents>
