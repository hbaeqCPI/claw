                  <TablixCells>
                    <TablixCell>
                      <CellContents>
                        <Textbox Name="SortOption">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>SortorderLabel</Label>
                                  <Value>=Switch(
Parameters!SortOrder.Value = 2, Parameters!LabelAttorney.Value, 
Parameters!SortOrder.Value = 3, Parameters!LabelClient.Value, 
Parameters!SortOrder.Value = 7, Parameters!LabelAgent.Value, 
Parameters!SortOrder.Value = 8, Parameters!LabelCountry.Value, 
Parameters!SortOrder.Value = 9, Parameters!LabelRespOffice.Value, 
True, "")</Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Value>: </Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label>SortCode</Label>
                                  <Value>=Switch(
Parameters!SortOrder.Value = 2, Fields!Attorney.Value, 
Parameters!SortOrder.Value = 3, Fields!Client.Value, 
Parameters!SortOrder.Value = 7, Fields!Agent.Value, 
Parameters!SortOrder.Value = 8, Fields!Country.Value, 
Parameters!SortOrder.Value = 9, Fields!RespOffice.Value, 
True, "")</Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                                <TextRun>
                                  <Label> - </Label>
                                  <Value>=Switch(
Parameters!SortOrder.Value = 2 AND Not (IsNothing(Fields!Attorney.Value) OrElse Fields!Attorney.Value=""), " - ", 
Parameters!SortOrder.Value = 3 AND Not (IsNothing(Fields!Client.Value) OrElse Fields!Client.Value=""), " - ", 
Parameters!SortOrder.Value = 7 AND Not (IsNothing(Fields!Agent.Value) OrElse Fields!Agent.Value=""), " - ", 
Parameters!SortOrder.Value = 8 AND Not (IsNothing(Fields!Country.Value) OrElse Fields!Country.Value=""), " - ", 
True, "")</Value>
                                  <Style>
                                    <FontWeight>Bold</FontWeight>
                                  </Style>
                                </TextRun>
                                <TextRun>
