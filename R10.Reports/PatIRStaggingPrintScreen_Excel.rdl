  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT s.[StaggeringId],s.[Year],sd.[Stage],sd.[AmountFrom],sd.[AmountTo],sd.[Reduction]"
+" ,s.[CreatedBy],s.[DateCreated],s.[UpdatedBy],s.[LastUpdate] FROM [tblPatIRStaggering] s LEFT JOIN [tblPatIRStaggeringDetail] sd ON s.StaggeringId = sd.StaggeringId"
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(s.StaggeringId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="StaggeringId">
          <DataField>StaggeringId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Year">
          <DataField>Year</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Stage">
          <DataField>Stage</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AmountFrom">
          <DataField>AmountFrom</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="AmountTo">
          <DataField>AmountTo</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="Reduction">
          <DataField>Reduction</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="CreatedBy">
          <DataField>CreatedBy</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DateCreated">
          <DataField>DateCreated</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="UpdatedBy">
          <DataField>UpdatedBy</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LastUpdate">
          <DataField>LastUpdate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
