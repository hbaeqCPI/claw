  <Code>Public Function DisplayAttorneyFilter(ByVal af As String) As String
	If af = Nothing Then
		Return ""
	End If

	Dim result = ""
	If af.Contains("A1") Then
		If result = "" Then
			result = "Attorney1"
		Else
			result = result + ", Attorney1"
		End If
	End If
	If af.Contains("A2") Then
		If result = "" Then
			result = "Attorney2"
		Else
			result = result + ", Attorney2"
		End If
	End If
	If af.Contains("A3") Then
		If result = "" Then
			result = "Attorney3"
		Else
			result = result + ", Attorney3"
		End If
	End If
	If af.Contains("AR") Then
		If result = "" Then
			result = "Responsible Person"
		Else
			result = result + ", Responsible Person"
		End If
	End If

	Return result
End Function

Public Function DisplayEqualSign(ByVal e As String) As String
        If e.Equals("eq") Then
            Return "="
        Else
            Return "&lt;&gt;"
        End If
    End Function

Public Function JoinArray(ByVal ParamArray mvs() As String) As String
        Dim result = ""
	result = mvs(0)
        Return result
    End Function
</Code>
