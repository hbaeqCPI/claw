  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT [FormulaId],[Name],[Description],[MaxValue],[MinValue],[RemunerationType],[EffStartDate],[EffEndDate],[Formula]"
+" ,FormulaFactorInfo = (SELECT LEFT(STUFF((SELECT ( CHAR(10) + '{'+[Variable]+'} - ' + [Name])"
+" FROM [tblPatIRRemunerationFormulaFactor] WITH (NOLOCK)"
+" WHERE [tblPatIRRemunerationFormula].[Formula] LIKE '%{' + [tblPatIRRemunerationFormulaFactor].[Variable] + '}%'"
+" FOR XML PATH( '' ), TYPE).value('.', 'VARCHAR(MAX)'),  1, 1, ''), 32767))"
+" ,[CreatedBy],[DateCreated],[UpdatedBy],[LastUpdate] FROM [tblPatIRRemunerationFormula]"
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(FormulaId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="FormulaId">
          <DataField>FormulaId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Name">
