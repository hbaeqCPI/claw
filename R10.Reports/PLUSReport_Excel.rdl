                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Label>SortOrder</Label>
                                  <Value>=Switch(
Parameters!ReportType.Value = 1, Fields!Examiner.Value, 
Parameters!ReportType.Value = 2, Fields!GroupArtUnit.Value, 
Parameters!ReportType.Value = 3, Fields!ConfirmNo.Value, 
Parameters!ReportType.Value = 4, Fields!Class.Value, 
Parameters!ReportType.Value = 5, 
Switch(
Parameters!SortOrder.Value = "1",Fields!CaseNumber.Value,
Parameters!SortOrder.Value = "2",Fields!ClientName.Value,
Parameters!SortOrder.Value = "3",Fields!FirstOwner.Value,
True, ""),
Parameters!ReportType.Value = 6, "", 
Parameters!ReportType.Value = 7, "", 
Parameters!ReportType.Value = 8, Fields!CorrespondenceName.Value, 
True, "")</Value>
                                  <Style />
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
