                    <TextRun>
                      <Label>FilterDateFromToLabel</Label>
                      <Value>=Parameters!LabelGazetteDate.Value + " " &amp; Parameters!LabelFrom.Value + " " &amp; IIF(IsNothing(Parameters!FromDate.Value), "", Format(Parameters!FromDate.Value, Parameters!SettingDateFormat.Value)) &amp; " " + Parameters!LabelTo.Value + " " &amp; IIF(IsNothing(Parameters!ToDate.Value), "", Format(Parameters!ToDate.Value, Parameters!SettingDateFormat.Value))</Value>
                      <Style>
                        <FontSize>11pt</FontSize>
                      </Style>
                    </TextRun>
                  </TextRuns>
                  <Style>
                    <TextAlign>Center</TextAlign>
                  </Style>
                </Paragraph>
              </Paragraphs>
              <rd:DefaultName>Textbox1</rd:DefaultName>
              <Top>0.3in</Top>
              <Left>2.2in</Left>
              <Height>0.2in</Height>
              <Width>6in</Width>
              <ZIndex>5</ZIndex>
              <Visibility>
                <Hidden>=IsNothing(Parameters!FromDate.Value) AndAlso IsNothing(Parameters!ToDate.Value)</Hidden>
              </Visibility>
              <Style>
                <Border>
                  <Style>None</Style>
                </Border>
              </Style>
            </Textbox>
          </ReportItems>
          <Style>
            <Border>
              <Style>None</Style>
            </Border>
          </Style>
        </PageHeader>
        <PageHeight>8.5in</PageHeight>
        <PageWidth>11in</PageWidth>
        <InteractiveHeight>0in</InteractiveHeight>
        <InteractiveWidth>11in</InteractiveWidth>
        <LeftMargin>0.3in</LeftMargin>
        <RightMargin>0.3in</RightMargin>
        <TopMargin>0.3in</TopMargin>
        <BottomMargin>0.3in</BottomMargin>
        <Style />
      </Page>
    </ReportSection>
  </ReportSections>
