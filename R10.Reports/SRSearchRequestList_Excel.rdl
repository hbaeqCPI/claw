                    <TablixCell>
                      <CellContents>
                        <Rectangle Name="Rectangle1">
                          <ReportItems>
                            <Tablix Name="Tablix2">
                              <TablixBody>
                                <TablixColumns>
                                  <TablixColumn>
                                    <Width>1in</Width>
                                  </TablixColumn>
                                </TablixColumns>
                                <TablixRows>
                                  <TablixRow>
                                    <Height>1in</Height>
                                    <TablixCells>
                                      <TablixCell>
                                        <CellContents>
                                          <Image Name="Image1">
                                            <Source>External</Source>
                                            <Value>=IIF(Parameters!SettingIsSharePointIntegrationOn.Value = false OrElse Fields!Img_ImageFile.Value Like "logo_*",
Parameters!ThumbnailsFilePath.Value + Fields!Img_ImageFile.Value,
Parameters!ApiUrl.Value+"/sharepoint/GetReportImageFile?system=C&amp;itemId="+
Fields!Img_DriveItemId.Value+"&amp;fileName="+
Fields!Img_UserFileName.Value+"&amp;lang=en&amp;t="+Parameters!token.Value
)</Value>
                                            <Sizing>FitProportional</Sizing>
                                            <Style>
                                              <Border>
                                                <Style>None</Style>
                                              </Border>
                                            </Style>
                                          </Image>
                                        </CellContents>
                                      </TablixCell>
                                    </TablixCells>
                                  </TablixRow>
                                </TablixRows>
                              </TablixBody>
                              <TablixColumnHierarchy>
                                <TablixMembers>
                                  <TablixMember>
                                    <Group Name="FileName">
                                      <GroupExpressions>
                                        <GroupExpression>=Fields!Img_OrderOfEntry.Value Mod 10000</GroupExpression>
                                      </GroupExpressions>
                                    </Group>
                                    <Visibility>
                                      <Hidden>=IsNothing(Fields!Img_LinkId.Value)</Hidden>
                                    </Visibility>
                                  </TablixMember>
                                </TablixMembers>
                              </TablixColumnHierarchy>
                              <TablixRowHierarchy>
                                <TablixMembers>
                                  <TablixMember>
                                    <Group Name="Id">
                                      <GroupExpressions>
                                        <GroupExpression>=Floor(Fields!Qst_OrderOfEntry.Value/10000)</GroupExpression>
                                      </GroupExpressions>
                                    </Group>
                                  </TablixMember>
                                </TablixMembers>
                              </TablixRowHierarchy>
                              <Height>1in</Height>
                              <Width>1in</Width>
                              <Style>
                                <Border>
                                  <Style>None</Style>
                                </Border>
                              </Style>
                            </Tablix>
                          </ReportItems>
                          <KeepTogether>true</KeepTogether>
                          <DataElementOutput>NoOutput</DataElementOutput>
                          <Style>
                            <Border>
                              <Color>LightGrey</Color>
                              <Style>Solid</Style>
                            </Border>
                          </Style>
                        </Rectangle>
                      </CellContents>
                    </TablixCell>
                  </TablixCells>
                </TablixRow>
              </TablixRows>
            </TablixBody>
            <TablixColumnHierarchy>
              <TablixMembers>
                <TablixMember>
                  <Visibility>
                    <Hidden>=Switch(
Parameters!SortOrder.Value = 2, false, 
Parameters!SortOrder.Value = 3, false, 
Parameters!SortOrder.Value = 4, false, 
True, true)</Hidden>
                  </Visibility>
                </TablixMember>
                <TablixMember>
                  <Visibility>
                    <Hidden>=Parameters!SortOrder.Value&lt;&gt;3</Hidden>
                  </Visibility>
                </TablixMember>
                <TablixMember />
                <TablixMember>
                  <Visibility>
                    <Hidden>=Parameters!SortOrder.Value=2</Hidden>
                  </Visibility>
                </TablixMember>
                <TablixMember />
                <TablixMember />
                <TablixMember />
                <TablixMember>
                  <Visibility>
                    <Hidden>=Parameters!SortOrder.Value=3</Hidden>
                  </Visibility>
                </TablixMember>
                <TablixMember>
                  <Visibility>
                    <Hidden>=Parameters!SortOrder.Value=3</Hidden>
                  </Visibility>
                </TablixMember>
                <TablixMember>
