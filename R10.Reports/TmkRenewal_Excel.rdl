                            <Image Name="Image3">
                              <Source>External</Source>
                              <Value>=IIF(Parameters!SettingIsSharePointIntegrationOn.Value = true,
Parameters!ApiUrl.Value+"/sharepoint/GetReportImageFile?system=T&amp;itemId="+
Fields!Tmk_DefaultDriveItemId.Value+"&amp;fileName="+
Fields!Tmk_DefaultFileName.Value+"&amp;lang=en&amp;t="+Parameters!token.Value,
Parameters!TrademarkFilePath.Value + Fields!DefaultImage.Value
+"&amp;driveItemId="+Fields!Tmk_DefaultDriveItemId.Value
)</Value>
                              <Sizing>FitProportional</Sizing>
                              <Height>1in</Height>
                              <Width>1.8125in</Width>
                              <Visibility>
                                <Hidden>=Parameters!PrintShowDefaultImage.Value=false OrElse IsNothing(Fields!DefaultImage.Value)</Hidden>
                              </Visibility>
                              <Style>
                                <Border>
                                  <Style>None</Style>
                                </Border>
                              </Style>
                            </Image>
                          </ReportItems>
