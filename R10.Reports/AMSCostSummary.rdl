  <Code>Public Function DisplayEqualSign(ByVal e As String) As String
        If e.Equals("eq") Then
            Return "="
        Else
            Return "&lt;&gt;"
        End If
    End Function

Public Function FormatDate(ByVal e As String) As String
        Return e.Substring(5, 2) + "/" + e.Substring(8, 2) + "/" + e.Substring(0, 4)
    End Function

Public Function UrlEncode (ByVal e As String) As String
	Return System.Web.HttpUtility.UrlEncode(e)
End Function
