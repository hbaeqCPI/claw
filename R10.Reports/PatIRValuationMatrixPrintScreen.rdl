<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Arial Unicode MS</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>DB</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>d85cd161-118b-4257-993c-5836eb77635a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT m.[MatrixId],m.[Name],m.[Description],m.[ActiveSwitch],m.[MatrixType],m.[Variable],m.[MaxValue],m.[MinValue],m.[DefaultValue],m.[AllowManualEntry]"
+" ,mt.[AvaliableMatrixOptions],mc.[Category] AS C_Category,mc.[ActiveSwitch] AS C_ActiveSwitch,mc.[MaxValue] AS C_MaxValue,mc.[MinValue] AS C_MinValue,mc.[Value] AS C_Value"
+" ,m.[CreatedBy],m.[DateCreated],m.[UpdatedBy],m.[LastUpdate] FROM [tblPatIRRemunerationValuationMatrix] m LEFT JOIN [tblPatIRRemunerationValuationMatrixType] mt ON m.MatrixType = mt.MatrixType LEFT JOIN [tblPatIRRemunerationValuationMatrixCriteria] mc ON m.MatrixId = mc.MatrixId"
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(m.MatrixId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="MatrixId">
          <DataField>MatrixId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
