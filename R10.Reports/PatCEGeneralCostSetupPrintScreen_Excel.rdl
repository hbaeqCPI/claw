  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT gs.CEGeneralId,gs.[CostSetup],gs.[Description],gs.[CreatedBy],gs.[UpdatedBy]"
     +" ,gs.[DateCreated],gs.[LastUpdate],gc.[CostId],gc.[Description] AS CostType,gc.DataType,gc.DefaultValue"
	 +" , gc.Cost,gc.AltCost,gc.Opts,gc.OrderOfEntry,gc.CPICost,gc.ActiveSwitch,gc.MultCost"
 +" FROM [tblPatCEGeneralSetup] gs LEFT JOIN [tblPatCEGeneralCost] gc on gs.CEGeneralId=gc.CEGeneralId "
  +" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(gs.CEGeneralId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="CEGeneralId">
          <DataField>CEGeneralId</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
