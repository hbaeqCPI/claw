                      <Label>SortOrder</Label>
                      <Value>=Switch(Parameters!SortOrder.Value = 1, Parameters!LabelByClientThenCaseNumber.Value, Parameters!SortOrder.Value = 2, Parameters!LabelByCountryThenCaseNumber.Value, Parameters!SortOrder.Value = 3, Parameters!LabelByClientThenDueDate.Value, Parameters!SortOrder.Value = 4, Parameters!LabelByCaseNumber.Value, Parameters!SortOrder.Value = 5, Parameters!LabelByDueDate.Value, True, "")</Value>
