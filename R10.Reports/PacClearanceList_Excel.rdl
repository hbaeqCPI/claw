+ Parameters!LabelMessage.Value 
+ Parameters!SettingFieldDelimiter.Value + " " 
+ Parameters!LabelPostedBy.Value 
+ Parameters!SettingFieldDelimiter.Value + " " 
+ Parameters!LabelPostedOn.Value 
+ "(" + Parameters!LabelReplyMessage.Value 
+ Parameters!SettingFieldDelimiter.Value + " " 
+ Parameters!LabelPostedBy.Value 
+ Parameters!SettingFieldDelimiter.Value + " " 
+ Parameters!LabelPostedOn.Value 
+ Parameters!SettingRecordDelimiter.Value + ")" 
