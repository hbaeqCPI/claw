  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT cp.ContactID, cp.Contact, cp.ContactName, cp.Address1, cp.Address2, cp.Address3, cp.Address4, cp.City, cp.Country, cp.State, cp.ZipCode, cp.FaxNumber, cp.MobileNumber, cp.PhoneNumber,"
      +" cp.EMail,"
      +" cp.Remarks, cp.CreatedBy, cp.DateCreated, cp.UpdatedBy, cp.LastUpdate"
+" FROM tblContactPerson AS cp"
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(cp.ContactID as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
