  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT f.FeeSetupId,f.[CEFeeSetupName] AS FeeSetupName,f.[Description],f.[CreatedBy],f.[UpdatedBy]"
     +" ,f.[DateCreated],f.[LastUpdate],fd.[FeeDetailId],fd.[OrderOfEntry],fd.Country,fd.CaseType"
	 +" , fd.Amount,fd.EffFromDate,fd.EffToDate"
 +" FROM [tblTmkCEFee] f LEFT JOIN [tblTmkCEFee_Dtl] fd on f.FeeSetupId=fd.FeeSetupId "
  +" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(f.FeeSetupId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="FeeSetupId">
          <DataField>FeeSetupId</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
