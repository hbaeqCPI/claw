  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT a.AgentID, a.Agent, a.AgentName, a.Address1, a.Address2, a.Address3, a.Address4, a.City, a.Country, a.State, a.ZipCode, a.FaxNumber, a.MobileNumber, a.PhoneNumber, a.Language,"
      +" a.EMail, a.WebSite, a.POAddress1, a.POAddress2, a.POAddress3, a.POAddress4,"
      +" a.POCity, a.POCountry, a.POState, a.POZipCode, left(ISNULL([a].[Remarks],''), 32767) AS Remarks, a.CreatedBy, a.DateCreated, a.UpdatedBy, a.LastUpdate, STUFF"
                            +" ((SELECT        TOP (100) PERCENT  cp.ContactName +'; ' "
                                +" FROM            tblContactPerson AS cp WITH (NOLOCK) INNER JOIN"
                                                         +" tblAgentContact AS ac WITH (NOLOCK) ON cp.ContactID = ac.ContactID"
                                +" WHERE        (ac.AgentID = a.AgentID)"
                                +" ORDER BY ac.[Default] FOR XML PATH('')), 1, 0, '') AS ContactName"
+" FROM tblAgent AS a "
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(a.AgentID as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
