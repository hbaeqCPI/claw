                                  <Label>SortOrderLabel</Label>
                                  <Value>=Switch(
Parameters!SortOrder.Value = 1, Parameters!LabelCaseNumber.Value, 
Parameters!SortOrder.Value = 2, Parameters!LabelCountry.Value, 
Parameters!SortOrder.Value = 3, Parameters!LabelClient.Value, 
Parameters!SortOrder.Value = 4, Parameters!LabelOwner.Value, 
Parameters!SortOrder.Value = 5, Parameters!LabelInventor.Value, 
Parameters!SortOrder.Value = 5, Parameters!LabelAttorney.Value, 
True, "")</Value>
