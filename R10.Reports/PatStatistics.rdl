  <Code>Public Function DisplayEqualSign(ByVal e As String) As String
        If e.Equals("eq") Then
            Return "="
        Else
            Return "&lt;&gt;"
        End If
    End Function

Public Function GetPivotLabel(ByVal t As Int32, ByVal e As String) As String
        Dim currentColumnName = ""
        If t = 1 Then
            currentColumnName = Right(e, 2) +
                         Right(Left(e, 4), 2)
        ElseIf t = 2 Then
            Dim q = ""
            Select Case Right(e, 1)
                Case "1"
                    q = "I"
                Case "2"
                    q = "II"
                Case "3"
                    q = "III"
                Case "4"
                    q = "IV"
            End Select
            currentColumnName = Right(Left(e, 4), 2) + "-" + q
        Else
            currentColumnName = e
        End If
        Return currentColumnName
    End Function
</Code>
