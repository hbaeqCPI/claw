<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Arial Unicode MS</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>DB</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>d85cd161-118b-4257-993c-5836eb77635a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>="SELECT [FactorId],[Name],[Description],[Variable],[MaxValue],[MinValue],[DefaultValue],[AllowManualEntry],[Formula]"
+" ,ValuationMatrixInfo = (SELECT LEFT(STUFF((SELECT ( CHAR(10) + '{'+[Variable]+'} - ' + [Name])"
+" FROM [tblPatIRRemunerationValuationMatrix] WITH (NOLOCK)"
+" WHERE [tblPatIRRemunerationFormulaFactor].[Formula] LIKE '%{' + [tblPatIRRemunerationValuationMatrix].[Variable] + '}%'"
+" FOR XML PATH( '' ), TYPE).value('.', 'VARCHAR(MAX)'),  1, 1, ''), 32767))"
+" ,[CreatedBy],[DateCreated],[UpdatedBy],[LastUpdate] FROM [tblPatIRRemunerationFormulaFactor]"
+" WHERE '"
+Parameters!IDs.Value
+"' LIKE ('%|' + CAST(FactorId as varchar(10)) + '|%')"</CommandText>
        <Timeout>180</Timeout>
      </Query>
      <Fields>
        <Field Name="FactorId">
          <DataField>FactorId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Variable">
          <DataField>Variable</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
        <Field Name="MaxValue">
          <DataField>MaxValue</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="MinValue">
          <DataField>MinValue</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="DefaultValue">
          <DataField>DefaultValue</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="AllowManualEntry">
          <DataField>AllowManualEntry</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="Formula">
          <DataField>Formula</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="ValuationMatrixInfo">
          <DataField>ValuationMatrixInfo</DataField>
          <rd:UserDefined>true</rd:UserDefined>
        </Field>
        <Field Name="CreatedBy">
          <DataField>CreatedBy</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DateCreated">
          <DataField>DateCreated</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="UpdatedBy">
          <DataField>UpdatedBy</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LastUpdate">
          <DataField>LastUpdate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
