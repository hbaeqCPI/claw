                      <Label>SortOrder</Label>
                      <Value>=Switch(Parameters!SortOrder.Value = 1, Parameters!LabelByCaseNumber.Value, Parameters!SortOrder.Value = 2, Parameters!LabelByRequestorName.Value, Parameters!SortOrder.Value = 3, Parameters!LabelByClient.Value, Parameters!SortOrder.Value = 4, Parameters!LabelByAttorney.Value, True, "")</Value>
