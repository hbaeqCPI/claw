                  <TextRuns>
                    <TextRun>
                      <Label>FilterDateFromToLabel</Label>
                      <Value>=Switch(
Parameters!DateType.Value = 1, Parameters!LabelDateRequested.Value, 
Parameters!DateType.Value = 2, Parameters!LabelStatusDate.Value, 
True, "")  
&amp; 
" "+Parameters!LabelFrom.Value+" " &amp; 
IIF(
IsNothing(Parameters!FromDate.Value),"", Format(Parameters!FromDate.Value,Parameters!SettingDateFormat.Value)) 
&amp; " "+Parameters!LabelTo.Value+" " &amp; 
IIF(
IsNothing(Parameters!ToDate.Value),"", Format(Parameters!ToDate.Value ,Parameters!SettingDateFormat.Value))</Value>
                      <Style>
                        <FontSize>11pt</FontSize>
                      </Style>
                    </TextRun>
