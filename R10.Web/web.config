<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <httpRuntime maxRequestLength="10240" useFullyQualifiedRedirectUrl="true" />
  </system.web>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <security>
        <requestFiltering removeServerHeader="true">
		  <requestLimits maxQueryString="10240" maxAllowedContentLength="1024000000" />			
        </requestFiltering>
      </security>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="%LAUNCHER_PATH%" arguments="%LAUNCHER_ARGS%" stdoutLogEnabled="false" requestTimeout="01:00:00" hostingModel="inprocess">
        <environmentVariables />
      </aspNetCore>
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <remove name="server" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>