@model IEnumerable<ChartDTO>
@using Newtonsoft.Json.Linq;
@using Microsoft.EntityFrameworkCore;
@inject IClientService ClientService
@inject R10.Core.Interfaces.DMS.IDMSInventorService _dmsInventorService
@inject IStringLocalizer<PatentResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var patSettings = await Settings.GetSetting();
    var clientLabel = Localizer[patSettings.LabelClient ?? "Client"];
    var clientNameLabel = Localizer[patSettings.LabelClientName ?? "Client Name"];
    var disclosureNumberLabel = Localizer[patSettings.LabelDisclosureNumber ?? "Disclosure Number"];

    WidgetViewModel widget = (WidgetViewModel)(ViewData["WidgetViewModel"] ?? new WidgetViewModel());
    var gridDetailTitle = Localizer[widget.Title + " - {0}"];
    var viewNameSplit = widget.ViewName.ToString().Split("/");
    var viewName = viewNameSplit[viewNameSplit.Length - 1];
    var userWidgetId = widget.Id.ToString() + viewName;

    var settings = widget.UserSettings;

    List<ClientListViewModel> clients = new List<ClientListViewModel>();

    if (settings.Property("Clients") != null)
    {
        try
        {
            int[] clientFilter = ((JArray)settings.Property("Clients").Value).Select(a => (int)a).ToArray();

            if (clientFilter.Count() > 0)
            {
                clients = await ClientService.QueryableList
                                        .Where(c => clientFilter.Contains(c.ClientID))
                                        .Select(c => new ClientListViewModel
                                                {
                                                    ClientID = c.ClientID,
                                                    ClientCode = c.ClientCode,
                                                    ClientName = c.ClientName
                                                })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }

    List<PatInventorListViewModel> inventors = new List<PatInventorListViewModel>();
    if (settings.Property("Inventors") != null)
    {
        try
        {
            int[] inventorFilter = ((JArray)settings.Property("Inventors").Value).Select(a => (int)a).ToArray();

            if (inventorFilter.Count() > 0)
            {
                inventors = await _dmsInventorService.QueryableListWithEntityFilter
                                .Where(c => inventorFilter.Contains(c.PatInventor.InventorID))
                                .Select(c => new PatInventorListViewModel
                                        {
                                            InventorID = c.PatInventor.InventorID,
                                            Inventor = c.PatInventor.Inventor
                                        })
                                .Distinct()
                                .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }

    var sortedStatus = Model.Select(d => new { Status = d.Category, Order = d.Color }).Distinct().ToList();
}
<script>
    var selectedStatus = "";
    var refresh = false;

    $(document).ready(function () {
        var clientList = [@String.Join(",", clients.Select(a => a.ClientID).ToList())];
        var inventorList = [@String.Join(",", inventors.Select(a => a.InventorID).ToList())];      
        
        setLabelColor();
        $(document).on("click", ".widget .view", function (e) {
            setLabelColor();
        });
        
        $(document).off("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close");
        $(document).on("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close", function (e) {
            if (refresh) {
                $("#@widget.Id .refresh").click();
            }
        });

        $(document).off("click", "#clientFilter_@userWidgetId .delete-client");
        $(document).off("change", "#ClientCode_@userWidgetId");
        $(document).on("click", "#clientFilter_@userWidgetId .delete-client", function (e) {
            var item = $.inArray($(this).data("id"), clientList);

            if (item !== -1) {
                clientList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#ClientCode_@userWidgetId", function (e) {
            var client = $(this).data("kendoMultiColumnComboBox");

            if (client.selectedIndex >= 0) {
                var dataItem = client.dataItem(client.selectedIndex);

                var clientId = dataItem.ClientID;
                var clientCode = dataItem.ClientCode;
                var clientName = dataItem.ClientName;

                if ($.inArray(clientId, clientList) == -1) {
                    clientList.push(clientId);
                    $("#clientFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="client-code">${clientCode}</span><span class="client-name">${clientName}</span></div><div class="delete-filter delete-client" data-id="${clientId}" title="Remove ${clientCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
                }
            }

            client.value("");
        });

        $(document).off("click", "#inventorFilter_@userWidgetId .delete-inventor");
        $(document).off("change", "#Inventor_@userWidgetId");
        $(document).on("click", "#inventorFilter_@userWidgetId .delete-inventor", function (e) {
            var item = $.inArray($(this).data("id"), inventorList);

            if (item !== -1) {
                inventorList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Inventors: [${inventorList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#Inventor_@userWidgetId", function (e) {
            var inventor = $(this).data("kendoComboBox");

            if (inventor.selectedIndex >= 0) {
                var dataItem = inventor.dataItem(inventor.selectedIndex);

                var inventorId = dataItem.InventorID;
                var inventorCode = dataItem.Inventor;

                if ($.inArray(inventorId, inventorList) == -1) {
                    inventorList.push(inventorId);
                    $("#inventorFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="inventor-code">${inventorCode}</span></div><div class="delete-filter delete-inventor" data-id="${inventorId}" title="Remove ${inventorCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Inventors: [${inventorList.toString()}] }`, function () { refresh = true; });
                }
            }

            inventor.value("");
        });

        if ('@(widget.IsDetail)' === '@true') {
            var chart = $("#@userWidgetId").data("kendoChart");
            chart.bind("seriesClick", onSeriesClick);
            $("#@userWidgetId").attr("style", "position: static !important;");
            $("#@userWidgetId-grid-header").hide();

            var grid = $("#@userWidgetId-grid").data("kendoGrid");
            grid.dataSource.read();
        }

    });

    function setLabelColor() {
        var chart = $("#@userWidgetId");
        var svg = chart.find("svg");
        $.each(svg.find("g"), function () {
            $.each(svg.find("text"), function () {
                if (this.getAttribute("fill").includes("white")) {
                    this.style.fill = 'white';
                }
            });
        });
    }

    function onSeriesClick(e) {
        var grid = $("#@userWidgetId-grid").data("kendoGrid");
        grid.dataSource.read({ userWidgetId: @widget.Id, status: e.dataItem["Category"] });

        var gridTitle = "@gridDetailTitle";
        $("#@userWidgetId-grid-title").text(gridTitle.replace("{0}",  e.dataItem["Category"]));
        $("#@userWidgetId-grid-header").show();

        selectedStatus = e.dataItem["Category"];
    };

    function gridExcelExport(e) {
        e.preventDefault();
        var excelExportUrl = "@Url.Action("DMSInventionProgressionDetailExportExcel", "Dashboard")";
        const dataJSON = JSON.stringify({ userWidgetId: @widget.Id, status: selectedStatus });
        const html = '<form method="POST" action="' + excelExportUrl + '">' +
            '<input type="hidden" name="__RequestVerificationToken" value="' + $("[name='__RequestVerificationToken']").val() + '">';
        let form = $(html);
        form.append($('<input type="hidden" name="filtersJSON"/>').val(dataJSON));
        $('body').append(form);
        form.submit();
    };

    function gridDetailSearchFilters() {
        return { userWidgetId: @widget.Id, status: selectedStatus };
    };

</script>

<div class="widget-settings" style="max-height: 425px;">
    <div class="settings-body">
        <ul id="clientFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@clientLabel</span>
                <span>@await Component.InvokeAsync("ComboBox", ComboBoxHelper.ClientID("ClientCode", @clientLabel, @clientNameLabel, "DisclosureLookup", "DMS", userWidgetId))</span>
            </li>
            @foreach (ClientListViewModel client in clients)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="client-code">@client.ClientCode</span>
                        <span class="client-name">@client.ClientName</span>
                    </div>
                    <div class="delete-filter delete-client" data-id="@client.ClientID" title="Remove @client.ClientCode"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
        <ul id="inventorFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@Localizer["Inventor"]</span>
                <span>@await Component.InvokeAsync("ComboBox", new { name = "Inventor", textProperty = "Inventor", valueProperty = "InventorID", controller = "DMSInventor", action = "GetFilteredInventorList", area = "DMS", listWidth = 400, screen = userWidgetId })</span>
            </li>
            @foreach (PatInventorListViewModel inventor in inventors)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="inventor-code">@inventor.Inventor</span>
                    </div>
                    <div class="delete-filter delete-inventor" data-id="@inventor.InventorID" title="Remove @inventor.Inventor"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
    </div>
    <div class="settings-footer mt-4">
        <button type="button" class="settings-close btn btn-primary float-right"><i class="fa fa-times pr-2"></i>Close</button>
    </div>
</div>

@(Html.Kendo().Chart(Model)
    .Name(userWidgetId)
    .Title("")
    .Legend(legend => legend
        .Visible(true)
        .Position(ChartLegendPosition.Top)
    )
    .ChartArea(chartArea => chartArea
        .Background("transparent")
    )
    .Series(series => series
        .Funnel(model => model.Value, model => model.Category)
        .Overlay(o => o.Gradient(ChartSeriesGradient.None))
        .Labels(labels => labels
            .Visible(true)
            .Template(string.IsNullOrEmpty(widget.LabelTemplate) ? "#= value #" : widget.LabelTemplate)
            .Background("transparent")
            .Color("white")
        )
        .DynamicSlope(true)
        .DynamicHeight(true)
        .SegmentSpacing(1)
    )
    .SeriesColors((string[])widget.SeriesColors)
    .Tooltip(tooltip => tooltip
        .Visible(true)
        .Template(string.IsNullOrEmpty(widget.TooltipTemplate) ? "#= dataItem.Category #: #= value #" : widget.TooltipTemplate)
    )    
    //Settings for PDF export using kendo built-in function
    .Pdf(pdf => pdf
        .FileName(@widget.Title.ToString())
        //.PaperSize("A4")
        .Landscape(false)
        .Margin(m => m
            .Left(10)
            .Right(10)
            .Top(10)
            .Bottom(10))
    )
)
@if (widget.IsDetail)
{
    <div id="@userWidgetId-grid-header">
        <h4><span id="@userWidgetId-grid-title"></span></h4>
    </div>

    @(Html.Kendo().Grid<DMSPortfolioByStatusDrillDownViewModel>()
        .Name(userWidgetId + "-grid")
        .Columns(columns =>
        {
            columns.Bound(a => a.DisclosureNumber).Title(disclosureNumberLabel).HtmlAttributes(new { @class = "text-nowrap" });
            columns.Bound(a => a.DisclosureTitle);
            columns.Bound(a => a.DisclosureDate).Format("{0:dd-MMM-yyyy}");
            columns.Bound(a => a.DisclosureStatus);
            columns.Bound(a => a.DisclosureStatusDate).Format("{0:dd-MMM-yyyy}");
            columns.Bound(a => a.ClientCode);
            columns.Bound(a => a.ClientName);
            columns.Bound(a => a.Inventors);
            columns.Bound(a => a.SubmittedDate).Format("{0:dd-MMM-yyyy}");
        })
        .ToolBar(tools => tools.Excel())
        .AutoBind(false)
        //.Excel(excel => excel.AllPages(true).ProxyURL(Url.Action("ExportToExcel", "Dashboard")))
        .Pageable(page => page.PageSizes(patSettings.SearchResultsPageSizeOptions))
        .Sortable(sort => sort.AllowUnsort(false))
        .DataSource(dataSource => dataSource
            .Ajax()
            .PageSize(patSettings.SearchResultsPageSize)
            .Read(read => read.Action("DMSInventionProgressionDetailRead", "Dashboard", new { userWidgetId = widget.Id }).Data("gridDetailSearchFilters"))
        )
        .Events(e => e.ExcelExport("gridExcelExport"))
        .HtmlAttributes(new { @class = "kendo-Grid", style = "width:100%" })
    )

    <style>
        .k-chart {
            margin: auto;
        }
    </style>
}