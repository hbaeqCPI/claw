@model IEnumerable<ChartDTO>
@using Newtonsoft.Json.Linq;
@using Microsoft.EntityFrameworkCore;
@inject IProductService ProductService
@inject IClientService ClientService
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<PatSetting> PatSettings
@inject ISystemSettings<TmkSetting> TmkSettings

@{
    var patSettings = await PatSettings.GetSetting();
    var tmkSettings = await TmkSettings.GetSetting();

    var clientLabel = Localizer[patSettings.LabelClient];
    var clientNameLabel = Localizer[patSettings.LabelClientName];
    var productLabel = Localizer["Product Code"];
    var productNameLabel = Localizer["Product Name"];

    WidgetViewModel widget = (WidgetViewModel)(ViewData["WidgetViewModel"] ?? new WidgetViewModel());
    var userWidgetId = widget.Id.ToString() + "-top-products-by-sales";
    var userSettings = widget.UserSettings;
    var widgetSettings = widget.WidgetSettings;

    string selectedStatus = userSettings.Property("SelectedStatus") != null ? userSettings["SelectedStatus"].Value<string>() : "All";
    string selectedSystem = userSettings.Property("SelectedSystem") != null ? userSettings["SelectedSystem"].Value<string>() : "Patent";

    List<SelectListItem> systems = new List<SelectListItem>();

    if (patSettings.IsProductsOn) { systems.Add(new SelectListItem() { Text = "Patent", Value = "Patent" }); }
    if (tmkSettings.IsProductsOn) { systems.Add(new SelectListItem() { Text = "Trademark", Value = "Trademark" }); }

    List<ClientListViewModel> clients = new List<ClientListViewModel>();
    if (userSettings.Property("Clients") != null)
    {
        try
        {
            int[] clientFilter = ((JArray)userSettings.Property("Clients").Value).Select(a => (int)a).ToArray();

            if (clientFilter.Count() > 0)
            {
                clients = await ClientService.QueryableList
                                        .Where(c => clientFilter.Contains(c.ClientID))
                                        .Select(c => new ClientListViewModel
                                        {
                                            ClientID = c.ClientID,
                                            ClientCode = c.ClientCode,
                                            ClientName = c.ClientName
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }

    List<ProductListViewModel> products = new List<ProductListViewModel>();
    if (userSettings.Property("Products") != null)
    {
        try
        {
            int[] productFilter = ((JArray)userSettings.Property("Products").Value).Select(a => (int)a).ToArray();

            if (productFilter.Count() > 0)
            {
                products = await ProductService.QueryableList
                                        .Where(p => productFilter.Contains(p.ProductId))
                                        .Select(p => new ProductListViewModel
                                        {
                                            ProductId = p.ProductId,
                                            ProductCode = p.ProductCode,
                                            ProductName = p.ProductName
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }

    List<string> years = new List<string>();
    if (userSettings.Property("Years") != null)
    {
        try
        {
            string[] yearFilter = ((JArray)userSettings.Property("Years").Value).Select(a => (string)a).Where(a => !string.IsNullOrEmpty(a)).ToArray();

            if (yearFilter.Count() > 0)
            {
                years = new List<string>(yearFilter);
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }

    var widgetSeriesColors = widget.SeriesColors.ToList();

    if (selectedSystem == "Trademark")
    {
        widgetSeriesColors.RemoveAt(0);      
    }
    else if (selectedSystem == "General Matter")
    {
        widgetSeriesColors.RemoveAt(0);
        widgetSeriesColors.RemoveAt(0); 
    }
}

<style>
    #clientFilter_@userWidgetId .client-code {
        font-weight: 600;
        margin-right: 10px;
    }
    #productFilter_@userWidgetId .product-code {
        font-weight: 600;
        margin-right: 10px;
    }
</style>
<script>
    var refresh = false;

    function saveSelectedSystem(e) {
        var widgetId = parseInt(this.element.attr("widgetId"));
        saveSetting(widgetId, `{ SelectedSystem: "${this.dataItem(this.selectedIndex).Text}" }`, function () { refresh = true; });
    }

    function saveSelectedStatus(e) {
        var widgetId = parseInt(this.element.attr("widgetId"));
        saveSetting(widgetId, `{ SelectedStatus: "${this.dataItem(this.selectedIndex).Text}" }`, function () { refresh = true; });
    }

    $(document).ready(function () {
        var clientList = [@String.Join(",", clients.Select(a => a.ClientID).ToList())];
        var productList = [@String.Join(",", products.Select(a => a.ProductId).ToList())];
        var yearList = "@String.Join(",", years.Select(a => (string)a).ToList())".split(",").filter(item => item);

        $(document).off("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close");
        $(document).on("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close", function (e) {
            if (refresh) {
                $("#@widget.Id .refresh").click();
            }
        });

        $(document).off("click", "#clientFilter_@userWidgetId .delete-client");
        $(document).off("change", "#ClientCode_@userWidgetId");
        $(document).on("click", "#clientFilter_@userWidgetId .delete-client", function (e) {
            var item = $.inArray($(this).data("id"), clientList);

            if (item !== -1) {
                clientList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#ClientCode_@userWidgetId", function (e) {
            var client = $(this).data("kendoMultiColumnComboBox");

            if (client.selectedIndex >= 0) {
                var dataItem = client.dataItem(client.selectedIndex);

                var clientId = dataItem.ClientID;
                var clientCode = dataItem.ClientCode;
                var clientName = dataItem.ClientName;

                if ($.inArray(clientId, clientList) == -1) {
                    clientList.push(clientId);
                    $("#clientFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="client-code">${clientCode}</span><span class="client-name">${clientName}</span></div><div class="delete-filter delete-client" data-id="${clientId}" title="Remove ${clientCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
                }
            }

            client.value("");
        });

        $(document).off("click", "#productFilter_@userWidgetId .delete-product");
        $(document).off("change", "#ProductCode_@userWidgetId");
        $(document).on("click", "#productFilter_@userWidgetId .delete-product", function (e) {
            var item = $.inArray($(this).data("id"), productList);

            if (item !== -1) {
                productList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Products: [${productList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#ProductCode_@userWidgetId", function (e) {
            var product = $(this).data("kendoComboBox");

            if (product.selectedIndex >= 0) {
                var dataItem = product.dataItem(product.selectedIndex);
                console.log(dataItem);
                var productId = dataItem.ProductId;
                var productCode = dataItem.ProductCode;
                var productName = dataItem.ProductName;

                if ($.inArray(productId, productList) == -1) {
                    productList.push(productId);
                    $("#productFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="product-code">${productCode}</span><span class="product-name">${productName}</span></div><div class="delete-filter delete-product" data-id="${productId}" title="Remove ${productCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Products: [${productList.toString()}] }`, function () { refresh = true; });
                }
            }

            product.value("");
        });

        $(document).off("click", "#yearRangeFilter_@userWidgetId .delete-yearRange");
        $(document).off("change", "#Year_@userWidgetId");
        $(document).on("click", "#yearRangeFilter_@userWidgetId .delete-yearRange", function (e) {
            /*Have to convert to string because js auto-recognize year as int*/
            var item = $.inArray(String($(this).data("id")), yearList);
            
            if (item !== -1) {
                yearList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Years: ['${yearList.join("','")}'] }`, function () { refresh = true; });
                }
        });
        $(document).on("change", "#Year_@userWidgetId", function (e) {
            var updated = $(this).data("kendoComboBox");

            if (updated.selectedIndex >= 0) {
                var dataItem = updated.dataItem(updated.selectedIndex);
                var year = dataItem.Year;

                if ($.inArray(year, yearList) == -1) {
                    yearList.push(year);
                    $("#yearRangeFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="yearRange">${year}</span></div><div class="delete-filter delete-yearRange" data-id="${year}" title="Remove ${year}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Years: ['${yearList.join("','")}'] }`, function () { refresh = true; });
                    }
                }
            updated.value("");
        });
    });
</script>
<div class="widget-settings" style="max-height: 425px;">
    <div class="settings-body">
        <ul class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@Localizer["System"]</span>
                <span>
                    @(Html.Kendo().DropDownList()
                                                .Name(userWidgetId + "-system")
                                                .DataTextField("Text")
                                                .DataValueField("Value")
                                                .Events(e => e.Change("saveSelectedSystem"))
                                                .BindTo(systems)
                                                .Value(selectedSystem)
                                                .HtmlAttributes(new { style = "width: 120px;", widgetId = $"{widget.Id}", data_widgetId = $"{widget.Id}", @class = "system-option" })
                        )
                </span>
            </li>
        </ul>
        <ul class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@Localizer["Status"]</span>
                <span>
                    @(Html.Kendo().DropDownList()
                                                .Name(userWidgetId + "-status")
                                                .DataTextField("Text")
                                                .DataValueField("Value")
                                                .Events(e => e.Change("saveSelectedStatus"))
                                                .BindTo(new List<SelectListItem>() {
                                                        new SelectListItem() {
                                                            Text = "Active",
                                                            Value = "Active"
                                                        },
                                                        new SelectListItem() {
                                                            Text = "Inactive",
                                                            Value = "Inactive"
                                                        },
                                                        new SelectListItem() {
                                                            Text = "All",
                                                            Value = "All"
                                                        }
                                                })
                                                .Value(selectedStatus)
                                                .HtmlAttributes(new { style = "width: 120px;", widgetId = $"{widget.Id}", data_widgetId = $"{widget.Id}", @class = "status-option" })
                        )
                </span>
            </li>
        </ul>
        <ul id="clientFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@clientLabel</span>
                <span>@await Component.InvokeAsync("ComboBox", ComboBoxHelper.ClientID("ClientCode", clientLabel, clientNameLabel, "Client", "Shared", userWidgetId))</span>
            </li>
            @foreach (ClientListViewModel client in clients)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="client-code">@client.ClientCode</span>
                        <span class="client-name">@client.ClientName</span>
                    </div>
                    <div class="delete-filter delete-client" data-id="@client.ClientID" title="Remove @client.ClientCode"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
        <ul id="productFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@productLabel</span>
                <span>@await Component.InvokeAsync("ComboBox", new { name = "ProductCode", action = "GetProductList", controller = "Product", area = "Shared", screen = userWidgetId })</span>
            </li>
            @foreach (ProductListViewModel product in products)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="product-code">@product.ProductCode</span>
                        <span class="product-name">@product.ProductName</span>
                    </div>
                    <div class="delete-filter delete-product" data-id="@product.ProductId" title="Remove @product.ProductCode"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
        <ul id="yearRangeFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@Localizer["Year"]</span>
                <span>
                    @await Component.InvokeAsync("ComboBox", new { name = "Year", area = "Shared", controller = "Product", action = "GetDistinctSaleYearList", screen = userWidgetId })
                </span>
            </li>
            @foreach (string yr in years)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="yearRange">@yr</span>
                    </div>
                    <div class="delete-filter delete-yearRange" data-id="@yr" title="Remove @yr"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
    </div>
    <div class="settings-footer mt-4">
        <button type="button" class="settings-close btn btn-primary float-right"><i class="fa fa-times pr-2"></i>Close</button>
    </div>
</div>

@(Html.Kendo().Chart(Model)
    .Name(userWidgetId)
    .Title("")
    .Legend(legend => legend
        .Visible(false)
    //.Position(ChartLegendPosition.Top)
    )
    .ChartArea(chartArea => chartArea
        .Background("transparent")
    )
    .Series(series => series
        .Bar(model => model.Value, model => model.Category)
        //.ColorField("Color")
        .Overlay(o => o.Gradient(ChartSeriesGradient.None))
        .Labels(labels => labels
            .Visible(true)
            .Template("#= value == null ? '' : value #")
            .Background("transparent")
            .Position(ChartBarLabelsPosition.OutsideEnd)            
        )
        .Name("#: group.items[0].Group #")
    )    
    //.ValueAxis(axis => axis.Labels(labels => labels.Rotation(-45)))
    .DataSource(dataSource => dataSource
        .Group(group => group.Add(model => model.Group))
    )
    .SeriesColors(widgetSeriesColors.ToArray())
    .Tooltip(tooltip => tooltip
        .Visible(true)
        .Template("#= category #: #= value == null ? 0 : value #")
    )
)
