@model IEnumerable<ChartViewModel>
@using Newtonsoft.Json.Linq;
@using Microsoft.EntityFrameworkCore;
@inject IStringLocalizer<TrademarkResource> Localizer
@inject IClientService ClientService
@inject ISystemSettings<TmkSetting> Settings
@inject IParentEntityService<TmkCountry, TmkAreaCountry> CountryService
@inject IEntityService<TmkStandardGood> GoodsService
@inject IEntityService<TmkMarkType> MarkTypeService;

@{
    var tmkSettings = await Settings.GetSetting();
    var clientLabel = Localizer[tmkSettings.LabelClient ?? ""];
    var clientNameLabel = Localizer[tmkSettings.LabelClientName ?? ""];
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];
    var caseNumberLabel = Localizer[tmkSettings.LabelCaseNumber ?? ""];

    WidgetViewModel widget = (WidgetViewModel)(ViewData["WidgetViewModel"] ?? new WidgetViewModel());
    var gridDetailTitle = Localizer[widget.Title + " - {0}"];
    var viewNameSplit = widget.ViewName.ToString().Split("/");
    var viewName = viewNameSplit[viewNameSplit.Length - 1];
    var userWidgetId = widget.Id.ToString() + viewName;

    var widgetSettings = widget.WidgetSettings;
    var settings = widget.UserSettings;    

    List<ClientListViewModel> clients = new List<ClientListViewModel>();
    var clientSettingProperty = settings.Property("Clients");
    if (clientSettingProperty != null)
    {
        try
        {
            int[] clientFilter = ((JArray)clientSettingProperty.Value).Select(a => (int)a).ToArray();

            if (clientFilter.Count() > 0)
            {
                clients = await ClientService.QueryableList
                                        .Where(c => clientFilter.Contains(c.ClientID))
                                        .Select(c => new ClientListViewModel
                                        {
                                            ClientID = c.ClientID,
                                            ClientCode = c.ClientCode,
                                            ClientName = c.ClientName
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;
        }
    }

    List<CountryLookupViewModel> countries = new List<CountryLookupViewModel>();
    var countrySettingProperty = settings.Property("Countries");
    if (countrySettingProperty != null)
    {
        try
        {
            int[] countryFilter = ((JArray)countrySettingProperty.Value).Select(a => (int)a).ToArray();

            if (countryFilter.Count() > 0)
            {
                countries = await CountryService.QueryableList
                                        .Where(c => countryFilter.Contains(c.CountryID))
                                        .Select(c => new CountryLookupViewModel
                                        {
                                            CountryID = c.CountryID,
                                            Country = c.Country,
                                            CountryName = c.CountryName
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;
        }
    }

    List<TmkStandardGoodListViewModel> classes = new List<TmkStandardGoodListViewModel>();
    var classSettingProperty = settings.Property("Classes");

    if (classSettingProperty != null)
    {
        try
        {
            int[] classFilter = ((JArray)classSettingProperty.Value).Select(a => (int)a).ToArray();

            if (classFilter.Count() > 0)
            {
                classes = await GoodsService.QueryableList
                                        .Where(c => classFilter.Contains(c.ClassId))
                                        .Select(c => new TmkStandardGoodListViewModel
                                        {
                                            ClassId = c.ClassId,
                                            ClassDesc = $"{c.Class} {c.ClassType}"
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;
        }
    }

    List<TmkMarkType> markTypes = new List<TmkMarkType>();
    var markTypeSettingProperty = settings.Property("MarkTypes");

    if (markTypeSettingProperty != null)
    {
        try
        {
            var markTypeFilter = ((JArray)markTypeSettingProperty.Value).Select(a => (string)a).ToList();

            if (markTypeFilter.Count() > 0)
            {
                markTypes = await MarkTypeService.QueryableList
                .Where(a => markTypeFilter.Contains(a.MarkType ?? ""))
                .Select(a => new TmkMarkType
                {
                    MarkTypeId = a.MarkTypeId,
                    MarkType = a.MarkType
                })
                .ToListAsync();

                markTypes.AddRange(markTypeFilter.Where(d => !markTypes.Any(m => m.MarkType == d)).Select(d => new TmkMarkType() { MarkType = d }).ToList());
            }
        }
        catch (Exception e)
        {
            var err = e.Message;
        }
    }
}
<script>
    var selectedTmkId = 0;
    var refresh = false;

    $(document).ready(function () {
        var clientList = [@String.Join(",", clients.Select(a => a.ClientID).ToList())];
        var countryList = [@String.Join(",", countries.Select(c => c.CountryID).ToList())];
        var markTypeList = [@Html.Raw(String.Join(",", markTypes.Select(c => $"'{c.MarkType}'").ToList()))];
        var classList = [@String.Join(",", classes.Select(c => c.ClassId).ToList())];        

        $(document).off("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close");
        $(document).on("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close", function (e) {
            if (refresh) {
                $("#@widget.Id .refresh").click();
            }
        });
        
        $(document).off("click", "#clientFilter_@userWidgetId .delete-client");
        $(document).off("change", "#ClientCode_@userWidgetId");
        $(document).on("click", "#clientFilter_@userWidgetId .delete-client", function (e) {
            var item = $.inArray($(this).data("id"), clientList);

            if (item !== -1) {
                clientList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#ClientCode_@userWidgetId", function (e) {
            var client = $(this).data("kendoMultiColumnComboBox");

            if (client.selectedIndex >= 0) {
                var dataItem = client.dataItem(client.selectedIndex);

                var clientId = dataItem.ClientID;
                var clientCode = dataItem.ClientCode;
                var clientName = dataItem.ClientName;

                if ($.inArray(clientId, clientList) == -1) {
                    clientList.push(clientId);
                    $("#clientFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="client-code">${clientCode}</span><span class="client-name">${clientName}</span></div><div class="delete-filter delete-client" data-id="${clientId}" title="Remove ${clientCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
                }
            }

            client.value("");
        });

        $(document).off("click", "#countryFilter_@userWidgetId .delete-country");
        $(document).off("change", "#Country_@userWidgetId");
        $(document).on("click", "#countryFilter_@userWidgetId .delete-country", function (e) {
            var item = $.inArray($(this).data("id"), countryList);

            if (item !== -1) {
                countryList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Countries: [${countryList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#Country_@userWidgetId", function (e) {
            var country = $(this).data("kendoMultiColumnComboBox");

            if (country.selectedIndex >= 0) {
                var dataItem = country.dataItem(country.selectedIndex);

                var countryId = dataItem.CountryID;
                var countryCode = dataItem.Country;
                var countryName = dataItem.CountryName;

                if ($.inArray(countryId, countryList) == -1) {
                    countryList.push(countryId);
                    $("#countryFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="country-code">${countryCode}</span><span class="country-name">${countryName}</span></div><div class="delete-filter delete-country" data-id="${countryId}" title="Remove ${countryCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Countries: [${countryList.toString()}] }`, function () { refresh = true; });
                }
            }

            country.value("");
        });

        $(document).off("click", "#MarkTypeFilter_@userWidgetId .delete-markType");
        $(document).off("change", "#MarkType_@userWidgetId");
        $(document).on("click", "#MarkTypeFilter_@userWidgetId .delete-markType", function (e) {
            var item = $.inArray($(this).data("id"), markTypeList);

            if (item !== -1) {
                markTypeList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ MarkTypes: ${JSON.stringify(markTypeList)} }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#MarkType_@userWidgetId", function (e) {
            var markType = $(this).data("kendoMultiColumnComboBox");

            if (markType.selectedIndex >= 0) {
                var dataItem = markType.dataItem(markType.selectedIndex);

                var markTypeId = dataItem.MarkTypeId;
                var markTypeCode = dataItem.MarkType;

                if ($.inArray(markTypeCode, markTypeList) == -1) {
                    markTypeList.push(markTypeCode);
                    $("#MarkTypeFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="markType-Code">${markTypeCode}</span></div><div class="delete-filter delete-markType" data-id="${markTypeCode}" title="Remove ${markTypeCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ MarkTypes: ${JSON.stringify(markTypeList)} }`, function () { refresh = true; });
                }
            }

            markType.value("");
        });

        $(document).off("click", "#classFilter_@userWidgetId .delete-class");
        $(document).off("change", "#ClassCode_@userWidgetId");
        $(document).on("click", "#classFilter_@userWidgetId .delete-class", function (e) {
            var item = $.inArray($(this).data("id"), classList);

            if (item !== -1) {
                classList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Classes: [${classList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#ClassCode_@userWidgetId", function (e) {
            var classCode = $(this).data("kendoComboBox");

            if (classCode.selectedIndex >= 0) {
                var dataItem = classCode.dataItem(classCode.selectedIndex);

                var classId = dataItem.ClassId;
                var classDesc = dataItem.ClassDesc;

                if ($.inArray(classId, classList) == -1) {
                    classList.push(classId);
                    $("#classFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="class-code">${classDesc}</span></div><div class="delete-filter delete-class" data-id="${classId}" title="Remove ${classDesc}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Classes: [${classList.toString()}] }`, function () { refresh = true; });
                }
            }

            classCode.value("");
        });

        if ('@(widget.IsDetail)' === '@true') {
            var chart = $("#@userWidgetId").data("kendoChart");
            chart.bind("seriesClick", onSeriesClick);
            $("#@userWidgetId").attr("style", "position: static !important;");
            $("#@userWidgetId-grid-header").hide();

            var grid = $("#@userWidgetId-grid").data("kendoGrid");
            grid.dataSource.read();
        }

    });

    function onSeriesClick(e) {
        var grid = $("#@userWidgetId-grid").data("kendoGrid");
        grid.dataSource.read({ userWidgetId: @widget.Id, tmkId: e.dataItem["Value1"] });

        var gridTitle = "@gridDetailTitle";
        $("#@userWidgetId-grid-title").text(gridTitle.replace("{0}", e.category));
        $("#@userWidgetId-grid-header").show();

        selectedTmkId = e.dataItem["Value1"];
    };

    function gridExcelExport(e) {
        e.preventDefault();
        var excelExportUrl = "@Url.Action("TmkTopLicenseTrademarkDetailExportExcel", "Dashboard")";
        const dataJSON = JSON.stringify({ userWidgetId: @widget.Id, tmkId: selectedTmkId });
        const html = '<form method="POST" action="' + excelExportUrl + '">' +
            '<input type="hidden" name="__RequestVerificationToken" value="' + $("[name='__RequestVerificationToken']").val() + '">';
        let form = $(html);
        form.append($('<input type="hidden" name="filtersJSON"/>').val(dataJSON));
        $('body').append(form);
        form.submit();
    };

    function gridDetailSearchFilters() {
        return { userWidgetId: @widget.Id, tmkId: selectedTmkId };
    };

    function customLabels(e) {
        //Assuming 4 lines = height * 4
        var rect = new kendo.geometry.Rect(e.rect.origin, [e.rect.size.width, e.rect.size.height * 4]);
        var layout = new kendo.drawing.Layout(rect, {
            orientation: "vertical",
            alignContent: "left"            
        });
        var words = splitSpaces(e.text);
        for (var i = 0; i < words.length; i++) {
            layout.append(new kendo.drawing.Text(words[i]));
        }
        layout.reflow();
        return layout;
    }

    function splitSpaces(str) {        
        const words = str.split(' ');
        const chunkSize = Math.ceil(words.length / 4);

        const chunks = [];
        for (let i = 0; i < words.length; i += chunkSize) {
            chunks.push(words.slice(i, i + chunkSize).join(' '));
        }
        return chunks;
    }

</script>

<div class="widget-settings" style="max-height: 425px;">
    <div class="settings-body">        
        <ul id="clientFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@clientLabel</span>
                <span>@await Component.InvokeAsync("ComboBox", ComboBoxHelper.ClientID("ClientCode", clientLabel, clientNameLabel, "TmkTrademarkLookup", "Trademark", userWidgetId))</span>
            </li>
            @foreach (ClientListViewModel client in clients)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="client-code">@client.ClientCode</span>
                        <span class="client-name">@client.ClientName</span>
                    </div>
                    <div class="delete-filter delete-client" data-id="@client.ClientID" title="Remove @client.ClientCode"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>   
        <ul id="countryFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@countryLabel</span>
                <span>@await Component.InvokeAsync("ComboBox", ComboBoxHelper.CountryID("Country", countryLabel, countryNameLabel, "TmkTrademarkLookup", "Trademark", userWidgetId))</span>
            </li>
            @foreach (CountryLookupViewModel country in countries)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="country-code">@country.Country</span>
                        <span class="country-name">@country.CountryName</span>
                    </div>
                    <div class="delete-filter delete-country" data-id="@country.CountryID" title="Remove @country.Country"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
        <ul id="MarkTypeFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@Localizer["Mark Type(s)"]</span>
                <span>                   
                    @await Component.InvokeAsync("ComboBox", new
                        {
                            name = "MarkType",
                            action = "GetMarkTypesList",
                            controller = "MarkType",
                            area = "Trademark",
                            screen = userWidgetId,
                            textProperty = "MarkType",
                            valueProperty = "MarkTypeId",
                            listWidth = 450,
                            columns = new List<ComboBoxColumn> {
                    new ComboBoxColumn{Name="MarkType",Header=Localizer["Mark Type"],Width=200},
                    new ComboBoxColumn{Name="Description",Header=Localizer["Description"],Width=500}
                    }
                        })
                </span>
            </li>
            @foreach (TmkMarkType markType in markTypes)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="markType-Code">@markType.MarkType</span>
                    </div>
                    <div class="delete-filter delete-markType" data-id="@markType.MarkType" title="Remove @markType.MarkType"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
        <ul id="classFilter_@userWidgetId" class="list-group">            
            <li class="list-group-item d-flex justify-content-between">
                <span>@Localizer["Class"]</span>
                <span>
                    @await Component.InvokeAsync("ComboBox", new
                        {
                            name = "ClassCode",
                            valueProperty = "ClassId",
                            textProperty = "ClassDesc",
                            text = "ClassDesc",
                            screen = userWidgetId,
                            area = "Trademark",
                            controller = "TmkTrademarkClass",
                            action = "GetClassList"
                        })
                </span>
            </li>
            @foreach (TmkStandardGoodListViewModel item in classes)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="class-code">@item.ClassDesc</span>
                    </div>
                    <div class="delete-filter delete-class" data-id="@item.ClassId" title="Remove @item.ClassDesc"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
    </div>
    <div class="settings-footer mt-4">
        <button type="button" class="settings-close btn btn-primary float-right"><i class="fa fa-times pr-2"></i>Close</button>
    </div>
</div>


@(Html.Kendo().Chart(Model)
    .Name(userWidgetId)
    .Title("")
    .Legend(legend => legend
        .Visible(false)
    //.Position(ChartLegendPosition.Top)
    )
    .ChartArea(chartArea => chartArea
        .Background("transparent")
    )
    .Series(series => series
        .Bar(model => model.Value, model => model.Category)
        //.ColorField("Color")
        .Overlay(o => o.Gradient(ChartSeriesGradient.None))
        .Labels(labels => labels
            .Visible(true)
            .Template("#= value == null ? '' : value #")
            .Background("transparent")
            .Position(ChartBarLabelsPosition.OutsideEnd)
            
        )
        .Name("#: group.items[0].Group #")
    )
    .DataSource(dataSource => dataSource
        .Group(group => group.Add(model => model.Group))
    )
    .CategoryAxis(axis => axis.Labels(title => title.Visual("customLabels").Position(ChartAxisLabelsPosition.Start)))
    .SeriesColors((string[])widget.SeriesColors)
    .Tooltip(tooltip => tooltip
        .Visible(true)
        .Template("#= category #: #= value == null ? 0 : value #")
    )
    //Settings for PDF export using kendo built-in function
    .Pdf(pdf => pdf
        .FileName(@widget.Title.ToString())
        //.PaperSize("A4")
        .Landscape(false)
        .Margin(m => m
            .Left(10)
            .Right(10)
            .Top(10)
            .Bottom(10))
    )
)
@if (widget.IsDetail)
{
    <div id="@userWidgetId-grid-header">
        <h4><span id="@userWidgetId-grid-title"></span></h4>
    </div>

    @(Html.Kendo().Grid<TmkTopLicenseTrademarkDrillDownViewModel>()
                        .Name(userWidgetId + "-grid")
                        .Columns(columns =>
                        {
                            columns.Bound(a => a.CaseNumber).Title(caseNumberLabel).HtmlAttributes(new { @class = "text-nowrap" });
                            columns.Bound(a => a.Country);
                            columns.Bound(a => a.SubCase);
                            columns.Bound(a => a.CaseType);
                            columns.Bound(a => a.MarkType);
                            columns.Bound(a => a.TrademarkName);
                            columns.Bound(a => a.Licensee);
                            columns.Bound(a => a.Licensor);
                            columns.Bound(a => a.LicenseNo);                            
                            columns.Bound(a => a.LicenseType);
                            columns.Bound(a => a.LicenseStart).Format("{0:dd-MMM-yyyy}");                            
                            columns.Bound(a => a.LicenseExpire).Format("{0:dd-MMM-yyyy}");
                        })
                        .ToolBar(tools => tools.Excel())
                        .AutoBind(false)
                        //.Excel(excel => excel.AllPages(true).ProxyURL(Url.Action("ExportToExcel", "Dashboard")))
                        .Pageable(page => page.PageSizes(tmkSettings.SearchResultsPageSizeOptions))
                        .Sortable(sort => sort.AllowUnsort(false))
                        .DataSource(dataSource => dataSource
                            .Ajax()
                            .PageSize(tmkSettings.SearchResultsPageSize)
                            .Read(read => read.Action("TmkTopLicenseTrademarksDetailRead", "Dashboard", new { userWidgetId = widget.Id }).Data("gridDetailSearchFilters"))
                        )
                        .Events(e => e.ExcelExport("gridExcelExport"))
                        .HtmlAttributes(new { @class = "kendo-Grid", style = "width:100%" })
    )

    <style>
        .k-chart {
            margin: auto;
        }
    </style>
}