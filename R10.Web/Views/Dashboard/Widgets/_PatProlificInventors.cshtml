@model IEnumerable<ChartDTO>
@inject IStringLocalizer<PatentResource> Localizer
@{
    WidgetViewModel widget = (WidgetViewModel)(ViewData["WidgetViewModel"] ?? new WidgetViewModel());
    var viewNameSplit = widget.ViewName.ToString().Split("/");
    var viewName = viewNameSplit[viewNameSplit.Length - 1];

    var userWidgetId = widget.Id.ToString() + viewName;
}

@(Html.Kendo().Chart(Model)
    .Name(userWidgetId)
    .Title("")
    .Legend(legend => legend
        .Visible(false)
    //.Position(ChartLegendPosition.Top)
    )
    .ChartArea(chartArea => chartArea
        .Background("transparent")
    )
    .Series(series => series
        .Bar(model => model.Value, model => model.Category)
        //.ColorField("Color")
        .Overlay(o => o.Gradient(ChartSeriesGradient.None))
        .Labels(labels => labels
            .Visible(true)
            .Template(Localizer["#= category# #= value == null ? '' : 'with ' + value + ' patent families' #"])
            //.Font("15px sans-serif")
            .Background("transparent")
            .Position(ChartBarLabelsPosition.InsideBase)
        )
        .Gap(0.2)
    )
    .SeriesColors((string[])widget.SeriesColors)
    .Tooltip(tooltip => tooltip
        .Visible(true)
        .Template(Localizer["#= category#: #= value == null ? 0 : value  + ' patent families'#"])
    )
    //Remove Value horizontal line
    .ValueAxis(axis => axis
        .Line(line => line.Visible(false))
        .Labels(labels => labels.Visible(false))
    )
    //Remove Category vertical line
    .CategoryAxis(axis => axis
        .Line(line => line.Visible(false))
        .Labels(labels => labels
            .Visible(false)
            .Template(Localizer["#= value # inventor(s)"])
            .Background("transparent")
            .Position(ChartAxisLabelsPosition.OnAxis))
    )
    //Remove gridlines
     .AxisDefaults(axis => axis
        .MajorGridLines(lines => lines.Visible(false))
    )
    //Settings for PDF export using kendo built-in function
    .Pdf(pdf => pdf
        .FileName(@widget.Title.ToString())
        //.PaperSize("A4")
        .Landscape(false)
        .Margin(m => m
            .Left(10)
            .Right(10)
            .Top(10)
            .Bottom(10))
    )
)