@model IEnumerable<ChartDTO>
@using Newtonsoft.Json.Linq;
@using Microsoft.EntityFrameworkCore;
@using System.Globalization; 
@inject IClientService ClientService
@inject IStringLocalizer<PatentResource> Localizer
@inject ISystemSettings<PatSetting> Settings

@{
    var patSettings = await Settings.GetSetting();
    var clientLabel = Localizer[patSettings.LabelClient];
    var clientNameLabel = Localizer[patSettings.LabelClientName];

    WidgetViewModel widget = (WidgetViewModel)(ViewData["WidgetViewModel"] ?? new WidgetViewModel());
    var gridDetailTitle = Localizer[widget.Title + " - {0}"];
    var viewNameSplit = widget.ViewName.ToString().Split("/");
    var viewName = viewNameSplit[viewNameSplit.Length - 1];
    var userWidgetId = widget.Id.ToString() + viewName;

    var settings = widget.UserSettings;
    List<ClientListViewModel> clients = new List<ClientListViewModel>();

    if (settings.Property("Clients") != null)
    {
        try
        {
            int[] clientFilter = ((JArray)settings.Property("Clients").Value).Select(a => (int)a).ToArray();

            if (clientFilter.Count() > 0)
            {
                clients = await ClientService.QueryableList
                                        .Where(c => clientFilter.Contains(c.ClientID))
                                        .Select(c => new ClientListViewModel
                                        {
                                            ClientID = c.ClientID,
                                            ClientCode = c.ClientCode,
                                            ClientName = c.ClientName
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }

    string submittedDateFromStr = settings.Property("SubmittedDateFrom") != null ? settings["SubmittedDateFrom"].Value<string>() : "";
    DateTime? submittedDateFrom = !string.IsNullOrEmpty(submittedDateFromStr) ? DateTime.ParseExact(submittedDateFromStr, "MM/dd/yyyy", CultureInfo.InvariantCulture) : null;
    string submittedDateToStr = settings.Property("SubmittedDateTo") != null ? settings["SubmittedDateTo"].Value<string>() : "";
    DateTime? submittedDateTo = !string.IsNullOrEmpty(submittedDateToStr) ? DateTime.ParseExact(submittedDateToStr, "MM/dd/yyyy", CultureInfo.InvariantCulture) : null;
}

<style>
    #clientFilter_@userWidgetId .client-code {
        font-weight: 600;
        margin-right: 10px;
    }

    .clearSubmittedDateRange_@userWidgetId {      
        color: dimgray;
        padding: 8px 10px;
    }

    .clearSubmittedDateRange_@userWidgetId:hover {
        cursor: pointer;
        color: black;
        background-color: #e7e7e7;
    }
</style>
<script>
    var selectedClient = "";

    var refresh = false;

    function saveSubmittedDateRange(e) {                
        var widgetId = parseInt('@widget.Id');
        var dateRange = this.range();
        var selectedStartDate = "";
        var selectedEndDate = "";
        if (dateRange) {
            if (dateRange.start) {
                selectedStartDate = kendo.toString(dateRange.start, 'MM/dd/yyyy');
            }
            if (dateRange.end) {
                selectedEndDate = kendo.toString(dateRange.end, 'MM/dd/yyyy');
            }
        }       
        saveSetting(widgetId, `{ SubmittedDateFrom: "${selectedStartDate}", SubmittedDateTo: "${selectedEndDate}" }`, function () { refresh = true;});        
    }

    function submittedDateRangeOnClose(e) {        
        $("#SubmittedDateRange_@userWidgetId input").blur();  
    }

    $(document).ready(function () {
        var clientList = [@String.Join(",", clients.Select(a => a.ClientID).ToList())];        

        $(document).on("click", ".clearSubmittedDateRange_@userWidgetId", function (e) {            
            var daterangepicker = $("#SubmittedDateRange_" + '@userWidgetId').data("kendoDateRangePicker");
            daterangepicker.range({
                start: null,
                end: null
            });
            daterangepicker.trigger('change');
        });

        $("#SubmittedDateRange_@userWidgetId input").addClass("non-sortable");
        var submittedDateRange = { start: null, end: null };        
        if ('@submittedDateFrom') {            
            submittedDateRange.start = new Date('@submittedDateFrom');
        }  
        if ('@submittedDateTo') {            
            submittedDateRange.end = new Date('@submittedDateTo');
        }   
        var drPicker = $("#SubmittedDateRange_@userWidgetId").data("kendoDateRangePicker");
        drPicker.range(submittedDateRange);

        $(document).off("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close");
        $(document).on("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close", function (e) {
            if (refresh) {
                $("#@widget.Id .refresh").click();
            }
        });

        $(document).off("click", "#clientFilter_@userWidgetId .delete-client");
        $(document).off("change", "#ClientCode_@userWidgetId");
        $(document).on("click", "#clientFilter_@userWidgetId .delete-client", function (e) {
            var item = $.inArray($(this).data("id"), clientList);

            if (item !== -1) {
                clientList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#ClientCode_@userWidgetId", function (e) {
            var client = $(this).data("kendoMultiColumnComboBox");

            if (client.selectedIndex >= 0) {
                var dataItem = client.dataItem(client.selectedIndex);

                var clientId = dataItem.ClientID;
                var clientCode = dataItem.ClientCode;
                var clientName = dataItem.ClientName;

                if ($.inArray(clientId, clientList) == -1) {
                    clientList.push(clientId);
                    $("#clientFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="client-code">${clientCode}</span><span class="client-name">${clientName}</span></div><div class="delete-filter delete-client" data-id="${clientId}" title="Remove ${clientCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
                }
            }

            client.value("");
        });
    });
</script>

<div class="widget-settings" style="max-height: 425px;">
    <div class="settings-body">
        <ul class="list-group">
           <li class="list-group-item d-flex justify-content-between">
                <span>@Localizer["Submitted Date Range"]</span>
                <span style="display:flex;">                    
                    @(Html.Kendo().DateRangePicker()
                      .Name("SubmittedDateRange_" + userWidgetId)                       
                      .Format("dd-MMM-yyyy")    
                      .Range(r => r.Start(submittedDateFrom).End(submittedDateTo))
                      .Labels(false)
                      .Events(e => e.Change("saveSubmittedDateRange").Close("submittedDateRangeOnClose"))                        
                      .HtmlAttributes(new { style = "width: 100%" })
                    )                       
                    <i class="fal fa-times clearSubmittedDateRange_@userWidgetId" title=@Localizer["Remove"]></i>
                </span>  
            </li>            
        </ul>
        <ul id="clientFilter_@userWidgetId" class="list-group">
            <li class="list-group-item d-flex justify-content-between">
                <span>@clientLabel</span>
                <span>@await Component.InvokeAsync("ComboBox", ComboBoxHelper.ClientID("ClientCode", @clientLabel, @clientNameLabel, "DisclosureLookup", "DMS", userWidgetId))</span>
            </li>
            @foreach (ClientListViewModel client in clients)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <div>
                        <span class="client-code">@client.ClientCode</span>
                        <span class="client-name">@client.ClientName</span>
                    </div>
                    <div class="delete-filter delete-client" data-id="@client.ClientID" title="Remove @client.ClientCode"><i class="fal fa-trash-alt"></i></div>
                </li>
            }
        </ul>
    </div>
    <div class="settings-footer mt-4">
        <button type="button" class="settings-close btn btn-primary float-right"><i class="fa fa-times pr-2"></i>Close</button>
    </div>
</div>
@if (!string.IsNullOrEmpty(submittedDateFromStr) || !string.IsNullOrEmpty(submittedDateToStr))
{
    <div class="submittedDateRangeLabel" style="text-align:center;"><span>@Localizer["Submitted Date Range: "]</span>@submittedDateFromStr - @submittedDateToStr</div>    
}
@(Html.Kendo().Chart(Model)
    .Name(userWidgetId)
    .Title("")
    .ChartArea(chartArea => chartArea
        .Background("transparent")
    )
    .Series(series => series
        .Column(model => model.Value, model => model.Category)
        .ColorField("Color")
        .Overlay(o => o.Gradient(ChartSeriesGradient.None))
        .Labels(labels => labels
            .Visible(true)
            .Format("{0}")
            .Template("#= value #")
            .Position(ChartBarLabelsPosition.OutsideEnd)
        )
        .Gap(1)
        .Spacing(1)
        .SegmentSpacing(2)
    )
    .SeriesColors(widget.SeriesColors)
    .Tooltip(tooltip => tooltip
        .Visible(true)
        .Format("{0}")
        .Template("#= category #: #= value #")
    )
    //Settings for PDF export using kendo built-in function
    .Pdf(pdf => pdf
        .FileName(@widget.Title.ToString())
        //.PaperSize("A4")
        .Landscape(false)
        .Margin(m => m
            .Left(10)
            .Right(10)
            .Top(10)
            .Bottom(10))
    )
)