@model IEnumerable<CaseListViewModel>
@using Newtonsoft.Json.Linq;
@using Microsoft.EntityFrameworkCore;
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<R10.Core.Entities.DMS.DMSSetting> Settings
@inject IPatInventorService InventorService
@inject IParentEntityService<PatCountry, PatAreaCountry> CountryService
@inject IClientService ClientService
@inject IAuthorizationService AuthorizationService
@{
    var settings = await Settings.GetSetting();
    var clientLabel = Localizer[settings.LabelClient ?? "Client"];
    var clientNameLabel = Localizer[settings.LabelClientName ?? "Client Name"];
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];

    WidgetViewModel widget = (WidgetViewModel)(ViewData["WidgetViewModel"] ?? new WidgetViewModel());

    var userWidgetId = widget.Id.ToString() + "-dms-caseList";
    var userSettings = widget.UserSettings;
    var widgetSettings = widget.WidgetSettings;
    var widgetTitle = widget.Title;

    var template = string.IsNullOrEmpty(widget.Template) ? $"<div class='name d-flex  justify-content-between'><span><a href='./#=System#/#=IdType#/detail/#=Id#'>#=kendo.htmlEncode(CaseNumber)# </a></span></div><div class='title small ellipsis'>#= Title == null ? '&nbsp;' : kendo.htmlEncode(Title)#</div><div class='title small ellipsis'>{Localizer["Due Date"]}: #= DueDate == null ? '' : kendo.format('{{0:dd-MMM-yyyy}}', DueDate)#</div>" : widget.Template;
    template = template.Replace("./#=System#/", $"{Url.ApplicationBaseUrl(Context.Request.Scheme)}/#=System#/");

    bool showAllowPaging = userSettings.Property("ShowAllowPaging") != null ? (userSettings["ShowAllowPaging"] ?? false).Value<bool>() : false;
    bool showRecommendationSwitch = widgetSettings.Property("ShowRecommendationSwitch") != null ? (widgetSettings["ShowRecommendationSwitch"] ?? false).Value<bool>() : false;
    bool showInventor = widgetSettings.Property("ShowInventor") != null ? (widgetSettings["ShowInventor"] ?? false).Value<bool>() : false;
    bool showClient = widgetSettings.Property("ShowClient") != null ? (widgetSettings["ShowClient"] ?? false).Value<bool>() : false;
    bool showCountry = widgetSettings.Property("ShowCountry") != null ? (widgetSettings["ShowCountry"] ?? false).Value<bool>() : false;
        
    bool isUserReviewer = (await AuthorizationService.AuthorizeAsync(User, DMSAuthorizationPolicy.Reviewer)).Succeeded;
    if (User.GetUserType() == CPiUserType.Inventor && !isUserReviewer) 
    {
        showInventor = false;
    }    

    bool showSettings = (showAllowPaging || showRecommendationSwitch || showInventor || showClient || showCountry);

    bool allowPaging = !showAllowPaging || userSettings.Property("AllowPaging") == null ? true : (userSettings["AllowPaging"] ?? false).Value<bool>();
    int pageSize = allowPaging ? userSettings.Property("PageSize") != null ? (userSettings["PageSize"] ?? 0).Value<int>() : 6 : 0;

    int recommendationSwitch = userSettings.Property("RecommendationSwitch") != null ? (userSettings["RecommendationSwitch"] ?? 1).Value<int>() : 1;
        
    var colorScheme = settings.ColorScheme ?? "";
    var patColor = colorScheme.Split("|")[0];
    var tmkColor = colorScheme.Split("|")[1];
    var gnmColor = colorScheme.Split("|")[2];
        
    List<PatInventorListViewModel> inventors = new List<PatInventorListViewModel>();
    if (userSettings.Property("Inventors") != null)
    {
        try
        {
            var inventorFilter = new List<int>();
            var userSettingValue = userSettings.Property("Inventors");

            if (userSettingValue != null && userSettingValue.Value != null)
            {
                inventorFilter = ((JArray)userSettingValue.Value).Select(a => (int)a).ToList();
            }

            if (inventorFilter.Count() > 0)
            {
                inventors = await InventorService.QueryableList
                                .Where(c => inventorFilter.Contains(c.InventorID))
                                .Select(c => new PatInventorListViewModel
                                {
                                    InventorID = c.InventorID,
                                    Inventor = c.Inventor
                                })
                                .Distinct()
                                .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;
        }
    }

    List<ClientListViewModel> clients = new List<ClientListViewModel>();
    if (userSettings.Property("Clients") != null)
    {
        try
        {
            var clientFilter = new List<int>();
            var userSettingValue = userSettings.Property("Clients");

            if (userSettingValue != null && userSettingValue.Value != null)
            {
                clientFilter = ((JArray)userSettingValue.Value).Select(a => (int)a).ToList();
            }

            if (clientFilter.Count() > 0)
            {
                clients = await ClientService.QueryableList
                                        .Where(c => clientFilter.Contains(c.ClientID))
                                        .Select(c => new ClientListViewModel
                                        {
                                            ClientID = c.ClientID,
                                            ClientCode = c.ClientCode,
                                            ClientName = c.ClientName
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }

    List<CountryLookupViewModel> countries = new List<CountryLookupViewModel>();
    if (userSettings.Property("Countries") != null)
    {
        try
        {
            var countryFilter = new List<int>();
            var userSettingValue = userSettings.Property("Countries");

            if (userSettingValue != null && userSettingValue.Value != null)
            {
                countryFilter = ((JArray)userSettingValue.Value).Select(a => (int)a).ToList();
            }
            
            if (countryFilter.Count() > 0)
            {
                countries = await CountryService.QueryableList
                                        .Where(c => countryFilter.Contains(c.CountryID))
                                        .Select(c => new CountryLookupViewModel
                                        {
                                            CountryID = c.CountryID,
                                            Country = c.Country,
                                            CountryName = c.CountryName
                                        })
                                        .ToListAsync();
            }
        }
        catch (Exception e)
        {
            var err = e.Message;

        }
    }
}

<script>
    $(document).ready(function () {
        var refresh = false;
        var inventorList = [@String.Join(",", inventors.Select(a => a.InventorID).ToList())];
        var countryList = [@String.Join(",", countries.Select(c => c.CountryID).ToList())];
        var clientList = [@String.Join(",", clients.Select(a => a.ClientID).ToList())];

        var widgetTitle = $("#@widget.Id .widget-header .widget-title");
            if ('@widget.CanEditTitle'.toLowerCase() === 'false') {                
                widgetTitle.text(`@Html.Raw(Localizer[widgetTitle])`);
            }

        $(document).off("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close");
        $(document).on("click", "#@widget.Id .settings, #@widget.Id .widget-settings .settings-close", function (e) {
            if (refresh) {
                $("#@widget.Id .refresh").click();
            }
        });

        $(document).off("click", "#@userWidgetId-recommendation-switch");
        $(document).on("click", "#@userWidgetId-recommendation-switch", function (e) {
            saveSetting(@widget.Id, `{ RecommendationSwitch: ${$(this).is(':checked') ? -1 : 1} }`, function () { refresh = true; });
        });

        $(document).off("click", "#inventorFilter_@userWidgetId .delete-inventor");
        $(document).off("change", "#Inventor_@userWidgetId");
        $(document).on("click", "#inventorFilter_@userWidgetId .delete-inventor", function (e) {
            var item = $.inArray($(this).data("id"), inventorList);

            if (item !== -1) {
                inventorList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Inventors: [${inventorList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#Inventor_@userWidgetId", function (e) {
            var inventor = $(this).data("kendoComboBox");

            if (inventor.selectedIndex >= 0) {
                var dataItem = inventor.dataItem(inventor.selectedIndex);

                var inventorId = dataItem.InventorID;
                var inventorCode = dataItem.Inventor;

                if ($.inArray(inventorId, inventorList) == -1) {
                    inventorList.push(inventorId);
                    $("#inventorFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="inventor-code">${inventorCode}</span></div><div class="delete-filter delete-inventor" data-id="${inventorId}" title="Remove ${inventorCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Inventors: [${inventorList.toString()}] }`, function () { refresh = true; });
                }
            }

            inventor.value("");
        });


        $(document).off("click", "#countryFilter_@userWidgetId .delete-country");
        $(document).off("change", "#Country_@userWidgetId");
        $(document).on("click", "#countryFilter_@userWidgetId .delete-country", function (e) {
            var item = $.inArray($(this).data("id"), countryList);

            if (item !== -1) {
                countryList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Countries: [${countryList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#Country_@userWidgetId", function (e) {
            var country = $(this).data("kendoMultiColumnComboBox");

            if (country.selectedIndex >= 0) {
                var dataItem = country.dataItem(country.selectedIndex);

                var countryId = dataItem.CountryID;
                var countryCode = dataItem.Country;
                var countryName = dataItem.CountryName;

                if ($.inArray(countryId, countryList) == -1) {
                    countryList.push(countryId);
                    $("#countryFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="country-code">${countryCode}</span><span class="country-name">${countryName}</span></div><div class="delete-filter delete-country" data-id="${countryId}" title="Remove ${countryCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Countries: [${countryList.toString()}] }`, function () { refresh = true; });
                }
            }

            country.value("");
        });

        $(document).off("click", "#clientFilter_@userWidgetId .delete-client");
        $(document).off("change", "#ClientCode_@userWidgetId");
        $(document).on("click", "#clientFilter_@userWidgetId .delete-client", function (e) {
            var item = $.inArray($(this).data("id"), clientList);

            if (item !== -1) {
                clientList.splice(item, 1);
                $(this).closest("li").remove();

                saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
            }
        });
        $(document).on("change", "#ClientCode_@userWidgetId", function (e) {
            var client = $(this).data("kendoMultiColumnComboBox");

            if (client.selectedIndex >= 0) {
                var dataItem = client.dataItem(client.selectedIndex);

                var clientId = dataItem.ClientID;
                var clientCode = dataItem.ClientCode;
                var clientName = dataItem.ClientName;

                if ($.inArray(clientId, clientList) == -1) {
                    clientList.push(clientId);
                    $("#clientFilter_@userWidgetId").append(`<li class="list-group-item d-flex justify-content-between"><div><span class="client-code">${clientCode}</span><span class="client-name">${clientName}</span></div><div class="delete-filter delete-client" data-id="${clientId}" title="Remove ${clientCode}"><i class="fal fa-trash-alt"></i></div></li>`);

                    saveSetting(@widget.Id, `{ Clients: [${clientList.toString()}] }`, function () { refresh = true; });
                }
            }

            client.value("");
        });
    });
</script>

@if (showSettings)
{
    <div class="widget-settings" style="max-height: 425px;">
        <div class="settings-body">
            @if (showRecommendationSwitch)
            {
                <ul class="list-group">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@Localizer["Include Disclosures with Recommendation"]</span>
                        <span>
                            <label class="toggle-switch">
                                <input id="@userWidgetId-recommendation-switch" type="checkbox" checked="@(recommendationSwitch == -1)">
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                </ul>
            }
            @if (showInventor)
            {
                <ul id="inventorFilter_@userWidgetId" class="list-group">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@Localizer["Inventor"]</span>
                        <span>@await Component.InvokeAsync("ComboBox", new { 
                            name = "Inventor", 
                            textProperty = "Inventor", 
                            valueProperty = "InventorID", 
                            controller = "DMSInventor", 
                            action = "GetInventorList", 
                            area = "DMS", 
                            listWidth = 400, 
                            screen = userWidgetId })</span>
                    </li>
                    @foreach (PatInventorListViewModel inventor in inventors)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <div>
                                <span class="inventor-code">@inventor.Inventor</span>
                            </div>
                            <div class="delete-filter delete-inventor" data-id="@inventor.InventorID" title="Remove @inventor.Inventor"><i class="fal fa-trash-alt"></i></div>
                        </li>
                    }
                </ul>
            }
            @if (showClient)
            {
                <ul id="clientFilter_@userWidgetId" class="list-group">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@clientLabel</span>                        
                        <span>@await Component.InvokeAsync("ComboBox", ComboBoxHelper.ClientID("ClientCode", @clientLabel, @clientNameLabel, "Client", "Shared", userWidgetId))</span>
                    </li>
                    @foreach (ClientListViewModel client in clients)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <div>
                                <span class="client-code">@client.ClientCode</span>
                                <span class="client-name">@client.ClientName</span>
                            </div>
                            <div class="delete-filter delete-client" data-id="@client.ClientID" title="Remove @client.ClientCode"><i class="fal fa-trash-alt"></i></div>
                        </li>
                    }
                </ul>
            }
            @if (showCountry)
            {
                <ul id="countryFilter_@userWidgetId" class="list-group">
                    <li class="list-group-item d-flex justify-content-between">
                        <span>@countryLabel</span>
                        <span>@await Component.InvokeAsync("ComboBox", new { 
                            name = "Country", 
                            textProperty = "Country",
                            valueProperty = "CountryID", 
                            controller = "DisclosureLookup", 
                            action = "GetPatCountryList", 
                            area = "DMS",
                            screen = userWidgetId,
                            columns = new List<ComboBoxColumn> {
                            new ComboBoxColumn{Name="Country",Header=countryLabel,Width=80},
                            new ComboBoxColumn{Name="CountryName",Header=countryNameLabel,Width=300}
                            }
                        })</span>
                    </li>
                    @foreach (CountryLookupViewModel country in countries)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <div>
                                <span class="country-code">@country.Country</span>
                                <span class="country-name">@country.CountryName</span>
                            </div>
                            <div class="delete-filter delete-country" data-id="@country.CountryID" title="Remove @country.Country"><i class="fal fa-trash-alt"></i></div>
                        </li>
                    }
                </ul>
            }
        </div>
        <div class="settings-footer mt-4">
            <button type="button" class="settings-close btn btn-primary float-right"><i class="fa fa-times pr-2"></i>Close</button>
        </div>
    </div>
}

@(Html.Kendo().Grid(Model)
    .Name(userWidgetId)
    .HtmlAttributes(new { @class = "widget-grid" })
    .Columns(columns =>
    {
        columns
            .Bound(u => u.CaseNumber)
            .ClientTemplate(template)
                .Title("")
                .HeaderHtmlAttributes(new { @class = "d-none" });
    })
    .Pageable(pageable => pageable
        .ButtonCount(4)
        .Enabled(pageSize > 0).Responsive(false))
    .DataSource(dataSource => dataSource
        .Ajax()
        .PageSize(pageSize)
        .ServerOperation(false)
        )
)

@if (Model?.Count() <= pageSize)
{
    <style>
    #@userWidgetId .k-pager-info {
        float: left;
        padding: 0;
    }
    #@userWidgetId .k-pager-nav {
        display: none;
    }
    #@userWidgetId .k-pager-numbers {
        display: none;
    }
    </style>
}

<style>
    .badge.within30 {
        background: @tmkColor;
        color: #fff;
    }
    .badge.within60 {
        background: @patColor;
        color: #fff;
    }
    .badge.beyond60 {
        background: @gnmColor;
        color: #fff;
    }
    .badge.pastDaysLimit {
        background: var(--bg-danger) !important;
        color: #fff;
    }
</style>

<script>
    $("#@widget.Id.ToString()").addClass("fixed-width");
</script>
