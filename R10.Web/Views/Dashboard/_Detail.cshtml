@inject IStringLocalizer<SharedResource> Localizer

<script src="~/lib/jquery/jquery.waypoints.min.js"></script>
<script src="~/lib/jquery/inview.min.js"></script>


<div id="dashboardDetail">
</div>


<script>

    function loadWidget() {

        id = @ViewBag.WidgetId;

        var $widget = $("<div>", { id: id, "class": "widget" });
        $widget.html("<div class='widget-spinner text-center'><h4><span>Loading</span><i class='ml-2 fa fa-circle-notch fa-spin'></i></h4></div><div class='widget-container'></div>");

        $("#dashboardDetail").html($widget);

        $.ajax({
            type: "POST",
            url: "@Url.Action("GetWidgetDetail", "Dashboard")",
            data: { userWidgetId: id },
            dataType: "html",
            success: function (data) {
                var $container = $widget.find(".widget-container");
                $widget.find(".widget-spinner").hide();

                if (id == null) {
                    $container.hide();
                }

                if (data.trim()) {
                    $container.append(data);
                }
                else {
                    $widget.remove();
                }

                if (id == null) {
                    $widget.attr("id", $widget.find(".widget-content").data("id"));
                    $container.empty();
                    $container.show();
                    $container.append(data);
                }

                checkSettings($widget);

            },
            error: function (data) {
                $widget.remove();
                if (id != null) {
                    kendo.alert("@Localizer["Unable to load widget. Please try again."]");
                }
            }
        });

    }

    function widgetPlaceholder(element) {
        return element.clone().addClass("widget-placeholder");
    }

    function widgetHint(element) {
        return element.clone().addClass("widget-hint")
            .height(element.height())
            .width(element.width());
    }

    function checkSettings(widget) {
        var settings = widget.find(".widget-settings");

        if (settings.length) {
            settings.hide();
        } else {
            widget.find(".widget-header .settings").remove();
        }        
    }

    function saveSetting(id, setting, successCallback, errorCallback) {
        $.ajax({
            type: "POST",
            url: "@Url.Action("SaveSetting", "Dashboard")",
            data: { id: id, setting: setting },
            dataType: "json",
            success: function (data) {
                if (successCallback && typeof successCallback === "function") {
                    successCallback();
                }
            },
            error: function (data) {
                if (errorCallback && typeof errorCallback === "function") {
                    errorCallback();
                }
            }
        });
    };

    $(document).ready(function () {

        @(ViewBag.WidgetId > 0 ? "loadWidget();" : "")
        
        $(document).on("click", ".widget .settings, .widget .widget-settings .settings-close", function (e) {
            var widget = $(e.target).closest(".widget");
            var id = widget.attr("id");
            var settings = widget.find(".widget-settings");

            settings.slideToggle("fast");
        });

        $(document).on("click", ".widget .refresh", function (e) {
            var widget = $(e.target).closest(".widget");
            var id = widget.attr("id");
            var spinner = widget.find(".widget-spinner");
            var container = widget.find(".widget-container");
            var content = widget.find(".widget-content");
            //var actions = widget.find(".widget-header i");

            spinner.show();
            //actions.css('visibility', 'hidden');
            content.css('visibility', 'hidden');

            $.ajax({
                type: "POST",
                url: "@Url.Action("GetWidgetDetail", "Dashboard")",
                data: { userWidgetId: id },
                dataType: "html",
                success: function (data) {
                    spinner.hide();
                    container.empty();
                    container.show();
                    container.append(data);

                    checkSettings(widget);
                },
                error: function (data) {
                    spinner.hide();
                    //actions.css('visibility', 'visible');
                    content.css('visibility', 'visible');
                    kendo.alert("@Localizer["Unable to refresh widget. Please try again."]");
                }
            });
        });
    });

    //creates and manages a tooltip for chart.
    function ChartTooltipManager(widgetName) {
        var $widget = $("#" + widgetName);
        var $chartWrapper = $widget.closest('.widget-content');

        // Create a unique tooltip element for this chart
        var $customTooltip = $('<div class="custom-chart-tooltip"></div>');
        $chartWrapper.append($customTooltip);

        var tooltipShowTimeout;
        var tooltipHideTimeout;
        var currentHoveredDrawingElement = null;

        // Public method to attach handlers to a chart's surface
        this.attachHandlers = function(surface) {
            surface.unbind("mouseenter", onSurfaceMouseEnter);
            surface.unbind("mouseleave", onSurfaceMouseLeave);

            surface.bind("mouseenter", onSurfaceMouseEnter);
            surface.bind("mouseleave", onSurfaceMouseLeave);
        };

        function onSurfaceMouseEnter(args) {
            clearTimeout(tooltipHideTimeout);

            var hoveredElement = args.element;

            // Traverse up the drawing hierarchy to find an element with tooltipContent
            while (hoveredElement && !hoveredElement.tooltipContent && hoveredElement.parent) {
                hoveredElement = hoveredElement.parent;
            }

            if (hoveredElement && hoveredElement.tooltipContent && hoveredElement !== currentHoveredDrawingElement) {
                currentHoveredDrawingElement = hoveredElement;

                $customTooltip.text(hoveredElement.tooltipContent);

                // Calculate position relative to the chart wrapper
                var wrapperOffset = $chartWrapper.offset();

                $customTooltip.css({
                    left: args.originalEvent.pageX + 15,
                    top: args.originalEvent.pageY - 15
                });

                clearTimeout(tooltipShowTimeout);
                tooltipShowTimeout = setTimeout(function() {
                    $customTooltip.addClass("visible");
                }, 10);
            } else if (hoveredElement && hoveredElement === currentHoveredDrawingElement) {
                // Still hovering over the same element, do nothing.
            } else {
                // No valid element found, hide tooltip
                hideTooltipImmediately();
            }
        }

        function onSurfaceMouseLeave() {
            clearTimeout(tooltipShowTimeout);
            currentHoveredDrawingElement = null;
            hideTooltipImmediately();
        }

        function hideTooltipImmediately() {
            clearTimeout(tooltipHideTimeout);
            $customTooltip.removeClass("visible");
        }
    }
</script>

<style>
    .k-chart {
        width: 95%;
    }

    .k-grid-toolbar {
        float: right;
    }

    /* Custom tooltip styling */
    .custom-chart-tooltip {
        position: absolute;
        background-color: rgba(0, 0, 0, 0.8);
        color: #fff;
        padding: 4px 6px;
        border-radius: 4px;
        font-size: 10px;
        white-space: pre-wrap; /* Allows line breaks if content has them */
        max-width: 300px;
        pointer-events: none; /* Important: allows mouse events to pass through to elements below */
        z-index: 1000;
        opacity: 0;
        transition: opacity 0.2s ease-in-out;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .custom-chart-tooltip.visible {
        opacity: 1;
    }
</style>