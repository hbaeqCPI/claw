@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<PatSetting> PatSettings
@inject ISystemSettings<TmkSetting> TmkSettings
@inject ISystemSettings<GMSetting> GMSettings
@inject IAuthorizationService AuthService
@{
    ViewData["Title"] = Localizer["Dashboard"].ToString();
    var canAccessCustomQuery = User.IsInRoles(CPiPermissions.CustomQuery);
    var deleteConfirmation = Html.Raw(Localizer["Delete the widget will delete this widget in other users dashboard too. Please confirm if you still want to delete it."].ToString());

}
<script src="~/lib/jquery/jquery.waypoints.min.js"></script>
<script src="~/lib/jquery/inview.min.js"></script>

<div class="widgetCategories form-row">
    @foreach(var category in WidgetCategory.Categories.OrderBy(c => c.SortOrder))
    {
        if(!category.DisplayName.Equals("My Widgets") || canAccessCustomQuery)
        {
            <div class="form-group">
            <input id="@category.Name" type="radio" name="widgetCat" value="@category.Id" @(category.Id == WidgetCategory.DefaultCategoryId ? "checked" : "") />
            <label class="widgetCatLbl" for="@category.Name"><i class="@category.Icon widgetCatIcon"></i>@Localizer[category.DisplayName]</label>
        </div>
        }
    }

    <div class="form-group">
        <nav class="nav">
            <a id="exportPPTWidgets" class="nav-link" href="#" role="button"><i class="fal fa-file-powerpoint pr-2"></i>@Localizer["Export Widgets"]</a>
        </nav>
    </div>

    <div class="form-group">
        <nav class="nav">
            <a id="removeWidgets" class="nav-link" href="#" role="button"><i class="fal fa-minus pr-2"></i>@Localizer["Clear Widgets"]</a>
        </nav>
    </div>

    <div class="form-group">
        <nav class="nav">
            <a id="addWidgetPopup" class="nav-link" href="#" role="button"><i class="fal fa-plus pr-2"></i>@Localizer["Add Widget"]</a>           
        </nav>
    </div>
</div>

<div id="dashboard">
</div>
@(Html.Kendo().Sortable()
    .Name("DashboardSortable")
    .For("#dashboard")
    //.Filter(">div")
    .Filter(".widget")
    .Handler(".widget-title")
    .Ignore(".non-sortable, .non-sortable *")
    //.Cursor("move")
    .PlaceholderHandler("widgetPlaceholder")
    .HintHandler("widgetHint")
    .Events(e => e.Change("widgetsOnChange"))
)

<div class="cpiContainerPopup"></div>
<script>    
    var widgetCopy = {};
    var refreshWidgetCopy = false;
    var widgetCopyTempSetting = "";

    var catWidgetList = [];
    var widgetList = [];

    var widgetCategory = $(':radio[name=widgetCat]:checked').val();

    $(window).resize(function () {
        kendo.resize($("div.k-chart[data-role='chart']"));
    });    

    function loadWidget(id, queueNext) {
        if (id != null && $(`#${id}`).length > 0) {
            //var title = $(`#${id}`).find(".widget-title").text().trim();
            //kendo.alert(`${title} already exists.`);
            return;
        }

        var $widget = $("<div>", { id: id, "class": "widget" });
        $widget.html("<div class='widget-spinner text-center'><h4><span>Loading</span><i class='ml-2 fa fa-circle-notch fa-spin'></i></h4></div><div class='widget-container'></div>");

        $("#dashboard").append($widget);
        
        var inview = new Waypoint.Inview({
            element: $widget,
            enter: function (direction) {
                if (!$widget.hasClass("loaded")) {
                    $widget.addClass("loaded");

                    $.ajax({
                        type: "POST",
                        url: "@Url.Action("GetWidget", "Dashboard")",
                        data: { id: id, queueNext: queueNext, widgetCategory: widgetCategory},
                        dataType: "html",
                        success: function (data) {
                            var $container = $widget.find(".widget-container");
                            $widget.find(".widget-spinner").hide();

                            if (id == null) {
                                $container.hide();
                            }

                            if (data.trim()) {
                                $container.empty();
                                $container.show();
                                $container.append(data);
                            }
                            else {
                                $widget.remove();
                            }

                            if (id == null) {
                                $widget.attr("id", $widget.find(".widget-content").data("id"));
                            }

                            checkSettings($widget);

                            var nextId = $widget.find(".widget-content").data("next-id");
                            if (nextId != null) {
                                loadWidget(nextId, true);
                            }
                        },
                        error: function (data) {
                            $widget.remove();
                            if (id != null) {
                                kendo.alert("@Localizer["Unable to load widget. Please try again."]");
                            }
                        }
                    });
                }
            },
            enable: false
        });
    }

    function widgetPlaceholder(element) {
        return element.clone().addClass("widget-placeholder");
    }

    function widgetHint(element) {
        return element.clone().addClass("widget-hint")
            .height(element.height())
            .width(element.width());
    }

    function widgetsOnChange(e) {
        var widget = e.item;
        var id = widget.attr("id");
        var newIndex = e.newIndex;
        var oldIndex = e.oldIndex;;

        $.ajax({
            type: "POST",
            url: "@Url.Action("SortUserWidget", "Dashboard")",
            data: { userWidgetId: id, newIndex: newIndex, widgetCategory: widgetCategory },
            dataType: "json",
            success: function (response) {
                if (!response.success) {
                    kendo.alert(response.message);
                }
            },
            error: function (response) {
                kendo.alert("@Localizer["Unable to sort widgets. Please try again."]");
            }
        });
    }
        
    function checkSettings(widget) {
        var settings = widget.find(".widget-settings");
        if (settings.length) {
            settings.hide();
        } else {
            widget.find(".widget-header .settings").remove();
        }

        var widgetCopyPopup = $("#widgetCopyDialog");
        var dashboardSettingPopup = $("#dashboardSettingDialog");

        if (widgetCopyPopup.length === 0 && dashboardSettingPopup.length === 0) {
            var view = widget.find(".widget-header .view")
            if (view != null) {
                if (widget.hasClass("double-width")) {
                    view.addClass("fa-compress-alt");
                    view.removeClass("fa-expand-alt");
                    view.attr("title", "Compress view");
                }
            }
        }

        applyChartOptions(widget);
    }    
       
    function saveSetting(id, setting, successCallback, errorCallback) {        
        var widgetCopyPopup = $("#widgetCopyDialog");
        var dashboardSettingPopup = $("#dashboardSettingDialog");
        if (widgetCopyPopup.length > 0) {
            let widgetSetting = widgetCopy.Setting;
            if (widgetSetting) {
                let newSetting = eval('(' + setting + ')');
                let savedSetting = eval('(' + widgetSetting + ')');

                var mergedSetting = Object.assign(savedSetting, newSetting);
                if (mergedSetting) {
                    widgetCopy.Setting = JSON.stringify(mergedSetting);
                }
            }
            else {
                if (widgetCopyTempSetting > "") {
                    let newSetting = eval('(' + setting + ')');
                    let savedSetting = eval('(' + widgetCopyTempSetting + ')');

                    var mergedSetting = Object.assign(savedSetting, newSetting);
                    if (mergedSetting) {
                        widgetCopy.Setting = JSON.stringify(mergedSetting);
                    }
                }
                else {
                    widgetCopy.Setting = setting;
                }                
            }
            widgetCopyTempSetting = widgetCopy.Setting;            

            if (successCallback && typeof successCallback === "function") {
                successCallback();
            }

            if (widgetSetting != widgetCopy.Setting) {
                refreshWidgetCopy = true;
            }
            else {
                refreshWidgetCopy = false;
            }
        }
        else if (dashboardSettingPopup.length > 0) {
            var widgetPreview = $("#" + id);
            if (widgetPreview.length > 0) {
                if (widgetList.filter(d => d.Id === id).length > 0) {
                    let widget = widgetList.filter(d => d.Id === id);
                    let widgetSetting = widget[0].Setting;
                    let objIndex = widgetList.findIndex(d => d.Id == id);

                    if (widgetSetting) {
                        let newSetting = eval('(' + setting + ')');
                        let savedSetting = eval('(' + widgetSetting + ')');

                        var mergedSetting = Object.assign(savedSetting, newSetting);
                        if (mergedSetting) {
                            widgetList[objIndex].Setting = JSON.stringify(mergedSetting);
                        }
                    }
                }
                else {
                    let widget = { Id: id, Setting: setting, Title: null };
                    widgetList.push(widget);
                }

                if (successCallback && typeof successCallback === "function") {
                    successCallback();
                }
            }
        }
        else {
            $.ajax({
                type: "POST",
                url: "@Url.Action("SaveSetting", "Dashboard")",
                data: { id: id, setting: setting },
                dataType: "json",
                success: function (data) {
                    if (successCallback && typeof successCallback === "function") {
                        successCallback();
                    }
                },
                error: function (data) {
                    if (errorCallback && typeof errorCallback === "function") {
                        errorCallback();
                    }
                }
            });       
        }
    };

    function getWidgetTempSetting(widgetId) {
        var widgetCopyPopup = $("#widgetCopyDialog");
        var dashboardSettingPopup = $("#dashboardSettingDialog");
        var tempSettings = "";
        if (widgetCopyPopup.length > 0) {
            tempSettings = widgetCopyTempSetting;
        }
        else if (dashboardSettingPopup.length > 0) {
            if (widgetList && widgetList.length > 0 && widgetList.filter(d => d.Id === widgetId).length > 0) {
                let widget = widgetList.filter(d => d.Id === widgetId);
                tempSettings = widget[0].Setting;
            }
        }

        return { tempSettings: tempSettings };
    }

    function handleSPFileDownload(event) {
        event.preventDefault();
        const baseUrl = $("body").data("base-url");
        const sharePointURL = `${baseUrl}/Graph/SharePoint`;
        var retry = 0;
        
        downloadFile();

        function downloadFile() {            
            fetch(event.target.href)
                .then(response => {
                    if (!response.ok) {
                        if ((response.url.indexOf("/Graph/SharePoint") > -1 || response.status == 401) && retry < 3) {
                            retry++;                            
                            sharePointGraphHelper.getGraphToken(sharePointURL, () => {
                                downloadFile();
                            });
                        }
                        else {
                            throw new Error(response.statusText);
                        }
                    }
                    else {
                        return response.blob();
                    }                    
                })
                .then(blob => {
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = event.target.download;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                })
                .catch(error => {  
                    if (error && error.status && error.status == 401 && retry < 3) {
                        retry++;
                        sharePointGraphHelper.getGraphToken(sharePointURL, () => {
                            downloadFile();
                        });
                    }
                    else {
                        pageHelper.showErrors(error.responseText);
                    }
                });
        }
    }

    function applyChartOptions(widget) {
        if (!widget || widget.length === 0) {
            return;
        }

        var chartElement = widget.find("div.k-chart[data-role='chart']");

        if (!chartElement || chartElement.length === 0) {
            return;
        }
                  
        const kendoChart = chartElement.data("kendoChart");

        if (!kendoChart) {
            return;
        }

        var redrawChart = false;

        // Estimate the plot area width by subtracting the chart's margins and padding.
        const containerWidth = kendoChart.element.width();        
        const chartPadding = 20;
        const plotAreaWidth = containerWidth - (chartPadding * 2);
        const moderateRotation = -45;
        const fullRotation = -90;

        // --- Category Label START---
        const chartType = kendoChart.options.series ? kendoChart.options.series[0].type : "";
        const showCategoryAxisLabels = (kendoChart.options.categoryAxis.labels.visible == undefined ? true: kendoChart.options.categoryAxis.labels.visible) && kendoChart.options.categoryAxis.categories;
        if (showCategoryAxisLabels && chartType === "column") {
            const labels = kendoChart.options.categoryAxis.categories;
            const numItems = labels.length;

            // Calculate the maximum available width for a single label
            const maxSingleLabelWidth = plotAreaWidth / numItems;

            // Get the font from the chart options to ensure accurate measurement
            const categoryAxisLabelFont = kendoChart.options.categoryAxis.labels.font || "12px Arial, sans-serif";

            let totalCategoryAxisLabelWidth = 0;
            let hasLongCategoryAxisLabel = false;

            // Iterate through labels to check for both total and individual width
            labels.forEach(label => {
                const labelWidth = getTextWidth(label, categoryAxisLabelFont);
                totalCategoryAxisLabelWidth += labelWidth;

                if (labelWidth > maxSingleLabelWidth) {
                    hasLongCategoryAxisLabel = true;
                }
            });

            const spacingBetweenLabels = 10;
            const requiredWidth = totalCategoryAxisLabelWidth + ((numItems - 1) * spacingBetweenLabels);

            // Define thresholds for rotation            
            const moderateRotationThreshold = 1.2; // Rotate -45deg if required width is > X available width
            const fullRotationThreshold = 1.6; // Rotate -90deg if required width is > X available width

            // Check for the need for moderate rotation
            if (requiredWidth > plotAreaWidth * moderateRotationThreshold || hasLongCategoryAxisLabel) {
                // Check for the need for full rotation
                if (requiredWidth > plotAreaWidth * fullRotationThreshold) {
                    kendoChart.options.categoryAxis.labels.rotation = fullRotation;
                } else {
                    kendoChart.options.categoryAxis.labels.rotation = moderateRotation;
                }
            } else {
                kendoChart.options.categoryAxis.labels.rotation = 0;
            }

            redrawChart = true;
        }        
        // --- Category Label END---

        // --- Series Label START---
        const series = kendoChart.options.series[0];
        const hasSeriesLabels = series.labels && series.labels.visible;
        if (hasSeriesLabels && series.type === "column") {
            const seriesLabelFont = series.labels.font || "11px Arial, sans-serif";
            const seriesFieldName = series.field;
            const longestSeriesLabel = series.data.reduce((max, item) => {                
                const text = String(item[seriesFieldName]); // Convert the value to a string                
                const width = getTextWidth(text, seriesLabelFont);
                return Math.max(max, width);
            }, 0);

            // Compare longest label width to the available space
            const requiredSeriesWidth = longestSeriesLabel * series.data.length;
            if (requiredSeriesWidth > plotAreaWidth) {
                series.labels.rotation = fullRotation;
            } else {
                series.labels.rotation = 0;
            }
            series.labels.background = "transparent";

            redrawChart = true;
        }
        // --- Series Label END---

        // --- Category Axis Label sort ---
        var axis = kendoChart.options.categoryAxis;        
        const hasCustomSort = chartElement.hasClass("customSort");
        if (hasCustomSort === false && axis && axis.categories) {
            axis.categories = axis.categories.sort(function(a, b) {                
                if (a.toLowerCase() > b.toLowerCase()) {
                    return 1;
                }
                if (a.toLowerCase() < b.toLowerCase()) {
                    return -1;
                }
                return 0;
            });
            
            redrawChart = true;
        }       

        if (redrawChart) {
            kendoChart.redraw();
        }        
    }

    function getTextWidth(text, font) {
        const canvas = getTextWidth.canvas || (getTextWidth.canvas = document.createElement("canvas"));
        const context = canvas.getContext("2d");
        context.font = font;
        const metrics = context.measureText(text);
        return metrics.width;
    }

