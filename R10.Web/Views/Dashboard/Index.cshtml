        //open widget popup
        $(document).on("click", "#addWidgetPopup", function (e) {
            cpiLoadingSpinner.show();
            $.get("@Url.Action("DashboardSetting", "Dashboard")")
                .done(function (response) {
                    const popupContainer = $(".cpiContainerPopup").last();
                    popupContainer.html("");
                    popupContainer.html(response);
                    const dialog = $("#dashboardSettingDialog");
                    dialog.unbind();
                    dialog.modal("show");
                    cpiLoadingSpinner.hide();

                    dialog.on('hidden.bs.modal', function (e) {
                        dialog.remove();
                        popupContainer.html("");
                        $("#dashboard").empty();
                        loadWidget();
                    })

                    catWidgetList = [];
                    widgetList = [];
                })
                .fail(function (error) {
                    cpiLoadingSpinner.hide();
                    pageHelper.showErrors(error);
                });
        });

        //widget title START
        $(document).off("click", ".widgetTitleClearIcon");
        $(document).on("click", ".widgetTitleClearIcon", function (e) {
            var widgetCopyPopup = $("#widgetCopyDialog");
            var dashboardSettingPopup = $("#dashboardSettingDialog");

            const userWidgetId = $(e.target).data("widgetid");
            var titleInput = $('#widgetTitle-' + userWidgetId);  
            
            if (widgetCopyPopup.length > 0) {
                titleInput = $('#copyPreviewTitle-' + userWidgetId);
            }
            else if (dashboardSettingPopup.length > 0) {
                titleInput = $('#previewTitle-' + userWidgetId);
            }            

            var defaultValue = titleInput.data("default-value"); 
            titleInput.val(defaultValue);
            titleInput.blur();            
            $('#saveTitleIcon-' + userWidgetId).hide();            
            $('#clearTitleIcon-' + userWidgetId).hide();

            if (widgetCopyPopup.length === 0 && dashboardSettingPopup.length === 0) {
                var editRow = $("#editTitleRow-" + userWidgetId);
                if (editRow) {
                    editRow.addClass("d-none");
                }
                var widgetTitle = $("#" + userWidgetId + " .widget-header .widget-title");
                if (widgetTitle)
                    widgetTitle.text(defaultValue);
            }            
        });

        $(document).off("click", ".widgetTitleSaveIcon");
        $(document).on("click", ".widgetTitleSaveIcon", function (e) {
            var widgetCopyPopup = $("#widgetCopyDialog");
            var dashboardSettingPopup = $("#dashboardSettingDialog");

            const userWidgetId = $(e.target).data("widgetid");
            var titleInput = $('#widgetTitle-' + userWidgetId);            
            var value = titleInput.val();     

            if (widgetCopyPopup.length > 0) {
                titleInput = $('#copyPreviewTitle-' + userWidgetId);
                value = titleInput.val();
                widgetCopy.Title = value;
            }
            else if (dashboardSettingPopup.length > 0) {
                titleInput = $('#previewTitle-' + userWidgetId);
                value = titleInput.val();
                if (widgetList.filter(d => d.Id == userWidgetId).length > 0) {
                    widgetList.filter(d => d.Id == userWidgetId)[0].Title = value;
                }
                else {
                    let widget = { Id: userWidgetId, Setting: "{}", Title: value };
                    widgetList.push(widget);
                }
            }
            else {
                $.ajax({
                    type: "POST",
                    url: "@Url.Action("SaveWidgetTitle", "Dashboard")",
                    data: { userWidgetId: userWidgetId, widgetTitle: value },
                    dataType: "json",
                    success: function (data) {                        
                        $("#" + userWidgetId + " .widget-actions .refresh").trigger("click");
                    },
                    error: function (data) {
                        kendo.alert("@Localizer["Unable to update title."]");
                    }
                });
            }
            titleInput.blur();
            $('#saveTitleIcon-' + userWidgetId).hide();
            $('#clearTitleIcon-' + userWidgetId).hide();                        
        });

        $(document).off("keyup", ".widgetTitleInput");
        $(document).on("keyup", ".widgetTitleInput", function (e) {
            const userWidgetId = $(e.target).data("id");
            $('#saveTitleIcon-' + userWidgetId).show();
            $('#clearTitleIcon-' + userWidgetId).show();
        });

        $(document).off("focus", ".widgetTitleInput");
        $(document).on("focus", ".widgetTitleInput", function (e) {
            const userWidgetId = $(e.target).data("id");
            $('#titleEditIcon-' + userWidgetId).hide();            
        });

        $(document).off("blur", ".widgetTitleInput");
        $(document).on("blur", ".widgetTitleInput", function (e) {
            const userWidgetId = $(e.target).data("id");
            $('#titleEditIcon-' + userWidgetId).show();
        });
        //widget title END  
    });    
        
    //get widget data for PowerPoint
    async function getPPTData(widgets) {
        var exportData = [];
        
        for (const item of widgets) {

            var pptData = await drawWidgetPPT(item.split("|")[0], item.split("|")[1]);
            exportData.push(pptData);
        }     
        if (exportData.length > 0) {             
            $.ajax({
                cache: false,
                url: "@Url.Action("ExportPowerPointList", "Dashboard")",
                data: JSON.stringify(exportData),
                dataType: "json",
                contentType: "application/json; charset=utf-8",
                type: "POST",                        
                success: function (result) {                    
                    if (result.isSuccess) {
                        var linkUrl = '@Url.Action("GetPPTExportList", "Dashboard", new { fileGuid = "-1" })';
                        linkUrl = linkUrl.replace("-1", result.fileGuid);
                        window.location = linkUrl;
                    }
                },
                error: function (error) {
                    pageHelper.showErrors(error.responseText);
                }
            });                         
        }
    }
    
    //get PowerPoint data
    function drawWidgetPPT(widgetName, widgetTitle) {
      return new Promise(resolve => {

        var kendoChart = $("#" + widgetName).data("kendoChart");
        if (kendoChart) {  
            kendoChart.exportImage({
                    paperSize: "auto",
                    margin: { left: "1cm", top: "1cm", right: "1cm", bottom: "1cm" }
            })
            .done(function (widgetData) {  
                resolve({ WidgetData: widgetData.replace("data:image/png;base64,", ""), WidgetTitle: widgetTitle + "|chart" });
            });           
        }   
        var kendoMap = $("#" + widgetName).data("kendoMap");
        if (kendoMap) {
            kendoMap.exportImage({
                    paperSize: "auto",
                    margin: { left: "1cm", top: "1cm", right: "1cm", bottom: "1cm" }
            })
            .done(function (widgetData) {
                resolve({ WidgetData: widgetData.replace("data:image/png;base64,", ""), WidgetTitle: widgetTitle + "|map" });
            });
        }   
        
      });
    }

    //creates and manages a tooltip for chart.
    function ChartTooltipManager(widgetName) {
        var $widget = $("#" + widgetName);
        var $chartWrapper = $widget.closest('.widget-content');

        // Create a unique tooltip element for this chart
        var $customTooltip = $('<div class="custom-chart-tooltip"></div>');
        $chartWrapper.append($customTooltip);

        var tooltipShowTimeout;
        var tooltipHideTimeout;
        var currentHoveredDrawingElement = null;

        // Public method to attach handlers to a chart's surface
        this.attachHandlers = function(surface) {
            surface.unbind("mouseenter", onSurfaceMouseEnter);
            surface.unbind("mouseleave", onSurfaceMouseLeave);

            surface.bind("mouseenter", onSurfaceMouseEnter);
            surface.bind("mouseleave", onSurfaceMouseLeave);
        };

        function onSurfaceMouseEnter(args) {
            clearTimeout(tooltipHideTimeout);

            var hoveredElement = args.element;

            // Traverse up the drawing hierarchy to find an element with tooltipContent
            while (hoveredElement && !hoveredElement.tooltipContent && hoveredElement.parent) {
                hoveredElement = hoveredElement.parent;
            }

            if (hoveredElement && hoveredElement.tooltipContent && hoveredElement !== currentHoveredDrawingElement) {
                currentHoveredDrawingElement = hoveredElement;

                $customTooltip.text(hoveredElement.tooltipContent);

                // Calculate position relative to the chart wrapper
                var wrapperOffset = $chartWrapper.offset();
                $customTooltip.css({
                    left: args.originalEvent.pageX - wrapperOffset.left + 15,
                    top: args.originalEvent.pageY - wrapperOffset.top + 15
                });

                clearTimeout(tooltipShowTimeout);
                tooltipShowTimeout = setTimeout(function() {
                    $customTooltip.addClass("visible");
                }, 10);
            } else if (hoveredElement && hoveredElement === currentHoveredDrawingElement) {
                // Still hovering over the same element, do nothing.
            } else {
                // No valid element found, hide tooltip
                hideTooltipImmediately();
            }
        }

        function onSurfaceMouseLeave() {
            clearTimeout(tooltipShowTimeout);
            currentHoveredDrawingElement = null;
            hideTooltipImmediately();
        }

        function hideTooltipImmediately() {
            clearTimeout(tooltipHideTimeout);
            $customTooltip.removeClass("visible");
        }
    }

</script>

