            var id = widget.attr("id");
            var url = "";
            var data = { };

            if (widgetCopyPopup.length > 0) {
                widget = $(e.target).closest(".copyWidgetPreview");
                id = widget.attr("id");
                if (id) {
                    id = id.replace("copyWidget-", "");
                }
                url = "@Url.Action("GetCopyPreviewWidgetDetail", "Dashboard")";
                data = { widgetId: id, isRefresh: true, widgetSettings: widgetCopy.Setting, title: widgetCopy.Title };                 
