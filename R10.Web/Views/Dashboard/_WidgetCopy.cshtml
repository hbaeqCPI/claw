@model int
@inject IStringLocalizer<SharedResource> Localizer
@{
    var selectedCategory = ViewData["WidgetCategory"] ?? 1;

    var categoryList = new List<SelectListItem>();
    foreach (var category in WidgetCategory.Categories.Where(d => d.Name.ToLower() != "customwidgets").OrderBy(o => o.SortOrder))
    {
        categoryList.Add(new SelectListItem() { Text = Localizer[category.DisplayName], Value = category.Id.ToString() });
    }
}
<script id="widgetCopyScript"> 

    //Category onDataBound - set default category selected value
    function copyCategoryDataBound(e) {
        e.sender.value(@selectedCategory);        
    }   

    //Category onChange - save selected Category to copy widget to
    function copyCategoryDropDownOnChange(e) {
        let selectedCat = e.sender.dataItem().Value;
        widgetCopy.Category = selectedCat;
    }           

    $(document).ready(function () {         
        widgetCopy.Category = "@selectedCategory";

        //Copy widget
        $("#saveWidgetCopy").bind("click", function (e) {            
            $.ajax({
                url: "@Url.Action("SaveWidgetCopy", "Dashboard")",
                type: 'POST',
                data: { userWidgetId: @Model, category: widgetCopy.Category, widgetSettings: widgetCopy.Setting, title: widgetCopy.Title },
                success: function (result) {
                    const dialog = $("#widgetCopyDialog");
                    dialog.modal("hide");
                    //location.reload();
                },
                error: function (error) {
                    pageHelper.showErrors(error.responseText);
                }
            });
        });

        //load widget
        const widgetId = @Model; 
        var $widget = $("<div>", { id: "copyWidget-" + widgetId, "class": "copyWidgetPreview" });        
        $widget.html("<div class='widget-spinner text-center'><h4><span>@Localizer["Loading preview"]</span><i class='ml-2 fa fa-circle-notch fa-spin'></i></h4></div><div class='widget-container'></div>");

        $("#previewWidgetCopy").html($widget);

        $.ajax({
            type: "POST",
            url: "@Url.Action("GetCopyPreviewWidgetDetail", "Dashboard")",
            data: { widgetId: widgetId },
            dataType: "html",
            success: function (data) {
                var $container = $widget.find(".widget-container");
                $widget.find(".widget-spinner").hide();
                if (widgetId == null) {
                    $container.hide();
                }
                if (data.trim()) {
                    $container.append(data);
                }
                else {
                    $widget.remove();
                }
                if (widgetId == null) {
                    $widget.attr("id", $widget.find(".widget-content").data("id"));
                    $container.empty();
                    $container.show();
                    $container.append(data);
                }
                checkSettings($widget);                
            },
            error: function (data) {
                $widget.remove();
                if (widgetId != null) {
                    kendo.alert("@Localizer["Unable to load widget. Please try again."]");
                }
            }
        });  

    });
   
</script>

<div class="modal fade" id="widgetCopyDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">            
            <div class="modal-header py-1">
                <h4 class="modal-title">@Localizer["Copy"]</h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body pt-0">
                <div class="container-fluid">  
                    <div class="row">
                        <div class="col">
                            <div class="row">
                                <div class="col-12 col-md-12 col-lg-6 col-xl-6">
                                    <div class="form-group float-label">
                                        <label for="UserType">@Localizer["Section"]</label>
                                        @(Html.Kendo().DropDownList()
                                            .Name("CategoryDropDown")
                                            .DataTextField("Text")
                                            .DataValueField("Value")
                                            .Events(e => e.DataBound("copyCategoryDataBound").Change("copyCategoryDropDownOnChange"))
                                            .BindTo(categoryList)
                                            )
                                    </div>
                                </div>                                
                            </div>
                            <div class="col">
                                <div id="previewWidgetCopy"></div>
                            </div>                            
                            <div class="modal-footer" style="border-top:none">
                                <button type="button" class="btn btn-secondary" id="cancelWidgetCopy" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                                <button type="button" class="btn btn-primary" id="saveWidgetCopy"><i class="fa fa-check pr-2"></i>@Localizer["Copy"]</button>
                            </div>
                        </div>                        
                    </div>                    
                </div>
            </div>            
        </div>
    </div>
</div>

