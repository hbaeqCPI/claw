@inject IStringLocalizer<SharedResource> Localizer
@inject IStringLocalizer<MenuResource> MenuLocalizer
@{
    ViewData["Title"] = "Home";
}

<div class="page-content">
    <div class="pt-3">
        @* Patent *@
        <div class="home-section mb-4">
            <h5 class="mb-0">@MenuLocalizer["Patent"]</h5>
            <hr class="mt-2 mb-3" />
            <div class="row">
                <div class="col-md-5">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Manage"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled">
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryLaw" asp-action="Search" class="home-link">@Localizer["Country Law"]</a></li>
                    </ul>
                </div>
                <div class="col-md-7">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Auxiliary"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled" style="column-count: 2; column-gap: 2rem;">
                        <li class="mb-1"><a asp-area="Patent" asp-controller="ActionType" asp-action="Index" class="home-link">@Localizer["Action Type"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="Area" asp-action="Index" class="home-link">@Localizer["Area"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CaseType" asp-action="Search" class="home-link">@Localizer["Case Type"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="Country" asp-action="Index" class="home-link">@Localizer["Country"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="Indicator" asp-action="Index" class="home-link">@Localizer["Indicator"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryDue" asp-action="Index" class="home-link">@Localizer["Country Due"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryExp" asp-action="Index" class="home-link">@Localizer["Country Expiry"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseType" asp-action="Index" class="home-link">@Localizer["Des Case Type"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeFields" asp-action="Index" class="home-link">@Localizer["Des Case Type Fields"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="AreaDelete" asp-action="Index" class="home-link">@Localizer["Area Delete"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="AreaCountryDelete" asp-action="Index" class="home-link">@Localizer["Area Country Delete"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryExpDelete" asp-action="Index" class="home-link">@Localizer["Country Exp Delete"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryLawExt" asp-action="Index" class="home-link">@Localizer["Country Law Ext"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeExt" asp-action="Index" class="home-link">@Localizer["Des Case Type Ext"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeDelete" asp-action="Index" class="home-link">@Localizer["Des Case Type Delete"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeDeleteExt" asp-action="Index" class="home-link">@Localizer["Des Case Type Delete Ext"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeFieldsExt" asp-action="Index" class="home-link">@Localizer["Des Case Type Fields Ext"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeFieldsDelete" asp-action="Index" class="home-link">@Localizer["Des Case Type Fields Delete"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeFieldsDeleteExt" asp-action="Index" class="home-link">@Localizer["Des Case Type Fields Delete Ext"]</a></li>
                    </ul>
                </div>
            </div>
        </div>

