@inject IStringLocalizer<SharedResource> Localizer
@inject IStringLocalizer<MenuResource> MenuLocalizer
@{
    ViewData["Title"] = "Home";
    var userName = User.FindFirst(R10.Core.Helpers.CPiClaimTypes.FirstName)?.Value ?? "";
}

<div class="page-content">
    <div class="home-welcome pt-4 pb-4">
        <h2 class="mb-1">@Localizer["Welcome back"], @userName</h2>
        <p class="text-muted mb-0">@Localizer["Select a module to get started."]</p>
    </div>

    <div class="pt-3">
        @* Patent *@
        <div class="home-section mb-4">
            <h5 class="mb-0">@MenuLocalizer["Patent"]</h5>
            <hr class="mt-2 mb-3" />
            <div class="row">
                <div class="col-md-5">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Manage"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled">
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryLaw" asp-action="Search" class="home-link">@Localizer["Country Law"]</a></li>
                    </ul>
                </div>
                <div class="col-md-7">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Auxiliary"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled" style="column-count: 2; column-gap: 2rem;">
                        <li class="mb-1"><a asp-area="Patent" asp-controller="ActionType" asp-action="Index" class="home-link">@Localizer["Action Type"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="Area" asp-action="Index" class="home-link">@Localizer["Area"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CaseType" asp-action="Search" class="home-link">@Localizer["Case Type"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="Country" asp-action="Index" class="home-link">@Localizer["Country"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="Indicator" asp-action="Index" class="home-link">@Localizer["Indicator"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryDue" asp-action="Index" class="home-link">@Localizer["Country Due"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="CountryExp" asp-action="Index" class="home-link">@Localizer["Country Expiry"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseType" asp-action="Index" class="home-link">@Localizer["Des Case Type"]</a></li>
                        <li class="mb-1"><a asp-area="Patent" asp-controller="DesCaseTypeFields" asp-action="Index" class="home-link">@Localizer["Des Case Type Fields"]</a></li>
                    </ul>
                </div>
            </div>
        </div>

        @* Trademark *@
        <div class="home-section mb-4">
            <h5 class="mb-0">@MenuLocalizer["Trademark"]</h5>
            <hr class="mt-2 mb-3" />
            <div class="row">
                <div class="col-md-5">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Manage"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled">
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="CountryLaw" asp-action="Search" class="home-link">@Localizer["Country Law"]</a></li>
                    </ul>
                </div>
                <div class="col-md-7">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Auxiliary"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled" style="column-count: 2; column-gap: 2rem;">
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="ActionType" asp-action="Index" class="home-link">@Localizer["Action Type"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="Area" asp-action="Index" class="home-link">@Localizer["Area"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="CaseType" asp-action="Search" class="home-link">@Localizer["Case Type"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="Country" asp-action="Index" class="home-link">@Localizer["Country"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="Indicator" asp-action="Index" class="home-link">@Localizer["Indicator"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="StandardGood" asp-action="Index" class="home-link">@Localizer["Standard Goods"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="CountryDue" asp-action="Index" class="home-link">@Localizer["Country Due"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="DesCaseType" asp-action="Index" class="home-link">@Localizer["Des Case Type"]</a></li>
                        <li class="mb-1"><a asp-area="Trademark" asp-controller="DesCaseTypeFields" asp-action="Index" class="home-link">@Localizer["Des Case Type Fields"]</a></li>
                    </ul>
                </div>
            </div>
        </div>

        @* Releases *@
        <div class="home-section mb-4">
            <h5 class="mb-0">@Localizer["Releases"]</h5>
            <hr class="mt-2 mb-3" />
            <div class="row">
                <div class="col-md-5">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Manage"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled">
                        <li class="mb-1"><a asp-area="Releases" asp-controller="Release" asp-action="Index" class="home-link">@Localizer["Releases"]</a></li>
                    </ul>
                </div>
                <div class="col-md-7">
                    <h6 class="text-muted text-uppercase small font-weight-bold mb-1">@Localizer["Auxiliary"]</h6>
                    <hr class="mt-1 mb-2" />
                    <ul class="list-unstyled">
                        <li class="mb-1"><a asp-area="Shared" asp-controller="System" asp-action="Index" class="home-link">@Localizer["Systems"]</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .home-welcome {
        border-bottom: 1px solid #eee;
        margin-bottom: 1.5rem;
    }
    .home-link {
        color: var(--link-nav, #337ab7);
        text-decoration: none;
        padding: 0.2rem 0;
        display: inline-block;
    }
    .home-link:hover {
        text-decoration: underline;
    }
</style>
