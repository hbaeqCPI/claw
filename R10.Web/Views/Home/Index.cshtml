            </div>
        </div>
    </div>
</div>

<style>
    .home-link {
        color: var(--link-nav, #337ab7);
        text-decoration: none;
        padding: 0.2rem 0;
        display: inline-block;
    }
    .home-link:hover {
        text-decoration: underline;
    }
</style>
