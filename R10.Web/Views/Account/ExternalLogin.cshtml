@using Microsoft.Extensions.Configuration;
@inject IConfiguration Configuration

@model ExternalLoginViewModel
@{
    if (ViewData["ErrorMessage"] == null)
    {
        ViewData["Title"] = "Register";
    }
    else
    {
        ViewData["Title"] = "Log in";
    }
}

<div class="row mt-3">
    <div class="col">
        @if (ViewData["ErrorMessage"] != null)
        {
            <div class="card card-account border-secondary mx-auto">
                <h3 class="card-header bg-transparent border-0 mt-0 text-center">@ViewData["Title"]</h3>
                <div class="card-body">
                    <div class="alert alert-danger mx-auto mb-4" role="alert">
                        @*<h4 class="alert-heading">Login failed</h4>*@
                        <p class="card-text">@Html.Raw(ViewData["ErrorMessage"])</p>
                    </div>
                    <p class="card-text text-center">
                        <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-primary">Back to Log in</a>
                    </p>
                </div>
            </div>

        }
        else if (ViewData["SuccessMessage"] == null)
        {
            <form asp-action="ExternalLoginConfirmation" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <div class="card card-account border-secondary mx-auto">
                    <h3 class="card-header bg-transparent border-0 mt-0 text-center">@ViewData["Title"]</h3>
                    <div class="card-body">
                        <div class="card-title mt-0 pb-3">
                            <p>You've successfully authenticated with <strong>@(Configuration[$"Authentication:{Model.LoginProvider}:Name"] ?? Model.LoginProvider)</strong>.</p>
                            <p>
                                Please provide the following information and click the Register button to finish
                                logging in.
                            </p>
                        </div>
                        <input asp-for="LoginProvider" name="LoginProvider" type="hidden" />
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger alert-dismissible validation-summary-errors mb-4" role="alert">
                                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                @*<h4 class='alert-heading'>Registration failed.</h4>*@
                                <ul class="list-unstyled">
                                    @foreach (var key in ViewData.ModelState.Keys)
                                    {
                                        @foreach (var error in ViewData.ModelState[key].Errors)
                                        {
                                            <li>@Html.Raw(error.ErrorMessage)</li>
                                        }
                                    }
                                </ul>
                            </div>
                        }
                        <div class="form-group float-label">
                            <label asp-for="FirstName"></label>
                            <input asp-for="FirstName" asp-is-autofocus="true" class="form-control form-control-sm" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="form-group float-label">
                            <label asp-for="LastName"></label>
                            <input asp-for="LastName" class="form-control form-control-sm" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="form-group float-label">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control form-control-sm" disabled />
                            <input asp-for="Email" class="form-control form-control-sm" hidden />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <div class=" custom-control custom-checkbox">
                                <input asp-for="UserConsent" class="custom-control-input" />
                                <label for="UserConsent" class="custom-control-label label-wrap">
                                    I have read and agree to the <a asp-area="" asp-controller="Home" asp-action="Terms" title="Terms of Service">Terms of Service</a>
                                    and <a asp-area="" asp-controller="Home" asp-action="Privacy" title="Privacy Policy">Privacy Policy</a>.
                                </label>
                            </div>

                            <span asp-validation-for="UserConsent" class="text-danger"></span>
                            <input asp-for="IsTrue" class="form-control" value="true" hidden />
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary btn-block-xs">Register</button>
                        </div>
                    </div>
                </div>
            </form>

            @*@section Scripts {
                @await Html.PartialAsync("_ValidationScriptsPartial")
            }*@

        }
        else
        {
            <div class="card card-account border-secondary mx-auto">
                <h3 class="card-header bg-transparent border-0 mt-0 text-center">@ViewData["Title"]</h3>
                <div class="card-body">
                    <p class="card-text">@Html.Raw(ViewData["SuccessMessage"])</p>
                    <p class="card-text text-center">
                        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">Continue</a>
                    </p>
                </div>
            </div>
        }
    </div>
</div>
