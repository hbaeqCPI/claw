@{
    ViewData["Title"] = "Confirm email";
}
<div class="row mt-3">
    <div class="col">
        <div class="card card-account border-secondary mx-auto">
            <h3 class="card-header bg-transparent border-0 mt-0 text-center">@ViewData["Title"]</h3>
            <div class="card-body">
                @if (ViewData.ModelState.IsValid)
                {
                    <p class="card-text">@Html.Raw(ViewData["SuccessMessage"])</p>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <p class="card-text text-center">
                            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-primary">Continue</a>
                        </p>
                    }
                    else
                    {
                        <p class="card-text text-center">
                            <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-primary">Log in</a>
                        </p>
                    }
                }
                else
                {
                    var errorMessage = ViewData.ModelState.Keys.Where(k => k == string.Empty).Select(k => ViewData.ModelState[k].Errors[0].ErrorMessage).First();

                    <div class="alert alert-danger alert-dismissible mb-4" role="alert">
                        <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        <span>@Html.Raw(@errorMessage)</span>
                    </div>

                    <p class="card-text">Please click the button below to request new email confirmation link.</p>
                    <form method="post">
                        <p class="card-text text-center">
                            <button type="submit" class="btn btn-primary">Send verification email</button>
                        </p>
                    </form>
                }
            </div>
        </div>
    </div>
</div>