@model ChangePasswordViewModel

<div class="page-content">
    @await Html.PartialAsync("_StatusMessage", Model.StatusMessage)
    <form method="post" class="needs-validation">
        <div class="row">
            <div class="col">
                <div asp-validation-summary="ModelOnly" class="list-unstyled alert alert-danger alert-dismissible mb-4" role="alert">
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label asp-for="OldPassword"></label>
                    <input asp-for="OldPassword" class="form-control form-control-sm" />
                    <span asp-validation-for="OldPassword" class="text-danger"></span>
                </div>
                <div class="form-group float-label">
                    <label asp-for="NewPassword"></label>
                    <input asp-for="NewPassword" class="form-control form-control-sm" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>
                <div class="form-group float-label">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" class="form-control form-control-sm" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary mt-5">Update password</button>
            </div>
        </div>
    </form>
</div>
<script>
    $(document).ready(function () {
        $("form").floatLabels();
    })
</script>
