@using Microsoft.Extensions.Configuration;
@inject IConfiguration Configuration
@inject IStringLocalizer<SharedResource> Localizer
@model ExternalLoginsViewModel
@{
    var showSSORequiredWarning = User.SSORequired();
    var providerName = "SSO";
    if (Model.OtherLogins != null && Model.OtherLogins.Count == 1)
        providerName = Model.OtherLogins.First().DisplayName ?? providerName;
}

<div class="page-content">
    @await Html.PartialAsync("_StatusMessage", Model.StatusMessage)
    @if (Model.CurrentLogins?.Count > 0)
    {
        <div class="pb-4">
            <h5>@Localizer["Registered Logins"]</h5>
            @foreach (var login in Model.CurrentLogins)
            {
                <div class="row pb-1">
                    <div class="col-6 col-md-4 col-xl-2"><h5>@(Configuration[$"Authentication:{login.LoginProvider}:Name"] ?? login.LoginProvider)</h5></div>
                    <div class="col-6 col-md-2 col-xl-2 text-right">
                        @if (Model.ShowRemoveButton)
                        {
                            <form asp-action="RemoveLogin" method="post">
                                <div>
                                    <input asp-for="@login.LoginProvider" name="LoginProvider" type="hidden" />
                                    <input asp-for="@login.ProviderKey" name="ProviderKey" type="hidden" />
                                    <button type="submit" class="btn btn-primary" title="Remove this @login.LoginProvider login from your account">Remove</button>
                                </div>
                            </form>
                        }
                        else
                        {
                            @: &nbsp;
                        }
                    </div>
                </div>
            }
        </div>
    }
    else if (showSSORequiredWarning)
    {
        <div class="alert alert-warning mb-4">
            <p><strong>@Localizer["Single Sign-On login is required."]</strong></p>
            <p>@Localizer["You must register your {0} account before you can log in and access the system.", providerName]</p>
        </div>
    }

    @if (Model.OtherLogins?.Count > 0)
    {
        <h5>@Localizer["Add another service to log in"]</h5>
            <form asp-action="LinkLogin" method="post" class="form-horizontal pt-4">
                <div id="socialLoginList row">
                    <div class="col-md-6 col-xl-4">
                        @foreach (var provider in Model.OtherLogins)
                    {
                        var displayName = Configuration[$"Authentication:{provider.Name}:Name"] ?? provider.DisplayName;
                        <div class="btn-group btn-block external-login" role="group" aria-label="Log in using your @displayName account">
                                <button type="submit" class="btn btn-@provider.Name p-0" name="provider" value="@provider.Name" title="Log in using your @displayName account"><img src="~/images/signin-@(provider.Name).png" class="signin-logo" alt="@provider.Name" /></button>
                                <button type="submit" class="btn btn-@provider.Name btn-outline-secondary btn-block text-left" name="provider" value="@provider.Name" title="Log in using your @displayName account"><span>Log in with @displayName</span></button>
                            </div>
                        }
                    </div>
                </div>
            </form>
    }
</div>