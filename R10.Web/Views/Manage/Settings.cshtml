                                <label for="ReceiveQuickEmail">@SharedLocalizer["Receive Quick Emails"]</label>
                                <span>
                                    <label class="toggle-switch">
                                        <input id="ReceiveQuickEmail" type="checkbox" checked="@Model.UserNotificationSettings.ReceiveQuickEmail" data-setting="ReceiveQuickEmail" class="toggle-option" onclick="saveEmailSetting(this, 'quick-email');">
                                        <span class="slider round"></span>
                                    </label>
                                </span>
                            </li>
                            <li class="d-flex justify-content-between">
                                <label for="QuickEmailCopyToSelf">@SharedLocalizer["Send copy to myself"]</label>
                                <span>
                                    <label class="toggle-switch">
                                        <input id="QuickEmailCopyToSelf" type="checkbox" checked="@Model.UserNotificationSettings.QuickEmailCopyToSelf" data-setting="QuickEmailCopyToSelf" class="notification-setting quick-email toggle-option" @(Model.UserNotificationSettings.ReceiveQuickEmail ? "" : "disabled")>
                                        <span class="slider round"></span>
                                    </label>
                                </span>
                            </li>
                            @if(User.IsInSystem(SystemType.Patent)) {
                                <li class="d-flex justify-content-between">
                                    <label for="ReceiveQuickEmailPatent">@SharedLocalizer["Receive Patent emails"]</label>
                                    <span>
                                        <label class="toggle-switch">
                                            <input id="ReceiveQuickEmailPatent" type="checkbox" checked="@Model.UserNotificationSettings.QuickEmailSystems.Contains('P')" data-setting="QuickEmailSystems" data-value="P" class="quick-email system-type toggle-option" @(Model.UserNotificationSettings.ReceiveQuickEmail ? "" : "disabled")>
                                            <span class="slider round"></span>
                                        </label>
                                    </span>
                                </li>
                            }
                            @if(User.IsInSystem(SystemType.PatClearance)) {
                                <li class="d-flex justify-content-between">
                                    <label for="ReceiveQuickEmailPatClearance">@SharedLocalizer["Receive Patent Clearance emails"]</label>
                                    <span>
                                        <label class="toggle-switch">
                                            <input id="ReceiveQuickEmailPatClearance" type="checkbox" checked="@Model.UserNotificationSettings.QuickEmailSystems.Contains('E')" data-setting="QuickEmailSystems" data-value="E" class="quick-email system-type toggle-option" @(Model.UserNotificationSettings.ReceiveQuickEmail ? "" : "disabled")>
                                            <span class="slider round"></span>
                                        </label>
                                    </span>
                                </li>
