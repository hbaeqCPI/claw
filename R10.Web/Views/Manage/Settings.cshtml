@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ISystemSettings<DefaultSetting> Settings
@inject IAuthorizationService AuthorizationService
@model SettingsViewModel
@{
    var settings = await Settings.GetSetting();
    var searchResultsPageSizeOptions = new List<SelectListItem>() { new SelectListItem() { Text = "Default", Value = "0" } };

    foreach(var pageSize in settings.SearchResultsPageSizeOptions)
    {
        searchResultsPageSizeOptions.Add(new SelectListItem() { Text = pageSize.ToString(), Value = pageSize.ToString() });
    }

    var themeColors = Model.Theme.Colors.Select(c => new SelectListItem() { Value = c.Key, Text = c.Value }).ToList();
    var isSystemUser = (await AuthorizationService.AuthorizeAsync(User, CPiAuthorizationPolicy.SystemUser)).Succeeded;
}

<div class="page-content">
    <div id="userSettingStatus" class="alert alert-dismissible mt-4" role="alert" style="display: none;">
        <button type="button" class="close" aria-label="Close" onclick="$('#userSettingStatus').hide()"><span aria-hidden="true">&times;</span></button>
        <span class="status-message"></span>
    </div>
    <div class="row user-settings">
        <div class="col-lg-6 col-xl-5">
            <h5>@SharedLocalizer["Display Options"]</h5>
            <ul class="list-group">
                @if (Model.DefaultPage != null)
                {
                    @if (isSystemUser)
                    {
                        <li class="d-flex justify-content-between ">
                            <label for="DefaultPageId">@SharedLocalizer["Default page"]</label>
                            <span>
                                @(Html.Kendo().DropDownList()
                                    .Name("DefaultPageId").AutoWidth(true)
                                    .DataTextField("Name")
                                    .DataValueField("Id")
                                    .OptionLabel(" ")
                                    .Value(Model.DefaultPage.DefaultPageId.ToString())
                                    .AutoBind(true)
                                    .DataSource(source =>
                                    {
                                        source.Read(read =>
                                        {
                                            read.Action("GetDefaultPageList", "Manage");
                                        })
                                        .ServerFiltering(true);
                                    })
                                    .Events(e =>
                                    {
                                        e.Change("saveDefaultPage");
                                    })
                                    .HtmlAttributes(new { @class = "k-control", style = "min-width: 150px;" })
                                    )
                            </span>
                        </li>
                    }
                }
                @if (Model.UserPreferences != null)
                {
                    <li class="d-flex justify-content-between">
                        <label for="Theme">@SharedLocalizer["Color theme"]</label>
                        <span>
                            @(Html.Kendo().DropDownList()
                                                            .Name("Theme")
                                                            .DataTextField("Text")
                                                            .DataValueField("Value")
                                                            .ValueTemplate("<i class='fas fa-square-full pr-2' style='color: #= data.Text #'></i><span class='theme-name'> #= data.Value #</span>")
                                                            .Template("<i class='fas fa-square-full pr-2' style='color: #= data.Text #'></i><span class='theme-name'> #= data.Value #</span>")
                                                            .Events(e => e.Change("saveTheme"))
                                                            .Value(Model.UserPreferences.Theme)
                                                            .BindTo(themeColors)
                                                            .HtmlAttributes(new { @class = "k-control", style="min-width: 150px;" })
                            )
                        </span>
                    </li>
                    @if (isSystemUser)
                    {
                        <li class="d-flex justify-content-between">
                            <label for="SearchResultsPageSize">@SharedLocalizer["Search results page size"]</label>
                            <span>
                                @(Html.Kendo().DropDownList()
                                    .Name("SearchResultsPageSize")
                                    .DataTextField("Text")
                                    .DataValueField("Value")
                                    .Events(e => e.Change("saveSearchResultsPageSize"))
                                    .Value(Model.UserPreferences.SearchResultsPageSize.ToString())
                                    .BindTo(searchResultsPageSizeOptions)
                                    .HtmlAttributes(new { @class = "k-control" })
                                    )
                            </span>
                        </li>
                    }
                }
            </ul>

        </div>
    </div>
    @if (Model.UserNotificationSettings != null)
