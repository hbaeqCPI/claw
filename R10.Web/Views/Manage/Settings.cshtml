                                    <span>
                                        <label class="toggle-switch">
                                            <input id="ReceiveQuickEmailAMS" type="checkbox" checked="@Model.UserNotificationSettings.QuickEmailSystems.Contains('A')" data-setting="QuickEmailSystems" data-value="A" class="quick-email system-type toggle-option" @(Model.UserNotificationSettings.ReceiveQuickEmail ? "" : "disabled")>
                                            <span class="slider round"></span>
                                        </label>
                                    </span>
                                </li>
