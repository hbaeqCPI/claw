@model Document
@{
    var noImageIcon = Model.GetIcon() ?? "fal fa-image";
}
@if (Model.IsImage())
{
    <img class="type-image lightbox thumbnail" title="@Model.Name" alt="@Model.Name" src="@Url.Action("Download", "iManageWork", new { Area = "", Id = Model.Id })" />
}
else
{
    <i class="no-image @noImageIcon fa-2x"></i>
}

<script>
    $(document).ready(function () {
        $(".type-image.lightbox").lightBox();
    });
</script>