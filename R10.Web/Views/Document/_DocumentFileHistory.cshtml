@model DocumentFileHistoryViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var fileHistoryGridName = $"fileHistoryGrid_{ViewData["PageId"]}";
    var param = $"{{id: {Model.ParentValue}}}";
    var viewUrl = Url.Action(Model.FileHistoryViewerAction, Model.FileHistoryViewerController, new { Area = Model.FileHistoryViewerArea, system = Model.FileHistoryArea, screenCode = Model.FileHistoryScreenCode });
    var viewerFunction = "openMainDocViewer(e, this)";

    // if (settings.DocumentStorage == DocumentStorageOptions.SharePoint)
    // {
    //     viewUrl = Url.Action("DownloadPTOFile", "SharePointGraph", new { area = "Shared", systemType = Model.SystemType });
    //     viewerFunction = "openSharePointFile(e,this)";
    // }
    // else if (settings.DocumentStorage == DocumentStorageOptions.iManage)
