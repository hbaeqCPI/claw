    //     viewUrl = Url.Action("DownloadPTOFile", "iManageWork", new { area = ""});
    //     viewerFunction = "openIManageFile(e, this)";
    // }

}

@(Html.Kendo().Grid<FileHistoryInfoViewModel>()
    .Name(fileHistoryGridName)
    .Columns(columns =>
    {
        columns.Bound(d => d.Description);
        columns.Command(command =>
        {
            command.Custom("View").Text(Localizer["View"].ToString()).Click($"function(e) {{{viewerFunction}}}").IconClass("k-icon fal fa-search-plus").HtmlAttributes(new { @class = "doc-viewer", style = "width:80px;" });
        }).Width(15);
        columns.Bound(d => d.MailRoomDate).Format("{0:dd-MMM-yyyy}").Width(200);
    })
    .HtmlAttributes(new { style = "height: 380px;" })
    //.Scrollable()
    .Pageable(page => page.Responsive(false))
    .Sortable(sort => sort.AllowUnsort(false))
    .AutoBind(false)
    .DataSource(dataSource => dataSource
    .Ajax()
    .PageSize(10)
    .Read(create => create.Action(Model.FileHistoryAction, Model.FileHistoryController, new { Area = Model.FileHistoryArea }).Data(param))
    .Events(events =>
    {
        events.Error("pageHelper.onGridError");

    })
    )
    .HtmlAttributes(new { @class = "mb-2 kendo-Grid" })
)

<script>
    openMainDocViewer = (e, grid) => {
        const selected = grid.dataItem($(e.currentTarget).closest("tr"));
        let url = "@Html.Raw(viewUrl)";
        url = url + "&filename=" + selected.Filename + "&key=" + selected.RecId + "&noPages=" + selected.NoPages + "&pageStart=" + selected.PageStart + "&zoom=1";
        if (selected && selected.ViewUrl) {
            url = selected.ViewUrl;
        }
        documentPage.zoomDocument(url)
