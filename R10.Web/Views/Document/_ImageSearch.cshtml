@model ImageSearchViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    var parentIdParam = $"{{parentId: {Model.ParentId}}}";
    //var screen = Model.View + "_" + ViewData["PageId"];
}

<div class="form-row">
    <input type="hidden" id="FolderId" name="FolderId"/>
    <input type="hidden" id="DocId" name="DocId"/>
    <input type="hidden" id="ScreenCode" name="ScreenCode"/>
    <input type="hidden" id="ParentId" name="ParentId"/>
    <div class="col">
        <div class="form-group float-label">
            <label for="ImagesLinks">@Localizer["Title"]</label>
            @await Component.InvokeAsync("ComboBox", new { name = "DocName", action = "GetImageSearchData", controller = Model.Controller, textProperty = "DocName", valueProperty = "DocName", data = parentIdParam })
        </div>
    </div>
    <div class="col">
        <div class="form-group float-label">
            <label for="ImagesLinks">@Localizer["File name"]</label>
            @await Component.InvokeAsync("ComboBox", new { name = "UserFileName", action = "GetImageSearchData", controller = Model.Controller, textProperty = "UserFileName", valueProperty = "UserFileName", data = parentIdParam })
        </div>
    </div>
    <div class="col">
        <div class="form-group float-label">
            <label for="ImagesLinks">@Localizer["Image Type"]</label>
            @await Component.InvokeAsync("ComboBox", new { name = "DocTypeName", action = "GetImageSearchData", controller = Model.Controller, textProperty = "DocTypeName", valueProperty = "DocTypeName", data = parentIdParam })
        </div>
    </div>
    <div class="col">
        <div class="form-group float-label">
            <label for="ImagesLinks">@Localizer["Folder"]</label>
            @await Component.InvokeAsync("ComboBox", new { name = "FolderName", action = "GetImageSearchData", controller = Model.Controller, textProperty = "FolderName", valueProperty = "FolderName", data = parentIdParam })
        </div>
    </div>
    @if (Model.HasScreenSource)
    {
    <div class="col">
        <div class="form-group float-label">
            <label for="ImagesLinks">@Localizer["Source Screen"]</label>
            @await Component.InvokeAsync("ComboBox", new { name = "ScreenCode", action = "GetImageSearchData", controller = Model.Controller, textProperty = "ScreenCode", valueProperty = "ScreenCode", data = parentIdParam })
        </div>
    </div>
    }
    <div class="col">
        <div class="form-group float-label">
            <label for="ImagesLinks">@Localizer["Tag"]</label>
            @await Component.InvokeAsync("ComboBox", new { name = "Tag", action = "GetImageSearchData", controller = Model.Controller, textProperty = "Tag", valueProperty = "Tag", data = parentIdParam })
        </div>
    </div>
    <div class="col">
        <div class="form-group float-label">
            <div class="form-group float-label">
                <label for="DateCreatedFrom">@Localizer["Date Created From"]</label>
                @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedFrom") )
            </div>
        </div>
    </div>
    <div class="col">
        <div class="form-group float-label">
            <label for="DateCreatedTo">@Localizer["Date Created To"]</label>
            @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedTo"))
        </div>
    </div>
    
</div>
