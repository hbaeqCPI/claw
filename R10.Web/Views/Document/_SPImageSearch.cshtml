    <div class="col">
        <div class="form-group float-label">
            <div class="form-group float-label">
                <label for="DateCreatedFrom">@Localizer["Last Modified From"]</label>
                @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateModifiedFrom") )
            </div>
        </div>
    </div>
    <div class="col">
        <div class="form-group float-label">
            <label for="DateCreatedTo">@Localizer["Last Modified To"]</label>
