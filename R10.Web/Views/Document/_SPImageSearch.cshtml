    @if (!settings.IsSharePointIntegrationByMetadataOn)
    {
        <div class="col">
            <div class="form-group float-label">
                <label for="ImagesLinks">@Localizer["Folder"]</label>
                @await Component.InvokeAsync("ComboBox", new { name = "Folder", area="Shared",action = "GetImageSearchData", controller = "SharePointGraph", textProperty = "Folder", valueProperty = "Folder", data = parentIdParam })
            </div>
        </div>
    }
    
    @if (Model.HasScreenSource)
    {
       @* <div class="col">
