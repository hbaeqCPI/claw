@model ImageSearchViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var parentIdParam = $"{{docLibrary: '{Model.SharePointDocLibrary}',docLibraryFolder: '{Model.SharePointDocLibraryFolder}',recKey:'{Model.SharePointRecKey}',parentId: {Model.ParentId}}}";
    var settings = await Settings.GetSetting();
}

<div class="form-row">
    <input type="hidden" id="TreeNodeId" name="TreeNodeId" />
    <input type="hidden" id="FromTreeView" name="FromTreeView" />

