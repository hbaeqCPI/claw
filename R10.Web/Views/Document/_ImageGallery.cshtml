    }

    .dropImageHereText {
        /*color: #c7c7c7;*/
        color: black;
        text-transform: uppercase;
        font-size: 12px;
    }

    .wrapper:after {
        content: ".";
        display: block;
        height: 0;
        clear: both;
        visibility: hidden;
    }

    .file {
        float: left;
        margin: 20px 30px;
        text-align: center;
    }

        .file img {
            display: block;
            margin-bottom: 10px;
        }
</style>
