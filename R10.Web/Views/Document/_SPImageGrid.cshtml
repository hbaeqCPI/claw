@model ChildImageViewModel
@inject ISystemSettings<DefaultSetting> Settings
@inject IStringLocalizer<SharedResource> Localizer
@inject ICPiUserSettingManager UserSettingManager
@{
    var userAccountSettings = await UserSettingManager.GetUserSetting<UserAccountSettings>(User.GetUserIdentifier());
    var settings = await Settings.GetSetting();
    var permission = Model.Permission;

    var screenCode = "";
    if (!string.IsNullOrEmpty(Model.DocumentLink))
    {
        screenCode = Model.DocumentLink.Split("|")[1];
    }

    //use icon if available
    var fileTemplate = "<span><i class='#=IconClass# pr-3'></i>#=Name#</span>";

    var pageId = ViewData["PageId"];
    var activePage = Model.ActivePage;

    var grid = $"imageGridView_{pageId}";
    var docTree = $"documentTree_{pageId}";
}

<script>
    function spImageGridDataBound(e,grid) {
        document.querySelectorAll('.k-grid-Edit').forEach(element => {
            var selector = $(`#${grid}`).data("kendoGrid");
            if (selector) {
                var currentDataItem = selector.dataItem($(element).closest("tr"));
                if (!currentDataItem || currentDataItem.EditUrl == null || currentDataItem.EditUrl == "") {
                    element.classList.add("d-none");
                }
            }
            
        });

        document.querySelectorAll('.esig-icon-push').forEach(element => {
            var selector = $(`#${grid}`).data("kendoGrid");
            if (selector) {
                var currentDataItem = selector.dataItem($(element).closest("tr"));
                if (!(currentDataItem && currentDataItem.ForSignature && currentDataItem.SignatureReviewed)) {
                    $(element).closest(".k-grid-DocuSignUpload").addClass("d-none");
                    //element.classList.add("d-none");
                }
            }
        });

        document.querySelectorAll('.esig-icon-pull').forEach(element => {
            var selector = $(`#${grid}`).data("kendoGrid");
            if (selector) {
                var currentDataItem = selector.dataItem($(element).closest("tr"));
                if (!(currentDataItem && currentDataItem.SentToDocuSign)) {
                    $(element).closest(".k-grid-DocuSignDownload").addClass("d-none");
                    //element.classList.add("d-none");
                }
            }
        });

        var dataItems = e.sender.dataSource.view();
        for (var j = 0; j < dataItems.length; j++) {
            var row = e.sender.tbody.find("[data-uid='" + dataItems[j].uid + "']");
            var checkout = row.children().find(".k-grid-Checkout");
            if (checkout) {
                if (dataItems[j].get("CheckOutUser")) {
                    checkout.addClass("d-none");
                }
            }
            var checkin = row.children().find(".k-grid-Checkin");
            if (checkin) {
                //IsCheckedOut = true when checkedout by the current user
                if (!dataItems[j].get("IsCheckedOut")) {
                    checkin.addClass("d-none");
                }
            }
        }
        
        //hide merge pdf files button
        const mergePDFBtn = e.sender.element.find(".k-grid-Merge");
        if (mergePDFBtn) {
            mergePDFBtn.hide();
            if (dataItems && dataItems.length > 0) {
                const pdfFiles = dataItems.filter(f => f.Name.endsWith(".pdf"));
                if (pdfFiles && pdfFiles.length > 1) {
                    mergePDFBtn.show();
                }
            }
        }

    }

    function markEPOCommunicationsAsHandled(e) {
        var imageGrid = $("#@grid").data("kendoGrid");
        var row = $(e.currentTarget).closest("tr")[0];
        var dataItem = imageGrid.dataItem(row);
        const url = "@Url.Action("MarkEPOCommunicationAsHandled", "SharePointGraph", new { area = "Shared" })";
        if (dataItem && dataItem.CommunicationId) {
            cpiLoadingSpinner.show();
            $.post(url, { communicationIds: [ dataItem.CommunicationId ] })
                .done(function (result) {
                    cpiLoadingSpinner.hide();
                    pageHelper.showSuccess("@Localizer["Marked EPO communication as handled successfully."]");
                    imageGrid.dataSource.read();
                })
                .fail((error) => {
                    cpiLoadingSpinner.hide();
                    pageHelper.showErrors(error)
                });
        }        
    }
</script>


<div class="image-container" id="SPImageContainer"
     data-folder-id="" data-parent-folder-id=""
     data-confirm="@Localizer["Please Confirm"]"
     data-send-prompt="@Localizer["Are you sure you want to send this document for eSignature?"]"
     data-resend-prompt="@Localizer["Document is already marked as sent. Are you sure you want to send it again?"]"
     data-pull-prompt="@Localizer["Are you sure you want to retrieve the signed document?"]"
     data-repull-prompt="@Localizer["Document was already retrieved before. Are you sure you want to do it again?"]">
    @(
        Html.Kendo().Grid<SharePointDocumentViewModel>()
                .Name(grid)
                .Columns(columns =>
                {
                    columns.Bound(p => p.Name).ClientTemplate(fileTemplate);
                    if (!settings.IsSharePointIntegrationByMetadataOn)
                    {
                       columns.Bound(p => p.Folder);
                    }
            columns.Bound(p => p.DateModified).ClientTemplate("#= (DateModified == null) ? '' : kendo.toString(DateModified,'dd-MMM-yyyy hh:mm:ss tt')#").Width(250).Sortable(true);
            columns.Bound(p => p.ModifiedBy);
            columns.Bound(p => p.CheckOutUser);

            if (settings.IsESignatureOn)
                columns.Bound(p => p.SentToDocuSign).ClientTemplate("<i class='fa fal #: SentToDocuSign ? 'fa-check' : ''#'></i>").Width(100);

            if (Model.AllowDownload)
                columns.Select().Width(50);

            columns.Command(command =>
            {
                command.Custom("View").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.viewFileGrid(e, '{grid}')}}").IconClass("k-icon fal fa-search-plus").HtmlAttributes(new { style = "width:30px;", title = Localizer["View"] });
                if (permission.CanUploadDocuments)
                {
                    command.Custom("Edit").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.editFileGrid(e, '{grid}')}}").IconClass("k-icon fal fa-pencil-alt").HtmlAttributes(new { style = "width:30px;", title = Localizer["Edit"] });
                    command.Custom("Modify").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.modifyFileGrid(e, '{grid}','{activePage}')}}").IconClass("k-icon fal fa-file").HtmlAttributes(new { style = "width:30px;", title = Localizer["Modify Settings"] });
                }
                command.Custom("Download").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.downloadFileGrid(e, '{grid}')}}").IconClass("k-icon fal fa-file-download").HtmlAttributes(new { style = "width:30px;", title = Localizer["Download"] });

                if (permission.CanUploadDocuments)
                {
                    command.Custom("Checkout").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.checkoutFileGrid(e, '{grid}')}}").IconClass("k-icon fal fa-lock-alt").HtmlAttributes(new { style = "width:30px;", title = Localizer["Checkout"] });
                    command.Custom("Checkin").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.checkinFileGrid(e, '{grid}')}}").IconClass("k-icon fal fa-lock-open-alt").HtmlAttributes(new { style = "width:30px;", title = Localizer["Checkin"] });
                    command.Custom("Versions").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.fileVersionGrid(e, '{grid}')}}").IconClass("k-icon fal fa-copy").HtmlAttributes(new { style = "width:30px;", title = Localizer["Version History"] });
                }
                if (permission.CanDeleteRecord)
                {
                    command.Custom("Delete").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.deleteFileGrid(e, '{grid}')}}").IconClass("k-icon fal fa-trash-alt").HtmlAttributes(new { style = "width:30px;", title = Localizer["Delete"] });
                }
                if (permission.CanUploadDocuments && settings.IsESignatureOn)
                {
                    command.Custom("DocuSignUpload").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.pushDocuSignDoc(e, '{grid}')}}").IconClass("k-icon fal fa-signature esig-icon-push").HtmlAttributes(new { style = "width:40px;", title = Localizer["Send for eSignature"] });
                    command.Custom("DocuSignDownload").Text(Localizer[" "]).Click($"function(e) {{sharePointGraphHelper.pullDocuSignDoc(e,'{grid}')}}").IconClass("k-icon fal fa-cloud-download esig-icon-pull").HtmlAttributes(new { style = "width:40px;", title = Localizer["Retrieve signed document"] });
                }
                if (userAccountSettings.AllowHandleMyEPOCommunications) 
                {
                    command.Custom("EPOHandle").Text(Localizer[" "])
                    .Visible("function(e) {return e.CommunicationId > '';}")
                    .Click($"function(e) {{markEPOCommunicationsAsHandled(e);}}")
                    .IconClass("k-icon fal fa-check")
                    .HtmlAttributes(new { style = "width:40px;", title = Localizer["Mark EPO Handle"] });
                }
            });
        })
        .PersistSelection()
        .Sortable(sort => sort.AllowUnsort(false))
        .ToolBar(toolbar =>
        {
            if (permission.CanUploadDocuments)
            {
                toolbar.Custom().Name("Upload").IconClass("k-icon fal fa-plus").Text(Localizer["Upload"].ToString()).HtmlAttributes(new { onclick = $"sharePointGraphHelper.addFileGrid('{grid}')" });//.HtmlAttributes(new { onclick = $"{activePage}.image.addImage()" });
            }
            @*toolbar.Custom().Name("Sync").IconClass("k-icon fal fa-sync").Text(Localizer["Sync"].ToString()).HtmlAttributes(new { onclick = $"{activePage}.image.refreshGrid()" });*@
            if (Model.AllowDownload)
            {
                toolbar.Custom().Name("Download").IconClass("k-icon fal fa-file-download").Text(Localizer["Download Selected Files"].ToString()).HtmlAttributes(new { onclick = $"sharePointGraphHelper.downloadDocs('#{grid}','{Model.SharePointDocLibrary}','{Model.SharePointDocLibraryFolder}','{Model.SharePointRecKey}')" });

                toolbar.Custom().Name("Merge").IconClass("k-icon fal fa-merge").Text(Localizer["Merge Selected Files"].ToString()).HtmlAttributes(new
                {
                    onclick = $"sharePointGraphHelper.mergeDocs(this,'#{grid}','{Model.SharePointDocLibrary}','{Model.SharePointDocLibraryFolder}','{Model.SharePointRecKey}', {Model.ParentId})",
                    data_no_files_selected_error = Localizer["Please select at least 2 PDF files to merge."],
                    data_file_type_error = Localizer["Please select only PDF files."]
                });
            }
            toolbar.Custom().Name("DocumentsSearch").IconClass("k-icon fal fa-search").Text(Localizer["Search"].ToString()).HtmlAttributes(new { onclick = $"sharePointGraphHelper.showSearchScreen('GridView')" });
        })
        .Editable(editable => editable.Enabled(true)
        .Mode(GridEditMode.InCell).
        ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
        .HtmlAttributes(new { style = "height:300px;" })
        .AutoBind(false)
        .DataSource(dataSource => dataSource
        .Ajax()
        .PageSize(10)
        .ServerOperation(false)
        .Model(model =>
        {
            model.Id(i => i.Id);
            model.Field(p => p.Name).Editable(false);
            model.Field(p => p.Folder).Editable(false);
            model.Field(p => p.DateModified).Editable(false);
            model.Field(p => p.ModifiedBy).Editable(false);
            model.Field(p => p.CheckOutUser).Editable(false);
            model.Field(p => p.SentToDocuSign).Editable(false);
        })
        .Create(create => create.Action("AddFile", "SharePointGraph", new { Area = "Shared", docLibrary = Model.SharePointDocLibrary, docLibraryFolder = Model.SharePointDocLibraryFolder, recKey = Model.SharePointRecKey, parentId = Model.ParentId, roleLink = Model.RoleLink }))
        .Read(read => read.Action("ImageRead", "SharePointGraph", new { Area = "Shared", docLibrary = Model.SharePointDocLibrary, docLibraryFolder = Model.SharePointDocLibraryFolder, recKey = Model.SharePointRecKey, parentId = Model.ParentId, screenCode = screenCode, isGallery = false }).Data($"sharePointGraphHelper.getSearchCriteria"))
        .Sort(sort => sort.Add(i => i.DateModified).Descending())
        .Destroy(destroy => destroy.Action("DeleteFile", "SharePointGraph", new { Area = "Shared" }))
        .Update(update => update.Action("ModifyFile", "SharePointGraph", new { Area = "Shared" }))
        .Events(events =>
        {
            //events.Error("sharePointGraphHelper.imageReadErrorHandler");
            events.Error($"function(e) {{sharePointGraphHelper.imageReadErrorHandler(e,'{docTree}');}}");
        })
        )
        .Pageable(pageable => pageable.Responsive(false)
        .Refresh(true)
        .PageSizes(true)
        .ButtonCount(5))
        .Events(events => events.DataBound($"function(e) {{spImageGridDataBound(e,'{grid}');}}"))
        .HtmlAttributes(new { @class = "imageGridView kendo-Grid" })
        )
</div>



