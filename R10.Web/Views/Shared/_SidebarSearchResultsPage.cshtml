@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{ 
    string gridId = $"{Model.PageId}-Grid";
    string formId = $"{Model.PageId}-RefineSearch";
}

<form method="post" id="@formId" class="search-top" style="display:none;" data-no-results="@Localizer["Your search did not match any records."]" 
    data-toggle-button-container=".page-main .sidebar-link.nav" 
    data-toggle-button-show="@Localizer["Show filters"]" 
    data-toggle-button-hide="@Localizer["Hide filters"]"
    data-toggle-button-show-icon=""
    data-toggle-button-hide-icon=""
    data-toggle-button-label-hidden="false">
    <ul class="nav nav-tabs refine-search" role="tablist">
        @await Html.PartialAsync("_SearchNavItems")
    </ul>
    @await Html.PartialAsync("_SearchTabContent")
</form>
@await Html.PartialAsync("_SearchResultsGrid", Model)

<script>
    $(document).ready(function () {
        if (typeof @(ViewData["ActivePage"]) != "undefined") {
            @(ViewData["ActivePage"]).initializeSidebarPage({
                container: "#@Model.PageId",
                url: "@Context.Request.PathBase@Context.Request.Path",
                title: "@Model.Title",
                grid: "#@gridId",
                form: "#@formId"
            });
        }
    });
</script>
