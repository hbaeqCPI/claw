@model DesignatedCountryLookupDTO
@(Html.Kendo().ComboBoxFor(m => m)
        .DataTextField("DesCtryName")
        .DataValueField("DesCtry")
        .AutoBind(false)
            .DataSource(source =>
            {
                source.Read(read =>
                {
                    string parentFilter = ViewData["parentfilter"] != null ? ViewData["parentfilter"].ToString() : "";
                    read.Action(ViewData["action"].ToString(), ViewData["controller"].ToString(), new { area = ViewData["area"].ToString() }).Data(parentFilter);
                })
                .ServerFiltering(false);
            })
        .Filter(FilterType.Contains)
        .Template("<span class='k-state-default'>#: data.DesCtryName #</span>")
        .HtmlAttributes(new { style = "width: 100%" })

)

