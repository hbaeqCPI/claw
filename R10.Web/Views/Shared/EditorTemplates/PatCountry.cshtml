@model PatCountry
@inject IStringLocalizer<SharedResource> Localizer
@{ 
    var headerTemplate = $"<div class='row border-bottom'><div class='col-md-2 mt-2 mb-2'><span>&nbsp;&nbsp;{Localizer["Code"]}</span></div><div class='col-md-5 mt-2 mb-2'><span>{Localizer["Description"]}</span></div></div>";
    var template = "<div class='row'><div class='col-md-2'><span>#: data.Country #</span></div><div class='col-md-5'><span>#: data.CountryName #</span></div></div>";
}

@(Html.Kendo().ComboBoxFor(m => m)
    .DataTextField("Country")
    .DataValueField("Country")
    .AutoBind(false)
    .AutoWidth(true)
    .DataSource(source =>
    {
        source.Read(read =>
        {
            read.Action("GetCountryList", "Country", new { area = "Patent", property = "Country" });
        })
        .ServerFiltering(true);
    })
    .Template(template)
    .HeaderTemplate(headerTemplate)
    .HtmlAttributes(new { style = "width: 100%" })
)

