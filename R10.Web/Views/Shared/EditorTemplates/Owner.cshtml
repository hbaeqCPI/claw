@model Owner
@{
    var id = ViewData["id"].ToString();
    var linkUrl = Url.Action("DetailLink", "Owner", new
    {
        Area = "Shared",
        id = "actualValue"
    });
    var headerTemplate = "<div class='row border-bottom'><div class='col-md-3 mt-2 mb-2'><span>&nbsp;&nbsp;Code</span></div><div class='col-md-5 mt-2 mb-2'><span>Name</span></div></div>";
    var template = "<div class='row'><div class='col-md-3'><span>#: data.OwnerCode #</span></div><div class='col-md-5'><span>#: data.OwnerName #</span></div></div>";
}
@(Html.Kendo().ComboBoxFor(m => m)
                .DataTextField("OwnerCode")
                .DataValueField("OwnerID")
                .AutoBind(false)
                .AutoWidth(true)
                .DataSource(source =>
                {
                    source.Read(read =>
                    {
                        read.Action("GetOwnerList", "Owner", new { area = "Shared", property = "OwnerCode" });
                    })
                    .ServerFiltering(false);
                })
                .Filter(FilterType.Contains)
                //.Events(e => e.Select("function(e) {page.onGridComboBoxSelect(e,'OwnerName');}"))
                .Events(e => e.Select("function(e) { pageHelper.refreshGridNameField(e, 'OwnerName'); }"))
                .Events(e => e.Filtering("function(e) {pageHelper.comboBoxFiltering(e,this,'OwnerCode,OwnerName');}"))
                .Template(template)
                .HeaderTemplate(headerTemplate)
                .HtmlAttributes(new { style = "width: 80%", id = @id })

)
<button type="button" class="btn">
    <i class="fal fa-search-plus btn-link cpiButtonLink" style="display:block !important" data-source="@id" data-url="@linkUrl"></i>
</button>


