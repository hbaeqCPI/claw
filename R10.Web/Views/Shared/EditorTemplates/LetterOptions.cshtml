@inject IStringLocalizer<SharedResource> Localizer
@*@model LetterOptionViewModel*@
@model int

    <script>
        function updateSelectRowGenAllLettersDescription(e) {
            var comboBox = e.sender;

            if (comboBox.selectedIndex >= 0) {
                const name = comboBox.dataItem()["Description"];
                @Html.Raw((ViewData["onSelect"].ToString() + "('GenAllLettersDescription',name);"))
            }
        }
    </script>

@(Html.Kendo().DropDownListFor(m => m)
        .DataValueField("GenAllLetters")
        .DataTextField("Description")
        .Events(e => e.DataBound("function () {  if (this.select() === -1) {  this.select(0);  this.trigger('change'); }}"))
        .Events(e => e.Change("updateSelectRowGenAllLettersDescription"))
        .BindTo(LetterOptionViewModel.BuildList(Localizer))
)
