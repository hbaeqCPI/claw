@model SystemTypeLookupDTO
@(Html.Kendo().ComboBoxFor(m => m)
        .DataTextField("SystemTypeName")
        .DataValueField("SystemType")
        .AutoBind(false)
            .DataSource(source =>
            {
                source.Read(read =>
                {
                    read.Action(ViewData["action"].ToString(), ViewData["controller"].ToString(), new { area = ViewData["area"].ToString() });
                })
                .ServerFiltering(false);
            })
        .Filter(FilterType.Contains)
        .Template("<span class='k-state-default'>#: data.SystemTypeName #</span>")
        .HtmlAttributes(new { style = "width: 100%" })

)

