@inject IStringLocalizer<SharedResource> Localizer
@model SendAsOptionViewModel
@(Html.Kendo().DropDownListFor(m => m)
         .DataTextField("Text")
         .DataValueField("Value")
        .BindTo(new List<SelectListItem>() {
              new SelectListItem() {
                  Text = Localizer["Alert"].ToString(),
                  Value = "A"
              },
             new SelectListItem() {
                  Text = Localizer["Info"].ToString(),
                  Value = "I"
              }
          })
)
