@model PatAssignmentStatus
@{
    var id = ViewData["id"].ToString();

    var area = id.Contains("pat") ? "Patent" : id.Contains("tmk") ? "Trademark" : "Patent";
    var linkUrl = Url.Action("DetailLink", "AssignmentStatus", new
    {
        Area = area,
        id = "actualValue"
    });
}
@(Html.Kendo().ComboBoxFor(m => m)
                                    .DataTextField("AssignmentStatus")
                                    .DataValueField("AssignmentStatus")
                                    .AutoBind(false)
                                    .AutoWidth(true)
                                    .ValuePrimitive(true)
                                    .DataSource(source =>
                                    {
                                        source.Read(read =>
                                        {
                                            read.Action("GetAssignmentStatusList", "AssignmentStatus", new { area = area, property = "AssignmentStatus" });
                                        })
                                        .ServerFiltering(true);
                                    })
                                    .Filter(FilterType.Contains)
                                    .Template("<span class='k-state-default'>#: data.AssignmentStatus #</span>")
                                    .HtmlAttributes(new { style = "width: 80%", id = @id })

)
<button type="button" class="btn">
    <i class="fal fa-search-plus btn-link cpiButtonLink" style="display:block !important" data-source="@id" data-url="@linkUrl"></i>
</button>
