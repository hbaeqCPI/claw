@model PatCaseType
@{ 
    var headerTemplate = "<div class='row border-bottom'><div class='col-md-2 mt-2 mb-2'><span>&nbsp;&nbsp;Code</span></div><div class='col-md-5 mt-2 mb-2'><span>Description</span></div></div>";
    var template = "<div class='row'><div class='col-md-2'><span>#: data.CaseType #</span></div><div class='col-md-5'><span>#: data.Description #</span></div></div>";
}

@(Html.Kendo().ComboBoxFor(m => m)
    .DataTextField("CaseType")
    .DataValueField("CaseType")
    .AutoBind(false)
    .AutoWidth(true)
    .DataSource(source =>
    {
        source.Read(read =>
        {
            read.Action("GetCaseTypesList", "PatCaseType", new { area = "Patent", property = "CaseType" });
        })
        .ServerFiltering(true);
    })

    .Template(template)
    .HeaderTemplate(headerTemplate)
    .HtmlAttributes(new { style = "width: 100%"})

)

