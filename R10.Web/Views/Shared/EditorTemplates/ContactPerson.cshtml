@model ContactPerson
@{
    var id = ViewData["id"].ToString();
    var linkUrl = Url.Action("DetailLink", "ContactPerson", new
    {
        Area = "Shared",
        id = "actualValue"
    });

    var headerTemplate = "<div class='row border-bottom'><div class='col-md-3 mt-2 mb-2'><span>&nbsp;&nbsp;Code</span></div><div class='col-md-5 mt-2 mb-2'><span>Name</span></div></div>";
    var template = "<div class='row'><div class='col-md-3'><span>#: data.Contact #</span></div><div class='col-md-5'><span>#: data.ContactName #</span></div></div>";
}
@(Html.Kendo().ComboBoxFor(m => m)
                .DataTextField("ContactName")
                .DataValueField("ContactID")
                .AutoBind(false)
                .DataSource(source =>
                {
                    source.Read(read =>
                    {
                        read.Action("GetContactList", "ContactPerson", new { area = "Shared", property = "ContactName" });
                    })
                    .ServerFiltering(true);
                })
                .Template(template)
                .HeaderTemplate(headerTemplate)
                .HtmlAttributes(new { style = "width: 90%", id = @id })

)

    <button type="button" class="btn">
        <i class="fal fa-search-plus btn-link cpiDetailsLink" id="@id" data-source="@id" data-url="@linkUrl"></i>
    </button>
    




