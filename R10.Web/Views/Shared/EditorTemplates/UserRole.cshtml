@model string
@inject IStringLocalizer<AdminResource> Localizer
@(Html.Kendo().DropDownListFor(m => m)
    .HtmlAttributes(new { 
        style = "width: 100px;", 
        data_val_required = Localizer["The Role field is required."].ToString() //data_val_required will trigger default validation
    })
    .DataValueField("Id")
    .DataTextField("Name")
    .AutoBind(false)
    .Events(e => e.Open("function (e) { e.sender.list.width(150); }"))
    .DataSource(dataSource => dataSource
        .Ajax()
        .Read(read => read.Action("UserRoles", "Roles").Data("getUserRoleFilter"))
    )
)
