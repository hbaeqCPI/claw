@model R10.Core.Entities.GeneralMatter.GMOtherPartyType

@{
    var id = ViewData["id"].ToString();

    var linkUrl = Url.Action("DetailLink", "OtherPartyType", new
    {
        Area = "GeneralMatter",
        id = "actualValue"
    });    
}
@(Html.Kendo().ComboBoxFor(m => m)
                                    .DataTextField("OtherPartyType")
                                    .DataValueField("OtherPartyType")
                                    .AutoBind(false)
                                    .AutoWidth(true)
                                    .ValuePrimitive(true)
                                    .DataSource(source =>
                                    {
                                        source.Read(read =>
                                        {
                                            read.Action("GetOtherPartyTypeList", "OtherPartyType", new { area = "GeneralMatter", property = "OtherPartyType" });
                                        })
                                        .ServerFiltering(true);
                                    })
                                    .Filter(FilterType.Contains)
                                    .Template("<span class='k-state-default'>#: data.OtherPartyType #</span>")                                    
                                    .HtmlAttributes(new { style = "width: 80%", id = @id })

)
<button type="button" class="btn">
    <i class="fal fa-search-plus btn-link cpiButtonLink" style="display:block !important" data-source="@id" data-url="@linkUrl"></i>
</button>
