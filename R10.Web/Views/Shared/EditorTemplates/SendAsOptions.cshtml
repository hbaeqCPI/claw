@inject IStringLocalizer<SharedResource> SharedLocalizer
@*@model SendAsOptionViewModel*@
@model string
@{
    var onSelect = ViewData["onSelect"] != null ? ViewData["onSelect"].ToString() : "";
}

<script>
    function updateSelectRowLetterSendAsDescription(e) {
        var comboBox = e.sender;

        if (comboBox.selectedIndex >= 0) {
            const name = comboBox.dataItem()["Description"];
            @Html.Raw(onSelect + "('LetterSendAsDescription',name);")
        }
    }
</script>


@(Html.Kendo().DropDownListFor(m => m)
        .DataValueField("LetterSendAs")
        .DataTextField("Description")
        .Events(e => e.Change("updateSelectRowLetterSendAsDescription"))
        .BindTo(SendAsOptionViewModel.BuildList(SharedLocalizer))
)
