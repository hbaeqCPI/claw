@model PatPriority
@(Html.Kendo().ComboBoxFor(m => m)
                .DataTextField("AppNumber")
                .DataValueField("AppNumber")
                //.AutoBind(false)
                .DataSource(source =>
                {
                    source.Read(read =>
                    {
                        read.Action("GetAppNumberAndFilDateList", "PatPriority", new { area = "Patent", property = "AppNumber" });
                    })
                    .ServerFiltering(true);
                })
    .Events(e => e.Select("function(e) {inventionPage.onAppNumberComboBoxSelect(e,'FilDate');}"))
    .Template("<span class='k-state-default'>#: data.AppNumber #</span>")
    .HtmlAttributes(new { style = "width: 100%" })

)

