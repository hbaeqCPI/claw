@inject IStringLocalizer<SharedResource> SharedLocalizer
@model ComboBoxOptions
@{
    var template = "";
    var nameOnly = false;
    template = "<span class='k-state-default'>#: data.DisclosureStatus #</span>";
}
@(Html.Kendo().ComboBox()
            .Name(Model.Name)
            .DataTextField(Model.DataTextProperty)
            .DataValueField(Model.DataValueProperty)
            .Filter(Model.ListFilterType)
            .Value(Model.DefaultValue)
            .Text(Model.DefaultValue)
            .AutoBind(false)
            .DataSource(source =>
            {
                source.Read(read =>
                {
                    read.Action(Model.Action, Model.Controller, new { area = Model.Area, textProperty = Model.DataTextProperty, filterType = Model.ListFilterType, requiredRelation = Model.RequiredRelation });
                })
                .ServerFiltering(true);
            })
            //.Events(e => e.Select("function(e) {pageHelper.UpdateIDFromComboBox(e,'DisclosureStatusID', '');}"))
            .Template(template)
            .HtmlAttributes(new { style = "width: " + Model.Width.ToString() + "%", id = Model.Id })
            .Events(e => e.Open($"function(e) {{ if (this.element.data('fetched')===0) {{this.dataSource.read();}} this.element.data('fetched',1); pageHelper.setKendoListWidth(e,{(nameOnly ? 0 : Model.ListWidth)})}}"))

)
@if (Model.LinkButtonUrl.Length > 0)
{
    <i class="btn btn-link fas fa-search cpiButtonLink" data-source="@Model.Id" data-url="@Model.LinkButtonUrl"></i>
}
