@using  R10.Web.Areas
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@model ReportPartialLookUpViewModel

@{
    var settings = await Settings.GetSetting();

    var attorneyLabel = "Attorney";
    var attorneyNameLabel = "Attorney Name";
}

<div class="form-group float-label col-xl-4 col-5 AttorneyMultiSelectClass" hidden>
    <label>@Localizer[attorneyLabel + "s"]</label>
    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
{
    Controller = Model.Controller,
    Area = Model.Area,
    Action = "GetAttorneyList",
    Name = "Attorneys_Options",
    DataTextProperty = "AttorneyCode",
    DataValueProperty = "AttorneyCode",
    ListWidth = 500,
    HeaderTemplate = ComboBoxHelper.GetHeaderTemplate(@Localizer[attorneyLabel], @Localizer[attorneyNameLabel]),
    ItemTemplate = ComboBoxHelper.GetItemTemplate("AttorneyCode", "AttorneyName"),
})
</div>
<div class="form-group float-label col-xl-4 col-5 AttorneyComboBoxClass">
    <label>@Localizer[attorneyLabel]</label>
    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyCode("Attorney", @Localizer[attorneyLabel], @Localizer[attorneyNameLabel], Model.Controller, "", "GetAttorneyList",  Model.Area))
</div>
@await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "AttorneyMultiSelectClass", SingleClass = "AttorneyComboBoxClass" })
<div class="form-group float-label col-xl-6 col-7 AttorneyNameMultiSelectClass" hidden>
    <label>@Localizer[attorneyNameLabel + "s"]</label>
    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
{
   Controller = Model.Controller,
   Area = Model.Area,
   Action = "GetAttorneyList",
   Name = "AttorneyNames_Options",
   DataTextProperty = "AttorneyName",
})
</div>
<div class="form-group float-label col-xl-6 col-7 AttorneyNameComboBoxClass">
    <label>@Localizer[attorneyNameLabel]</label>
    @await Component.InvokeAsync("ComboBox", new { name = "AttorneyName", controller = Model.Controller, action = "GetAttorneyList", area = Model.Area })
</div>
@await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "AttorneyNameMultiSelectClass", SingleClass = "AttorneyNameComboBoxClass" })