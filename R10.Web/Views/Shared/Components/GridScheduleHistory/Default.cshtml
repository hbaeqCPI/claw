@using R10.Web.Areas.Shared.ViewModels.ReportScheduler
@inject IStringLocalizer<SharedResource> SharedLocalizer
@model GridOptions
@inject IStringLocalizer<SharedResource> Localizer
@{
    //var taskIdParam = $"{{taskId: {Model.TaskId}}}";
    //var permission = Model.Permission;
    //bool addMode = Model.TaskId == 0;
    //var detailsUrl = Url.Action("Detail", "ReportScheduler", new { taskId = "#: TaskId#" });
    ////var detailsAddUrl = Url.Action("Detail", "ReportScheduler", new { taskId = 0 });
    //var detailsLinkTemplate = $"<a href={detailsUrl} class='details-link' >#: Schedule#</a>";

    var pageName = ViewBag.ActivePage;
}
<div data-parentid="@Model.ParentId" data-url-open="@Url.Action("HistoryView", Model.Controller)">
    @(Html.Kendo().Grid<RSHistoryViewModel>()
                                    .Name("scheduleHistoryGrid")
                                    .Columns(columns =>
                                    {
                                        columns.Command(command =>
                                        {
                                            command.Custom("View").Click("function(e) {ReportSchedulerPage.openHistoryRecord(e,this)}").IconClass("k-icon fal fa-search")
                                            ;
                                        });
                                        columns.Bound(a => a.ScheduleName)
                                        .HtmlAttributes(new { @class = "name-field" })
                                        ;
                                        columns.Bound(a => a.Frequency)
                                        .HtmlAttributes(new { @class = "name-field" });
                                        columns.Bound(a => a.Action)
                                        .HtmlAttributes(new { @class = "name-field" });

                                        columns.Bound(a => a.StartTime)
                                        .HtmlAttributes(new { @class = "name-field" });

                                        columns.Bound(a => a.EndTime)
                                        .HtmlAttributes(new { @class = "name-field" });

                                        columns.Bound(a => a.ElapsedTime)
                                        .HtmlAttributes(new { @class = "name-field" });

                                        columns.Bound(a => a.RunResult)
                                        .HtmlAttributes(new { @class = "name-field" });

                                    })
                                    .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
                                    //.ToolBar(toolbar =>
                                    //{
                                    //    toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"]).HtmlAttributes(new { @class = "grid-action" });
                                    //    toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                                    //    toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
                                    //})
                                    //.Editable(editable => editable.Enabled(true)
                                    //                .Mode(GridEditMode.InCell).
                                    //                ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))

                                    .Pageable()
                                    //.AutoBind(false)
                                    .DataSource(dataSource => dataSource
                                        .Ajax()
                                        .Batch(true)
                                        .PageSize(10)
                                        //.ServerOperation(false)
                                        .Model(model =>
                                        {
                                            model.Id(s => s.LogId);
                                            model.Field(s => s.ScheduleName).Editable(false);
                                            model.Field(s => s.Frequency).Editable(false);
                                            model.Field(s => s.Action).Editable(false);
                                            model.Field(s => s.StartTime).Editable(false);
                                            model.Field(s => s.EndTime).Editable(false);
                                            model.Field(s => s.ElapsedTime).Editable(false);
                                            model.Field(s => s.RunResult).Editable(false);
                                        })
                                        .Read(read => read.Action("GetHistorysList", Model.Controller, new { parentId = Model.ParentId }))
                                        .Events(events =>
                                        {
                                            events.Error("pageHelper.onGridError");
                                        })
                                    )
                                    //.Events(events =>
                                    //{
                                    //    events.DataBound("inventionPage.setGridReadOnlyRow");
                                    //})
                                    .HtmlAttributes(new { @class = "k-grid-border" })
    )
    </div>

