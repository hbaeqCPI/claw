@model AreaGridOptions
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    var pageName = ViewBag.ActivePage;

    //Use Model.Area
    //var area = pageName.Contains("pat") ? "Patent" : pageName.Contains("tmk") ? "Trademark" : pageName.Contains("gm") ? "GeneralMatter" : "Shared";

    var areaLinkUrl = Url.Action("DetailLink", "Area", new
    {
        Area = Model.Area,
        id = "actualValue"
    });
    var areaTemplate = $"<span class='pr-3'>#=kendo.htmlEncode(Area)#</span><i class='fal fa-search-plus btn-link areaLink' data-url='{areaLinkUrl}' title='{Localizer["Open Area Screen"]}'></i>";
}

@(Html.Kendo().Grid<CountryAreaViewModel>()
            .Name("areasGrid")
            .Columns(columns =>
            {
                columns.Bound(ca => ca.AreaID)
                    .Width(400)
                    .ClientTemplate(areaTemplate)
                    .EditorTemplateName("AreaDropdown")
                    .Editable($"{pageName}.isGridColumnEditable")
                    //.EditorTemplateName("ComboBox")
                    //.EditorViewData(new
                    //{
                    //    dataTextField = "Area",
                    //    dataValueField = "AreaID",
                    //    action = "GetAreaList",
                    //    controller = "Area",
                    //    routeValues = new { property = "Area" },
                    //    template = "<div class='row combobox-item'><div class='col-sm-2'><span class='k-state-default'>#: data.Area #</span></div><div class='col-sm-5'><span class='k-state-default'>#: data.Description #</span></div></div>",
                    //    headerTemplate = $"<div class='row combobox-header'><div class='col-sm-2'><span>{Localizer["Area"]}</span></div><div class='col-sm-5'><span>{Localizer["Description"]}</span></div></div>",
                    //    width = "80",
                    //    onSelect = "function(e) { pageHelper.refreshGridNameField(e, 'Description'); }"
                    //})
                    .EditorViewData(new { id = "AreasGrid_Area", area = Model.Area })
                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
                columns.Bound(ca => ca.AreaDescription)
                    .HtmlAttributes(new { @class = "d-none d-sm-table-cell name-field" })
                    .HeaderHtmlAttributes(new { @class = "d-none d-sm-table-cell" });
                columns.Command(command =>
                {
                    if (detailPagePermission.CanDeleteRecord)
                        command.Custom("Delete")
                                .Click("function(e) {" + pageName + ".deleteGridRow(e,this)}")
                                .IconClass("k-icon fal fa-trash-alt")
                                .Text($"<span class='grid-action-label'>{Localizer["Delete"]}</span>")
                                .HtmlAttributes(new { @class = "grid-action" });
                }).Width(10);
            })
            .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
            .ToolBar(toolbar =>
            {
                if (detailPagePermission.CanAddRecord)
                {
                    toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"]).HtmlAttributes(new { @class = "grid-action" });
                }
                if (detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
                {
                    toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                    toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
                }

            })
            .Editable(editable => editable.Enabled(detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
                        .Mode(GridEditMode.InCell).
                        ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
            .Sortable(sort => sort.AllowUnsort(false))
            .Pageable()
            //.Scrollable()
            .DataSource(dataSource => dataSource
            .Ajax()
            .Batch(true)
            .PageSize(settings.SubFormPageSize)
            .ServerOperation(false) //allow pending changes to persist when paging or sorting
            //.Batch(detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
            .ServerOperation(false)
            .Model(model =>
            {
                model.Id(ca => ca.AreaCtryId);
                model.Field(ca => ca.Country).DefaultValue(Model.Country);
                // model.Field(ca => ca.Area).DefaultValue(new AreaLookupViewModel() { Area = "" });
                // model.Field(ca => ca.Area.Description).Editable(false);
                // model.Field(ca => ca.Area.Area).Editable(false);
            })
            .Read(read => read.Action("AreasRead", Model.Controller).Data($"{{country: '{Model.Country}'}}"))
            .Update(update => update.Action("AreasUpdate", Model.Controller))
            .Destroy(destroy => destroy.Action("AreaDelete", Model.Controller))
            .Events(events =>
            {
                events.Error("pageHelper.onGridError");
            })
            )
.HtmlAttributes(new { @class = "kendo-Grid" })
)
