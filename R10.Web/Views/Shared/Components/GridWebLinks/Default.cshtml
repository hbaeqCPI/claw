@model WebLinksGridOptions
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var param = $"{{id: {Model.ParentId}, module: '{Model.Module}', subModule: '{Model.SubModule}', subSystem: '{Model.SubSystem}', displayChoice: 2}}";
    var url = Url.Action("Navigate", "WebLinks", new {Area="Shared", mainId = "#: MainId#",id=Model.ParentId, module=Model.Module, subModule=Model.SubModule, subSystem=Model.SubSystem });
    var detailsLinkTemplate = $"<a href='{url}' target='_blank' class='details-link' data-id='#: MainId#'>#: MainCode#</a>";
    //var optionsName = $"{Model.Module}_webLinksDisplayOption";
    //var gridName = $"{Model.Module}_webLinksGrid";

    var optionsName = $"webLinksDisplayOption_{ViewData["PageId"]}";
    var gridName = $"webLinksGrid_{ViewData["PageId"]}";
}
