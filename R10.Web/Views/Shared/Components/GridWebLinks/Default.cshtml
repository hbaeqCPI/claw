<div class="weblinks" data-init="1">
    <div class="grid-options">
        <div class="display-type d-flex">
            <label class="mr-2">@Localizer["Display"]</label>
            @(Html.Kendo().DropDownList().AutoWidth(true)
                .Name(optionsName)
                .DataTextField("Text")
                .DataValueField("Value")
                .BindTo(
                    new List<SelectListItem>()
                    {
                    new SelectListItem() {Text = Localizer["Record Links"].ToString(), Value = ((int) WebLinksDisplayOption.RecordLink).ToString()},
                    new SelectListItem() {Text = Localizer["Main/Search Pages"].ToString(), Value = ((int) WebLinksDisplayOption.Search).ToString()}
                    }
                )
                .HtmlAttributes(new { @class = "weblinks-option" })
                .Events(e=> e.Change("pageHelper.setWebLinksOption"))
            )
        </div>
    </div>
    @(Html.Kendo().Grid<WebLinksDTO>().Name(gridName)
            .Columns(columns =>
            {
                columns.Bound(w => w.MainCode).ClientTemplate(detailsLinkTemplate).Width(300);
                columns.Bound(w => w.Description);
            })
        .Pageable(page => page.Responsive(false))
            .Sortable(sort => sort.AllowUnsort(false))
            .AutoBind(false)
            .DataSource(dataSource => dataSource
                .Ajax()
                .Batch(true)
                .PageSize(settings.SubFormPageSize)
                .ServerOperation(false)
                .Read(create => create.Action("Search", "WebLinks", new {Area = "Shared"}).Data($"function(e){{ return pageHelper.getWebLinksOption(e, '{optionsName}', {Html.Raw(param)}); }}"))
                .Events(events =>
                {
                    events.Error("pageHelper.onGridError");
                })
            )
            .HtmlAttributes(new { @class = "webLinksGrid kendo-Grid" })
            .Events(e=> e.DataBinding("pageHelper.setWebLinksDefaultOption"))
            )
</div>
