@model ComboBoxOptions
@{
    var template = "";
    var headerTemplate = "";
    var onChange = Model.OnChange.Length > 0 ? Model.OnChange : "function() {}";
    if (Model.CodeProperty != Model.DescProperty)
    {
        headerTemplate = "<div class='row border-bottom'><div class='col-md-3 mt-2 mb-2'><span>&nbsp;&nbsp;Code</span></div><div class='col-md-5 mt-2 mb-2'><span>Description</span></div></div>";
        template = $"<div class='row'><div class='col-md-3'><span>#: data.{Model.CodeProperty}  #</span></div><div class='col-md-5'><span>#: data.{Model.DescProperty} #</span></div></div>";
    }
    else
    {
        template = $"<span class='k-state-default'>#: data.{Model.CodeProperty} #</span>";
    }
    var htmlAttributes = new Dictionary<string, object>();
    htmlAttributes.Add("style", "width: " + Model.Width.ToString() + "%");
    htmlAttributes.Add("id", Model.Id);
    if (Model.Required) { htmlAttributes.Add("required", "required"); }
}
@(Html.Kendo().ComboBox()
        .Name(Model.Name)
        .DataTextField(Model.DataTextProperty)
        .DataValueField(Model.DataValueProperty)
        .Value(Model.DefaultValue)
        .Text(Model.DefaultValue)
        .Filter(Model.ListFilterType)
        .AutoBind(false)
        .AutoWidth(true)
        .DataSource(source =>
        {
            source.Read(read =>
            {
                read.Action(Model.Action, Model.Controller, new { area = Model.Area, property = Model.DataTextProperty, filterType = Model.ListFilterType, requiredRelation = Model.RequiredRelation });
            })
            .ServerFiltering(true);
        })
        .Template(template)
        .HeaderTemplate(headerTemplate)
        .HtmlAttributes(htmlAttributes)
        .Events(e => e.Open($"function(e) {{ if (this.element.data('fetched')===0) {{this.dataSource.read();}} this.element.data('fetched',1);}}").Change(onChange))
)

