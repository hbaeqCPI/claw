@inject IStringLocalizer<SharedResource> Localizer
<div class="modal fade" id="cpiConfirm" data-backdrop="static" tabindex="-1" role="dialog" aria-labelledby="cpiConfirmLabel" aria-hidden="true"
     data-title="@Localizer["Confirm Dialog"]"
     data-btn-yes="@Localizer["Yes"]"
     data-btn-no="@Localizer["No"]"
     data-btn-cancel="@Localizer["Cancel"]"
     data-btn-delete="@Localizer["Delete"]"
     data-btn-save="@Localizer["Save"]"
     data-btn-ok="@Localizer["Ok"]"
     >
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title" id="cpiConfirmLabel"></h4>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="modal-message"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn modal-close" data-dismiss="modal"><i class="pr-2"></i><span></span></button>
                <button type="button" class="btn modal-action"><i class="pr-2"></i><span></span></button>
            </div>
        </div>
    </div>
</div>
@*<script src="~/js/confirmDialog.js" asp-append-version="true"></script>*@