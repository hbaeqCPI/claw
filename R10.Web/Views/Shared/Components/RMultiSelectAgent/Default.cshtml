@using  R10.Web.Areas
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@model ReportPartialLookUpViewModel

@{
    var settings = await Settings.GetSetting();

    var agentLabel = settings.LabelAgent;
    var agentNameLabel = settings.LabelAgentName;
}

<div class="form-group float-label col-xl-4 col-5 AgentMultiSelectClass" hidden>
    <label>@Localizer[agentLabel + "s"]</label>
    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
    {
        Controller = Model.Controller,
        Area = Model.Area,
        Action = "GetAgentList",
        Name = "Agents_Options",
        DataTextProperty = "AgentCode",
        DataValueProperty = "AgentCode",
        ListWidth = 500,
        HeaderTemplate = ComboBoxHelper.GetHeaderTemplate(@Localizer[agentLabel], @Localizer[agentNameLabel]),
        ItemTemplate = ComboBoxHelper.GetItemTemplate("AgentCode", "AgentName"),
    })
</div>
<div class="form-group float-label col-xl-4 col-5 AgentComboBoxClass">
    <label>@Localizer[agentLabel]</label>
    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AgentCode("Agent", @Localizer[agentLabel], @Localizer[agentNameLabel], Model.Controller, "", Model.Area))
</div>
@await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "AgentMultiSelectClass", SingleClass = "AgentComboBoxClass" })
<div class="form-group float-label col-xl-6 col-7 AgentNameMultiSelectClass" hidden>
    <label>@Localizer[agentNameLabel + "s"]</label>
    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
{
   Controller = Model.Controller,
   Area = Model.Area,
   Action = "GetAgentList",
   Name = "AgentNames_Options",
   DataTextProperty = "AgentName",
})
</div>
<div class="form-group float-label col-xl-6 col-7 AgentNameComboBoxClass">
    <label>@Localizer[agentNameLabel]</label>
    @await Component.InvokeAsync("ComboBox", new { name = "AgentName", controller = Model.Controller, action = "GetAgentList", area = Model.Area })
</div>
@await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "AgentNameMultiSelectClass", SingleClass = "AgentNameComboBoxClass" })
