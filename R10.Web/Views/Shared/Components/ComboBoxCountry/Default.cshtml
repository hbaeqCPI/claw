@model ComboBoxOptions
@{
    var template = "";
    var headerTemplate = "";
    var onChange = Model.OnChange.Length > 0 ? Model.OnChange : "function() {}";
    var onOpen = Model.OnOpen.Length > 0 ? Model.OnOpen : "function(e) {{ if (this.element.data('fetched')===0) {{this.dataSource.read();}} this.element.data('fetched',1);}}";

    if (Model.DataTextProperty.ToLower() == "countryname")
    {
        template = "<span class='k-state-default'>#: data.CountryName #</span>";
    }
    else
    {
        headerTemplate = "<div class='row border-bottom'><div class='col-md-2 mt-2 mb-2'><span>&nbsp;&nbsp;Code</span></div><div class='col-md-5 mt-2 mb-2'><span>Description</span></div></div>";
        template = "<div class='row'><div class='col-md-2'><span>#: data.Country #</span></div><div class='col-md-5'><span>#: data.CountryName #</span></div></div>";
    }
    var htmlAttributes = new Dictionary<string, object>();
    htmlAttributes.Add("style", "width: " + Model.Width.ToString() + "%");
    htmlAttributes.Add("id", Model.Id);
    if (Model.Required) { htmlAttributes.Add("required", "required"); }

}
@(Html.Kendo().ComboBox()
            .Name(Model.Name)
            .DataTextField(Model.DataTextProperty)
            .DataValueField(Model.DataValueProperty)
            .Value(Model.DefaultValue)
            .Text(Model.DefaultValue)
            .Filter(Model.ListFilterType)
            .AutoBind(false)
            .AutoWidth(true)
            .DataSource(source =>
            {
                source.Read(read =>
                {
                    read.Action(Model.Action, Model.Controller, new { area = Model.Area, property = Model.DataTextProperty, filterType = Model.ListFilterType, requiredRelation = Model.RequiredRelation })
                    .Data(Model.Data);
                })
                .ServerFiltering(true);
            })
            .Template(template)
            .HeaderTemplate(headerTemplate)
            .Events(e => e.Select("function(e) {pageHelper.onComboBoxSelect(e,'CountryName');}"))
            .HtmlAttributes(htmlAttributes)
            .Events(e => e.Open(onOpen).Change(onChange))

)
@if (Model.LinkButtonUrl.Length > 0)
{
    <i class="btn btn-link fal fa-search-plus cpiButtonLink" data-source="@Model.Id" data-url="@Model.LinkButtonUrl"></i>
}
