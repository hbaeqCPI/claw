@inject IStringLocalizer<SharedResource> SharedLocalizer
@model DetailPagePermission

<div class="mb-md-2 ml-md-3 text-right cpiButtonsDetail">
    <div class="row pt-3 ">
        <div class="col-md-4 text-left">
            <h3 class="page-title">@ViewBag.Title</h3>
        </div>
        <div class="col-md mr-md-2">
            
            @if (Model.CanAddRecord)
            {
                <button class="btn btn-link" data-url="@Model.AddScreenUrl" data-container="@Model.Container"><span class="fal fa-plus"></span> @SharedLocalizer["Add"]</button>
            }
            @if (Model.CanDeleteRecord)
            {
                <button class="btn btn-link" data-url="@Model.DeleteScreenUrl" data-popup="true" data-container="@Model.Container"><span class="fal fa-trash"></span> @SharedLocalizer["Delete"]</button>
            }
            @if (Model.CanCopyRecord)
            {
                <button class="btn btn-link" data-url="@Model.CopyScreenUrl" data-container="@Model.Container"><span class="fal fa-copy"></span> @SharedLocalizer["Copy"]</button>
            }

            <button class="btn btn-link" data-url="@Model.PrintScreenUrl" data-container="@Model.Container"><span class="fal fa-print"></span> @SharedLocalizer["Print"]</button>

            @if (Model.CanEmail)
            {
                <button class="btn btn-link" data-url="@Model.EmailScreenUrl" data-container="@Model.Container"><span class="fal fa-envelope"></span> @SharedLocalizer["Email"]</button>
            }

            <button class="btn btn-link show-search" data-url="@Model.SearchScreenUrl"><span class="fal fa-binoculars"></span> @SharedLocalizer["Search"]</button>
            <button class="btn btn-link refresh-record" data-url="@Model.RefreshRecordUrl"><span class="fal fa-sync"></span> @SharedLocalizer["Refresh"]</button>

            @foreach (var option in Model.PageActions)
            {
                <button class="btn btn-link" data-url="@option.Url" @(option.IsPopup ? "data-popup='true'" : "") id="@option.ControlId" @(option.AppendContent ? "" : $"data-container={@Model.Container}")><span class="fal @option.IconClass"></span> @SharedLocalizer[option.Label]</button>
            }
        </div>
    </div>
</div>



