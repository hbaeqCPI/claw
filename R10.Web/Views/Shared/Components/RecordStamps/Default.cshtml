@inject IStringLocalizer<SharedResource> SharedLocalizer
@model R10.Web.Views.Shared.Components.RecordStamps.RecordStampsEntity

    <div class="record-stamp">
        <input asp-for="tStamp" type="hidden" />
        <input asp-for="CreatedBy" type="hidden" />
        <input asp-for="DateCreated" type="hidden" value="@Model.DateCreated.FormatToSave()"/>
        <input asp-for="UpdatedBy" type="hidden" />
        <input asp-for="LastUpdate" type="hidden" value="@Model.LastUpdate.FormatToSave()"/>
        <div class="form-row">
            <div class="col-sm-6">
            <label>@SharedLocalizer["Created"]</label><span class="user">@Model.CreatedBy</span><span class="date">@Model.DateCreated.FormatToDisplayWithTime()</span>
            </div>

            <div class="col-sm-6 text-sm-right">
            <label>@SharedLocalizer["Updated"]</label><span class="user">@Model.UpdatedBy</span><span class="date">@Model.LastUpdate.FormatToDisplayWithTime()</span>
            </div>
