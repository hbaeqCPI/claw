@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    Layout = "_Layout.cshtml";
}
@section Scripts {
    @RenderSection("Scripts", required: false)
}

<div class="site-content">
    @await Component.InvokeAsync("StatusMessage")
    <nav class="container-crumbs" aria-label="breadcrumb" role="navigation" data-dirty-page-title="@SharedLocalizer["Confirm Cancel Changes"]" data-dirty-page-msg="@SharedLocalizer["Changes you made may not be saved. Do you want to continue?"]" data-not-saved-msg="@SharedLocalizer["Not saved yet."]"></nav>
    <div id="errorSummary" class="alert alert-danger d-none alert-dismissible fade show boxy" role="alert">
        <div class="content"></div>
        <button type="button" class="close alert-close" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
    <div id="page" class="page-content @ViewData["PageSelector"]">
        @RenderBody()
    </div>
    <div class="popup"></div>
</div>

@await Component.InvokeAsync("AlertDialog")
@await Component.InvokeAsync("ConfirmDialog")
@await Component.InvokeAsync("LoadingSpinner")

<script>
    $(document).ready(function() {
        // Show any deferred success message from a previous action (e.g., delete)
        var msg = sessionStorage.getItem('cpiDeferredSuccess');
        if (msg) {
            sessionStorage.removeItem('cpiDeferredSuccess');
            setTimeout(function() {
                if (typeof cpiStatusMessage !== 'undefined') cpiStatusMessage.success(msg, 5000);
            }, 500);
        }

        // Monkey-patch showSuccess to store message for post-navigation display
        if (typeof pageHelper !== 'undefined') {
            var _origShowSuccess = pageHelper.showSuccess;
            pageHelper.showSuccess = function(message) {
                if (message) sessionStorage.setItem('cpiDeferredSuccess', message);
                _origShowSuccess(message);
            };
        }
    });
</script>