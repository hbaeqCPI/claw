@model PageViewModel
@{
    ViewData["Title"] = Model.Title;
}
@await Html.PartialAsync("_SidebarPage", new SidebarPageViewModel() {
    Title = "IP Decision Central",
    PageId = Model.PageId,
    MainPartialView = Model.PartialViewName,
    MainViewModel = Model,
    SideBarPartialView = "_SidebarNav",
    SideBarViewModel = Model.PageId
})
