@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="desCaseTypeFieldsExtSearchMainTabContent" aria-labelledby="desCaseTypeFieldsExtSearchMainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DesCaseType">@Localizer["Des Case Type"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "DesCaseType", multiSelect = true })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="FromField">@Localizer["From Field"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "FromField", multiSelect = true })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ToField">@Localizer["To Field"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "ToField", multiSelect = true })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="SystemName">@Localizer["Systems"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "SystemName", controller = "System", area = "Shared", action = "GetPicklistData", multiSelect = true })
                </div>
            </div>
        </div>
    </div>
</div>