@model PatAreaCountryDelete
@using R10.Core.Entities.Patent
@inject IStringLocalizer<SharedResource> Localizer

<form cpi-detail-form action="Save">
    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="Area"></label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Area", controller = "Area", area = "Patent", action = "GetPicklistData", defaultValue = Model.Area })
                    <span asp-validation-for="Area"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="Country"></label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Country", controller = "Country", area = "Patent", action = "GetPicklistData", defaultValue = Model.Country })
                    <span asp-validation-for="Country"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="AreaNew"></label>
                    @await Component.InvokeAsync("ComboBox", new { name = "AreaNew", controller = "Area", area = "Patent", action = "GetPicklistData", defaultValue = Model.AreaNew })
                    <span asp-validation-for="AreaNew"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="CountryNew"></label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CountryNew", controller = "Country", area = "Patent", action = "GetPicklistData", defaultValue = Model.CountryNew })
                    <span asp-validation-for="CountryNew"></span>
                </div>
            </div>
        </div>
    </div>
    <div class="form-row mt-3">
        <div class="col">
            <button type="submit" class="btn btn-primary btn-sm"><i class="fal fa-save mr-1"></i>@Localizer["Save"]</button>
        </div>
    </div>
</form>
