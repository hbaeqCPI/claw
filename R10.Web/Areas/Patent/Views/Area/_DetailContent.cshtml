@model PatArea
@inject IStringLocalizer<SharedResource> Localizer
@{
    var id = Model.Area;
    var isCopy = ViewBag.CopyOptions != null;
    var addMode = string.IsNullOrEmpty(id) || isCopy;

    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;
    bool isReadOnlyRemarks = !(fullModify || detailPagePermission.CanEditRemarksOnly);
}
<form cpi-detail-form action="Save">
    @if (addMode)
    {
        <input type="hidden" name="IsNewRecord" value="true" class="boolean" />
    }
    <input type="hidden" name="OriginalSystems" value="@(addMode ? "__NEW__" : (string.IsNullOrEmpty(Model.Systems) ? "__EMPTY__" : Model.Systems))" />
    <vc:detail-page-nav-links page-permission="detailPagePermission" title="" add-mode="addMode"></vc:detail-page-nav-links>

    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="Area"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="Area" asp-is-readonly="@isReadOnly" asp-is-autofocus="@addMode" />
                    <span asp-validation-for="Area"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-8 col-md-7 col-lg-6 col-xl-5">
                <div class="form-group float-label">
                    <label asp-for="Description"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="Description" asp-is-readonly="@isReadOnly" />
                    <span asp-validation-for="Description"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label asp-for="Systems"></label>
                    <input type="hidden" name="Systems" id="areaSystemsHidden" value="@Model.Systems" />
                    <div class="border rounded p-2 position-relative" style="min-height: 60px; padding-top: 30px !important;">
                        @if (!isReadOnly)
                        {
                            <div class="position-absolute" style="top: 4px; right: 8px;">
                                <label class="small mb-0" style="cursor:pointer;"><input type="checkbox" id="areaSystemsToggleAll" class="mr-1"/>Select All</label>
                            </div>
                        }
                        <div id="areaSystemsCheckboxes"></div>
                    </div>
                    <script>
                        $(document).ready(function() {
                            var disabled = @(isReadOnly ? "true" : "false");
                            var selected = ($('#areaSystemsHidden').val() || '').split(',').filter(function(s) { return s.length > 0; });
                            $.getJSON('@Url.Action("GetSystemList", "Area")', function(data) {
                                var html = '';
                                $.each(data, function(i, name) {
                                    var checked = selected.indexOf(name) > -1 ? ' checked' : '';
                                    var dis = disabled ? ' disabled' : '';
                                    html += '<label class="mr-3" style="white-space:nowrap;"><input type="checkbox" class="areaSystemChk mr-1" value="' + name + '"' + checked + dis + '/>' + name + '</label>';
                                });
                                $('#areaSystemsCheckboxes').html(html);
                                var allCount = $('.areaSystemChk').length;
                                var checkedCount = $('.areaSystemChk:checked').length;
                                $('#areaSystemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $(document).on('change', '.areaSystemChk', function() {
                                var vals = [];
                                $('.areaSystemChk:checked').each(function() { vals.push($(this).val()); });
                                $('#areaSystemsHidden').val(vals.join(',')).trigger('change');
                                var allCount = $('.areaSystemChk').length;
                                var checkedCount = $('.areaSystemChk:checked').length;
                                $('#areaSystemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $('#areaSystemsToggleAll').click(function() {
                                var isChecked = $(this).prop('checked');
                                $('.areaSystemChk').prop('checked', isChecked).first().trigger('change');
                            });
                        });
                    </script>
                </div>
            </div>
        </div>
    </div>
    @if (!addMode)
    {
        <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" role="tablist">
            <li class="nav-item">
                <a id="patAreaDetailCountryTab" href="#patAreaDetailCountryTabContent" class="nav-link active" data-toggle="tab" role="tab" aria-controls="patAreaDetailCountryTabContent" title="@Localizer["Countries"]">@Localizer["Countries"]</a>
            </li>
        </ul>
        <div class="tab-content detail">
            <div class="tab-pane active show" id="patAreaDetailCountryTabContent" role="tabpanel" aria-labelledby="patAreaDetailCountryTab">
                @await Component.InvokeAsync("GridCountries", new GridOptions { ParentCode = Model.Area, Area = "Patent", Permission = detailPagePermission })
            </div>
        </div>
        <div class="content-stamp">
            <vc:record-stamps created-by="@Model.UserID" date-created="@Model.DateCreated" updated-by="@Model.UserID" last-update="@Model.LastUpdate"></vc:record-stamps>
        </div>
    }
</form>

<script>
    patAreaPage.afterInsert = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    // Override edit mode afterSubmit to handle systems change redirect
    patAreaPage.showDetails = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    patAreaPage.editableGrids = [
            {
            title: '@Localizer["Countries"]', name: 'countriesGrid', isDirty: false, filter: { areaId: '@Model.Area'},
            afterSubmit: patAreaPage.updateRecordStamps
            }
    ];

    $(document).ready(() => {
        const countriesGrid = $("#countriesGrid");
        countriesGrid.on("click", ".countryLink", (e) => {
            e.stopPropagation();

            let url = $(e.target).data("url");
            const row = $(e.target).closest("tr");
            const dataItem = countriesGrid.data("kendoGrid").dataItem(row);
            const linkUrl = url.replace("actualValue", dataItem.Country);
            pageHelper.openLink(linkUrl, false);
        });
    })
</script>