@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Area"];
    ViewData["ActivePage"] = "patAreaPage";
}

@section Scripts {
    <script>
        var @ViewBag.ActivePage = new ActivePage();
    </script>
}

<script>
    if (typeof patAreaPage === 'undefined') {
        var patAreaPage = new ActivePage();
    }
</script>

@await Html.PartialPageAsync(Model.Page, Model)
