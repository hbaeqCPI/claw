@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using R10.Core.Entities.Patent

@(Html.Kendo().Grid<PatCountryExpDelete>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.CExpId).Width(100);
        columns.Bound(m => m.Country).Width(200);
        columns.Bound(m => m.CaseType).Width(200);
        columns.Bound(m => m.Type).Width(200);
        columns.Bound(m => m.BasedOn).Width(200);
        columns.Bound(m => m.Yr).Width(100);
        columns.Bound(m => m.Mo).Width(100);
        columns.Bound(m => m.EffBasedOn).Width(200);
        columns.Bound(m => m.EffStartDate).Format("{0:dd-MMM-yyyy}").Width(150);
        columns.Bound(m => m.EffEndDate).Format("{0:dd-MMM-yyyy}").Width(150);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("CountryExpDeleteList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "CountryExpDelete")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("patCountryExpDeletePage.searchResultGridError"))
        .Events(events => events.RequestEnd("patCountryExpDeletePage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "CountryExpDelete").Data("patCountryExpDeletePage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
