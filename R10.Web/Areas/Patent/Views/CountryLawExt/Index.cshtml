@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CountryLaw Ext"];
    ViewData["ActivePage"] = "patCountryLawExtPage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof patCountryLawExtPage === 'undefined') { var patCountryLawExtPage = new ActivePage(); }
patCountryLawExtPage.mainSearchRecordIds = patCountryLawExtPage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)
