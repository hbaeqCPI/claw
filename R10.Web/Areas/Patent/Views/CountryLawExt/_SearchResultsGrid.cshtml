@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using R10.Core.Entities.Patent

@(Html.Kendo().Grid<PatCountryLawExt>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.Country).Width(200);
        columns.Bound(m => m.CaseType).Width(200);
        columns.Bound(m => m.LabelTaxSched).Width(200);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("CountryLawExtList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "CountryLawExt")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("patCountryLawExtPage.searchResultGridError"))
        .Events(events => events.RequestEnd("patCountryLawExtPage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "CountryLawExt").Data("patCountryLawExtPage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
