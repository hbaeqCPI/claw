@model CountryLawChildViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{

    var permission = Model.Permission;
    var childLinkParam = $"{{country: '{Model.Country}', caseType: '{Model.CaseType}'}}";

    var basedOnOptions = typeof(BasedOnOption).GetPublicConstantValues<string>().OrderBy(o => o);
}

@(Html.Kendo().Grid<PatCountryExp>()
                     .Name("patCountryExpGrid")
                     .Columns(columns =>
                     {
                         columns.Bound(e => e.Type)
                            .EditorTemplateName("ComboBox").Width(150)
                            .EditorViewData(new {action = "GetExpirationTypeList", controller = "CountryLaw", area = "Patent", dataTextField = "Text", dataValueField = "Text" });

                         columns.Bound(e => e.BasedOn)
                             .EditorTemplateName("DropDownList").Width(150)
                             .EditorViewData(new {data = basedOnOptions});

                         columns.Bound(e => e.Yr).Width(80);
                         columns.Bound(e => e.Mo).Width(80);
                         columns.Bound(e => e.Dy).Width(80);
                         columns.Bound(e => e.EffBasedOn)
                             //.EditorTemplateName("ComboBox").Width(200)
                             //.EditorViewData(new {action = "GetBasedOnList", controller = "CountryLaw", area = "Patent", dataTextField = "Text", dataValueField = "Text" });
                             .EditorTemplateName("DropDownList").Width(150)
                             .EditorViewData(new {data = basedOnOptions});

                         columns.Bound(a => a.EffStartDate).EditorTemplateName("Date").Format("{0:dd-MMM-yyyy}").Width(130);
                         columns.Bound(a => a.EffEndDate).EditorTemplateName("Date").Format("{0:dd-MMM-yyyy}").Width(130);
                         columns.Command(command =>
                         {
                             if (Model.CanDeleteChild)
                                 command.Custom("Delete").Click("function(e) {patCountryLawPage.deleteGridRow(e,this)}").IconClass("k-icon fal fa-trash-alt")
                                 .Text(Localizer["Delete"]);

                         }).Width(10);
                     })
                     .Pageable(page=> page.Responsive(false))
                     .Sortable(sort => sort.AllowUnsort(false))
                    .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
                     .ToolBar(toolbar =>
                     {
                         if (permission.CanAddRecord)
                         {
                             toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"]);
                         }

                         if (permission.CanEditRecord)
                         {
                             toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                             toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
                         }

                     })
                     .Editable(editable => editable.Enabled(permission.CanEditRecord)
                         .Mode(GridEditMode.InCell).
                         ConfirmDelete(Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
                     .AutoBind(false)
                     .DataSource(dataSource => dataSource
                         .Ajax()
                         .Batch(true)
                         .ServerOperation(false)
                         .Model(model =>
                         {
                             model.Id(e => e.CExpId);
                             model.Field(e => e.Country).DefaultValue(Model.Country);
                             model.Field(e => e.CaseType).DefaultValue(Model.CaseType);
                             model.Field(e => e.Systems).DefaultValue(Model.Systems ?? "");

                         })
                         .Read(create => create.Action("CountryExpRead", "CountryLaw").Data(childLinkParam))
                         .Update(create => create.Action("CountryExpUpdate", "CountryLaw").Data(childLinkParam))
                         .Destroy(create => create.Action("CountryExpDelete", "CountryLaw"))
                         .Events(events =>
                         {
                             events.Error("pageHelper.onGridError");
                         })
                     )

                     .HtmlAttributes(new { @class = "kendo-Grid" })
)
    <style>
        #patCountryExpGrid .k-command-cell {
            padding-left: 1px;
            padding-right: 1px;
        }
    </style>