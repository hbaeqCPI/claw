@model PageViewModel
@inject IStringLocalizer<CountryLawResource> Localizer
@{
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];
}

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="countryLawSearchMainTabContent" role="tabpanel" aria-labelledby="countryLawSearchMainTab">
        <div class="form-row">
            <div class="col-md-4 col-lg-4 col-xl-3">
                <div class="form-group float-label">
                    <label for="ClientCode">@countryLabel</label>
                    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.Country("Country", countryLabel, countryNameLabel, "CountryLaw"))
                </div>
            </div>
            <div class="col-md-8 col-lg-8 col-xl-4">
                <div class="form-group float-label">
                    <label for="ClientName">@countryNameLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CountryName", controller = "CountryLaw", action = "GetCountryList", area = "Patent"})
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4 col-lg-4 col-xl-3">
                <div class="form-group float-label">
                    <label for="Contact">@Localizer["Case Type"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CaseType", action = "GetCaseTypeList",
                   headerTemplate = ComboBoxHelper.GetHeaderTemplate(Localizer["Case Type"], Localizer["Description"]),
                   itemTemplate = ComboBoxHelper.GetItemTemplate("CaseType", "Description"),listWidth = 500})
                </div>
            </div>
            <div class="col-md-4 col-lg-4 col-xl-3">
                <div class="form-group float-label">
                    <label for="SystemName">@Localizer["Systems"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "SystemName", controller = "System", area = "Shared", action = "GetPicklistData" })
                </div>
            </div>
        </div>
        <div class="form-row mt-4">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="CreatedBy">@Localizer["Created By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CreatedBy" })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedFrom">@Localizer["Date Created From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedTo">@Localizer["Date Created To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedTo"))
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="UpdatedBy">@Localizer["Updated By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "UpdatedBy" })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateFrom">@Localizer["Last Update From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateTo">@Localizer["Last Update To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateTo"))
                </div>
            </div>
        </div>
    </div>
    
    
</div>