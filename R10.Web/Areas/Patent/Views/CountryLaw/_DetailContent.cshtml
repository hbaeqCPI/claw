@model PatCountryLawDetailViewModel
@inject ISystemSettings<PatSetting> Settings
@inject IStringLocalizer<CountryLawResource> Localizer
@inject ICountryLookupViewModelService CountryLookupService
@{
    var settings = await Settings.GetSetting();

    var addMode = string.IsNullOrEmpty(Model.Country) && string.IsNullOrEmpty(Model.CaseType);

    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];

    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;
    bool isReadOnlyRemarks = !(fullModify || detailPagePermission.CanEditRemarksOnly);
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];
    var childViewModel = new CountryLawChildViewModel { Id=0, CanDeleteChild=Model.CanDeleteChild, Country=Model.Country, CaseType = Model.CaseType, Permission = detailPagePermission };

    var pageId = ViewData["PageId"];
    var saveAction = detailPagePermission.CanEditRemarksOnly ? "SaveRemarks" : fullModify ? "Save" : "";
}

<form cpi-detail-form action="@saveAction">
    <input type="hidden" asp-for="Country" />
    <input type="hidden" asp-for="CaseType" />
    <input type="hidden" name="CopyOptions" value="@(ViewBag.CopyOptions ?? "")" />
    <input type="hidden" name="OriginalSystems" value="@(addMode ? "__NEW__" : (string.IsNullOrEmpty(Model.Systems) ? "__EMPTY__" : Model.Systems))" />
    <vc:detail-page-nav-links page-permission="detailPagePermission" title="" add-mode="addMode"></vc:detail-page-nav-links>
    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label asp-for="Country"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="Country" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AuxiliaryWithLink(
                            name: "Country",
                            labels: new string[] { countryLabel, countryNameLabel },
                            columns: new string[] { "Country", "CountryName" },
                            onChange: "function(e) {pageHelper.onComboBoxChangeDisplayName(e,'CountryName');}",
                            defaultValue: Model.Country,
                            validationMessage: Localizer["Country field is required."]
                            ))
                        <span asp-validation-for="Country"></span>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label asp-for="CountryName"></label>
                    <input type="text" id="Country_@(pageId)_Name" class="form-control form-control-sm" readonly="readonly" asp-for="CountryName" />
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label asp-for="CaseType"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="CaseType" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AuxiliaryWithLink(
                            name: "CaseType",
                            labels: new string[] {Localizer["Case Type"], Localizer["Description"] },
                            columns: new string[] {"CaseType", "Description"},
                            onChange: "function(e) {pageHelper.onComboBoxChangeDisplayName(e,'Description');}",
                            defaultValue: Model.CaseType,
                            validationMessage: Localizer["Case Type field is required."]
                            ))
                        <span asp-validation-for="CaseType"></span>
                    }
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label asp-for="CaseTypeDescription"></label>
                    <input type="text" id="CaseType_@(pageId)_Name" class="form-control form-control-sm" readonly="readonly" asp-for="CaseTypeDescription" />
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label asp-for="Systems"></label>
                    <input type="hidden" name="Systems" id="SystemsHidden" value="@Model.Systems" />
                    <div class="border rounded p-2 position-relative" style="min-height: 60px; padding-top: 30px !important;">
                        @if (!isReadOnlyRemarks)
                        {
                            <div class="position-absolute" style="top: 4px; right: 8px;">
                                <label class="small mb-0" style="cursor:pointer;"><input type="checkbox" id="systemsToggleAll" class="mr-1"/>Select All</label>
                            </div>
                        }
                        <div id="systemsCheckboxes"></div>
                    </div>
                    <script>
                        $(document).ready(function() {
                            var disabled = @(isReadOnlyRemarks ? "true" : "false");
                            var selected = ($('#SystemsHidden').val() || '').split(',').filter(function(s) { return s.length > 0; });
                            $.getJSON('@Url.Action("GetSystemList", "CountryLaw")', function(data) {
                                var html = '';
                                $.each(data, function(i, name) {
                                    var checked = selected.indexOf(name) > -1 ? ' checked' : '';
                                    var dis = disabled ? ' disabled' : '';
                                    html += '<label class="mr-3" style="white-space:nowrap;"><input type="checkbox" class="systemChk mr-1" value="' + name + '"' + checked + dis + '/>' + name + '</label>';
                                });
                                $('#systemsCheckboxes').html(html);
                                // Sync toggle checkbox
                                var allCount = $('.systemChk').length;
                                var checkedCount = $('.systemChk:checked').length;
                                $('#systemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $(document).on('change', '.systemChk', function() {
                                var vals = [];
                                $('.systemChk:checked').each(function() { vals.push($(this).val()); });
                                $('#SystemsHidden').val(vals.join(','));
                                var allCount = $('.systemChk').length;
                                var checkedCount = $('.systemChk:checked').length;
                                $('#systemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $('#systemsToggleAll').click(function() {
                                var isChecked = $(this).prop('checked');
                                $('.systemChk').prop('checked', isChecked).first().trigger('change');
                            });
                        });
                    </script>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-check">
                    @if (isReadOnly)
                    {
                        <input type="checkbox" class="k-checkbox" asp-for="AutoGenDesCtry" disabled="disabled" />
                        <input type="hidden" asp-for="AutoGenDesCtry" />
                    }
                    else
                    {
                        <input type="checkbox" class="k-checkbox" asp-for="AutoGenDesCtry" />
                    }
                    <label class="k-checkbox-label" asp-for="AutoGenDesCtry"></label>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-check">
                    @if (isReadOnly)
                    {
                        <input type="checkbox" class="k-checkbox" asp-for="AutoUpdtDesPatRecs" disabled="disabled" />
                        <input type="hidden" asp-for="AutoUpdtDesPatRecs" />
                    }
                    else
                    {
                        <input type="checkbox" class="k-checkbox" asp-for="AutoUpdtDesPatRecs" />
                    }
                    <label class="k-checkbox-label" asp-for="AutoUpdtDesPatRecs"></label>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-check">
                    @if (isReadOnly)
                    {
                        <input type="checkbox" class="k-checkbox" asp-for="CalcExpirBeforeIssue" disabled="disabled" />
                        <input type="hidden" asp-for="CalcExpirBeforeIssue" />
                    }
                    else
                    {
                        <input type="checkbox" class="k-checkbox" asp-for="CalcExpirBeforeIssue" />
                    }
                    <label class="k-checkbox-label" asp-for="CalcExpirBeforeIssue"></label>
                </div>
            </div>
        </div>
    </div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="patCountryLaw-tab" role="tablist">
        @if (!addMode)
        {
            <li class="nav-item">
                <a class="nav-link active" id="countryLawDetailLawActionsTab" data-toggle="tab" role="tab" aria-controls="countryLawDetailLawActionsContent" aria-selected="true" href="#countryLawDetailLawActionsTabContent">@Localizer["Law Actions"] </a>
            </li>
        }
        @if (!addMode)
        {
            <li class="nav-item">
                <a class="nav-link" id="countryLawDetailExpirationTab" data-toggle="tab" role="tab" aria-controls="countryLawDetailExpirationTabContent" aria-selected="false" href="#countryLawDetailExpirationTabContent">@Localizer["Expiration Terms"]</a>
            </li>
        }
        @if (!addMode && Model.HasDesignatedCountries)
        {
            <li class="nav-item">
                <a class="nav-link" id="countryLawDetailDesigCountriesTab" data-toggle="tab" role="tab" aria-controls="countryLawDetailDesigCountriesTabContent" aria-selected="false" href="#countryLawDetailDesigCountriesTabContent">@Localizer["Designated Countries"]</a>
            </li>
        }
    </ul>
    <div class="tab-content">
        @if (!addMode)
        {
            <div class="tab-pane page-content show active" id="countryLawDetailLawActionsTabContent" role="tabpanel" aria-labelledby="countryLawDetailLawActions">
                @await Html.PartialAsync("_GridCountryDue", childViewModel)
            </div>
        }
        @if (!addMode)
        {
            <div class="tab-pane page-content" id="countryLawDetailExpirationTabContent" role="tabpanel" aria-labelledby="countryLawDetailExpirationTab">
                @await Html.PartialAsync("_GridCountryExp", childViewModel)
            </div>
        }
        @if (!addMode && Model.HasDesignatedCountries)
        {
            <div class="tab-pane page-content" id="countryLawDetailDesigCountriesTabContent" role="tabpanel" aria-labelledby="countryLawDetailDesigCountriesTab">
                @await Html.PartialAsync("_GridDesignatedCountry", childViewModel)
            </div>
        }
    </div>
    @if (!addMode)
    {
        <div class="content-stamp">
            <vc:record-stamps created-by="@Model.UserID" date-created="@Model.DateCreated" updated-by="@Model.UserID" last-update="@Model.LastUpdate" t-stamp="null"></vc:record-stamps>
        </div>
    }
</form>
<div class="cpiContainerPopup"></div>

<script>
    patCountryLawPage.afterInsert = function (result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    patCountryLawPage.editableGrids = [
        {
            name: 'patCountryDueGrid', isDirty: false, filter: patCountryLawPage.getKeyFields, afterSubmit: patCountryLawPage.updateRecordStamps
        },
        {
            name: 'patCountryExpGrid', isDirty: false, filter: patCountryLawPage.getKeyFields, afterSubmit: patCountryLawPage.updateRecordStamps
        },
        {
            name: 'patDesCaseTypeGrid', isDirty: false, filter: patCountryLawPage.getKeyFields, afterSubmit: patCountryLawPage.updateRecordStamps
        }
    ];
    patCountryLawPage.tabsLoaded = [];
    patCountryLawPage.tabChangeSetListener();

</script>
