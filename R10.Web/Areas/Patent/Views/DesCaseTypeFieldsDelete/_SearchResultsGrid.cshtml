@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using R10.Core.Entities.Patent

@(Html.Kendo().Grid<PatDesCaseTypeFieldsDelete>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.DesCaseType).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { desCaseType = "#: DesCaseType#", fromField = "#: FromField#", toField = "#: ToField#", desCaseTypeNew = "#: DesCaseTypeNew#", fromFieldNew = "#: FromFieldNew#", toFieldNew = "#: ToFieldNew#", systems = "#: Systems#", fromSearch = true }), "DesCaseType")).Width(150);
        columns.Bound(m => m.FromField).Width(200);
        columns.Bound(m => m.ToField).Width(200);
        columns.Bound(m => m.Systems).Width(200);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("DesCaseTypeFieldsDeleteList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DesCaseTypeFieldsDelete")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("patDesCaseTypeFieldsDeletePage.searchResultGridError"))
        .Events(events => events.RequestEnd("patDesCaseTypeFieldsDeletePage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "DesCaseTypeFieldsDelete").Data("patDesCaseTypeFieldsDeletePage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
