@model PatDesCaseTypeFieldsDelete
@using R10.Core.Entities.Patent
@inject IStringLocalizer<SharedResource> Localizer

<form cpi-detail-form action="Save">
    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="DesCaseType"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="DesCaseType" />
                    <span asp-validation-for="DesCaseType"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="FromField"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="FromField" />
                    <span asp-validation-for="FromField"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="ToField"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="ToField" />
                    <span asp-validation-for="ToField"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="DesCaseTypeNew"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="DesCaseTypeNew" />
                    <span asp-validation-for="DesCaseTypeNew"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="FromFieldNew"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="FromFieldNew" />
                    <span asp-validation-for="FromFieldNew"></span>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="ToFieldNew"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="ToFieldNew" />
                    <span asp-validation-for="ToFieldNew"></span>
                </div>
            </div>
        </div>
    </div>
    <div class="form-row mt-3">
        <div class="col">
            <button type="submit" class="btn btn-primary btn-sm"><i class="fal fa-save mr-1"></i>@Localizer["Save"]</button>
        </div>
    </div>
</form>
