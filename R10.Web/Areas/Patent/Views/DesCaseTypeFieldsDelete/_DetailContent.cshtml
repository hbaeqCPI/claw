@model PatDesCaseTypeFieldsDelete
@using R10.Core.Entities.Patent
@inject IStringLocalizer<SharedResource> Localizer
@{
    var addMode = Model.IsNewRecord;
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;
    bool keyFieldsReadOnly = isReadOnly || !addMode; // Key fields readonly on edit
}

<form cpi-detail-form action="Save">
    @if (addMode)
    {
        <input type="hidden" name="IsNewRecord" value="true" class="boolean" />
    }
    <input type="hidden" name="OriginalSystems" value="@(addMode ? "__NEW__" : (string.IsNullOrEmpty(Model.Systems) ? "__EMPTY__" : Model.Systems))" />
    <vc:detail-page-nav-links page-permission="detailPagePermission" title="" add-mode="addMode"></vc:detail-page-nav-links>

    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="DesCaseType"></label>
                    @if (keyFieldsReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="DesCaseType" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "DesCaseType", controller = "DesCaseType", area = "Patent", action = "GetPicklistData", textProperty = "DesCaseType", defaultValue = Model.DesCaseType })
                        <span asp-validation-for="DesCaseType"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="FromField"></label>
                    @if (keyFieldsReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="FromField" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "FromField", controller = "DesCaseTypeFields", area = "Patent", action = "GetPicklistData", textProperty = "FromField", defaultValue = Model.FromField })
                        <span asp-validation-for="FromField"></span>
                    }
                </div>
            </div>
            <div class="col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="ToField"></label>
                    @if (keyFieldsReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="ToField" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "ToField", controller = "DesCaseTypeFields", area = "Patent", action = "GetPicklistData", textProperty = "ToField", defaultValue = Model.ToField })
                        <span asp-validation-for="ToField"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="DesCaseTypeNew"></label>
                    <input type="hidden" name="DesCaseTypeNew" id="DesCaseTypeNew" value="@Model.DesCaseTypeNew" />
                    <input type="text" class="form-control form-control-sm" id="DesCaseTypeNewDisplay" value="@Model.DesCaseTypeNew" readonly />
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="FromFieldNew"></label>
                    <input type="hidden" name="FromFieldNew" id="FromFieldNew" value="@Model.FromFieldNew" />
                    <input type="text" class="form-control form-control-sm" id="FromFieldNewDisplay" value="@Model.FromFieldNew" readonly />
                </div>
            </div>
            <div class="col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="ToFieldNew"></label>
                    <input type="hidden" name="ToFieldNew" id="ToFieldNew" value="@Model.ToFieldNew" />
                    <input type="text" class="form-control form-control-sm" id="ToFieldNewDisplay" value="@Model.ToFieldNew" readonly />
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label asp-for="Systems"></label>
                    <input type="hidden" name="Systems" id="patDCTFDelSystemsHidden" value="@Model.Systems" />
                    <div class="border rounded p-2 position-relative" style="min-height: 60px; padding-top: 30px !important;">
                        @if (!isReadOnly)
                        {
                            <div class="position-absolute" style="top: 4px; right: 8px;">
                                <label class="small mb-0" style="cursor:pointer;"><input type="checkbox" id="patDCTFDelSystemsToggleAll" class="mr-1"/>Select All</label>
                            </div>
                        }
                        <div id="patDCTFDelSystemsCheckboxes"></div>
                    </div>
                    <script>
                        $(document).ready(function() {
                            var disabled = @(isReadOnly ? "true" : "false");
                            var selected = ($('#patDCTFDelSystemsHidden').val() || '').split(',').filter(function(s) { return s.length > 0; });
                            $.getJSON('@Url.Action("GetSystemList", "DesCaseTypeFieldsDelete")', function(data) {
                                var html = '';
                                $.each(data, function(i, name) {
                                    var checked = selected.indexOf(name) > -1 ? ' checked' : '';
                                    var dis = disabled ? ' disabled' : '';
                                    html += '<label class="mr-3" style="white-space:nowrap;"><input type="checkbox" class="patDCTFDelSystemChk mr-1" value="' + name + '"' + checked + dis + '/>' + name + '</label>';
                                });
                                $('#patDCTFDelSystemsCheckboxes').html(html);
                                var allCount = $('.patDCTFDelSystemChk').length;
                                var checkedCount = $('.patDCTFDelSystemChk:checked').length;
                                $('#patDCTFDelSystemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $(document).on('change', '.patDCTFDelSystemChk', function() {
                                var vals = [];
                                $('.patDCTFDelSystemChk:checked').each(function() { vals.push($(this).val()); });
                                $('#patDCTFDelSystemsHidden').val(vals.join(',')).trigger('change');
                                var allCount = $('.patDCTFDelSystemChk').length;
                                var checkedCount = $('.patDCTFDelSystemChk:checked').length;
                                $('#patDCTFDelSystemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $('#patDCTFDelSystemsToggleAll').click(function() {
                                var isChecked = $(this).prop('checked');
                                $('.patDCTFDelSystemChk').prop('checked', isChecked).first().trigger('change');
                            });
                        });
                    </script>
                </div>
            </div>
        </div>
    </div>

</form>

<script>
    $(document).ready(function() {
        function syncNewFields() {
            var desCaseType = $('[name=DesCaseType]').val() || $('input[name=DesCaseType]').val() || '';
            $('#DesCaseTypeNew').val(desCaseType);
            $('#DesCaseTypeNewDisplay').val(desCaseType);
            var fromField = $('[name=FromField]').val() || $('input[name=FromField]').val() || '';
            $('#FromFieldNew').val(fromField);
            $('#FromFieldNewDisplay').val(fromField);
            var toField = $('[name=ToField]').val() || $('input[name=ToField]').val() || '';
            $('#ToFieldNew').val(toField);
            $('#ToFieldNewDisplay').val(toField);
        }
        // Only sync on change, not on load (model values are already set)
        $(document).on('change', '[name=DesCaseType], [name=DesCaseType_input]', syncNewFields);
        $(document).on('change', '[name=FromField], [name=FromField_input]', syncNewFields);
        $(document).on('change', '[name=ToField], [name=ToField_input]', syncNewFields);
    });
    patDesCaseTypeFieldsDeletePage.afterInsert = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    patDesCaseTypeFieldsDeletePage.showDetails = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    $(document).ready(function() {
        $('.page-nav.add-record').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var url = $(this).data('url');
            if (url) pageHelper.openLink(url, true);
        });
        $('.copy-record').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var url = $(this).data('url');
            if (url) pageHelper.openLink(url, true);
        });
    });
</script>
