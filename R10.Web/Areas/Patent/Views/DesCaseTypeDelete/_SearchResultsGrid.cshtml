@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using R10.Core.Entities.Patent

@(Html.Kendo().Grid<PatDesCaseTypeDelete>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.IntlCode).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { intlCode = "#: IntlCode#", caseType = "#: CaseType#", desCountry = "#: DesCountry#", desCaseType = "#: DesCaseType#", intlCodeNew = "#: IntlCodeNew#", caseTypeNew = "#: CaseTypeNew#", desCountryNew = "#: DesCountryNew#", desCaseTypeNew = "#: DesCaseTypeNew#", systems = "#: Systems#", fromSearch = true }), "IntlCode")).Width(120);
        columns.Bound(m => m.CaseType).Width(100);
        columns.Bound(m => m.DesCountry).Width(120);
        columns.Bound(m => m.DesCaseType).Width(120);
        columns.Bound(m => m.Default).ClientTemplate("#: Default ? '\\u2713' : '' #").Width(80);
        columns.Bound(m => m.IntlCodeNew).Width(120);
        columns.Bound(m => m.CaseTypeNew).Width(120);
        columns.Bound(m => m.DesCountryNew).Width(120);
        columns.Bound(m => m.DesCaseTypeNew).Width(120);
        columns.Bound(m => m.Systems).Width(200);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("DesCaseTypeDeleteList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DesCaseTypeDelete")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("patDesCaseTypeDeletePage.searchResultGridError"))
        .Events(events => events.RequestEnd("patDesCaseTypeDeletePage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "DesCaseTypeDelete").Data("patDesCaseTypeDeletePage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
