@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<PatSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<PatCountryDue>()
                .Name($"{Model.PageId}-Grid")
                .Columns(columns =>
                {
                    columns.Bound(m => m.Country).Width(100);
                    columns.Bound(m => m.CaseType).Width(100);
                    columns.Bound(m => m.ActionType).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: CDueId#", fromSearch = true }), "ActionType"));
                    columns.Bound(m => m.ActionDue);
                    columns.Bound(m => m.BasedOn).Width(150);
                    columns.Bound(m => m.Yr).Width(80);
                    columns.Bound(m => m.Mo).Width(80);
                    columns.Bound(m => m.Dy).Width(80);
                    columns.Bound(m => m.Indicator).Width(150);
                })
                .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                .AutoBind(false)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                .Excel(excel => excel.FileName("CountryDueList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "CountryDue")))
                .DataSource(dataSource => dataSource
                .Ajax().Events(events => events.Error("patCountryDuePage.searchResultGridError"))
                .Events(events => events.RequestEnd("patCountryDuePage.searchResultGridRequestEnd"))
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                .Read(read => read.Action("PageRead", "CountryDue")
                .Data("patCountryDuePage.gridMainSearchFilters")
                )
                .Sort(sort => sort.Add(m => m.ActionType))
                )
                .HtmlAttributes(new { @class = "kendo-Grid" })
)