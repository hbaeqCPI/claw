@model PatDesCaseTypeFields
@using R10.Core.Entities.Patent
@inject IStringLocalizer<SharedResource> Localizer
@{
    var addMode = Model.IsNewRecord;
    var isCopyGroup = !string.IsNullOrEmpty(Model.CopyFromSystems);
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;
}

@if (addMode)
{
    <form cpi-detail-form action="Save">
        <input type="hidden" name="IsNewRecord" value="true" class="boolean" />
        <input type="hidden" name="OriginalSystems" value="__NEW__" />
        <input type="hidden" name="CopyFromSystems" value="@(Model.CopyFromSystems ?? "")" />
        <input type="hidden" name="CopyFromDesCaseType" value="@(Model.CopyFromDesCaseType ?? "")" />
        @await Component.InvokeAsync("DetailPageNavLinks", new { pagePermission = detailPagePermission, title = "", addMode = true })

        <div class="page-content detail cpiMainEntry">
            <div class="form-row">
                <div class="col col-sm-5 col-md-4 col-lg-3 col-xl-2">
                    <div class="form-group float-label">
                        <label asp-for="DesCaseType"></label>
                        @await Component.InvokeAsync("ComboBox", new { name = "DesCaseType", controller = "DesCaseType", area = "Patent", action = "GetPicklistData", textProperty = "DesCaseType", defaultValue = Model.DesCaseType })
                        <span asp-validation-for="DesCaseType"></span>
                    </div>
                </div>
            </div>
            @if (!isCopyGroup)
            {
                <div class="form-row">
                    <div class="col col-sm-8 col-md-7 col-lg-6 col-xl-5">
                        <div class="form-group float-label">
                            <label asp-for="FromField"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="FromField" />
                            <span asp-validation-for="FromField"></span>
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col col-sm-8 col-md-7 col-lg-6 col-xl-5">
                        <div class="form-group float-label">
                            <label asp-for="ToField"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="ToField" />
                            <span asp-validation-for="ToField"></span>
                        </div>
                    </div>
                </div>
            }
            <div class="form-row">
                <div class="col-md-6">
                    <div class="form-group float-label">
                        <label asp-for="Systems"></label>
                        @await Html.PartialAsync("~/Views/Shared/_SystemsDropdown.cshtml", null, new ViewDataDictionary(ViewData) {
                            { "SystemsValue", Model.Systems },
                            { "SystemsPrefix", "patDCTF" },
                            { "SystemsAction", Url.Action("GetSystemList") },
                            { "SystemsReadOnly", false }
                        })
                    </div>
                </div>
            </div>
        </div>
    </form>
}
else
{
    <form cpi-detail-form action="Save" data-save-message="@Localizer["Record has been saved successfully."]">
        <input type="hidden" name="OriginalSystems" value="@(string.IsNullOrEmpty(Model.Systems) ? "__EMPTY__" : Model.Systems)" />
        <input type="hidden" name="FromField" value="" />
        <input type="hidden" name="ToField" value="" />
        @await Component.InvokeAsync("DetailPageNavLinks", new { pagePermission = detailPagePermission, title = "", addMode = false })

        <div class="page-content detail cpiMainEntry">
            <div class="form-row align-items-end">
                <div class="col col-sm-5 col-md-4 col-lg-3 col-xl-2">
                    <div class="form-group float-label">
                        <label asp-for="DesCaseType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="DesCaseType" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group float-label">
                        <label asp-for="Systems"></label>
                        @await Html.PartialAsync("~/Views/Shared/_SystemsDropdown.cshtml", null, new ViewDataDictionary(ViewData) {
                            { "SystemsValue", Model.Systems },
                            { "SystemsPrefix", "patDCTF_detail" },
                            { "SystemsAction", Url.Action("GetSystemList") },
                            { "SystemsReadOnly", false }
                        })
                    </div>
                </div>
                <div class="col-auto mb-3">
                    <button type="button" class="btn btn-warning btn-sm" id="btnMoveToDelete"
                            data-url="@Url.Action("MoveToDelete", new { desCaseType = Model.DesCaseType, systems = Model.Systems })">
                        <i class="fal fa-exchange-alt pr-1"></i> Move to Delete
                    </button>
                </div>
            </div>
        </div>
        <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" role="tablist">
            <li class="nav-item">
                <a id="patDCTFieldsTab" href="#patDCTFieldsTabContent" class="nav-link active" data-toggle="tab" role="tab" aria-controls="patDCTFieldsTabContent" title="@Localizer["Fields"]">@Localizer["Fields"]</a>
            </li>
        </ul>
        <div class="tab-content detail">
            <div class="tab-pane active show" id="patDCTFieldsTabContent" role="tabpanel" aria-labelledby="patDCTFieldsTab">
                @await Html.PartialAsync("_GridDesCaseTypeFields", new R10.Web.Areas.Shared.ViewModels.ChildViewModel { Code = Model.DesCaseType, Permission = detailPagePermission }, new ViewDataDictionary(ViewData) { { "Systems", Model.Systems } })
            </div>
        </div>
    </form>
}

<script>
    patDesCaseTypeFieldsPage.afterInsert = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    patDesCaseTypeFieldsPage.showDetails = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    patDesCaseTypeFieldsPage.editableGrids = [
        {
            name: 'desCaseTypeFieldsGrid', isDirty: false,
            filter: { desCaseType: '@Model.DesCaseType', systems: '@Model.Systems' },
            afterSubmit: patDesCaseTypeFieldsPage.updateRecordStamps,
            beforeSubmit: function() {
                var defer = $.Deferred();
                var grid = $("#desCaseTypeFieldsGrid").data("kendoGrid");
                var allData = [];
                var data = grid.dataSource.data();
                for (var i = 0; i < data.length; i++) {
                    allData.push({ FromField: data[i].FromField, ToField: data[i].ToField });
                }
                var postData = {
                    desCaseType: '@Model.DesCaseType',
                    systems: '@Model.Systems',
                    allRows: allData
                };
                $.ajax({
                    url: '@Url.Action("FieldsReplaceAll", "DesCaseTypeFields")',
                    data: JSON.stringify(postData),
                    contentType: 'application/json',
                    type: 'POST',
                    success: function() {
                        grid.dataSource.read();
                        defer.resolve();
                        setTimeout(function() { pageHelper.showSuccess('Record has been saved successfully.'); }, 500);
                    },
                    error: function(e) {
                        pageHelper.showErrors(e);
                        defer.reject();
                    }
                });
                return defer.promise();
            }
        }
    ];
    function moveRowToDelete(e) {
        e.preventDefault();
        var grid = $("#desCaseTypeFieldsGrid").data("kendoGrid");
        var dataItem = grid.dataItem($(e.currentTarget).closest("tr"));
        cpiConfirm.confirm('Move to Delete', 'Move this field to the delete table?', function() {
            cpiLoadingSpinner.show();
            $.post('@Url.Action("MoveRowToDelete", "DesCaseTypeFields")', {
                desCaseType: dataItem.DesCaseType,
                fromField: dataItem.FromField,
                toField: dataItem.ToField,
                systems: dataItem.Systems
            }).done(function(result) {
                cpiLoadingSpinner.hide();
                pageHelper.showSuccess(result.success || 'Field moved to delete table.');
                grid.dataSource.read();
            }).fail(function(err) {
                cpiLoadingSpinner.hide();
                pageHelper.showErrors(err);
            });
        });
    }
    $(document).ready(function() {
        $('#btnMoveToDelete').on('click', function() {
            var btn = $(this);
            var url = btn.data('url');
            cpiConfirm.confirm('Move to Delete', 'Are you sure you want to move this record to the delete table?', function() {
                cpiLoadingSpinner.show();
                $.post(url).done(function(result) {
                    cpiLoadingSpinner.hide();
                    pageHelper.showSuccess(result.success || 'Records moved to delete table successfully.');
                    pageHelper.showSearchScreen('@Url.Action("Index")');
                }).fail(function(e) {
                    cpiLoadingSpinner.hide();
                    pageHelper.showErrors(e);
                });
            });
        });
        $('.page-nav.add-record').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var url = $(this).data('url');
            if (url) pageHelper.openLink(url, true);
        });
        $('.copy-record').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var url = $(this).data('url');
            if (url) pageHelper.openLink(url, true);
        });
    });
</script>
