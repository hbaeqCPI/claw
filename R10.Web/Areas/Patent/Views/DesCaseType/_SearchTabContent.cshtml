@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="desCaseTypeSearchMainTabContent" aria-labelledby="desCaseTypeSearchMainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="IntlCode">@Localizer["Intl Code"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "IntlCode" })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="CaseType">@Localizer["Case Type"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CaseType" })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DesCountry">@Localizer["Country"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "DesCountry" })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DesCaseType">@Localizer["Des. Case Type"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "DesCaseType" })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="SystemName">@Localizer["Systems"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "SystemName", controller = "System", area = "Shared", action = "GetPicklistData" })
                </div>
            </div>
        </div>
    </div>
</div>