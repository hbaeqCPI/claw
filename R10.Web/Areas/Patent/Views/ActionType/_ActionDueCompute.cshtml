@model R10.Core.ActionDueRetroParam
@inject IStringLocalizer<SharedResource> Localizer
@{
    var isGenActionDue = Model.ActParamId > 0;
    var hasCountryFilter = !string.IsNullOrEmpty(Model.Country);
}

<div class="modal fade" id="patActionDueComputeDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form method="post" asp-action="GenerateActionDues"
                data-save-message="@Localizer["Process completed successfully."]">
                <div class="modal-header py-1">
                    <h4 class="modal-title">@Localizer["Retroactive Action Generation"]</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-1">
                    <div class="container-fluid">                        
                        <input type="hidden" asp-for="ActionTypeID" />
                        <input type="hidden" asp-for="ActParamId" />

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="Country"></label>
                                    <input type="text" class="form-control form-control-sm" asp-for="Country" readonly="readonly" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label>@Localizer["Case Types"]</label>
                                    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
                                    {
                                        Name = "CaseTypes",
                                        DataTextProperty = "CaseType",
                                        DataValueProperty = "CaseType",
                                        Controller = "CaseType",
                                        Action = hasCountryFilter ? "GetCaseTypeByCountry" : "GetCaseTypeList",
                                        Data = hasCountryFilter ? $"{{country: '{Model.Country}'}}" : "",
                                        Area = "Patent",
                                        HeaderTemplate = ComboBoxHelper.GetHeaderTemplate(Localizer["Case Type"], Localizer["Description"]),
                                        ItemTemplate = ComboBoxHelper.GetItemTemplate("CaseType", "Description")
                                    })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="ActionType"></label>
                                    <input type="text" class="form-control form-control-sm" asp-for="ActionType" readonly="readonly" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="ActionDue"></label>
                                    <input type="text" class="form-control form-control-sm" asp-for="ActionDue" readonly="readonly" />
                                </div>
                            </div>

                        </div>
                        <div class="row @(isGenActionDue ? "d-none" : "")">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="BaseDate"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("BaseDate") {Value=DateTime.Now.Date })
                                </div>
                            </div>
                        </div>
                        <div class="row @(isGenActionDue ? "d-none" : "")">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="FilDateFrom"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("FilDateFrom") { })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="FilDateTo"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("FilDateTo") { })
                                </div>
                            </div>
                        </div>
                        <div class="row @(isGenActionDue ? "d-none" : "")">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="PubDateFrom"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("PubDateFrom") { })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="PubDateTo"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("PubDateTo") { })
                                </div>
                            </div>
                        </div>
                        <div class="row @(isGenActionDue ? "d-none" : "")">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="IssDateFrom"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("IssDateFrom") { })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="IssDateTo"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("IssDateTo") { })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="DueDateCutOff"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DueDateCutOff") { })
                                </div>
                            </div>
                            <div class="col-md-6">
                                @(Html.Kendo().CheckBoxFor(m => m.ActiveOnly).Label(Localizer["Active applications only?"]))
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="d-none modal-footer-status"><span class="font-weight-bold pr-2">@Localizer["Processing..."]</span><i class="far fa-spinner fa-spin fa-2x"></i></div>
                    <div class="modal-footer-buttons">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                        <button type="submit" class="btn btn-primary"><i class="fa fa-check pr-2"></i>@Localizer["Generate"]</button>
                    </div>
                  
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        const popupContainer = $(".site-content .popup").last();
        const dialogContainer = popupContainer.find(".modal");
        let entryForm = dialogContainer.find("form")[0];
        dialogContainer.modal("show");

        entryForm = $(entryForm);        
        entryForm.cpiPopupEntryForm(
            { 
                dialogContainer: dialogContainer, 
                closeOnSubmit: true,
                beforeSubmit: function() {
                    $(".modal-footer-buttons").hide();
                    $(".modal-footer-status").removeClass("d-none");
                },
                afterSubmit: function () {                    
                    dialogContainer.modal("hide");                       
                }
            }
        );
        entryForm.floatLabels();
    });
</script>





