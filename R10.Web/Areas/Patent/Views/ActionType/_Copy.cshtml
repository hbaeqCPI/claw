@model ActionTypeCopyViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="modal fade" id="patActionTypeCopyDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" asp-action="EditCopied">
                <div class="modal-header py-1">
                    <h4 class="modal-title">@Localizer["Copy Action Type"]</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pt-0">
                    <div class="container-fluid">

                        <input type="hidden" asp-for="ActionTypeId" />
                        <div class="row">
                            <div class="col-md-12 px-0">
                                <div class="form-group float-label">
                                    <label asp-for="ActionType" class="required"></label>
                                    <input asp-for="ActionType" class="form-control form-control-sm" />
                                    <span asp-validation-for="ActionType"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <h5>@Localizer["Data to Copy:"]</h5>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input type="checkbox" class="k-checkbox" asp-for="CopyParameters">
                                    <label class="k-checkbox-label" asp-for="CopyParameters"></label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check">
                                    <input type="checkbox" class="k-checkbox" asp-for="CopyRemarks">
                                    <label class="k-checkbox-label" asp-for="CopyRemarks"></label>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                    <button type="submit" class="btn btn-primary"><i class="fa fa-check pr-2"></i>@Localizer["Copy"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        patActionTypePage.showCopyScreen();
    });
</script>








