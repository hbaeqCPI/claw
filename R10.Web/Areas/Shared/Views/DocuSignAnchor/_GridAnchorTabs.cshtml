@model int
@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var isCPIAnchor = (bool)ViewData["IsCPIAnchor"];
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && !isCPIAnchor;

}

@(Html.Kendo().Grid<DocuSignAnchorTab>()
    .Name("docuSignAnchorTabsGrid")
        .Columns(columns =>
        {
            columns.Bound(r => r.AnchorType).EditorTemplateName("DropdownList")
       .EditorViewData(new
       {
           data = new string[] { "Sign", "Initial", "DateSigned" }
       }).Editable("eSignatureTabPage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);

            @*columns.Bound(p => p.AnchorType)
                                    .Editable("eSignatureTabPage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);*@
            columns.Bound(p => p.Anchor)
                                                .Editable("eSignatureTabPage.isGridColumnEditable")
                                                .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);

            columns.Bound(p => p.AnchorYOffSet).Width(100)
                                    .Editable("eSignatureTabPage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
            columns.Bound(p => p.AnchorXOffSet).Width(100)
                                    .Editable("eSignatureTabPage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);

            columns.Command(command =>
            {
                if (detailPagePermission.CanDeleteRecord && !isCPIAnchor)
                    command.Custom("Delete")
                            .Click("function(e) {eSignatureTabPage.deleteGridRow(e,this)}")
                            .IconClass("k-icon fal fa-trash-alt")
                            .Text($"<span class='grid-action-label'>{SharedLocalizer["Delete"]}</span>")
                            .HtmlAttributes(new { @class = "grid-action" });
            }).Width(10);
        })
        .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
        .ToolBar(toolbar =>
        {
            if (detailPagePermission.CanAddRecord && !isCPIAnchor)
            {
                toolbar.Create().IconClass("k-icon fal fa-plus").Text(SharedLocalizer["Add"])
                                .HtmlAttributes(new { @class = "grid-action" });
            }
            if (detailPagePermission.CanEditRecord &&  !isCPIAnchor)
            {
                toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(SharedLocalizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(SharedLocalizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
            }

        })
        .Editable(editable => editable.Enabled(detailPagePermission.CanEditRecord && !isCPIAnchor)
                    .Mode(GridEditMode.InCell).
                    ConfirmDelete(@SharedLocalizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
        .Sortable(sort => sort.AllowUnsort(false))
        .Pageable()
        .DataSource(dataSource => dataSource
        .Ajax()
        .Batch(true)
        //.Batch(detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
        .PageSize(settings.SubFormPageSize)
        .ServerOperation(false)
        .Model(model =>
        {
            model.Id(p => p.DocuSignTabId);
        })
.Read(create => create.Action("DocuSignAnchorTabsRead", "DocuSignAnchor", new { anchorCodeId = Model }))
.Update(create => create.Action("DocuSignAnchorTabsUpdate", "DocuSignAnchor"))
.Destroy(create => create.Action("DocuSignAnchorTabsDelete", "DocuSignAnchor"))
        .Events(events =>
        {
            events.Error("pageHelper.onGridError");
        })
        )
        .HtmlAttributes(new { @class = "kendo-Grid" })
    )

