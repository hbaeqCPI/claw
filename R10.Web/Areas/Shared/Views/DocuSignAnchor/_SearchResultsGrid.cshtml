@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<DocuSignAnchor>()
                .Name($"{Model.PageId}-Grid")
                .Columns(columns =>
                {
                    columns.Bound(m => m.AnchorCode).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: DocuSignAnchorId#", fromSearch = true }), "AnchorCode"));
                    columns.Bound(m => m.Description);
                })
                .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                .AutoBind(false)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                //.ColumnMenu()
                .Excel(excel => excel.FileName("DocuSignAnchorList.xlsx").AllPages(true))
                .DataSource(dataSource => dataSource
                .Ajax().Events(events => events.Error("eSignatureTabPage.searchResultGridError"))
                .Events(events => events.RequestEnd("eSignatureTabPage.searchResultGridRequestEnd"))
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                .Read(read => read.Action("PageRead", "DocuSignAnchor")
                .Data("eSignatureTabPage.gridMainSearchFilters")
                )
                .Sort(sort => sort.Add(m => m.AnchorCode))
                )
                .HtmlAttributes(new { @class = "kendo-Grid" })
)
