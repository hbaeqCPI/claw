@model DataQueryPageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    var pageId = Model.PageId;
}

<ul class="nav nav-tabs refine-search nav-tabs-vertical" role="tablist">
    <li class="nav-item">
        <a id="@(pageId)MainTab" href="#@(pageId)MainTabContent" class="nav-link active" data-toggle="tab" role="tab"
           aria-controls="@(pageId)MainTabContent" title="@Localizer["Main"]">@Localizer["Main"]</a>
    </li>
</ul>

<div class="accordion-content show">
    <div class="tab-pane show form-sidebar active" id="@(pageId)MainTabContent" aria-labelledby="@(pageId)MainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="QueryName">@Localizer["Query Name"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "QueryName", action = "GetPicklistData", controller = "DataQuery", area = "Shared", screen = pageId })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DQCatId">@Localizer["Category"]</label>
                    @await Component.InvokeAsync("ComboBox", new
                        {
                            name = "DQCatId_Search",
                            textProperty = "DQCat",
                            valueProperty = "DQCatId",
                            controller = "DataQueryCategory",
                            area = "Shared",
                            action = "GetDataQueryCategoryList",
                        })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="QueryOwner">@Localizer["Owner"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "OwnedBy", action = "GetPicklistData", controller = "DataQuery", area = "Shared", screen = pageId })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Tags">@Localizer["Tags"]</label>
                    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
               {
                   Controller = "DataQuery",
                   Area = "Shared",
                   Action = "GetTagPickListData",
                   Name = "Tag",
                   DataTextProperty = "Tag",
                   DataValueProperty = "Tag",
               })
                </div>
            </div>
        </div>
       
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group">
                    <label class="label" for="ShowOnlyMyQueries">@Localizer["Show Only My Queries"]</label>
                    <label class="toggle-switch">
                        <input id=" ShowOnlyMyQueries" name="ShowOnlyMyQueries" type="checkbox" class="toggle-option">
                        <span class="slider round"></span>
                    </label>
                </div>
            </div>
        </div>
    </div>
</div>



