@model ContactPersonViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ICountryLookupViewModelService CountryLookupService
@inject IAuthorizationService AuthorizationService
@{
    var id = Model.ContactID;
    var addMode = id == 0;

    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;
    bool isReadOnlyRemarks = !(fullModify || detailPagePermission.CanEditRemarksOnly);

    var countryLabel = SharedLocalizer["Country"];
    var countryNameLabel = SharedLocalizer["Country Name"];
        
    var showReviewerCheckBox = false;
    var pageId = ViewData["PageId"];
    var isShowCustomFieldOn = false;
}
<form cpi-detail-form action="@(detailPagePermission.CanEditRemarksOnly ? "SaveRemarks" :"Save")">
    <input type="hidden" asp-for="ContactID" />
    <vc:detail-page-nav-links page-permission="detailPagePermission" title="" add-mode="addMode"></vc:detail-page-nav-links>

    <div class="page-content  detail cpiMainEntry">
        <div class="form-row">
            @if (User.IsAdmin())
            {
            <div class="order-md-last order-md-3 col-md-4 text-right">
                @if (Model.IsDMSReviewer) 
                {
                    <span class="badge badge-info badge-dm-dms badge-pill ml-1" title="@SharedLocalizer["Invention Disclosure Reviewer"]">DMS</span>
                }
                @if (Model.IsAMSDecisionMaker) 
                {
                    <span class="badge badge-info badge-dm-ams badge-pill ml-1" title="@SharedLocalizer["Annuity Management Decision Make"]">AMS</span>
                }
                @if (Model.IsTmkSearchReviewer) 
                {
                    <span class="badge badge-info badge-dm-tr badge-pill ml-1" title="@SharedLocalizer["Trademark Request Reviewer"]">TR</span>
                }
                @if (Model.IsPatClearanceReviewer) 
                {
                    <span class="badge badge-info badge-dm-pc badge-pill ml-1" title="@SharedLocalizer["Patent Clearance Reviewer"]">PC</span>
                }
                @if (Model.IsRMSDecisionMaker) 
                {
                    <span class="badge badge-info badge-dm-rms badge-pill ml-1" title="@SharedLocalizer["Renewal Management Decision Maker"]">RMS</span>
                }
                @if (Model.IsFFDecisionMaker) 
                {
                    <span class="badge badge-info badge-dm-ff badge-pill ml-1" title="@SharedLocalizer["Foreign Filing Decision Maker"]">FF</span>
                }
            </div>
            }
            <div class="col-sm-6 col-md-4">
                <div class="form-group float-label">
                    <label asp-for="Contact"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="Contact" asp-is-readonly="@isReadOnly" asp-is-autofocus="@addMode" />
                    <span asp-validation-for="Contact"></span>
                </div>
            </div>
            <div class="col-sm-6 col-md-4 pt-3 pt-sm-4 pl-md-2">
            @if (showReviewerCheckBox)
            {
                    <div class="form-group float-label">
                        <div class=" custom-control custom-checkbox">
                            <input asp-for="IsReviewer" class="custom-control-input" asp-is-readonly="@isReadOnly" />
                            <label asp-for="IsReviewer" class="custom-control-label">
                            </label>
                        </div>
                        <span asp-validation-for="IsReviewer"></span>
                    </div>
            }
                </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label asp-for="FirstName"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="FirstName" asp-is-readonly="@isReadOnly" />
                    <span asp-validation-for="FirstName"></span>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label asp-for="LastName"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="LastName" asp-is-readonly="@isReadOnly" />
                    <span asp-validation-for="LastName"></span>
                </div>
            </div>
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label asp-for="MiddleInitial"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="MiddleInitial" asp-is-readonly="@isReadOnly" />
                    <span asp-validation-for="MiddleInitial"></span>
                </div>
            </div>
             <div class="col-md-2 pt-3">
                    @if (isReadOnly)
                    {
                    @(Html.Kendo().CheckBoxFor(m => m.IsActive).HtmlAttributes(new { id = "Contact_IsActive", disabled = "true" }))
                    }
                    else
                    {
                    @(Html.Kendo().CheckBoxFor(m => m.IsActive).HtmlAttributes(new { id = "Contact_IsActive" }))
                    }
            </div>
        </div>
    </div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" role="tablist">
        <li class="nav-item">
            <a id="contactPersonDetailContactInfoTab" href="#contactPersonDetailContactInfoTabContent" class="nav-link active" data-toggle="tab" role="tab" aria-controls="contactPersonDetailContactInfoTabContent" title="@SharedLocalizer["Contact Info"]">@SharedLocalizer["Contact Info"]</a>
        </li>
        <li class="nav-item">
            <a id="contactPersonDetailAddressTab" href="#contactPersonDetailAddressTabContent" class="nav-link" data-toggle="tab" role="tab" aria-controls="contactPersonDetailAddressTabContent" title="@SharedLocalizer["Address"]">@SharedLocalizer["Address"]</a>
        </li>
        @if (!detailPagePermission.HasLimitedRead)
        {
            <li class="nav-item">
                <a id="contactPersonDetailRemarksTab" href="#contactPersonDetailRemarksTabContent" class="nav-link @(string.IsNullOrEmpty(Model.Remarks) ? null : "has-remarks")" data-toggle="tab" role="tab" aria-controls="contactPersonDetailRemarksTabContent" title="@SharedLocalizer["Remarks"]">@SharedLocalizer["Remarks"]</a>
            </li>
        }
        @if (isShowCustomFieldOn && Model.SysCustomFieldSettings != null && Model.SysCustomFieldSettings.Any())
        {
            <li class="nav-item">
                <a class="nav-link" id="contactPersonCustomFieldTab" data-toggle="tab" role="tab" aria-controls="contactPersonCustomFieldTabContent" aria-selected="false" href="#contactPersonCustomFieldTabContent">@SharedLocalizer[""]</a>
            </li>
        }
    </ul>
        <div class="tab-content page-content detail cpiMainEntry">
            <div class="tab-pane active show" id="contactPersonDetailContactInfoTabContent" role="tabpanel" aria-labelledby="contactPersonDetailContactInfoTab">
                <div class="form-row">
                    <div class="col-sm-6 col-md-6 col-lg-3 col-xl-2">
                        <div class="form-group float-label">
                            <label asp-for="Language"></label>
                            @if (isReadOnly)
                            {
                                <input type="text" class="form-control form-control-sm" asp-for="Language" readonly />
                            }
                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.LanguageWithLink("Language", Model.Language))
                            }
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-sm-6 col-md-6 col-lg-3 col-xl-2">
                        <div class="form-group float-label">
                            <label asp-for="ContactTitle"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="ContactTitle" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="ContactTitle"></span>
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-3 col-xl-2">
                        <div class="form-group float-label">
                            <label asp-for="Greeting"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="Greeting" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="Greeting"></span>
                        </div>
                    </div>
                </div>
                @*<div class="form-row">
                <div class="col-sm-6 col-md-6 col-lg-3 col-xl-2">
                    <div class="form-group float-label">
                        <label asp-for="Language"></label>
                        @if (isReadOnly)
                        {
                            <input type="text" class="form-control form-control-sm" asp-for="Language" readonly />
                        }
                        else
                        {
                            @await Component.InvokeAsync("ComboBox", ComboBoxHelper.LanguageWithLink("Language", Model.Language))
                        }
                    </div>
                </div>
            </div>*@
                <div class="form-row">
                    <div class="col-md-6 col-lg-6 col-xl-4">
                        <div class="form-group float-label">
                            <label asp-for="PhoneNumber"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="PhoneNumber" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="PhoneNumber"></span>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-6 col-xl-4">
                        <div class="form-group float-label">
                            <label asp-for="FaxNumber"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="FaxNumber" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="FaxNumber"></span>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-6 col-xl-4">
                        <div class="form-group float-label">
                            <label asp-for="MobileNumber"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="MobileNumber" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="MobileNumber"></span>
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-md-6 col-lg-6 col-xl-4">
                        <div class="form-group float-label">
                            <label asp-for="EMail"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="EMail" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="EMail"></span>
                        </div>
                    </div>
                    @*<div class="col-md-6 col-lg-6 col-xl-4">
                    <div class="form-group float-label">
                        <label asp-for="WebSite"></label>
                        <div class="input-group">
                            <input type="text" class="form-control form-control-sm" asp-for="WebSite" asp-is-readonly="@isReadOnly" />
                            @if (!string.IsNullOrEmpty(Model.WebSite))
                            {
                                <div class="input-group-append">
                                    <button class="btn btn-outline-secondary p-0 pl-2 pr-2" type="button" onClick="window.open('@Model.WebSite')" title="@SharedLocalizer["Open website in new window."]"><i class="fal fa-external-link"></i></button>
                                </div>
                            }
                        </div>
                        <span asp-validation-for="WebSite"></span>
                    </div>
                </div>*@
                </div>
            </div>
            <div class="tab-pane" id="contactPersonDetailAddressTabContent" role="tabpanel" aria-labelledby="contactPersonDetailAddressTab">
                <div class="form-row">
                    <div class="col-md-7 col-lg-6 col-xl-4">
                        <div class="form-group float-label">
                            <label asp-for="Address1"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="Address1" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="Address1"></span>
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-md-7 col-lg-6 col-xl-4">
                        <input type="text" class="form-control form-control-sm" asp-for="Address2" asp-is-readonly="@isReadOnly" />
                        <span asp-validation-for="Address2"></span>
                    </div>
                </div>
                <div class="form-row pt-1">
                    <div class="col-md-7 col-lg-6 col-xl-4">
                        <input type="text" class="form-control form-control-sm" asp-for="Address3" asp-is-readonly="@isReadOnly" />
                        <span asp-validation-for="Address3"></span>
                    </div>
                </div>
                <div class="form-row pt-1 pb-1">
                    <div class="col-md-7 col-lg-6 col-xl-4">
                        <input type="text" class="form-control form-control-sm" asp-for="Address4" asp-is-readonly="@isReadOnly" />
                        <span asp-validation-for="Address4"></span>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-md-7 col-lg-6 col-xl-4">
                        <div class="form-group float-label">
                            <label asp-for="City"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="City" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="City"></span>
                        </div>
                    </div>
                    <div class="col-md-5 col-lg-4 col-xl-3">
                        <div class="form-group float-label">
                            <label asp-for="State"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="State" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="State"></span>
                        </div>
                    </div>
                    <div class="col-md-4 col-lg-2 col-xl-2">
                        <div class="form-group float-label">
                            <label asp-for="ZipCode"></label>
                            <input type="text" class="form-control form-control-sm" asp-for="ZipCode" asp-is-readonly="@isReadOnly" />
                            <span asp-validation-for="ZipCode"></span>
                        </div>
                    </div>
                </div>
                <div class="form-row">
                    <div class="col-md-4 col-lg-3 col-xl-2">
                        <div class="form-group float-label">
                            <label asp-for="Country"></label>
                            @if (isReadOnly)
                            {
                                <input type="text" class="form-control form-control-sm" asp-for="Country" disabled />
                            }
                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.CountryWithLink("Country", countryLabel, countryNameLabel, Model.Country, showLinkButton: User.IsInSystem(CountryLookupService.CountrySource)))
                                <span asp-validation-for="Country"></span>
                            }
                        </div>
                    </div>
                    <div class="col-md-8 col-lg-9 col-xl-7">
                        <div class="form-group float-label">
                            <label for="Country_@(ViewData["PageId"])_Name">@SharedLocalizer["Country Name"]</label>
                            <input type="text" class="form-control form-control-sm" id="Country_@(ViewData["PageId"])_Name" readonly="readonly" asp-for="CountryName" />
                        </div>
                    </div>
                </div>
            </div>
            @if (!detailPagePermission.HasLimitedRead)
            {
                <div class="tab-pane" id="contactPersonDetailRemarksTabContent" role="tabpanel" aria-labelledby="contactPersonDetailRemarksTab">
                    <div class="form-row">
                        <div class="col">
                            <textarea rows="12" class="form-control form-control-sm" asp-for="Remarks" asp-is-readonly="@isReadOnlyRemarks"></textarea>
                            <span asp-validation-for="Remarks"></span>
                        </div>
                    </div>
                </div>
            }
        @if (isShowCustomFieldOn && Model.SysCustomFieldSettings != null && Model.SysCustomFieldSettings.Any())
        {
            <div class="tab-pane" id="contactPersonCustomFieldTabContent" role="tabpanel" aria-labelledby="contactPersonCustomFieldTab">
                @* <div class="page-content cpiMainEntry"> *@
                    <div class="form-row">
                        @foreach (var item in Model.SysCustomFieldSettings)
                        {
                            var customFieldValue = Model.GetType().GetProperty(item.ColumnName).GetValue(Model, null);

                            object htmlAttributes;
                            if (@isReadOnly)
                            {
                                htmlAttributes = new
                                {@@class = "form-control form-control-sm",
                                    @readonly = "true"
                                };
                            }
                            else
                            {
                                htmlAttributes = new
                                {@@class = "form-control form-control-sm"
                                };
                            }

                            <div class="col-md-4">

                                @if (item.EditorType.ToLower() != "checkbox")
                                {
                                    <div class="form-group float-label">
                                        <label>@SharedLocalizer[item.ColumnLabel]</label>
                                        @if (item.EditorType.ToLower() == "textbox")
                                        {
                                            @Html.TextBox(item.ColumnName, customFieldValue, "", htmlAttributes)
                                        }
                                        else if (item.EditorType.ToLower() == "textarea")
                                        {
                                            @Html.TextArea(item.ColumnName, (string)customFieldValue, 10, 0, htmlAttributes)
                                        }
                                        else if (item.EditorType.ToLower() == "combobox")
                                        {
                                            if (isReadOnly)
                                            {
                                                @Html.TextBox(item.ColumnName, customFieldValue, "", htmlAttributes)
                                            }
                                            else
                                            {
                                                @await Component.InvokeAsync("ComboBox", new { name = item.ColumnName, controller = "ContactPerson", defaultValue = (string)customFieldValue })
                                            }

                                        }
                                        else if (item.EditorType.ToLower() == "datepicker")
                                        {
                                            if (isReadOnly)
                                            {
                                                customFieldValue = customFieldValue != null ? ((DateTime?)Convert.ToDateTime(customFieldValue)).FormatToDisplay() : "";
                                                @Html.TextBox(item.ColumnName, customFieldValue, "", htmlAttributes)
                                            }
                                            else
                                            {
                                                @await Component.InvokeAsync("DatePicker", new DatePickerOptions(item.ColumnName) { Screen = pageId.ToString(), Value = customFieldValue == null ? (DateTime?)null : Convert.ToDateTime(customFieldValue) })
                                            }
                                        }

                                    </div>
                                }
                                else
                                {
                                    <div class="form-check form-check-inline">
                                        @if (isReadOnly)
                                        {
                                            @Html.CheckBox(item.ColumnName, customFieldValue == null ? false : Convert.ToBoolean(customFieldValue), new { id = $"{item.ColumnName}_{pageId}", @class = "form-check-input",@disabled="disabled"})
                                        }
                                        else
                                        {
                                            @Html.CheckBox(item.ColumnName, customFieldValue == null ? false : Convert.ToBoolean(customFieldValue), new { id = $"{item.ColumnName}_{pageId}", @class = "form-check-input"})
                                        }
                                        <label class="form-check-label" for="@($"{item.ColumnName}_{pageId}")">@SharedLocalizer[item.ColumnLabel]</label>
                                    </div>
                                }
                            </div>

                        }
                    </div>
                @* </div> *@
            </div>
        }
        </div>

    @if (!addMode)
    {
        <div class="content-stamp">
            <vc:record-stamps created-by="@Model.CreatedBy" date-created="@Model.DateCreated" updated-by="@Model.UpdatedBy" last-update="@Model.LastUpdate" t-stamp="@Model.tStamp"></vc:record-stamps>
        </div>
    }
</form>
