@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    string formId = $"{Model.PageId}-RefineSearch";
    var initialButtonGroup = await Component.InvokeAsync("InitialButtonGroup", new InitialButtonGroupOptions { Name = "Initial", FormId = formId });
}

@(Html.Kendo().Grid<ContactPerson>()
                .Name($"{Model.PageId}-Grid")
                .Columns(columns =>
                {
                    columns.Bound(m => m.Contact).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: ContactID#", fromSearch = true }), "Contact")).Width(300);
                    columns.Bound(m => m.LastName);
                    columns.Bound(m => m.FirstName);
                    columns.Bound(m => m.MiddleInitial);
                    columns.Bound(m => m.EMail);
                })
                .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(initialButtonGroup, Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                .AutoBind(false)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                //.ColumnMenu()
                .Excel(excel => excel.FileName("ContactPersonList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "ContactPerson")))
                .DataSource(dataSource => dataSource
                    .Ajax()
                    .Events(events => events.Error("contactPersonPage.searchResultGridError"))
                    .Events(events => events.RequestEnd("contactPersonPage.searchResultGridRequestEnd"))
                    .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                    .Read(read => read.Action("PageRead", "ContactPerson")
                    .Data("contactPersonPage.gridMainSearchFilters")
                )
                .Sort(sort => sort.Add(m => m.Contact))
                )
                .HtmlAttributes(new { @class = "kendo-Grid" })
)
