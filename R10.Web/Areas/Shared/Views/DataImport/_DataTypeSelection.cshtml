<style>

    #importDataType button.collapsed i.chevron {
        transform: rotate(180deg);
    }

    #updateDataType button.collapsed i.chevron {
        transform: rotate(180deg);
    }

    .accordion .card-header {
        background: transparent;
    }

    .accordion .fa-stack {
        font-size: 18px;
    }

    .accordion .btn {
        width: 100%;
        font-weight: bold;
        color: var(--text-body);
        font-size: .9rem;
        padding: 0;
    }

    .accordion .btn-link:hover,
    .accordion .btn-link:focus {
        text-decoration: none;
    }
</style>
