@model DataImportHistory
@inject IStringLocalizer<DataImportResource> Localizer
<div class="d-flex flex-row">
    <div class="rounded-circle import-icon mt-2" style="width:45px; height:45px;">
        <span>
            <i class="fal fa-file-spreadsheet" style="padding:15px;font-size: 20px; color: #fff"></i>
        </span>

    </div>
    <div class="pl-3">
        <h4 class="pb-1">@Localizer["Fix column mapping"]</h4>
        <span style="font-size: .9rem;">@Localizer["Please fix the auto-mapped columns if necessary, unmapped columns will not get imported."]</span>
    </div>
</div>
<div class="mt-3">
    @await Html.PartialAsync("_GridFieldsMapping", Model)
</div>

<div class="d-flex justify-content-end mb-3 pb-2">
    <button class="btn btn-primary mr-3 prev" type="button"><span class="fal fa-arrow-left"></span> @Localizer["Previous"]</button>
    <button class="btn btn-primary next" type="button"><span class="fal fa-arrow-right"></span> @Localizer["Next"]</button>
</div>