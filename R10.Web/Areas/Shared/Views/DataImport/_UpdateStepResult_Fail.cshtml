@inject IStringLocalizer<DataImportResource> Localizer

<div class="d-flex flex-row">
    <div class="rounded-circle bg-danger" style="width:45px; height:45px;">
        <span>
            <i class="far fa-exclamation-circle" style="padding:10px;font-size: 25px; color: #fff"></i>
        </span>
    </div>
    <div class="pl-3">
        <h4 class="pb-1">@Localizer["Update Failed!"]</h4>
        <span style="font-size: .9rem;">@Localizer["Update aborted, the errors reported below must be fixed first."]</span>
    </div>

</div>
<div class="mt-5">
    <div class="col-md-10">
        <div class="d-flex justify-content-between">
            <h5>@Localizer["Errors"]</h5>
            <div id="updateDownloadError">
                <form action="@Url.Action("DownloadErrors","DataImport")" method="post">
                    <input type="hidden" name="ImportId" value="@ViewBag.ImportId" />
                    <input type="hidden" name="IsUpdate" value="true" />
                </form>
                <a class="nav-link" href="#">
                    <i class="fal fa-arrow-circle-down pr-2"></i>
                    <span>@Localizer["Download"]</span>
                </a>
            </div>
            
        </div>
        @(Html.Kendo().Grid<DataImportError>()
                     .Name("dataUpdateErrors")
                     .Columns(columns =>
                     {
                         columns.Bound(e => e.Row);
                         columns.Bound(e => e.Error);
                     })
                     .Pageable(page=> page.Responsive(false))
                     .Sortable(sort => sort.AllowUnsort(false))
                    .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
                    .AutoBind(true)
                    .DataSource(dataSource => dataSource
                         .Ajax()
                         .Batch(true)
                         .ServerOperation(false)
                         .Read(create => create.Action("ImportErrorsRead", "DataImport",new {importId=ViewBag.ImportId}))
                         .Sort(sort => sort.Add(e => e.Row))
                         .Events(events =>
                         {
                             events.Error("pageHelper.onGridError");
                         })
                     )

                     .HtmlAttributes(new { @class = "kendo-Grid", style = "width:100%" })
)
    </div>
</div>
<div class="d-flex justify-content-end mb-3 pb-2">
    <button class="btn btn-primary mr-3 prev" type="button"><span class="fal fa-arrow-left"></span> @Localizer["Previous"]</button>
</div>
