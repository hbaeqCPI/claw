@inject IStringLocalizer<SharedResource> Localizer
@{
    // ViewData["Title"] = ViewBag.Title;
    var activeTab = ViewBag.ActiveTab ?? "ptoImport-tab";

    var canAccessUpdate = ViewBag.DataUpdateTypes != null && (List<DataImportType>)ViewBag.DataUpdateTypes != null && ((List<DataImportType>)ViewBag.DataUpdateTypes).Count > 0;
}

<div>
    <ul class="nav nav-tabs nav-tabs-horizontal flush-left" id="ptoImport-tab" role="tablist">
        <li class="nav-item">
            <a class="nav-link @(activeTab == "ptoImport-tab" ? "active" : null)" id="ptoImport-tab" data-toggle="tab" role="tab" aria-controls="ptoImport" aria-selected="@(activeTab == "ptoImport-tab" ? "true" : "false")" href="#ptoImport">@Localizer["Import Data"] </a>
        </li>
        @if (canAccessUpdate)
        {
            <li class="nav-item">
                <a class="nav-link @(activeTab == "ptoUpdate-tab" ? "active" : null)" id="ptoUpdate-tab" data-toggle="tab" role="tab" aria-controls="ptoUpdate" aria-selected="@(activeTab == "ptoUpdate-tab" ? "true" : "false")" href="#ptoUpdate">@Localizer["Update Data"] </a>
            </li>
        }
        <li class="nav-item">
            <a class="nav-link" id="ptoExport-tab" data-toggle="tab" role="tab" aria-controls="ptoExport" aria-selected="false" href="#ptoExport">@Localizer["Export Structure"]</a>
        </li>
    </ul>
</div>
<div class="tab-content" id="data-import-main">
    <div class="tab-pane page-content fade @(activeTab == "ptoImport-tab" ? "show active" : null) px-4" id="ptoImport" role="tabpanel" aria-labelledby="ptoImport">
        @await Html.PartialAsync("_Import")
    </div>
    @if (canAccessUpdate)
    {
        <div class="tab-pane page-content fade @(activeTab == "ptoUpdate-tab" ? "show active" : null) px-4" id="ptoUpdate" role="tabpanel" aria-labelledby="ptoUpdate">
            @await Html.PartialAsync("_Update")
        </div>
    }
    <div class="tab-pane page-content fade px-4" id="ptoExport" data-url="" role="tabpanel" aria-labelledby="ptoExport">
        @await Html.PartialAsync("_Export")
    </div>
</div>
<div class="cpiContainerPopup"></div>
<style>
    .page-content {
        padding: 0px 0px;
    }
</style>