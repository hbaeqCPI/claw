@model DocuSignRecipientViewModel
@inject IStringLocalizer<SharedResource> Localizer


<div class="modal fade" id="signatoryDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form id="signatory" method="post">
                <div class="modal-header py-1">
                    <h4 class="modal-title">@Localizer["Recipients"]</h4>
                    <button type="button" class="close pt-3" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-1">
                    @(Html.Kendo().Grid<DocuSignRecipientViewModel>()
                        .Name("usersToNotifyGrid")
                        .Columns(columns =>
                        {
                            columns.Bound(p => p.Role);
                            columns.Bound(p => p.Name);
                            columns.Bound(p => p.Email);
                            //columns.Bound(p => p.sentDateTime).ClientTemplate("#=kendo.toString(sentDateTime, 'dd-MMM-yyyy')#");
                            columns.Bound(p => p.signedDateTime).ClientTemplate("#=signedDateTime != null ? kendo.toString(signedDateTime, 'dd-MMM-yyyy') : ''#");
                        })
                        .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
                        .Editable(editable => editable.Enabled(false))
                        .Sortable(sort => sort.AllowUnsort(false))
                        .AutoBind(true)
                        .DataSource(dataSource => dataSource
                        .Ajax()
                        .Batch(true)
                        .PageSize(10)
                        .ServerOperation(false)
                        .Read(read => read.Action("RecipientsRead", "Signature", Model))
                        .Sort(sort => sort.Add("Role").Ascending())
                        .Events(events =>
                        {
                            events.Error("pageHelper.onGridError");
                        })
                        )
                        .HtmlAttributes(new { @class = "kendo-Grid" })
                        )
                </div>
                <div class="modal-footer">
                    <div class="modal-footer-buttons">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Close"]</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>



