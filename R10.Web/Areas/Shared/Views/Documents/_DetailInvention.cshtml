@model DocInventionViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<PatSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var caseNumberLabel = Localizer[settings.LabelCaseNumber];
    var clientNameLabel = Localizer[settings.LabelClientName];
    var ownerNameLabel = Localizer[settings.LabelOwnerName];

}
<div class="page-content">
    <div class="form-row">
        <div class="col">
            <span id="ctryAppDocumentHeader" style="font-weight:600">@Model.CaseNumber</span>
        </div>
        <div class="col d-flex justify-content-end">
            <span style="font-style: italic">@Localizer["Invention"]</span>
        </div>
    </div>
</div>

<div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="inventionDocumentTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="inventionDetailTab" data-toggle="tab" role="tab" aria-controls="inventionDetailTabContent" aria-selected="true" href="#inventionDetailTabContent">@Localizer["Invention Details"]</a>
        </li>
    </ul>
    <div class="tab-content">
        <div class="tab-pane show active" id="inventionDetailTabContent" role="tabpanel" aria-labelledby="inventionDetailTab">
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="CaseNumber">@caseNumberLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="CaseNumber" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="FamilyNumber"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="FamilyNumber" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="ClientName">@clientNameLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="ClientName" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="InvTitle"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="InvTitle" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="Attorney1"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="Attorney1" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="Attorney2"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="Attorney2" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="Attorney3"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="Attorney3" readonly />
                    </div>
                </div>
                
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="DisclosureStatus"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="DisclosureStatus" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="DisclosureDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="DisclosureDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>