@model DocPatCostViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<PatSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var headerLabel = Model.CaseNumber + "/" + Model.Country + (string.IsNullOrEmpty(Model.SubCase) ? "" : "-" + Model.SubCase) +
                        " -  " + Model.CostType + " (" + Model.InvoiceDate.ToString("dd-MMM-yyyy") + ")";

    var caseNumberLabel = settings.IsClientMatterOn ? Localizer[settings.LabelClientMatter] : Localizer[settings.LabelCaseNumber];
    var clientNameLabel = Localizer[settings.LabelClientName];
}

<div class="page-content">
    <div class="form-row">
        <div class="col">
            <span id="patCostDocumentHeader"><b>@headerLabel</b></span>
        </div>
        <div class="col d-flex justify-content-end">
            <span style="font-style: italic">@Localizer["Patent Costs"]</span>
        </div>
    </div>
</div>

<div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="patCostDocumentTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="patCostDetailTab" data-toggle="tab" role="tab" aria-controls="patCostDetailTabContent" aria-selected="true" href="#patCostDetailTabContent">@Localizer["Patent Cost Details"]</a>
        </li>
    </ul>
    <div class="tab-content">
        <div class="tab-pane show active" id="patCostDetailTabContent" role="tabpanel" aria-labelledby="patCostDetailTab">
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="CaseNumber">@caseNumberLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="CaseNumber" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="Country"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="Country" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="SubCase"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="SubCase" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="CaseType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="CaseType" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="ClientName">@clientNameLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="ClientName" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="Status"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="Status" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="AppTitle"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="AppTitle" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="AppNumber"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="AppNumber" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="FilDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="FilDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="PatNumber"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="PatNumber" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="IssDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="IssDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="CostType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="CostType" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="InvoiceDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="InvoiceDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="InvoiceNumber"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="InvoiceNumber" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="InvoiceAmount"></label>
                        <input type="text" class="form-control form-control-sm" disabled value="@(Model.InvoiceAmount.FormatToDisplay())" />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="PayDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="PayDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="CurrencyType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="CurrencyType" readonly />
                    </div>
                </div>

                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="ExchangeRate"></label>
                        <input type="text" class="form-control form-control-sm" disabled value="@(((decimal)Model.ExchangeRate).FormatToDisplay())" />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="NetCost"></label>
                        <input type="text" class="form-control form-control-sm" disabled value="@(((decimal)Model.NetCost).FormatToDisplay())" />
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>