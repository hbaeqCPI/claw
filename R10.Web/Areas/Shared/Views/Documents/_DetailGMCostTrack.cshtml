@model DocGMCostViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<GMSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var headerLabel = Model.CaseNumber + (string.IsNullOrEmpty(Model.SubCase) ? "" : "-" + Model.SubCase) +
                        " -  " + Model.CostType + " (" + Model.InvoiceDate.ToString("dd-MMM-yyyy") + ")";

    var caseNumberLabel = settings.IsClientMatterOn ? Localizer[settings.LabelClientMatter] : Localizer[settings.LabelCaseNumber];
    var clientNameLabel = Localizer[settings.LabelClientName];
}

<div class="page-content">
    <div class="form-row">
        <div class="col">
            <span id="gmCostDocumentHeader"><b>@headerLabel</b></span>
        </div>
        <div class="col d-flex justify-content-end">
            <span style="font-style: italic">@Localizer["General Matter Costs"]</span>
        </div>
    </div>
</div>

<div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="gmCostDocumentTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="gmCostDetailTab" data-toggle="tab" role="tab" aria-controls="gmCostDetailTabContent" aria-selected="true" href="#gmCostDetailTabContent">@Localizer["General Matter Cost Details"]</a>
        </li>
    </ul>
    <div class="tab-content">
        <div class="tab-pane show active" id="gmCostDetailTabContent" role="tabpanel" aria-labelledby="gmCostDetailTab">
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="CaseNumber">@caseNumberLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="CaseNumber" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="SubCase"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="SubCase" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterType" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="EffectiveOpenDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="EffectiveOpenDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="TerminationEndDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="TerminationEndDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterStatus"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterStatus" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterTitle"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterTitle" readonly />
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="ResultRoyalty"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="ResultRoyalty" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="CostType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="CostType" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="InvoiceDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="InvoiceDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="InvoiceNumber"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="InvoiceNumber" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="InvoiceAmount"></label>
                        <input type="text" class="form-control form-control-sm" disabled value="@(Model.InvoiceAmount.FormatToDisplay())" />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="PayDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="PayDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="CurrencyType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="CurrencyType" readonly />
                    </div>
                </div>

                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="ExchangeRate"></label>
                        <input type="text" class="form-control form-control-sm" disabled value="@(((decimal)Model.ExchangeRate).FormatToDisplay())" />
                    </div>
                </div>
                <div class="col-3">
                    <div class="form-group float-label">
                        <label asp-for="NetCost"></label>
                        <input type="text" class="form-control form-control-sm" disabled value="@(((decimal)Model.NetCost).FormatToDisplay())" />
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
