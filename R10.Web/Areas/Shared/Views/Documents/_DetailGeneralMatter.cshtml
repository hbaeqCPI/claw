@model DocGeneralMatterViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<R10.Core.Entities.GeneralMatter.GMSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var headerLabel = Model.CaseNumber + (string.IsNullOrEmpty(Model.SubCase) ? "" : "-" + Model.SubCase) + "/" + Model.MatterType;

    var caseNumberLabel = Localizer[settings.LabelCaseNumber];
    var clientNameLabel = Localizer[settings.LabelClientName];   
    var ownerNameLabel = Localizer[settings.LabelOwnerName];   
    var agentNameLabel = Localizer[settings.LabelAgentName];
}

<div class="page-content">
    <div class="form-row">
        <div class="col">
            <span id="generalMatterDocumentHeader" style="font-weight:600">@headerLabel</span>
        </div>
        <div class="col d-flex justify-content-end">
            <span style="font-style: italic">@Localizer["General Matter"]</span>
        </div>
    </div>
</div>

<div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="generalMatterDocumentTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="generalMatterDetailTab" data-toggle="tab" role="tab" aria-controls="generalMatterDetailTabContent" aria-selected="true" href="#generalMatterDetailTabContent">@Localizer["General Matter Details"]</a>
        </li>
    </ul>
    <div class="tab-content">
        <div class="tab-pane show active" id="generalMatterDetailTabContent" role="tabpanel" aria-labelledby="generalMatterDetailTab">
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="CaseNumber">@caseNumberLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="CaseNumber" readonly />
                    </div>
                </div>                
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="SubCase"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="SubCase" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterType" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="ClientName">@clientNameLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="ClientName" readonly />
                    </div>
                </div>                
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="AgentName">@agentNameLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="AgentName" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterTitle"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterTitle" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterStatus"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterStatus" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterStatusDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterStatusDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="EffectiveOpenDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="EffectiveOpenDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="TerminationEndDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="TerminationEndDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="ResultRoyalty"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="ResultRoyalty" readonly />
                    </div>
                </div>
            </div>  
        </div>
    </div>
</div>