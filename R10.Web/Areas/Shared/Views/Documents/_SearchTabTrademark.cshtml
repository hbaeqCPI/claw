@model PageViewModel

@inject ISystemSettings<TmkSetting> Settings
@inject IStringLocalizer<TrademarkResource> Localizer
@{
    var settings = await Settings.GetSetting();

    var caseNumberLabel = Localizer[settings.LabelCaseNumber];
    var oldCaseNumberLabel = Localizer[settings.LabelOldCaseNumber];
    var ownerLabel = Localizer[settings.LabelOwner];
    var ownerNameLabel = Localizer[settings.LabelOwnerName];
    var clientLabel = Localizer[settings.LabelClient];
    var clientNameLabel = Localizer[settings.LabelClientName];
    var agentLabel = Localizer[settings.LabelAgent];
    var agentNameLabel = Localizer[settings.LabelAgentName];

    var attorneyLabel = Localizer["Attorney"];
    var attorneyNameLabel = Localizer["Attorney Name"];
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];
    var clientRefLabel = Localizer[settings.LabelClientRef];
    var agentRefLabel = Localizer[settings.LabelAgentRef];

    var area = "Trademark";
    var controller = "TmkTrademark";

    var isRespOfficeOn = User.IsRespOfficeOn(SystemType.Trademark);
    var screen = Model.PageId;
    var enableComboPaging = settings.EnableComboBoxPaging;
    var comboPagingSize = settings.ComboBoxPagingSize;
}

<ul class="nav nav-tabs refine-search nav-tabs-vertical" role="tablist">
    <li class="nav-item">
        <a id="mainTab" href="#docMgtMainTabContent" class="nav-link active" data-toggle="tab" role="tab"
           aria-controls="docMgtMainTabContent" title="@Localizer["Trademark"]">@Localizer["Trademark"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="trademarkSearchEntitiesTab" data-toggle="tab" href="#trademarkSearchEntitiesTabContent" role="tab" aria-controls="trademarkSearchEntitiesTabContent" aria-selected="true">@Localizer["Entities"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="trademarkSearchBiblioTab" data-toggle="tab" href="#trademarkSearchBiblioTabContent" role="tab" aria-controls="trademarkSearchBiblioTabContent" aria-selected="true">@Localizer["Bibliographic Info"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" id="trademarkSearchDocumentsTab" data-toggle="tab" href="#trademarkSearchDocumentsTabContent" role="tab" aria-controls="trademarkSearchDocumentsTabContent" aria-selected="true">@Localizer["Documents"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-toggle="tab" id="trademarkSearchOtherInfoTab" href="#trademarkSearchOtherInfoTabContent" role="tab" aria-controls="trademarkSearchOtherInfoTabContent" title="@Localizer["Other Info"]">@Localizer["Other Info"]</a>
    </li>
</ul>

<div class="accordion-content show">
    <div class="tab-pane show form-sidebar active" id="docMgtMainTabContent" aria-labelledby="mainTab" role="tabpanel" data-case-number-mapper-url="@Url.Action("CaseNumberSearchValueMapper", "TmkTrademarkLookup", new { Area = "Trademark" })">
        <div class="form-row group">
            <div class="col-12">
                <div class="form-group float-label">
                    <label for="CaseNumber">@caseNumberLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CaseNumber", controller = "TmkTrademarkLookup", area = area, enablePaging = enableComboPaging, pagingSize = comboPagingSize, valueMapper = "tmkTrademarkPage.caseNumberSearchValueMapper" })
                </div>
            </div>
            <div class="col-4">
                <div class="form-group float-label">
                    <label for="CountryOp"></label>
                    @await Component.InvokeAsync("FilterOperatorList", new { name = "CountryOp" })
                </div>

            </div>
            <div class="col-8">
                <div class="form-group float-label">
                    <label for="Country">@countryLabel</label>
                    @await Component.InvokeAsync("MultiSelect", MultiSelectOptions.Country("Country", countryLabel, countryNameLabel, "TmkTrademarkLookup", null, area))
                </div>
            </div>
            <div class="col-12">
                <div class="form-group float-label">
                    <label>@countryNameLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CountryName", controller = "TmkTrademarkLookup", action = "GetCountryList", area = "Trademark", screen = screen })
                </div>
            </div>
            <div class="col-12">
                <div class="form-group float-label">
                    <label for="SubCase">@Localizer["Sub Case"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "SubCase", controller = "TmkTrademarkLookup", area = "Trademark", screen = screen })
                </div>
            </div>
            <div class="col-12">
                @if (isRespOfficeOn)
                {
                    <div class="form-group float-label">
                        <label for="RespOffice">@Localizer["Responsible Office"]</label>
                        @await Component.InvokeAsync("ComboBox", new { name = "RespOffice", controller = "TmkTrademarkLookup", area = "Trademark", screen = screen })
                    </div>
                }
            </div>
        </div>
        <div class="form-row group">
            <div class="col-12">
                <div class="form-group float-label">
                    <label for="TrademarkName">@Localizer["Trademark"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "TrademarkName", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
            <div class="col-4">
                <div class="form-group float-label">
                    <label for="CaseTypeOp"></label>
                    @await Component.InvokeAsync("FilterOperatorList", new { name = "CaseTypeOp" })
                </div>
            </div>
            <div class="col-8">
                <div class="form-group float-label">
                    <label for="CaseType">@Localizer["Case Type"]</label>
                    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions { Name = "CaseType", Controller = "TmkTrademarkLookup", Screen = screen, Area = area })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label for="Area">@Localizer["Area"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Area", controller = "Area", action = "GetAreasWithTrademarks", area = "Trademark", screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ParentTmkId">@Localizer["Family Reference"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "ParentCase", controller = "TmkTrademarkLookup", action = "GetFamilyReferenceList", area = "Trademark", screen = screen })
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="ActiveSwitch1">@Localizer["Status Codes"]</label>
                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                        <label class="btn btn-outline">
                            <input type="radio" name="TmkTrademarkStatus.ActiveSwitch" class="form-control" value="true" data-role="option"> @Localizer["Active"]
                        </label>
                        <label class="btn btn-outline">
                            <input type="radio" name="TmkTrademarkStatus.ActiveSwitch" class="form-control" value="false" data-role="option"> @Localizer["Inactive"]
                        </label>
                        <label class="btn btn-outline active">
                            <input type="radio" name="TmkTrademarkStatus.ActiveSwitch" class="form-control" value="" data-role="option"> @Localizer["All"]
                        </label>
                    </div>
                </div>
            </div>
        </div>
        <div class="form-row group">
            <div class="col-4">
                <div class="form-group float-label">
                    <label for="CaseTypeOp"></label>
                    @await Component.InvokeAsync("FilterOperatorList", new { name = "TrademarkStatusOp" })
                </div>
            </div>
            <div class="col-8">
                <div class="form-group float-label">
                    <label for="CaseType">@Localizer["Status"]</label>
                    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions { Name = "TrademarkStatus", Controller = "TmkTrademarkLookup", Screen = screen, Area = area })
                </div>
            </div>
            <div class="col-12">
                <div class="form-group float-label">
                    <label for="TrademarkStatusDateFrom">@Localizer["Status Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("TrademarkStatusDateFrom"))
                </div>
            </div>
            <div class="col-12">
                <div class="form-group float-label">
                    <label for="TrademarkStatusDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("TrademarkStatusDateTo"))
                </div>
            </div>
        </div>
    </div>
    <div class="tab-pane" id="trademarkSearchEntitiesTabContent" role="tabpanel" aria-labelledby="trademarkSearchEntitiesTab">
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label for="Client.ClientCode">@clientLabel</label>
                    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.ClientCode("Client.ClientCode", clientLabel, clientNameLabel, "TmkTrademarkLookup", "", area))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Client.ClientName">@clientNameLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Client.ClientName", textProperty = "ClientName", controller = "TmkTrademarkLookup", action = "GetClientList", area = "Trademark", screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ClientRef">@clientRefLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "ClientRef", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label for="Attorney.AttorneyCode">@attorneyLabel</label>
                    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyCode("Attorney.AttorneyCode", attorneyLabel, attorneyNameLabel, "TmkTrademarkLookup", "", "GetAttorneyList", area))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Attorney.AttorneyName">@attorneyNameLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Attorney.AttorneyName", textProperty = "AttorneyName", controller = "TmkTrademarkLookup", area = area, action = "GetAttorneyList", screen = screen })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label for="Agent.AgentCode">@agentLabel</label>
                    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AgentCode("Agent.AgentCode", agentLabel, agentNameLabel, "TmkTrademarkLookup", "", area))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Agent.AgentName">@agentNameLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Agent.AgentName", textProperty = "AgentName", screen = screen, area = area, controller = "TmkTrademarkLookup", action = "GetAgentList" })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="AgentRef">@agentRefLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "AgentRef", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-2">
                <div class="form-group float-label">
                    <label for="Owner.OwnerCode">@ownerLabel</label>
                    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.OwnerCode("Owner.OwnerCode", ownerLabel, ownerNameLabel, "TmkTrademarkLookup", "", area))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Owner.OwnerName">@ownerNameLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Owner.OwnerName", textProperty = "OwnerName", screen = screen, area = area, controller = "TmkTrademarkLookup", action = "GetOwnerList" })
                </div>
            </div>
        </div>
    </div>
    <div class="tab-pane" id="trademarkSearchBiblioTabContent" role="tabpanel" aria-labelledby="trademarkSearchBiblioTab">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="PriNumber">@Localizer["Priority No."]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "PriNumber", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="PriDateFrom">@Localizer["Priority Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("PriDateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="PriDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("PriDateTo"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="PriCountry">@Localizer["Priority Country"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "PriCountry", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="AppNumber">@Localizer["Application No."]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "AppNumber", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="FilDateFrom">@Localizer["Filing Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("FilDateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="FilDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("FilDateTo"))
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="PubNumber">@Localizer["Publication No."]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "PubNumber", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="PubDateFrom">@Localizer["Publication Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("PubDateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="PubDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("PubDateTo"))
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="RegNumber">@Localizer["Registration No."]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "RegNumber", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="IssDateFrom">@Localizer["Registration Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("RegDateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="IssDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("RegDateTo"))
                </div>
            </div>
        </div>

        <div cpi-more-info id="moreTmkBiblioInfo"></div>

        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="NextRenewalDateFrom">@Localizer["Next Renewal Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("NextRenewalDateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="NextRenewalDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("NextRenewalDateTo"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastRenewalDateFrom">@Localizer["Last Renewal Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastRenewalDateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastRenewalDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastRenewalDateTo"))
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group">
                    <label for="IntentToUse">@Localizer["Intent to Use"]</label><br />
                    <input type="checkbox" name="IntentToUse" id="IntentToUse" value="true">
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="AllowanceDateFrom">@Localizer["Allowance Date"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("AllowanceDateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="AllowanceDateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("AllowanceDateTo"))
                </div>
            </div>
        </div>
    </div>
    <div class="tab-pane" id="trademarkSearchDocumentsTabContent" role="tabpanel" aria-labelledby="trademarkSearchDocumentsTab">
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">                   
                    <label for="ImagesLinks">@Localizer["Documents"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Images.ImageTitle", controller = "TmkImage", textProperty = "ImageTitle", valueProperty = "ImageTitle", area = area })
                </div>
            </div>
        </div>
    </div>
    <div class="tab-pane" id="trademarkSearchOtherInfoTabContent" role="tabpanel" aria-labelledby="trademarkSearchOtherInfoTab">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Remarks">@Localizer["Remarks"]</label>
                    <input type="text" name="Remarks" class="form-control form-control-sm" />
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="CreatedBy">@Localizer["Created By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CreatedBy", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedFrom">@Localizer["Date Created"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedTo"))
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="UpdatedBy">@Localizer["Updated By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "UpdatedBy", controller = "TmkTrademarkLookup", area = area, screen = screen })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateFrom">@Localizer["Last Update"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateTo">@Localizer["To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateTo"))
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        documentPage.initializeSubSearchPage({
            tabNameId: "#mainTab",
            systemTabId: "#systemTab"
        })
    });
</script>
