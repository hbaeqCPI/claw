@model DocFixedFolderViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="page-content">
    <div class="form-row">
        <div class="col">
            <span id="userFolderHeader" style="font-weight:600">@Model.FolderName</span>
        </div>
        <div class="col d-flex justify-content-end">
            <span style="font-style: italic">@Localizer["System Folder"]</span>
        </div>
    </div>
</div>

<div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="fixedFolderTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="fixedFolderDetailTab" data-toggle="tab" role="tab" aria-controls="fixedFolderDetailTabContent" aria-selected="true" href="#fixedFolderDetailTabContent">@Localizer["Fixed Folder Details"]</a>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane show active" id="fixedFolderDetailTabContent" role="tabpanel" aria-labelledby="fixedFolderDetailTab" data-refresh-url="@Url.Action("UserFolderDetailEdit", "Documents")">
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="FolderName"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="FolderName" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="FolderDesc"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="FolderDesc" readonly />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
