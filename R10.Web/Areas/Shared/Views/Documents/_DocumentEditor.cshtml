@model DocDocumentViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings

@{
    var settings = await Settings.GetSetting();

    var addMode = Model.DocId == 0;
    var fileSizeLimit = settings.FileUploadSizeLimit;

    var showReleaseLock = !string.IsNullOrEmpty(Model.LockedBy) && User.GetUserName() == Model.LockedBy;
}

<div id="documentEditorDialog" class="modal fade" data-backdrop="static" tabindex="-1" role="dialog" aria-labelledby="documentEditorDialogTitle" aria-hidden="true">
    <div class="modal-dialog  modal-xl" role="document">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="documentEditorDialogTitle">@Localizer["Document Detail"]</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="@Localizer["Close"]">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body container-fluid">
                <form id="documentEditorForm" asp-area="Shared" asp-controller="DocDocument" asp-action="SaveDocument" method="post" enctype="multipart/form-data">
                    <div id="errorSummary" class="alert alert-danger d-none alert-dismissible fade show" role="alert">
                        <div class="content"></div>
                        <button type="button" class="close alert-close" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="form-row mb-2 cpiMainEntry">
                        <div class="col">
                            <div class="form-group float-label">
                                <label asp-for="DocName"></label>
                                <input type="text" class="form-control form-control-sm" asp-for="DocName" />
                                <span asp-validation-for="DocName"></span>
                            </div>
                        </div>
                    </div>
                    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="docDetailTab" role="tablist">
                        <li class="nav-item">
                            <a class="nav-link active" id="docDetailTab" data-toggle="tab" role="tab" aria-controls="docDetailTabContent" aria-selected="true" href="#docDetailTabContent">@Localizer["Details"]</a>
                        </li>
                        @if (Model.IsDocViewable)
                        {
                            <li class="nav-item">
                                <a class="nav-link" id="docPreviewTab" data-toggle="tab" role="tab" aria-controls="docPreviewTabContent" aria-selected="true" href="#docPreviewTabContent">@Localizer["Preview"]</a>
                            </li>
                        }
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane show active" id="docDetailTabContent" role="tabpanel" aria-labelledby="docDetailTab">
                            <div class="cpiMainEntry">
                                <input type="hidden" asp-for="DocId" />
                                <input type="hidden" asp-for="FolderId" />
                                <input type="hidden" asp-for="FileId" />
                                <input type="hidden" asp-for="CreatedBy" />
                                <input type="hidden" asp-for="DateCreated" />
                                @if (Model.DocId > 0)
                                {
                                    <input type="hidden" name="tStamp" value="@Convert.ToBase64String(Model.tStamp)" />
                                }

                                <div class="form-row">
                                    <div class="col">
                                        <div class="form-group float-label">
                                            <label asp-for="Author"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="Author" readonly />
                                        </div>
                                    </div>
                                </div>
                                @if (addMode || Model.FileId == 0 || Model.FileId == null)
                                {
                                    <div class="form-row pt-2 pb-2" style="font-size: small">
                                        <div class="col-12">
                                            @(Html.Kendo().Upload()
                                            .Name("UploadedFiles")
                                            .Messages(m => m.Select(Localizer["Select a file to upload..."]))
                                            .Multiple(false) // limit upload to one file at a time
                                            .Validation(validation => validation.MaxFileSize(fileSizeLimit))
                                        )
                                        </div>
                                    </div>
                                }
                                <div class="form-row">
                                    <div class="col">
                                        <div class="form-group float-label">
                                            <label asp-for="DocUrl"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="DocUrl" />
                                        </div>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col">
                                        <div class="form-group float-label">
                                            <label asp-for="DocTypeId"></label>
                                            @*<input type="text" class="form-control form-control-sm" asp-for="DocTypeName" readonly />*@

                                            @await Component.InvokeAsync("ComboBox", new
                                            {
                                                    name = "DocTypeId",
                                                    controller = "DocType",
                                                    action = "GetPicklistData",
                                                    textProperty = "DocTypeName",
                                                    valueProperty = "DocTypeId",
                                                    defaultValue = Model.DocTypeId == -1 ? (Model.DocTypeName ?? "") : Model.DocTypeId == null || Model.DocTypeId == 0 ? "" : Model.DocTypeId.ToString(),
                                                    defaultText = Model.DocTypeName
                                                })
                                        </div>
                                    </div>
                                    <div class="col offset-2">
                                        <div class="form-group float-label">
                                            <div class="form-check">
                                                <input asp-for="IsPrivate" class="form-check-input" type="checkbox">
                                                <label asp-for="IsPrivate" class="form-check-label pt-2"></label>
                                            </div>
                                        </div>
                                    </div>
                                    @if (showReleaseLock)
                                    {
                                        <div class="col">
                                            <div class="form-group float-label">
                                                <div class="form-check">
                                                    <input asp-for="ReleaseFileLock" class="form-check-input" type="checkbox" checked>
                                                    <label asp-for="ReleaseFileLock" class="form-check-label pt-2"></label>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <div class="form-row">
                                    <div class="col">
                                        <div class="form-group float-label">
                                            <label asp-for="Remarks"></label>
                                            <textarea class="form-control form-control-sm" rows="6" asp-for="Remarks"></textarea>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>
                        @if (Model.IsDocViewable)
                        {
                            <div class="tab-pane" id="docPreviewTabContent" role="tabpanel" aria-labelledby="docPreviewTab">
                                <div>
                                    <div class="form-row">
                                        <div class="col-12">
                                            @*<div id="docViewerContainer" data-viewer-url="@Url.Action("GetDocumentViewer", "DocViewer", new { docFileName = Model.DocFileName, width = 800, height = 500 })">*@
                                            <div id="docViewerContainer" data-viewer-url="@Url.Action("PreviewDocument", "DocViewer", new { system = Model.SystemType })">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                    </div>

                    <div class="modal-footer">
                        <button id="save" type="submit" class="btn btn-primary d-none"><i class="fa fa-check pr-2"></i>@Localizer["Save"]</button>
                        <button id="cancel" type="button" class="btn btn-secondary  float-right" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        documentPage.initializeDocumentEditor({
            modalDialog: "documentEditorDialog",
            tabName: "docDetailTab",
            previewTab: "docPreviewTab",
            docViewerContainer: "docViewerContainer",
            docFileName: "@Model.DocFileName",
            screenCode: "@Model.ScreenCode",
            key: @Model.ParentId,
            docViewer: "@Model.DocViewer"
        });

    });
</script>