@model DocDocumentViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    var addMode = Model.DocId == 0;


    var systemName = SystemTypeHelper.GetSystem(Model.SystemType);
    var zoomUrl = @Url.Action("ZoomDocument", "DocViewer", new { fileType = ImageHelper.CPiSavedFileType.DocMgt });
    var thumbnailUrl = @Url.Content("~/FileViewer/GetDocMgtThumbnail?system=" + systemName) + "&thumbnailFile=" + Uri.EscapeDataString(Model.ThumbFileName)
                                            + "&screenCode=" + Model.ScreenCode + "&key=" + Model.ParentId.ToString();

    var showReleaseLock = !string.IsNullOrEmpty(Model.LockedBy) && User.GetUserName() == Model.LockedBy;
}

<script>
    function zoomDocument() {
        // build url here to avoid unnecessary escape characters
        const url = "@zoomUrl" + "&system=" + "@systemName" + "&fileName=" + "@Model.DocFileName" + "&screenCode=" + "@Model.ScreenCode" + "&key=" + "@Model.ParentId.ToString()";
        documentPage.zoomDocument(url);
        return false;
    }
</script>

<div class="page-content">
    <div class="form-row">
        <div class="col">
            <span id="userDocumentHeader" style="font-weight:600">@Model.DocName</span>
        </div>
        <div class="col d-flex justify-content-end">
            <span style="font-style: italic">@Localizer["Document"]</span>
        </div>
    </div>
</div>

<div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="userDocumentTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="userDocumentDetailTab" data-toggle="tab" role="tab" aria-controls="userDocumentDetailTabContent" aria-selected="true" href="#userDocumentDetailTabContent">@Localizer["Document Details"]</a>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane show active" id="userDocumentDetailTabContent" role="tabpanel" aria-labelledby="userDocumentDetailTab">
            <form cpi-detail-form form-name="userDocumentDetailForm" data-refresh-url="@Url.Action("UserDocumentDetail","Documents")" data-save-url="@Url.Action("SaveDocument", "DocDocument")" enctype="multipart/form-data">
                <div id="documentEditActionButtons" class="detail-page-nav pr-2 d-none">
                    <nav class="nav nav-right">
                        <a class="nav-link save-changes" href="#" title="Save" role="button"><i class="fal fa-save pr-2"></i><span>@Localizer["Save"]</span></a>
                        <a class="nav-link cancel-changes" href="#" title="Cancel" role="button"><i class="fal fa-undo pr-2"></i><span>@Localizer["Cancel"]</span></a>
                    </nav>
                </div>
                <div class="form-row">
                    <div class="col-10">
                        <div class="cpiMainEntry">
                            <input type="hidden" asp-for="DocId" />
                            <input type="hidden" asp-for="FolderId" />
                            <input type="hidden" asp-for="FileId" />
                            <input type="hidden" asp-for="CreatedBy" />
                            <input type="hidden" asp-for="DateCreated" />
                            <input type="hidden" name="tStamp" value="@Convert.ToBase64String(Model.tStamp)" />
                            @if (Model.DocId > 0)
                            {
                                <input type="hidden" name="tStamp" value="@Convert.ToBase64String(Model.tStamp)" />
                            }
                            <div class="form-row">
                                <div class="col">
                                    <div class="form-group float-label">
                                        <label asp-for="DocName"></label>
                                        <input type="text" class="form-control form-control-sm" asp-for="DocName" />
                                        <span asp-validation-for="DocName"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col">
                                    <div class="form-group float-label">
                                        <label asp-for="Author"></label>
                                        <input type="text" class="form-control form-control-sm" asp-for="Author" readonly />
                                    </div>
                                </div>
                                <div class="col">
                                    <div class="form-group float-label">
                                        <label asp-for="DateCreated"></label>
                                        <input type="text" class="form-control form-control-sm" asp-for="DateCreated" asp-format="{0:dd-MMM-yyyy hh:mm tt}" readonly />
                                    </div>
                                </div>
                            </div>
                            @if (addMode || Model.FileId == 0 || Model.FileId == null)
                            {
                                <div class="form-row pt-2 pb-2" style="font-size: small">
                                    <div class="col-12">
                                        @(Html.Kendo().Upload()
                                            .Name("UploadedFiles")
                                            .Messages(m => m.Select(Localizer["Select a file to upload..."]))
                                            .Multiple(false) // limit upload to one file at a time
                                            .Validation(validation => validation.MaxFileSize(1500000))
                                        )
                                    </div>
                                </div>
                            }
                            <div class="form-row">
                                <div class="col">
                                    <div class="form-group float-label">
                                        <label asp-for="DocUrl"></label>
                                        <input type="text" class="form-control form-control-sm" asp-for="DocUrl" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col">
                                    <div class="form-group float-label">
                                        <label asp-for="DocTypeId"></label>
                                        @*<input type="text" class="form-control form-control-sm" asp-for="DocTypeName" readonly />*@

                                        @await Component.InvokeAsync("ComboBox", new
                                        {
                                                name = "DocTypeId",
                                                controller = "DocType",
                                                action = "GetPicklistData",
                                                textProperty = "DocTypeName",
                                                valueProperty = "DocTypeId",
                                                defaultValue = Model.DocTypeId == -1 ? (Model.DocTypeName ?? "") : Model.DocTypeId == null || Model.DocTypeId == 0 ? "" : Model.DocTypeId.ToString(),
                                                defaultText = Model.DocTypeName
                                            })
                                    </div>
                                </div>
                                <div class="col pl-5">
                                    <div class="form-check">
                                        <input asp-for="IsPrivate" type="checkbox">
                                        <label asp-for="IsPrivate"></label>
                                    </div>
                                </div>
                                @if (showReleaseLock)
                                {
                                    <div class="col">
                                        <input type="checkbox" asp-for="ReleaseFileLock" checked>
                                        <label>@Localizer["Release Lock?"]</label>

                                    </div>
                                }

                            </div>

                            <div class="form-row">
                                <div class="col">
                                    <div class="form-group float-label">
                                        <label asp-for="Remarks"></label>
                                        <textarea class="form-control form-control-sm" rows="4" asp-for="Remarks"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                    <div class="col-2">
                        @if (!addMode)
                        {
                            @if (Model.IsDocViewable)
                            {
                                <div class="text-wrap text-center pt-5" style="max-width: 100%;">
                                    @if (Model.IsImage == true)
                                    {
                                        @*<img class="detail-image" title="@Model.DocName" src="@Url.Content($"~/UserFiles/Documents/{Model.DocFileName}")" />*@
                                        <img class="detail-image" title="@Model.DocName" src="@thumbnailUrl" alt="@Model.UserFileName" asp-append-version="true" /><br />
                                    }
                                    <a role="button" href="" onclick="return zoomDocument()" )><span class="details-link"></span>@Localizer["Click here to view document."]</a>
                                </div>
                            }
                            else if (Model.IsDocLinkable)
                            {
                                <div class="text-wrap text-center pt-5" style="max-width: 100%;">
                                    <a role="button" href="@Model.DocUrl" target="_blank"><span class="details-link"></span>@Localizer["Click here to open link."]</a>
                                </div>
                            }
                        }

                    </div>
                </div>

            </form>
        </div>
    </div>
</div>

<style>
    .detail-image {
        max-width: 100%;
        height: auto;
    }
</style>

<script>
    $(document).ready(function () {
        documentPage.initializeUserDocumentEdit({
            pageContainer: ".documentDetailContainer",
            editActionButtonsId: "#documentEditActionButtons",
            pageHeaderId: "#userDocumentHeader",
            uploadFile: true
        });

    });
</script>


