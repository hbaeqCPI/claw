@model PageViewModel
@inject ISystemSettings<TmkSetting> Settings;
@inject IStringLocalizer<TrademarkResource> Localizer

@{
    var settings = await Settings.GetSetting();
    var caseNumberLabel = Localizer[settings.LabelCaseNumber];

    var gridId = $"{Model.PageId}-SearchGrid";

    var numberTitle = Localizer["Application No."] + "<br/>" + Localizer["Registration No."];
    var dateTitle = Localizer["Filing Date"] + "<br/>" + Localizer["Registration Date"];

    var numberTemplate = "<span>#= AppNumber == null ? '' : kendo.htmlEncode(AppNumber) # <br> #= RegNumber == null ? '' : kendo.htmlEncode(RegNumber) #</span>";
    var dateTemplate = "<span>#= FilDate == null ? '' : kendo.toString(FilDate,'dd-MMM-yyyy') # <br> #= RegDate == null ? '' : kendo.toString(RegDate,'dd-MMM-yyyy') #</span>";
    //var dataBoundEvent = "documentPage.viewResultDatabound('#" + gridId + "')";

    var dataKeyValue = ViewData["RecordId"] != null ? ViewData["RecordId"] : 0;
    var screenCode = ViewData["ScreenCode"] != null ? ViewData["ScreenCode"].ToString() : "";
}


@(Html.Kendo().Grid<DocumentTrademarkResultsViewModel>()
        .Name(gridId)
        .Columns(columns =>
        {
            columns.Bound(a => a.CaseNumber).Title(caseNumberLabel)
                .HtmlAttributes(new { @class = "text-nowrap"});
            columns.Bound(a => a.Country);
            columns.Bound(a => a.SubCase);
            columns.Bound(a => a.CaseType);
            columns.Bound(a => a.TrademarkStatus);
            columns.Bound(a => a.AppNumber).Title(numberTitle).ClientTemplate(numberTemplate);
            columns.Bound(a => a.FilDate).Title(dateTitle).ClientTemplate(dateTemplate);
            //columns.Bound(a => a.PatNumber);
            //columns.Bound(a => a.IssDate).Format("{0:dd-MMM-yyyy}");
            //columns.Bound(a => a.AppTitle);
        })
        .AutoBind(false)
        .Pageable(page => page.PageSizes(true).Refresh(true))
        .Sortable(sort => sort.AllowUnsort(false))
        .DataSource(dataSource => dataSource
            .Ajax()
            .Events(events => events.RequestEnd("documentPage.searchResultGridRequestEnd"))
            .PageSize(Model.GridPageSize)
            .Read(read => read.Action("PageRead", "DocTrademark").Data("documentPage.gridMainSearchFilters"))
            .Sort(sort => sort.Add(a => a.CaseNumber))
         )
        .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
        .Events(events => events.Change("documentPage.loadDocumentTree"))
        .HtmlAttributes(new { @class = "kendo-Grid" })


    )

<style>
    .k-grid td, .k-listview .col {
        font-size: smaller !important;
    }
</style>

<script>
    $(document).ready(function () {
        if (@dataKeyValue > 0) {
            documentPage.initializeSearchResultPage({
                resultGridId: "#@gridId",
                screenCode: "@screenCode",
                defaultRecordId: "@dataKeyValue"

            });

            @*var combobox = $("#ScreenCode_documentSearch").data("kendoComboBox");
            var len = combobox.dataSource._data.length;
