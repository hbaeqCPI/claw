                    }
                }
            }
            var resultGrid = $('#@gridId').data("kendoGrid");
            resultGrid.dataSource.read({ keyId:@dataKeyValue}).then(function () { resultGrid.select("tr:eq(1)"); documentPage.loadDocumentTree(this); });*@
        }

     });
</script>