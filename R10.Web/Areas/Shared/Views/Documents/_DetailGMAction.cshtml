@model DocGMActViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<PatSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var headerLabel = Model.CaseNumber + (string.IsNullOrEmpty(Model.SubCase) ? "" : "-" + Model.SubCase) +
                        " -  " + Model.ActionType + " (" + Model.BaseDate.ToString("dd-MMM-yyyy") + ")";

    var caseNumberLabel = settings.IsClientMatterOn ? Localizer[settings.LabelClientMatter] : Localizer[settings.LabelCaseNumber];
    var clientNameLabel = Localizer[settings.LabelClientName];
}

<div class="page-content">
    <div class="form-row">
        <div class="col">
            <span id="patActionDocumentHeader"><b>@headerLabel</b></span>
        </div>
        <div class="col d-flex justify-content-end">
            <span style="font-style: italic">@Localizer["General Matter Action"]</span>
        </div>
    </div>
</div>

<div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="patActionDocumentTab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="gmActionDetailTab" data-toggle="tab" role="tab" aria-controls="gmActionDetailTabContent" aria-selected="true" href="#gmActionDetailTabContent">@Localizer["Patent Action Details"]</a>
        </li>
    </ul>
    <div class="tab-content">
        <div class="tab-pane show active" id="gmActionDetailTabContent" role="tabpanel" aria-labelledby="gmActionDetailTab">
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="CaseNumber">@caseNumberLabel</label>
                        <input type="text" class="form-control form-control-sm" asp-for="CaseNumber" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="SubCase"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="SubCase" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterType" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="EffectiveOpenDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="EffectiveOpenDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="TerminationEndDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="TerminationEndDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterStatus"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterStatus" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="MatterTitle"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="MatterTitle" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col">
                    <div class="form-group float-label">
                        <label asp-for="ResultRoyalty"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="ResultRoyalty" readonly />
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col-8">
                    <div class="form-group float-label">
                        <label asp-for="ActionType"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="ActionType" readonly />
                    </div>
                </div>
                <div class="col-4">
                    <div class="form-group float-label">
                        <label asp-for="BaseDate"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="BaseDate" asp-format="{0:dd-MMM-yyyy}" readonly />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
