    ul.doc-settings {
        margin: 0;
        padding: 0;
        list-style: none;
    }

        ul.doc-settings li {
            display: inline-block;
            width: 15em;
        }

            ul.doc-settings li input {
                margin-right: .25em;
            }

            ul.doc-settings li label {
                margin-left: 5px;
            }
</style>