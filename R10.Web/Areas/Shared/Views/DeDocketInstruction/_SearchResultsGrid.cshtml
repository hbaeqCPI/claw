@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<DeDocketInstruction>()
                .Name($"{Model.PageId}-Grid")
                .Columns(columns =>
                {
                    columns.Bound(m => m.Instruction).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: InstructionId#", fromSearch = true }), "Instruction")).Width(400);
                    columns.Bound(m => m.Description);
                })
                .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                .AutoBind(false)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                //.ColumnMenu()
                .Excel(excel => excel.FileName("InstructionList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DeDocketInstruction")))
                .DataSource(dataSource => dataSource
                .Ajax().Events(events => events.Error("deDocketInstructionPage.searchResultGridError"))
                .Events(events => events.RequestEnd("deDocketInstructionPage.searchResultGridRequestEnd"))
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                .Read(read => read.Action("PageRead", "DeDocketInstruction")
                .Data("deDocketInstructionPage.gridMainSearchFilters")
                )
                .Sort(sort => sort.Add(m => m.Instruction))
                )
                .HtmlAttributes(new { @class = "kendo-Grid" })
)
