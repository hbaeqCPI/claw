@model PageViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var ownerLabel = settings.LabelOwner;
    var ownerNameLabel = settings.LabelOwnerName;
}

@(Html.Kendo().Grid<OwnerSearchResultViewModel>()
                                        .Name($"{Model.PageId}-Grid")
                                        .Columns(columns =>
                                        {
                                            columns.Bound(c => c.OwnerCode).Title(SharedLocalizer[ownerLabel])
                                                    .ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: OwnerID#", fromSearch = true }), "OwnerCode"))
                                                    .Width(200);
                                            columns.Bound(c => c.OwnerName).Title(SharedLocalizer[ownerNameLabel]);
                                            columns.Bound(c => c.CreatedBy).Hidden();
                                            columns.Bound(c => c.UpdatedBy).Hidden();
                                            columns.Bound(c => c.DateCreated).Format("{0:dd-MMM-yyyy}").Hidden();
                                            columns.Bound(c => c.LastUpdate).Format("{0:dd-MMM-yyyy}").Hidden();
                                        })
                                        .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), SharedLocalizer["Add"], SharedLocalizer["Export to Excel"])))
                                        .AutoBind(false)
                                        .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                                        .Sortable(sort => sort.AllowUnsort(false))
                                        //.Selectable(selectable=>selectable.Mode(GridSelectionMode.Single))
                                        //.ColumnMenu()
                                        .Excel(excel => excel.FileName($"{ownerLabel}List.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "Owner")))
                                        .DataSource(dataSource => dataSource
                                            .Ajax()
                                            .Events(events => events.Error("ownerPage.searchResultGridError"))
                                            .Events(events => events.RequestEnd("ownerPage.searchResultGridRequestEnd"))
                                            .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                                            .Read(read => read.Action("PageRead", "Owner")
                                            .Data("ownerPage.gridMainSearchFilters")
                                            )
                                        .Sort(sort => sort.Add(c => c.OwnerName))
                                    )
                                    .HtmlAttributes(new { @class = "kendo-Grid" })

)
