@model int
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings

@{
    var settings = await Settings.GetSetting();
    int id = Model;
    bool addMode = id == 0;
    var noRecord = id < 0;

    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    bool fullModify = detailPagePermission.CanEditRecord && !noRecord;        // no edit remarks only for letters
    var systemType = ViewData["SystemType"].ToString();
    IDictionary<string, object> htmlAttributes = new Dictionary<string, object>();
    htmlAttributes.Add("maxlength", "50");
}
<div id="letterTagsGridContainer">
    @(Html.Kendo().Grid<LetterTagViewModel>()
        .Name("letterTagsGrid")
        .Columns(column =>
        {
            column.Bound(t => t.LetId).Hidden();
            column.Bound(t => t.LetTagId).Hidden();
            column.Bound(t => t.Tag)
            .Editable("letterSetup.isGridColumnEditable")
            .EditorTemplateName("ComboBox")
            .EditorViewData(new
            {
                action = "GetLetterTags",
                controller = "LetterSetup",
                area = "Shared",
                limitToList = false,
                dataValueField = "",
                htmlAttributes = htmlAttributes
            })
            .Width(50)
            .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
            column.Command(command =>
            {
                if (detailPagePermission.CanDeleteRecord)
                    command.Custom("Delete")
                .Click("function(e) {letterSetup.deleteGridRow(e,this)}")
                .IconClass("k-icon fal fa-trash-alt")
                .Text($"<span class='grid-action-label'>{Localizer["Delete"]}</span>")
                .HtmlAttributes(new { @class = "grid-action" });
            }).Width(10);
        })
        .AutoBind(false)
        .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
        .ToolBar(toolbar =>
        {
            if (detailPagePermission.CanAddRecord && !addMode)
            {
                toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"]).HtmlAttributes(new { @class = "grid-action" });
            }
            if (detailPagePermission.CanEditRecord)
            {
                toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
            }
        })
        .Editable(editable => editable
        .Enabled(fullModify)
        .Mode(GridEditMode.InCell)
        .ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false)
        )
        .Pageable(page => page.PageSizes(true).Refresh(true))
        .Scrollable()
        .Sortable(sortable => sortable.SortMode(GridSortMode.SingleColumn).ShowIndexes(true))
        .DataSource(dataSource => dataSource
        .Ajax()
        .PageSize(settings.SubFormPageSize)
        .ServerOperation(false) //allow pending changes to persist when paging or sorting
        .Model(model =>
        {
            model.Id(t => t.LetTagId);
        })
        .Read(read => read.Action("LetterTagsRead", "LetterSetup", new { parentId = id }))
        .Update(update => update.Action("LetterTagsUpdate", "LetterSetup"))
        .Destroy(update => update.Action("LetterTagDelete", "LetterSetup"))
        .Events(events =>
        {
            events.Error("pageHelper.onGridError");
        })
        .Sort(sort => sort.Add(t => t.Tag))
        )
        .HtmlAttributes(new { @class = "kendo-Grid" })
        )
</div>