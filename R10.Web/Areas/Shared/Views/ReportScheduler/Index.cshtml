@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Report Scheduler"];
    ViewData["ActivePage"] = "ReportSchedulerPage"; //js filename
}

@*@section Scripts {
        <script src="~/js/@(ViewBag.ActivePage).js" asp-append-version="true"></script>
    }*@

@if (Model.Page == PageType.Search)
{
    @await Html.PartialPageAsync(Model.Page, Model)

    <script>
        $(document).ready(function () {
            ReportSchedulerPage.scheduleNameSearchValueMapperUrl = "@Url.Action("ScheduleNameSearchValueMapper", "ReportScheduler")";
        });
    </script>
}
else
{
    @await Html.PartialPageAsync(Model.Page, Model)
}
