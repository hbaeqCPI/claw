@model ChildQuickEmailSetupViewModel

@using Microsoft.Extensions.Options;
@using R10.Web.Services;
 
@inject IStringLocalizer<QuickEmailResource> Localizer
@inject IOptions<SmtpSettings> SmtpSettings
@{
    var id = Model.Id;
    var addMode = id == 0;
    var permission = Model.Permission;
    var isReadOnly = !permission.CanEditRecord || permission.CanEditRemarksOnly;
    var smtpSettings = SmtpSettings.Value;

    var anchorCodeLinkUrl = Url.Action("DetailLink", "DocuSignAnchor", new
    {
        anchorCode = "actualValue"
    });
    var anchorCodeTemplate = $"<span class='pr-3'>#=AnchorCode ? kendo.htmlEncode(AnchorCode) : ''#</span><i style='#=AnchorCode ? '' : 'display:none'#' class='fal fa-search-plus btn-link anchorCodeLink' data-url='{anchorCodeLinkUrl}' title='{Localizer["Open eSignature Tabs Screen"]}'></i>";

}

<div class="row">
    <div id="recipientContainer" class="col-md-6">
        <h5>@Localizer["Recipient"]</h5>
        @(
            Html.Kendo().Grid<QuickEmailSetupRecipientViewModel>()
                                                         .Name("qeSetupRecipientGrid")
                                                         .Columns(columns =>
                                                         {
                columns.Bound(r => r.QERoleSource).ClientTemplate("#=kendo.htmlEncode(QERoleSource.RoleName)#").Width(250).EditorTemplateName("QERoleSource").EditorViewData(new { id = "qeRecipientGrid_RoleName", systemType = Model.SystemType,screenName = Model.ParentViewModel.ScreenName });
                                                             columns.Bound(r => r.SendAs).ClientTemplate("#= (SendAs == null) ? '': kendo.htmlEncode(SendAs)#").EditorTemplateName("DropDownList").EditorViewData(new { action = "GetSendAsData", controller = "QuickEmailSetup", area = "Shared", property = "" }).Width(40);
                                                             columns.Bound(r => r.RoutingOrder).Width(30);
                                                             columns.Bound(r => r.AnchorCode).ClientTemplate(anchorCodeTemplate).EditorTemplateName("AnchorCode");

                                                                 @*columns.Bound(r => r.AnchorCode).EditorTemplateName("ComboBox").EditorViewData(new { action = "GetAnchorCodes", area="Shared", controller = "DocuSignTab",property="AnchorCode" });*@

                                                                 columns.Command(command =>
                                                                                              {
                                                     if (permission.CanDeleteRecord)
                                                         command.Custom("Delete").Click("function(e) {quickEmailSetup.deleteGridRow(e,this)}").IconClass("k-icon fal fa-trash-alt")
                                                         .Text(Localizer["Delete"]);

                                                 }).Width(10);
                                                             })
                                             .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
                                             .ToolBar(toolbar =>
                                             {
                                                 if (permission.CanAddRecord && addMode)
                                                 {
                                                     toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"]);
                                                 }
                                                 if (permission.CanEditRecord && !permission.CanEditRemarksOnly)
                                                 {
                                                     toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                                                     toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
                                                 }

                                             })
                                             .Editable(editable => editable.Enabled(permission.CanEditRecord && !permission.CanEditRemarksOnly)
                                                 .Mode(GridEditMode.InCell).
                                                 ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))

                                             .DataSource(dataSource => dataSource
                                                 .Ajax()
                                                 .Batch(true)
                                                 .PageSize(10)
                                                 .Model(model =>
                                                 {
                                                     model.Id(r => r.RecipientID);
                                                     model.Field(r => r.QERoleSource).DefaultValue(new QERoleSource());
                                                     model.Field(r => r.SendAs).DefaultValue("To");
                                                     model.Field(r => r.RoutingOrder).DefaultValue(1);
                                                 })
                                             .Read(read => read.Action("RecipientRead", "QuickEmailSetup").Data($"{{qeSetupId: {Model.ParentViewModel.QESetupID} }}"))
                                             .Update(update => update.Action("RecipientsUpdate", "QuickEmailSetup"))
                                             .Destroy(update => update.Action("RecipientDelete", "QuickEmailSetup"))
                                             .Events(events =>
                                             {
                                                 events.Error("pageHelper.onGridError");
                                             })
                                         )
                                         .HtmlAttributes(new { @class = "mb-2 kendo-Grid" })
              )
    </div>
    
</div>

