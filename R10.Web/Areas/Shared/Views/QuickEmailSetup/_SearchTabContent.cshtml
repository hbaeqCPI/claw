@model PageViewModel
@inject IStringLocalizer<QuickEmailResource> Localizer
@{
    var additionalFilter = $"{{systemType: '{Model.SystemType}'}}";
}

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="qeSetupSearchMainTabContent" aria-labelledby="qeSetupSearchMainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-6">
                <input type="hidden" name="SystemType" value="@Model.SystemType" />
                <div class="form-group float-label">
                    <label for="qeSetup">@Localizer["Template Name"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "TemplateName", data = additionalFilter })
                </div>
            </div>
            @*<div class="col-md-6">
            <div class="form-group float-label">
            <label for="qeSetup">@Localizer["Page Name"]</label>
            @await Component.InvokeAsync("ComboBox", new { name = "PageName" })
            </div>
            </div>*@
        </div>
        <div class="form-row">
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label for="QECatId">@Localizer["Category"]</label>
                    @await Component.InvokeAsync("ComboBox", new
                        {
                            name = "QECatId_Search",
                            textProperty = "QECat",
                            valueProperty = "QECatId",
                            controller = "QuickEmailCategory",
                            area = "Shared",
                            action = "GetQECategoryList",
                        })
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label for="Tags">@Localizer["Tags"]</label>
                    @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
               {
                   Controller = "QuickEmailSetup",
                   Area = "Shared",
                   Action = "GetTagPickListData",
                   Name = "Tag",
                   DataTextProperty = "Tag",
                   DataValueProperty = "Tag",
               })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="CreatedBy">@Localizer["Created By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CreatedBy", data = additionalFilter })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedFrom">@Localizer["Date Created From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedTo">@Localizer["Date Created To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedTo"))
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="UpdatedBy">@Localizer["Updated By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "UpdatedBy", data = additionalFilter })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateFrom">@Localizer["Last Update From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateTo">@Localizer["Last Update To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateTo"))
                </div>
            </div>
        </div>
    </div>
</div>