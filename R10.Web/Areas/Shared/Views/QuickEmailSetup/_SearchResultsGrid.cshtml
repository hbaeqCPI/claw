@model PageViewModel
@inject IStringLocalizer<QuickEmailResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<QEMain>()
      .Name($"{Model.PageId}-Grid")
      .Columns(columns =>
      {
          columns.Bound(m => m.TemplateName).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: QESetupID#", fromSearch = true }), "TemplateName")).Width(300);
      })
      .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true,systemType=Model.SystemType}), Localizer["Add"], Localizer["Export to Excel"])))
      .AutoBind(false)
      .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
      .Sortable(sort => sort.AllowUnsort(false))
      //.ColumnMenu()
      // .Excel(excel => excel.FileName("QuickEmailSetupList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "QuickEmailSetup")))
      .DataSource(dataSource => dataSource
          .Ajax().Events(events => events.Error("quickEmailSetup.searchResultGridError"))
          .Events(events => events.RequestEnd("quickEmailSetup.searchResultGridRequestEnd"))
          .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
          .Read(read => read.Action("PageRead", "QuickEmailSetup")
              .Data("quickEmailSetup.gridMainSearchFilters")
          )
          .Sort(sort => sort.Add(m => m.TemplateName))
      )
      .HtmlAttributes(new { @class = "kendo-Grid" })
      )
