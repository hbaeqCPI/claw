@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Product Import Utility"];
}

<div>
    <ul class="nav nav-tabs nav-tabs-horizontal flush-left" id="ptoImport-tab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="ptoImport-tab" data-toggle="tab" role="tab" aria-controls="ptoImport" aria-selected="true" href="#ptoImport">@Localizer["Import Product Data"] </a>
        </li>        
    </ul>
</div>
<div class="tab-content" id="product-import-main">
    <div class="tab-pane page-content fade show active px-4" id="ptoImport" role="tabpanel" aria-labelledby="ptoImport">
        @await Html.PartialAsync("_Import")
    </div>   
</div>
<div class="cpiContainerPopup"></div>
<style>
    .page-content {
        padding: 0px 0px;
    }
</style>