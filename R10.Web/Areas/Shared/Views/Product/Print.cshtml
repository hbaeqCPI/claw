@using  R10.Web.Areas
@inject IStringLocalizer<SharedResource> Localizer
@model ProductPrintViewModel

@{
    Layout = "";
}

<form method="post"
      id="ReportCriteriaForm"
      data-url="@ViewBag.Url">
    <div class="col-sm-12">
        <div class="row">
            <div class="col-sm-6" style="text-align:left">
                <div class="form-group">
                    <input asp-for="PrintChart" type="checkbox" checked />
                    <label>@Localizer["Charts"]</label>
                </div>
                @if (User.IsInSystem(SystemType.GeneralMatter))
                {
                    <div class="form-group">
                        <input asp-for="PrintRelatedMatters" type="checkbox" checked />
                        <label>@Localizer["Related General Matters"]</label>
                    </div>
                }
                @if (User.IsInSystem(SystemType.Patent))
                {
                    <div class="form-group">
                        <input asp-for="PrintRelatedPatents" type="checkbox" checked />
                        <label>@Localizer["Related Patents"]</label>
                    </div>
                }
                <div class="form-group">
                    <input asp-for="PrintRelatedProducts" type="checkbox" checked />
                    <label>@Localizer["Related Products"]</label>
                </div>
            </div>
            
            <div class="col-sm-6" style="text-align:left">
                @if (User.IsInSystem(SystemType.Trademark))
                {
                    <div class="form-group">
                        <input asp-for="PrintRelatedTrademarks" type="checkbox" checked />
                        <label>@Localizer["Related Trademarks"]</label>
                    </div>
                }
                <div class="form-group">
                    <input asp-for="PrintSales" type="checkbox" checked />
                    <label>@Localizer["Sales"]</label>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-12" hidden>
        <div class="form-group">
            <label for="ReportFormat">@Localizer["Report Format"]</label>
            <input id="ReportFormat" asp-for="ReportFormat" />
        </div>
        <div class="form-group">
            <label for="IDs">@Localizer["IDs"]</label>
            <input id="IDs" asp-for="IDs" type="text" value="" />
        </div>
        <div class="form-group">
            <input id="DownloadName" type="text" value="@ViewBag.DownloadName" />
        </div>
    </div>
</form>