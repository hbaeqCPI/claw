@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{ 
    var settings = await Settings.GetSetting(); 
    string formId = $"{Model.PageId}-RefineSearch";
    var initialButtonGroup = await Component.InvokeAsync("InitialButtonGroup", new InitialButtonGroupOptions { Name = "ProductCodeInitial", FormId = formId });
}

@(Html.Kendo().Grid<ProductSearchResultViewModel>()
                    .Name($"{Model.PageId}-Grid")
                    .Columns(columns =>
                    {
                        columns.Bound(m => m.ProductCode).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: ProductId#", fromSearch = true }), "ProductCode")).Width(200);
                        columns.Bound(m => m.ProductName);
                    })
                    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(initialButtonGroup, Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                    .AutoBind(false)
                    .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                    .Sortable(sort => sort.AllowUnsort(false))
                    //.ColumnMenu()
                    .Excel(excel => excel.FileName("ProductList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "Area")))
                    .DataSource(dataSource => dataSource
                        .Ajax().Events(events => events.Error("productPage.searchResultGridError"))
                        .Events(events => events.RequestEnd("productPage.searchResultGridRequestEnd"))
                        .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                        .Read(read => read.Action("PageRead", "Product")
                        .Data("productPage.gridMainSearchFilters")
                    )
                    .Sort(sort => sort.Add(m => m.ProductCode))
                    )
                    .HtmlAttributes(new { @class = "kendo-Grid" })
)
