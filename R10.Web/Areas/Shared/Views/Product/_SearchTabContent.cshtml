@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="productSearchMainTabContent" aria-labelledby="productSearchMainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ProductCode">@Localizer["Product Code"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "ProductCode", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ProductName">@Localizer["Product"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "ProductName", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-8">
                <div class="form-group float-label">
                    <label for="Description">@Localizer["Description"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Description", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-8">
                <div class="form-group float-label">
                    <label for="MarketingClaims">@Localizer["Marketing Claims"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "MarketingClaims", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ProductName">@Localizer["Product Group"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "ProductGroup", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ProductName">@Localizer["Product Category"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "ProductCategory", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ProductName">@Localizer["Brand"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Brand", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-8">
                <div class="form-group float-label">
                    <label for="Description">@Localizer["Supplier"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Supplier", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-8">
                <div class="form-group float-label">
                    <label for="Description">@Localizer["Manufacturer"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Manufacturer", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ProductName">@Localizer["Country of Origin"]</label>
                    @await Component.InvokeAsync("ComboBox", ComboBoxHelper.Country("Country", Localizer["Country"], Localizer["Country Name"]))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="ProductName">@Localizer["Country Name"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CountryName", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group">
                    <label for="ActiveSwitch">@Localizer["Active Switch"]</label>
                    <div>
                        <div class="btn-group btn-group-toggle" data-toggle="buttons">
                            <label class="btn btn-outline">
                                <input type="radio" name="Active" class="form-control" value="true" data-role="option"> @Localizer["Active"]
                            </label>
                            <label class="btn btn-outline">
                                <input type="radio" name="Active" class="form-control" value="false" data-role="option"> @Localizer["Inactive"]
                            </label>
                            <label class="btn btn-outline active">
                                <input type="radio" name="Active" class="form-control" value="" data-role="option"> @Localizer["All"]
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-8">
                <div class="form-group float-label">
                    <label for="Remarks">@Localizer["Remarks"]</label>
                    <input type="text" class="form-control" id="Remarks" name="Remarks" />
                </div>
            </div>
        </div>
        <div class="form-row mt-4">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="CreatedBy">@Localizer["Created By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CreatedBy", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedFrom">@Localizer["Date Created From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="DateCreatedTo">@Localizer["Date Created To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedTo"))
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="UpdatedBy">@Localizer["Updated By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "UpdatedBy", controller = "Product", area = "Shared", screen = Model.PageId })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateFrom">@Localizer["Last Update From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateFrom"))
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="LastUpdateTo">@Localizer["Last Update To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateTo"))
                </div>
            </div>
        </div>
    </div>
</div>