@inject IStringLocalizer<SharedResource> Localizer

<div>
    @(Html.Kendo().Grid<GSDocCriteriaViewModel>()
            .Name("gridDocFilter")
            .Columns(columns =>
            {
                columns.Bound(f => f.Field).ClientTemplate("#=kendo.htmlEncode(Field.FieldLabel)#").HtmlAttributes(new { @class = "editable-cell" });
                columns.Bound(f => f.Criteria).HtmlAttributes(new { @class = "editable-cell" });
                columns.Bound(f => f.DocSearchMode).EditorTemplateName("GSDocSearchMode").Width(150);
                columns.Bound(f => f.DocQueryType).EditorTemplateName("GSDocQueryType").Width(150);
                columns.Command(command =>
                {
                    command.Custom("Delete").IconClass("k-icon fal fa-trash-alt").Text(" ").Click("globalSearch.deleteFilterRow");
                }).Width(70);
            })
            .AutoBind(false)
            .ToolBar(toolbar =>
            {
                toolbar.ClientTemplateId("gridToolbarTemplate");
            })
            .Editable(editable => editable.Enabled(true).Mode(GridEditMode.InCell).ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
            .Navigatable()
            .Scrollable()
            .DataSource(dataSource => dataSource
                .Ajax()
                .Batch(true)
                .ServerOperation(true)
                .Model(model => {
                    model.Id(f => f.FieldId);
                    model.Field(f => f.Field).DefaultValue(new GSFieldListViewModel { FieldLabel = "" });
                    model.Field(f => f.DocSearchMode).DefaultValue("Any");
                    model.Field(f => f.DocQueryType).DefaultValue("Simple");
                })
                .Read(read => read.Action("GridDocFilterRead", "GlobalSearch"))
            )
        //.HtmlAttributes(new { @class = "kendo-Grid" })
        )
</div>

