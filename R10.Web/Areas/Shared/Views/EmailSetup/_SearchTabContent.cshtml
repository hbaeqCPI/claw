@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    var systemType = ViewData["SystemType"]?.ToString();
}
<div class="tab-content search page-content">
    <div class="tab-pane show active" id="emailSetupSearchTabContent" aria-labelledby="emailSetupSearchTab" role="tabpanel">
        <input type="hidden" id="SystemType" name="SystemType" value="@systemType" />
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">
                    <label for="Name">@Localizer["Name"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Name", requiredRelation = systemType })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">
                    <label for="Description">@Localizer["Description"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Description", requiredRelation = systemType })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">
                    <label for="EmailContentType.Description">@Localizer["Notification Type"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "EmailContentType.Description", textProperty = "Description", action = "GetContentTypeList", requiredRelation = systemType })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">
                    <label for="EmailTemplate.Name">@Localizer["Template"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "EmailTemplate.Name", textProperty = "Name", action = "GetEmailTemplateList" })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">
                    <label for="EmailSetups.Language">@Localizer["Language"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "EmailSetups.Language", textProperty = "Language", controller = "EmailSetupDetail" })
                </div>
            </div>
        </div>
        <div class="form-row mt-4">
            <div class="col">
                <div class="form-group float-label">
                    <label for="CreatedBy">@Localizer["Created By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CreatedBy", requiredRelation = systemType })
                </div>
            </div>
            <div class="col">
                <div class="form-group float-label">
                    <label for="DateCreatedFrom">@Localizer["Date Created From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedFrom"))
                </div>
            </div>
            <div class="col">
                <div class="form-group float-label">
                    <label for="DateCreatedTo">@Localizer["Date Created To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("DateCreatedTo"))
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">
                    <label for="UpdatedBy">@Localizer["Updated By"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "UpdatedBy", requiredRelation = systemType })
                </div>
            </div>
            <div class="col">
                <div class="form-group float-label">
                    <label for="LastUpdateFrom">@Localizer["Last Update From"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateFrom"))
                </div>
            </div>
            <div class="col">
                <div class="form-group float-label">
                    <label for="LastUpdateTo">@Localizer["Last Update To"]</label>
                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("LastUpdateTo"))
                </div>
            </div>
        </div>
    </div>
</div>