@model int
@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    var detailsUrl = Url.Action("Detail", "EmailSetupDetail", new { id = "#: EmailSetupId#", fromSearch = true });
    var detailsLinkTemplate = $"<a href={detailsUrl} class='details-link' >#: Language#</a> <span class='ml-2 badge badge-pill badge-info #=Default ? '' : 'd-none'#' title='{SharedLocalizer["Default Inventor"]}'>{SharedLocalizer["Default"]}</span>";
}

        @(Html.Kendo().Grid<EmailSetupListViewModel>()
            .Name("emailSetupGrid")
            .Columns(columns =>
            {
                columns.Bound(e => e.Language).ClientTemplate(detailsLinkTemplate);
                columns.Bound(e => e.Subject);
                columns.Command(command =>
                {
                    command.Custom("Preview")
                            .Click($"function(e) {{{ViewBag.ActivePage}.preview(e,this)}}")
                            .IconClass("k-icon fal fa-search")
                            .Text($"<span class='grid-action-label'>{SharedLocalizer["Preview"]}</span>")
                            .HtmlAttributes(new { @class = "grid-action", data_url = Url.Action("Preview", "EmailSetupDetail") });
                    if (detailPagePermission.CanDeleteRecord)
                        command.Custom("Delete")
                                .Click($"function(e) {{{ViewBag.ActivePage}.deleteGridRow(e,this)}}")
                                .IconClass("k-icon fal fa-trash-alt")
                                .Text($"<span class='grid-action-label'>{SharedLocalizer["Delete"]}</span>")
                                .HtmlAttributes(new { @class = "grid-action" });
                }).HtmlAttributes(new { style = "text-align: right;" });
            })
            .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
            .ToolBar(toolbar =>
            {
                if (detailPagePermission.CanAddRecord)
                {
                    toolbar.Custom().IconClass("k-icon fal fa-plus").Text(SharedLocalizer["Add"]).HtmlAttributes(new { @class = "grid-action details-link", href = Url.Action("Add", "EmailSetupDetail", new { id = Model, fromSearch = true }) });
                }
                if (detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
                {
                    toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(SharedLocalizer["Save"]).HtmlAttributes(new {@class="d-none"});
                    toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(SharedLocalizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
                }

            })
            .AutoBind(false)
            .Editable(editable => editable
                        .Enabled(detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
                        .Mode(GridEditMode.InCell)
                        .ConfirmDelete(@SharedLocalizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
            .Sortable(sort => sort.AllowUnsort(false))
            .Pageable()
            //.Scrollable()
            .DataSource(dataSource => dataSource
            .Ajax()
            .Batch(true)
            //.Batch(detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
            .PageSize(settings.SubFormPageSize)
            .ServerOperation(false)
            .Model(model =>
            {
                model.Id(e => e.EmailSetupId);
                model.Field(e => e.Language).Editable(false);
                model.Field(e => e.Subject).Editable(false);
                model.Field(e => e.Default).Editable(false);
            })
            .Sort(sort => sort.Add("Language").Ascending())
            .Read(create => create.Action("GridRead", "EmailSetupDetail", new {id = Model}))
            //.Update(create => create.Action("GridUpdate", "EmailSetupDetail"))
            .Destroy(create => create.Action("GridDelete", "EmailSetupDetail"))
            .Events(events =>
            {
                events.Error("pageHelper.onGridError");
            })
            )
            .HtmlAttributes(new { @class = "kendo-Grid" })
        )
