@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var agentLabel = settings.LabelAgent;

    ViewData["Title"] = Localizer[agentLabel];
    ViewData["ActivePage"] = "agentPage";
}

@*@section Scripts {
    <script>
        var @ViewBag.ActivePage = new ActivePage();
    </script>
}*@

@await Html.PartialPageAsync(Model.Page, Model)