@model ChildViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<RMSSetting> RMSSettings
@inject ISystemSettings<TmkSetting> TmkSettings
@{    
    var rmsSettings = await RMSSettings.GetSetting();
    var tmkSettings = await TmkSettings.GetSetting();
    var agentIdParam = $"{{agentId: {Model.Id}}}";
    var fullModify = Model.Permission.CanEditRecord && !Model.Permission.CanEditRemarksOnly;   
}  
<style>    
    .k-window-content {
        overflow: hidden !important;
    }

    .k-window-titlebar {
        padding-bottom: 0;
    }

    .k-edit-form-container {
        width: 950px;
        display: flex;
        flex-direction: column;
        box-sizing: border-box;
        flex-grow: 1;
    }

    .k-edit-form-container .modal-body {
        padding: 0;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        overflow: hidden;
    }

    .editor-content-wrapper {
        flex-grow: 1;
        /* overflow-y: auto;  */
        padding: 15px;
        box-sizing: border-box;
    }


    .k-edit-form-footer {
        flex-shrink: 0;
        width: 100%;
        box-sizing: border-box;
    }

    .k-edit-form-container .modal-body .form-row > [class*=col-] {
        padding-right: 10px;
        padding-left: 10px;
    }

    .k-floating-label-container {
        position: relative;
        padding-top: 0px;
    }

    .k-floating-label-container > .k-label, .k-textbox-container > .k-label {
        margin: 0;
        left: 16px !important;
        top: 23px !important;
        position: absolute;
        z-index: 9;
    }

    .agentCEFeeEditor .field-validation-error {
        position: relative !important;
    }
</style>
@(
    Html.Kendo().Grid<AgentCEFee>()
    .Name("agentCEFeesGrid")
    .Columns(columns =>
    {
        columns.Bound(t => t.Country).Width("5%");
        columns.Bound(p => p.SystemTypeName).Width("10%");
        columns.Bound(t => t.CostType).Width("20%");
        columns.Bound(t => t.CurrencyType).Width("10%");
        columns.Bound(t => t.Amount).Format("{0:N}").Width("12%");
        columns.Bound(t => t.OriginatingLanguage).Width("15%");
        columns.Bound(t => t.CostFactors).Width("12%");

        if (Model.Permission.CanEditRecord && !Model.Permission.CanEditRemarksOnly)
        {
            columns.Command(command =>
                {
                    command.Edit().UpdateText("Save").CancelText("Close");
                    if (Model.Permission.CanDeleteRecord)
                        command.Destroy().IconClass("k-icon fal fa-trash-alt");
                }).Width("15%");
        }
    })        
    .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
    .ToolBar(toolbar =>
    {
        if (fullModify)
        {
            toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"])
                .HtmlAttributes(new { @class = "grid-action" });
        }
    })
    .Editable(editable => editable
        .Enabled(Model.Permission.CanEditRecord && !Model.Permission.CanEditRemarksOnly)
        .Mode(GridEditMode.PopUp)
        .TemplateName("CEFeeEditTemplate").Window(w => w.Title(Localizer["Fee Description"]).Events(e => e.Close("function (e) {$('#agentCEFeesGrid').data('kendoGrid').dataSource.read();}")))
        .ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(true)
    )
    .Sortable(sort => sort.AllowUnsort(false))    
    .DataSource(dataSource => dataSource
        .Ajax()
        .PageSize(tmkSettings.SubFormPageSize)
        .Model(model =>
        {
            model.Id(c => c.FeeID);
            model.Field(t => t.AgentID).DefaultValue(Model.Id);
        })
        .Read(create => create.Action("CEFeesRead", "Agent", new { agentId = Model.Id }))
        .Update(create => create.Action("CEFeesUpdate", "Agent", new { isUpdate = true, agentId = Model.Id }))
        .Create(create => create.Action("CEFeesUpdate", "Agent", new { isUpdate = false, agentId = Model.Id }))
        .Destroy(create => create.Action("CEFeesDelete", "Agent"))
        .Events(events =>
        {
            events.Error("pageHelper.onGridError");
        })
    )
    .Events(events =>
    {
        events.Edit("agentPage.agentCEFeesGridEdit");
        events.Save("agentPage.agentCEFeesGridSave");
    })
    .HtmlAttributes(new { @class = "mb-2 k-grid" })
)