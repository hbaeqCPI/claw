@using R10.Web.Areas.Shared.ViewModels.ReportScheduler
@inject IStringLocalizer<SharedResource> SharedLocalizer
@model GridOptions
@inject IStringLocalizer<SharedResource> Localizer
@{
    //var detailPagePermission = Model.Permission ?? (DetailPagePermission)ViewData["PagePermission"];
    //var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    var pageName = ViewBag.ActivePage;
    var id = Model.ParentId;
    bool addMode = id == 0;

    var detailsAddUrl = Url.Action("ActionAdd", Model.Controller, new { actionId = 0 });
    var detailsEditUrl = Url.Action("ActionEdit", Model.Controller, new { actionId = Model.ParentId });
}

    @(Html.Kendo().Grid<RSActionHistoryViewModel>()
                                                .Name("rSActionHistoryGrid")

                                            .Columns(columns =>
                                            {
                                                columns.Bound(a => a.ActionName);
                                                columns.Bound(a => a.OutputFormat);
                                                columns.Bound(a => a.SortOrder);
                                                columns.Bound(a => a.Setting);

                                            })
                                            //.Sortable()
                                            .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
                                            .Editable(editable => editable.Enabled(true)
                                                            .Mode(GridEditMode.InCell).
                                                            ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))

                                            .Pageable()
                                            //.AutoBind(false)
                                            .AutoBind(true)
                                            .DataSource(dataSource => dataSource
                                                .Ajax()
                                                .Batch(true)
                                                .PageSize(10)
                                                //.ServerOperation(false)
                                                .Model(model =>
                                                {
                                                    model.Field(s => s.ActionName).Editable(false);
                                                    model.Field(s => s.OutputFormat).Editable(false);
                                                    model.Field(s => s.SortOrder).Editable(false);
                                                    model.Field(s => s.Setting).Editable(false);

                                                })
                                                .Read(read => read.Action("GridActionHistoryRead", Model.Controller, new { parentId = Model.ParentId }))
                                                .Events(events =>
                                                {
                                                    events.Error("pageHelper.onGridError");
                                                })
                                            )
                                            .HtmlAttributes(new { @class = "k-grid-border" })//, @style =" width:800px;"
    )

