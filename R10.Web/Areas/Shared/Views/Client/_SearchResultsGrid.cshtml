@model PageViewModel
@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();

    var clientLabel = SharedLocalizer[settings.LabelClient];
    var clientNameLabel = SharedLocalizer[settings.LabelClientName];
}

@(Html.Kendo().Grid<ClientSearchResultViewModel>()
                                        .Name($"{Model.PageId}-Grid")
                                        .Columns(columns =>
                                        {
                                            columns.Bound(c => c.ClientCode)
                                                    .Title(clientLabel)
                                                    .ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: ClientID#", fromSearch = true }), "ClientCode"))
                                                    .Width(200);
                                            columns.Bound(c => c.ClientName).Title(clientNameLabel);
                                            columns.Bound(c => c.CreatedBy).Hidden();
                                            columns.Bound(c => c.UpdatedBy).Hidden();
                                            columns.Bound(c => c.DateCreated).Format("{0:dd-MMM-yyyy}").Hidden();
                                            columns.Bound(c => c.LastUpdate).Format("{0:dd-MMM-yyyy}").Hidden();
                                        })
                                        .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), SharedLocalizer["Add"], SharedLocalizer["Export to Excel"])))
                                        .AutoBind(false)
                                        .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                                        .Sortable(sort => sort.AllowUnsort(false))
                                        .Excel(excel => excel.FileName($"{clientLabel}List.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "Client")))
                                        .DataSource(dataSource => dataSource
                                            .Ajax()
                                            .Events(events => events.Error("clientPage.searchResultGridError"))
                                            .Events(events => events.RequestEnd("clientPage.searchResultGridRequestEnd"))
                                            .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                                            .Read(read => read.Action("PageRead", "Client")
                                            .Data("clientPage.gridMainSearchFilters")
                                            )
                                        .Sort(sort => sort.Add(c => c.ClientName))
                                    )
                                    .HtmlAttributes(new { @class = "kendo-Grid" })
)
