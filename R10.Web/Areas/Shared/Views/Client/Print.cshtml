@using  R10.Web.Areas
@inject IStringLocalizer<SharedResource> Localizer
@inject IAuthorizationService AuthorizationService
@model ClientPrintViewModel

@{
    Layout = "";

    var showReviewers = false;
}

<form method="post"
      id="ReportCriteriaForm"
      data-url="@ViewBag.Url">
    <div class="col-sm-12">
        <div class="row">
            <div class="col-sm-6" style="text-align:left">
                <div class="form-group">
                    <input asp-for="PrintContactPerson" type="checkbox" checked />
                    <label>@Localizer["Contact Person"]</label>
                </div>
                @if (User.IsInSystem("Patent") || User.IsInSystem("Trademark"))
                {
                    <div class="form-group">
                        <input asp-for="PrintDesCountries" type="checkbox" checked />
                        <label>@Localizer["Designated Countries"]</label>
                    </div>
                }
            </div>
            <div class="col-sm-6" style="text-align:left">
                @if (showReviewers)
                {
                    <div class="form-group">
                        <input asp-for="PrintReviewers" type="checkbox" checked />
                        <label>@Localizer["Reviewers"]</label>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-sm-12" hidden>
        <div class="form-group">
            <label for="ReportFormat">@Localizer["Report Format"]</label>
            <input id="ReportFormat" asp-for="ReportFormat" />
        </div>
        <div class="form-group">
            <label for="IDs">@Localizer["IDs"]</label>
            <input id="IDs" asp-for="IDs" type="text" value="" />
        </div>
        <div class="form-group">
            <input id="DownloadName" type="text" value="@ViewBag.DownloadName" />
        </div>
    </div>
</form>