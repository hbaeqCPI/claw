@model ClientDetailViewModel
@inject ISystemSettings<DefaultSetting> Settings
@inject ISystemSettings<PatSetting> PATSettings
@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ICountryLookupViewModelService CountryLookupService
@inject IAuthorizationService AuthorizationService
@{
    var settings = await Settings.GetSetting();
    var patSettings = await PATSettings.GetSetting();

    var id = Model.ClientID;
    var addMode = id == 0;

    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;
    bool isReadOnlyRemarks = !(fullModify || detailPagePermission.CanEditRemarksOnly);

    var countryLabel = SharedLocalizer["Country"];
    var countryNameLabel = SharedLocalizer["Country Name"];
    var clientLabel = settings.LabelClient;
    var clientNameLabel = settings.LabelClientName;
    var attorneyLabel = SharedLocalizer["Attorney"];
    var attorneyNameLabel = SharedLocalizer["Attorney Name"];
    var ownerLabel = settings.LabelOwner;

    var childViewModel = new ChildViewModel { Id = id, Permission = detailPagePermission };
    var showReviewers = false;
    var pageId = ViewData["PageId"];

    var hasAMS = false;
    var showPrepay = false;
    var showReminderSettings = false;
    var showCTESettings = false;

    var hasRMS = false;
    var showRMSPrepay = false;

    var hasFF = false;

    Model.Attorney1Label = SharedLocalizer[settings.LabelAttorney1];
    Model.Attorney2Label = SharedLocalizer[settings.LabelAttorney2];
    Model.Attorney3Label = SharedLocalizer[settings.LabelAttorney3];
    Model.Attorney4Label = SharedLocalizer[settings.LabelAttorney4];
    Model.Attorney5Label = SharedLocalizer[settings.LabelAttorney5];

    var showPatCESettings = User.IsInSystem(SystemType.Patent) && (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.CanAccessCostEstimator)).Succeeded;
    var showTmkCESettings = User.IsInSystem(SystemType.Trademark) && (await AuthorizationService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.CanAccessCostEstimator)).Succeeded;
    var showCESettings = showPatCESettings || showTmkCESettings;

    var showIRSettings = User.IsInSystem(SystemType.Patent)
    && (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.CanAccessGermanRemuneration)).Succeeded
    && patSettings.IsInventorRemunerationOn
    && patSettings.IsInventorRemunerationMultiClientsOn;

    var showDMS = false;

    var isShowCustomFieldOn = settings.IsShowCustomFieldOn;
    var showDueDateExtension = User.IsInSystem("Patent") || User.IsInSystem("Trademark") || User.IsInSystem("GeneralMatter");
}

<form cpi-detail-form action="@(detailPagePermission.CanEditRemarksOnly ? "SaveRemarks" :"Save")"
      data-confirm-title="@SharedLocalizer["Please Confirm"]"
      data-copy-success-msg="@SharedLocalizer["Record has been copied successfully."]"
      data-copy-owner-msg="@SharedLocalizer[$"The current {clientLabel} will be copied over to the {ownerLabel} table. Do you want to continue?"]">
    <input type="hidden" asp-for="ClientID" />
    <vc:detail-page-nav-links page-permission="detailPagePermission" title="" add-mode="addMode"></vc:detail-page-nav-links>
    <div class="page-content  detail cpiMainEntry">
        <div class="form-row">
            <div class="col-md-3">
                <div class="form-group float-label">
                    <label for="ClientCode" class="required">@SharedLocalizer[clientLabel]</label>
                    <input type="text" class="form-control form-control-sm" asp-for="ClientCode" asp-is-readonly="@isReadOnly" asp-is-autofocus="@addMode" />
                    <span asp-validation-for="ClientCode"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label for="ClientName" class="required">@SharedLocalizer[clientNameLabel]</label>
                    <input type="text" class="form-control form-control-sm" asp-for="ClientName" asp-is-readonly="@isReadOnly" />
                    <span asp-validation-for="ClientName"></span>
                </div>
            </div>
            <div class="col-md-1 pt-3">
                @if (isReadOnly)
                {
                    @(Html.Kendo().CheckBoxFor(m => m.IsActive).HtmlAttributes(new { id = "Client_IsActive", disabled = "true" }))
                }
                else
                {
                    @(Html.Kendo().CheckBoxFor(m => m.IsActive).HtmlAttributes(new { id = "Client_IsActive" }))
                }
            </div>
            @if (showDMS)
            {
                <div class="col-md-2 pt-3">
                    @if (isReadOnly)
                    {
                        @(Html.Kendo().CheckBoxFor(m => m.UseInDMS).HtmlAttributes(new { id = "Client_UseInDMS", disabled = "true" }))
                    }
                    else
                    {
                        @(Html.Kendo().CheckBoxFor(m => m.UseInDMS).HtmlAttributes(new { id = "Client_UseInDMS" }))
                    }
                </div>
            }
            else
            {
                <input type="hidden" asp-for="UseInDMS" class="boolean" />
            }
        </div>
    </div>
    <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="clientDetailMainTab" data-toggle="tab" role="tab" aria-controls="clientDetailMainTabContent" aria-selected="true" href="#clientDetailMainTabContent">@SharedLocalizer[$"{clientLabel} Info"] </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="clientDetailAddressTab" data-toggle="tab" role="tab" aria-controls="clientDetailAddressTabContent" aria-selected="false" href="#clientDetailAddressTabContent">@SharedLocalizer["Address"]</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="clientDetailPOBoxAddressTab" data-toggle="tab" role="tab" aria-controls="clientDetailPOBoxAddressTabContent" aria-selected="false" href="#clientDetailPOBoxAddressTabContent">@SharedLocalizer["PO Box"]</a>
        </li>
        @if (hasAMS)
        {
            <li class="nav-item">
                <a class="nav-link" id="clientDetailAMSSettingsTab" data-toggle="tab" role="tab" aria-controls="clientDetailAMSSettingsTabContent" aria-selected="false" href="#clientDetailAMSSettingsTabContent">@SharedLocalizer["AMS Settings"]</a>
            </li>
        }
        @if (hasFF)
        {
            <li class="nav-item">
                <a class="nav-link" id="clientDetailFFSettingsTab" data-toggle="tab" role="tab" aria-controls="clientDetailFFSettingsTabContent" aria-selected="false" href="#clientDetailFFSettingsTabContent">@SharedLocalizer["Foreign Filing Settings"]</a>
            </li>
        }
        @if (hasRMS)
        {
            <li class="nav-item">
                <a class="nav-link" id="clientDetailRMSSettingsTab" data-toggle="tab" role="tab" aria-controls="clientDetailRMSSettingsTabContent" aria-selected="false" href="#clientDetailRMSSettingsTabContent">@SharedLocalizer["RMS Settings"]</a>
            </li>
        }
        @if (showCESettings)
        {
            <li class="nav-item">
                <a class="nav-link" id="clientDetailCESettingsTab" data-toggle="tab" role="tab" aria-controls="clientDetailCESettingsTabContent" aria-selected="false" href="#clientDetailCESettingsTabContent">@SharedLocalizer["Cost Estimator Settings"]</a>
            </li>
        }
        @if (showIRSettings)
        {
            <li class="nav-item">
                <a class="nav-link" id="clientDetailIRSettingsTab" data-toggle="tab" role="tab" aria-controls="clientDetailIRSettingsTabContent" aria-selected="false" href="#clientDetailIRSettingsTabContent">@SharedLocalizer["Remuneration Settings"]</a>
            </li>
        }
        @if (!detailPagePermission.HasLimitedRead)
        {
            <li class="nav-item">
                <a class="nav-link @(string.IsNullOrEmpty(Model.Remarks) ? null : "has-remarks")" id="clientDetailRemarksTab" data-toggle="tab" role="tab" aria-controls="clientDetailRemarksTabContent" aria-selected="false" href="#clientDetailRemarksTabContent">@SharedLocalizer["Remarks"]</a>
            </li>
        }
        @if (!addMode)
        {
            <li class="nav-item">
                <a class="nav-link" id="clientDetailContactsTab" data-toggle="tab" role="tab" aria-controls="clientDetailContactsTabContent" aria-selected="false" href="#clientDetailContactsTabContent">@SharedLocalizer["Contact Persons"]</a>
            </li>
            @if (User.IsInSystem("Patent") || User.IsInSystem("Trademark"))
            {
                <li class="nav-item">
                    <a class="nav-link" id="clientDetailDesCountriesTab" data-toggle="tab" role="tab" aria-controls="clientDetailDesCountriesTabContent" aria-selected="false" href="#clientDetailDesCountriesTabContent">@SharedLocalizer["Designated Countries"]</a>
                </li>
            }
            @if (showReviewers)
            {
                <li class="nav-item">
                    <a class="nav-link" id="clientDetailReviewersTab" data-toggle="tab" role="tab" aria-controls="clientDetailReviewersTabContent" aria-selected="false" href="#clientDetailReviewersTabContent">@SharedLocalizer["Reviewers"]</a>
                </li>
            }
            @if (showDueDateExtension)
            {
                <li class="nav-item">
                    <a class="nav-link" id="clientDetailDuedateExtensionTab" data-toggle="tab" role="tab" aria-controls="clientDetailDuedateExtensionTabContent" aria-selected="false" href="#clientDetailDuedateExtensionTabContent">@SharedLocalizer["Due date Extension Settings"]</a>
                </li>
            }
        }
        @if (isShowCustomFieldOn && Model.SysCustomFieldSettings != null && Model.SysCustomFieldSettings.Any())
        {
            <li class="nav-item">
                <a class="nav-link" id="clientCustomFieldTab" data-toggle="tab" role="tab" aria-controls="clientCustomFieldTabContent" aria-selected="false" href="#clientCustomFieldTabContent">@SharedLocalizer[settings.AuxCustomFieldsTabLabel]</a>
            </li>
        }
    </ul>
    <div class="tab-content">
        <div class="tab-pane page-content cpiMainEntry show active" id="clientDetailMainTabContent" role="tabpanel" aria-labelledby="clientDetailMainTab">
            <div class="form-row">
                <div class="col-md-4">
                    <div class="form-group float-label">
                        <label asp-for="Language"></label>
                        @if (isReadOnly)
                        {
                            <input type="text" class="form-control form-control-sm" asp-for="Language" readonly />
                        }
                        else
                        {
                            @await Component.InvokeAsync("ComboBox", ComboBoxHelper.LanguageWithLink("Language", Model.Language))
                        }
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-group float-label">
                        <label asp-for="TaxSchedule"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="TaxSchedule" asp-is-readonly="@isReadOnly" />
                    </div>
                </div>
               @*  <div class="col-md-4 pt-3">
                    @if (isReadOnly)
                    {
                        @(Html.Kendo().CheckBoxFor(m => m.ClientPaidThruCPi).HtmlAttributes(new { id = "ClientPaidThruCPi_IsActive", disabled = "true" }))
                    }
                    else
                    {
                        @(Html.Kendo().CheckBoxFor(m => m.ClientPaidThruCPi).HtmlAttributes(new { id = "ClientPaidThruCPi_IsActive" }))
                    }
                </div> *@

            </div>
            <div class="form-row">
                <div class="col-md-6 col-lg-6 col-xl-4">
                    <div class="form-group float-label">
                        <label asp-for="PhoneNumber"></label>
                        <input type="text" class="form-control form-control-sm" asp-for="PhoneNumber" asp-is-readonly="@isReadOnly" />
