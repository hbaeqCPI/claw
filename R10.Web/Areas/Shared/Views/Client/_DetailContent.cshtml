                            @if (isReadOnly)
                            {
                                <input type="text" class="form-control form-control-sm" asp-for="PatDefaultAtty2Code" disabled />
                            }
                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyWithLink("PatAttorney2ID", attorneyLabel, attorneyNameLabel, Model.PatAttorney2ID, Model.PatDefaultAtty2Code))
                                <span asp-validation-for="PatAttorney2ID"></span>
                            }
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-3 col-xl-2">
                        <div class="form-group float-label">
                            <label>@Model.Attorney3Label</label>
                            @if (isReadOnly)
                            {
                                <input type="text" class="form-control form-control-sm" asp-for="PatDefaultAtty3Code" disabled />
                            }
                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyWithLink("PatAttorney3ID", attorneyLabel, attorneyNameLabel, Model.PatAttorney3ID, Model.PatDefaultAtty3Code))
                                <span asp-validation-for="PatAttorney3ID"></span>
                            }
                        </div>
                    </div>

                    <div class="col-sm-6 col-md-6 col-lg-4 col-xl-2">
                        <div class="form-group float-label">
                            <label>@Model.Attorney4Label</label>
                            @if (isReadOnly)
                            {
                                <input type="text" class="form-control form-control-sm" asp-for="PatDefaultAtty4Code" disabled />
                            }
                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyWithLink("PatAttorney4ID", attorneyLabel, attorneyNameLabel, Model.PatAttorney4ID, Model.PatDefaultAtty4Code))
                                <span asp-validation-for="PatAttorney4ID"></span>
                            }
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-5 col-xl-2">
                        <div class="form-group float-label">
                            <label>@Model.Attorney5Label</label>
                            @if (isReadOnly)
                            {
                                <input type="text" class="form-control form-control-sm" asp-for="PatDefaultAtty5Code" disabled />
                            }
                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyWithLink("PatAttorney5ID", attorneyLabel, attorneyNameLabel, Model.PatAttorney5ID, Model.PatDefaultAtty5Code))
                                <span asp-validation-for="PatAttorney5ID"></span>
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="PatAttorney1ID" />
                <input type="hidden" asp-for="PatAttorney2ID" />
                <input type="hidden" asp-for="PatAttorney3ID" />
                <input type="hidden" asp-for="PatAttorney4ID" />
                <input type="hidden" asp-for="PatAttorney5ID" />
            }

            @if (User.IsInSystem("Trademark"))
            {
