                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyWithLink("TmkAttorney3ID", attorneyLabel, attorneyNameLabel, Model.TmkAttorney3ID, Model.TmkDefaultAtty3Code))
                                <span asp-validation-for="TmkAttorney3ID"></span>
