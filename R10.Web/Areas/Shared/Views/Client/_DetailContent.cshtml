                            <label>@Model.Attorney1Label</label>
                            @if (isReadOnly)
                            {
                                <input type="text" class="form-control form-control-sm" asp-for="PatDefaultAtty1Code" disabled />
                            }
                            else
                            {
                                @await Component.InvokeAsync("ComboBox", ComboBoxHelper.AttorneyWithLink("PatAttorney1ID", attorneyLabel, attorneyNameLabel, Model.PatAttorney1ID, Model.PatDefaultAtty1Code))
                                <span asp-validation-for="PatAttorney1ID"></span>
                            }
                        </div>
                    </div>
                    <div class="col-sm-6 col-md-6 col-lg-3 col-xl-2">
                        <div class="form-group float-label">
