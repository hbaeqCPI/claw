@model LetterDataSourcePageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    var pageId = Model.PageId;
    var systemType = Model.SystemType;
}

<ul class="nav nav-tabs refine-search nav-tabs-vertical" role="tablist">
    <li class="nav-item">
        <a id="@(pageId)MainTab" href="#@(pageId)MainTabContent" class="nav-link active" data-toggle="tab" role="tab"
           aria-controls="@(pageId)MainTabContent" title="@Localizer["Main"]">@Localizer["Main"]</a>
    </li>
</ul>

<div class="accordion-content show">
    <div class="tab-pane show form-sidebar active" id="@(pageId)MainTabContent" aria-labelledby="@(pageId)MainTab" role="tabpanel">
        <form cpi-detail-form form-name="letterDataSourceSearchForm">
            <div class="form-row">
                <div class="col-md-4">
                    <div class="form-group float-label">
                        <label for="DataSourceDescMain">@Localizer["Data Source"]</label>
                        @await Component.InvokeAsync("ComboBox", new { name = "DataSourceDescMain", action = "GetPicklistData", controller = "LetterDataSourceSetup", area = "Shared", screen = pageId, data = $"{{system: '{Model.SystemType}'}}" })
                    </div>
                </div>
            </div>
            <div class="form-row">
                <div class="col-md-4">
                    <div class="form-group float-label">
                        <label for="LetCatId">@Localizer["Category"]</label>
                        @await Component.InvokeAsync("ComboBox", new { name = "LetterCategory.LetCatDesc", textProperty = "LetCatDesc", controller = "LetterCategory", area = "Shared", action = "GetCategoryList", screen = pageId })
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
