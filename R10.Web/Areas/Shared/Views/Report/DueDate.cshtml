<script type="text/javascript">
    var byTitleLabel = '@Localizer["by Title"]';
    var byTrademarkLabel = '@Localizer["by Trademark"]';
    var byTitleOrTrademarkLabel = '@Localizer["by Title or Trademark"]';

    const printImageDetail = document.getElementById("PrintImageDetail");
    const printImage = document.getElementById("PrintImage");

    function PrintImageChanged() {
        if (printImage && !printImage.checked && printImageDetail) {
            printImageDetail.checked = false;
        }
    }

    function PrintImageDetailChanged() {
        if (printImageDetail && printImageDetail.checked && printImage) {
            printImage.checked = true;
        }
    }

    function PrintSystemChanged() {
        CombineSystems();
        var systems = document.getElementById("PrintSystems").value;
        rebindDataSource('@actionTypeDataSourceUrl', systems, $('#ActionTypes_Options_DueDateList'), $('#ActionType_dueDateList'));
        rebindDataSource('@actionDueDataSourceUrl', systems, $('#ActionDues_Options_DueDateList'), $('#ActionDue_dueDateList'));
        rebindDataSource('@keywordDataSourceUrl', systems, $('#Keywords_Options_DueDateList'), $('#Keyword_dueDateList'));
        var PatentDependences = document.querySelectorAll('.PatentDependence');
        var TrademarkDependences = document.querySelectorAll('.TrademarkDependence');
        
        //disable if only ams is selected
        var selectedSystems = $(".systems input[type=checkbox]:checked");
        if (selectedSystems.length == 1 && $(selectedSystems[0]).attr("name") == "PrintSystemsA") {
            $(".disable-ams-only").attr("disabled", true);
            $("input[type=checkbox].disable-ams-only").prop("checked", false);
        }
        else
            $(".disable-ams-only").removeAttr("disabled");

        if (document.getElementById("PrintSystemsP").checked || document.getElementById("PrintSystemsL").checked || document.getElementById("PrintSystemsD").checked) {
            PatentDependences.forEach(element => {
                element.removeAttribute("disabled");
            });
        }
        else {
            PatentDependences.forEach(element => {
                element.setAttribute("disabled", "disabled");
                if(element.type === "checkbox"){
                    element.checked = false;
                }
            });
        }
        if (document.getElementById("PrintSystemsT").checked || document.getElementById("PrintSystemsM").checked) {
            TrademarkDependences.forEach(element => {
                element.removeAttribute("disabled");
            });
        }
        else {
            TrademarkDependences.forEach(element => {
                element.setAttribute("disabled", "disabled");
                if(element.type === "checkbox"){
                    element.checked = false;
                }
            });
        }
    }

    $(document).ready(function () {
        const formName = "#ReportCriteriaForm";
        ReportCriteriaPage.initialize(formName);
        const form = $(formName);

        PrintImageDetailChanged();
        PrintSystemChanged();

        form.find(".PrintSystemCheckBox").on("change", function (e) { OptionChanged() })
        $(document).off("change", "#ReportFormat");
        $(document).on("change", "#ReportFormat", function (e) {
            ReportCriteriaPage.ReportFormatChange();
        });

        const reportPageId = 'DueDateListReport';

        form.find(".email-report").on("click", function (e) { ReportCriteriaPage.emailReport(form) })

        form.find(".search-save").on("click", function () {
            CombineFields();
            pageHelper.getSearchCriteriaScreen(formName, reportPageId, true);
        })
        form.find(".search-load").on("click", function () {
            pageHelper.getSearchCriteriaScreen(formName, reportPageId, false, function (response) {
                form.clearSearch();
                pageHelper.loadSearchCriteria(response, { refineSearchContainer: formName });
                loadCombinedFields();
                ReportCriteriaPage.ReportFormatChange();
                setTimeout(function () { OptionChanged(); }, 500);
                setTimeout(function () { pageHelper.loadSearchCriteria(response, { refineSearchContainer: formName }); }, 1000);
                setTimeout(function () { ReportCriteriaPage.showMultiWhenNotEmpty(); }, 1500);
            });
        })
        if(@ViewBag.LoadDefault.ToString().ToLower()){
            pageHelper.loadDefaultSearchCriteria(formName, reportPageId, { refineSearchContainer: formName });
            loadCombinedFields();
            ReportCriteriaPage.ReportFormatChange();
            setTimeout(function () { OptionChanged(); }, 500);
            setTimeout(function () { pageHelper.loadDefaultSearchCriteria(formName, reportPageId, { refineSearchContainer: formName }); }, 1000);
            setTimeout(function () { ReportCriteriaPage.showMultiWhenNotEmpty(); }, 1500);
        }
    })

    function loadCombinedFields() {
        var printSystems = "," + document.getElementById("PrintSystems").value + ",";
        if (printSystems.includes(",G,"))
            document.getElementById("PrintSystemsG").checked = true;
        if (printSystems.includes(",T,"))
            document.getElementById("PrintSystemsT").checked = true;
        if (printSystems.includes(",P,"))
            document.getElementById("PrintSystemsP").checked = true;
        if (printSystems.includes(",D,"))
            document.getElementById("PrintSystemsD").checked = true;
        if (printSystems.includes(",L,"))
            document.getElementById("PrintSystemsL").checked = true;
        if (printSystems.includes(",M,"))
            document.getElementById("PrintSystemsM").checked = true;
        if (printSystems.includes(",A,"))
            document.getElementById("PrintSystemsA").checked = true;

        //var filterAtty = "," + document.getElementById("FilterAtty").value + ",";
        var filterAtty = "";
        if (document.getElementById("FilterAtty"))
            filterAtty = "," + document.getElementById("FilterAtty").value + ",";
        if (filterAtty.includes(",A1,"))
            document.getElementById("FilterAtty1").checked = true;
        if (filterAtty.includes(",A2,"))
            document.getElementById("FilterAtty2").checked = true;
        if (filterAtty.includes(",A3,"))
            document.getElementById("FilterAtty3").checked = true;
        if (filterAtty.includes(",A4,"))
            document.getElementById("FilterAtty4").checked = true;
        if (filterAtty.includes(",A5,"))
            document.getElementById("FilterAtty5").checked = true;
        if (filterAtty.includes(",AR,"))
            document.getElementById("FilterAttyR").checked = true;
        if (filterAtty.includes(",AD,"))
            document.getElementById("FilterAttyD").checked = true;
    }

    function printReport(form) {
        cpiLoadingSpinner.show();

        CombineFields();

        ReportCriteriaPage.submitForm(form, "@title");
    }

    function OptionChanged() {
        var emailsortOption = document.getElementById("EmailSortOrder");
        var calendarSortOption = document.getElementById("CalendarSortOrder");
        var CalendarDependences = document.querySelectorAll('.CalendarDependence');
        var reportFormat = document.getElementById("ReportFormat");
        var reportFormatListBox = document.getElementById("ReportFormat_listbox");

        if (calendarSortOption && calendarSortOption.checked)
        {
            if (reportFormatListBox.childElementCount != 2) {
                var dataSource = new kendo.data.DataSource({
                    data: [{Text:"PDF",Value:"0"}, {Text:"Word",Value:"2"}]
                });
                var dropdownlist = $("#ReportFormat").data("kendoDropDownList");
                dropdownlist.setDataSource(dataSource);

                dropdownlist.value("0");
            }

            PrintSystemChanged();
            PrintImageChanged();
            CalendarDependences.forEach(element => {
                element.setAttribute("disabled", "disabled");
            });
        } else if (emailsortOption && emailsortOption.checked && reportFormatListBox.childElementCount != 3) {
            var dataSource = new kendo.data.DataSource({
                data: [{ Text: "PDF", Value: "0" }, { Text: "Excel", Value: "1" }, { Text: "Word", Value: "2" }]
            });
            var dropdownlist = $("#ReportFormat").data("kendoDropDownList");
            dropdownlist.setDataSource(dataSource);
            dropdownlist.value("0");
        } else {
            if (reportFormatListBox.childElementCount != 6) {
                var dataSource = new kendo.data.DataSource({
                    data: [{ Text: "PDF", Value: "0" }, { Text: "Excel", Value: "1" }, { Text: "Word", Value: "2" }, { Text: "XML", Value: "3" }, { Text: "HTML", Value: "4" }, { Text: "CSV", Value: "5" }]
                });
                var dropdownlist = $("#ReportFormat").data("kendoDropDownList");
                dropdownlist.setDataSource(dataSource);
            }

            CalendarDependences.forEach(element => {
                element.removeAttribute("disabled");
            });

            PrintSystemChanged();
            PrintImageChanged();
        }

        document.querySelectorAll('.email-report').forEach(element => {
            if (emailsortOption && !emailsortOption.checked && (reportFormat.value == 0 || reportFormat.value == 1 || reportFormat.value == 2)) {
                element.removeAttribute("hidden");
            } else {
                element.setAttribute("hidden", "hidden");
            }
        });
    }

    function CombineFields() {
        CombineSystems();
        CombineAttorneyFilters();
        ReportCriteriaPage.combineMultiSelect();
    }

    function CombineSystems() {
        var result = ","
        var target = document.getElementById("PrintSystems");
        document.querySelectorAll('.PrintSystemCheckBox').forEach(element => {
            if (element.nodeName == "INPUT" && element.checked) {
                result += element.id.substring(element.id.length - 1) + ",";
            }
        });
        if (result == ",")
            result = "";
        else {
            result = result.substring(1, result.length - 1);
        }

        target.value = result;
        resetTitleLabel(result);
    }

        function rebindDataSource(DataSourceUrl, systemType, multiSelect, comboBox) {
        if (systemType === "")
            return;
        var dataSource = new kendo.data.DataSource({
            transport: {
                read: {
                    url: DataSourceUrl + "&systemType=" + systemType,
                }
            }
        });
        if (multiSelect && multiSelect.data("kendoMultiSelect"))
            multiSelect.data("kendoMultiSelect").setDataSource(dataSource);
        if (comboBox && comboBox.data("kendoComboBox"))
            comboBox.data("kendoComboBox").setDataSource(dataSource);
    }

    function CombineAttorneyFilters() {
        var result = ","
        var target = document.getElementById("FilterAtty");
        document.querySelectorAll('.AttorneyFilterCheckBox').forEach(element => {
            if (element.nodeName == "INPUT" && element.checked) {
                result += "A" + element.id.substring(element.id.length - 1) + ",";
            }
        });
        if (result == ",")
            result = "";
        else {
            result = result.substring(1, result.length - 1);
        }

        if (target)
            target.value = result;
    }

    function resetTitleLabel(systemType) {
        var label = byTitleLabel;
        if (systemType === "") {
            return;//label = titleLabel;
        } else {
            if (systemType === 'T' || systemType === 'M' || systemType === 'T,M')
                label = byTrademarkLabel
            else if (systemType.includes("T") || systemType.includes("M"))
                label = byTitleOrTrademarkLabel;
            else
                label = byTitleLabel;
        }

        if (document.getElementById("byTitleLabel"))
            document.getElementById("byTitleLabel").innerHTML = label;
    }

    function DeDocketInstructionChanged() {
        var instructionDependences = document.querySelectorAll('.InstructionDependence');

        if (document.getElementById("DeDocketInstructionOnly").checked) {
            instructionDependences.forEach(element => {
                element.removeAttribute("hidden");
            });
        }
        else {
            instructionDependences.forEach(element => {
                element.setAttribute("hidden", "hidden");
                var Clear = element.getElementsByClassName("k-clear-value");
                if (Clear.length != 1)
                    return;
                Clear[0].click();
            });
        }

    }

    function PrintCriteriaChanged() {
        var actionDependences = document.querySelectorAll('.CriteriaDependence');

        if (document.getElementById("PrintShowCriteria").checked) {
            actionDependences.forEach(element => {
                element.removeAttribute("disabled");
            });
        }
        else {
            actionDependences.forEach(element => {
                element.setAttribute("disabled", "disabled");
                if(element.type === "checkbox"){
                    element.checked = false;
                }
            });
        }
    }
</script>