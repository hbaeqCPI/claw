@using  R10.Web.Areas
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@inject ISystemSettings<PatSetting> PatSettings
@inject IAuthorizationService AuthService
@model DueDateListReportViewModel
@{
    var title = Localizer["Due Date List Report"].ToString();
    ViewData["Title"] = title;
    ViewData["ActivePage"] = "ReportCriteriaPage";

    var screen = "dueDateList";
    ViewBag.PageId = "DueDateList";
    var isRespOfficeOn = User.IsRespOfficeOn(SystemType.Patent) || User.IsRespOfficeOn(SystemType.Trademark) || User.IsRespOfficeOn(SystemType.GeneralMatter) || User.IsRespOfficeOn(SystemType.AMS);
    var settings = await Settings.GetSetting();
    var patSettings = await PatSettings.GetSetting();
    var isProductsOn = settings.IsProductsOn || patSettings.IsInventionProductOn;

    var deDocketOn = settings.IsDeDocketOn;
    var isInIDSPermissionOnly = !(User.IsInSystem(SystemType.Patent) || User.IsInSystem(SystemType.Trademark) || User.IsInSystem(SystemType.GeneralMatter) || User.IsInRoles(SystemType.AMS, CPiPermissions.RegularUser));
    var isDMSActionOn = false;
    var isReportSchedulerOn = settings.IsReportSchedulerON;
    var isDelegationOn = settings.IsDelegationOn;
    var isShowCustomFieldOn = settings.IsShowCustomFieldOn;
    var isSoftDocketOn = settings.IsSoftDocketOn;
    var isCorporation = settings.IsCorporation;
    var caseNumberLabel = settings.LabelCaseNumber;
    var ownerLabel = settings.LabelOwner;
    var ownerNameLabel = settings.LabelOwnerName;
    var clientLabel = settings.LabelClient;
    var clientNameLabel = settings.LabelClientName;
    var clientRefLabel = settings.LabelClientRef;
    var agentLabel = settings.LabelAgent;
    var agentNameLabel = settings.LabelAgentName;
    var agentRefLabel = settings.LabelAgentRef;
    var disclosureNumberRefLabel = settings.LabelDisclosureNumber;
    var keywordLabel = settings.LabelKeyword;
    var attorneyLabel = "Attorney";
    var attorneyNameLabel = "Attorney Name";

    var enableComboPaging = settings.EnableComboBoxPaging;
    var comboPagingSize = settings.ComboBoxPagingSize;

    var actionTypeDataSourceUrl = Url.Action("GetActionTypeList", "DueDateLookUp", new { area = "Shared", property = "ActionType" });
    var actionDueDataSourceUrl = Url.Action("GetActionDueList", "DueDateLookUp", new { area = "Shared", property = "ActionDue" });
    var keywordDataSourceUrl = Url.Action("GetKeywordList", "DueDateLookUp", new { area = "Shared", property = "Keyword" });

    var partialViewModel = new ReportPartialLookUpViewModel { Controller = "DueDateLookUp", Area = "Shared" };
    var reportPageOption = new ReportPageOption { CanPrint = true, CanEmail = true, CanSave = true, CanLoad = true, CanClear = true, Url = ViewBag.Url };
    var statusDataSourceUrl = Url.Action("GetStatusList", "DueDateLookUp", new { area = "Shared", property = "Status" });

    var isUserDMSInventor = ((await AuthService.AuthorizeAsync(User, DMSAuthorizationPolicy.Inventor)).Succeeded && !User.IsAdmin());
    var isUserDMSReviewer = ((await AuthService.AuthorizeAsync(User, DMSAuthorizationPolicy.Reviewer)).Succeeded && !User.IsAdmin());
}

<style>
    .input-validation-error {
    border-color: red;
    }
</style>

<div class="page-main">
    <form method="post"
    id="ReportCriteriaForm"
    data-url="@ViewBag.Url"
    data-email-report-url="@Url.Action("EmailDueDate","Report", new { Area = "Shared", subjectTitle = title})">

        <div class="container-fluid cpiMainEntry page-header">
            <div class="row">
                <div class="row col-md-6 col-lg-7" style="padding:0px 0px 0px 0px; margin:0px 0px 0px 0px">
                    <h2>@title</h2>
                    <div class="col-1"></div>
                    <div>
                        <div class="form-group vertical-center">
                            <label for="ReportFormat">@Localizer["Report Format"]</label>
                            @(Html.Kendo().DropDownList()
                                .Name("ReportFormat")
                                .HtmlAttributes(new { style = "width: 100px" })
                                .BindTo(Html.GetEnumSelectList<ReportOutputType>())
                                .Events(events => events.Open("function() {this.element.getKendoDropDownList().list.find('li.k-item').first().hide();}"))
                                )
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-5" style="padding:0px 15px 0px 0px; margin:0px 0px 0px 0px">
                    @await Component.InvokeAsync("ReportPageNavLinks", reportPageOption)
                </div>
            </div>
        </div>


        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="container-fluid cpiMainEntry">
            <div class="row col-sm-12">
                <div class="form-group col-md-auto">
                    <label asp-for="SortOrder"><strong>@Localizer["Sort"]</strong></label><br />
                    <input id="DueDateSortOrder" asp-for="SortOrder" type="radio" value="1" onclick="OptionChanged();" checked>
                    <label for="DueDateSortOrder">@Localizer["by Due Date"]</label><br />
                    @if (!isUserDMSInventor && !isUserDMSReviewer)
                    {
                        <input id="CalendarSortOrder" asp-for="SortOrder" type="radio" value="4" onclick="OptionChanged();">
                        <label for="CalendarSortOrder">@Localizer["by Due Date (Calendar)"]</label>

                        <br />
                        <input id="AttorneySortOrder" asp-for="SortOrder" type="radio" value="2" onclick="OptionChanged();">
                        <label for="AttorneySortOrder">@Localizer["by " + attorneyLabel]</label>

                        <br />
                        <input id="EmailSortOrder" asp-for="SortOrder" type="radio" value="5" onclick="OptionChanged();">
                        <label for="EmailSortOrder">@Localizer["by " + attorneyLabel + " (Email)"]</label>

                        <br />
                        <input id="ClientSortOrder" asp-for="SortOrder" type="radio" value="3" onclick="OptionChanged();">
                        <label for="ClientSortOrder">@Localizer["by " + clientLabel]</label>

                        <br />
                        <input id="TitleSortOrder" asp-for="SortOrder" type="radio" value="6" onclick="OptionChanged();">
                        <label for="TitleSortOrder" id="byTitleLabel">@Localizer["by Title or Trademark"]</label>

                        <br />
                        <input id="AgentSortOrder" asp-for="SortOrder" type="radio" value="7" onclick="OptionChanged();">
                        <label for="AgentSortOrder">@Localizer["by Agent"]</label>

                        <br />
                        <input id="CountrySortOrder" asp-for="SortOrder" type="radio" value="8" onclick="OptionChanged();">
                        <label for="CountrySortOrder">@Localizer["by Country"]</label>

                        <br />
                    }                    
                    @if (isRespOfficeOn)
                    {
                        <input id="RespOfficeSortOrder" asp-for="SortOrder" type="radio" value="9" onclick="OptionChanged();">
                        <label for="RespOfficeSortOrder">@Localizer["by Responsible Office"]</label><br />
                    }
                </div>
                <div class="form-group col-md-auto">
                    <label asp-for="LayoutFormat"><strong>@Localizer["Layout Format"]</strong></label><br />
                    <input id="ComprehensiveLayout" class="CalendarDependence" asp-for="LayoutFormat" type="radio" value="0" checked>
                    <label for="ComprehensiveLayout">@Localizer["Comprehensive"]</label><br />
                    <input id="ConciseLayout" class="CalendarDependence" asp-for="LayoutFormat" type="radio" value="1">
                    <label for="ConciseLayout">@Localizer["Concise"]</label><br />
                </div>
                <div class="col-md-auto">
                    <label class="form-check-label"><strong>@Localizer["Includes"]</strong></label><br />
                    <input class="CalendarDependence disable-ams-only" asp-for="PrintActionDueRemarks" type="checkbox" />
                    <label for="PrintActionDueRemarks">@Localizer["Action Due Remarks"]</label><br />
                    <input class="CalendarDependence disable-ams-only" asp-for="PrintDueDateRemarks" type="checkbox" />
                    <label for="PrintDueDateRemarks">@Localizer["Due Date Remarks"]</label><br />
                    <input class="CalendarDependence disable-ams-only" asp-for="PrintRemarks" type="checkbox" />
                    <label for="PrintRemarks">@Localizer["Case Remarks"]</label><br />
                    @if (isShowCustomFieldOn)
                    {
                        <input class="CalendarDependence disable-ams-only" asp-for="PrintCustomFields" type="checkbox" />
                        <label for="PrintCustomFields">@Localizer["Custom Fields"]</label>

                        <br />
                    }
                    @if (deDocketOn)
                    {
                        <input class="disable-ams-only" asp-for="DeDocketInstructionOnly" id="DeDocketInstructionOnly" type="checkbox" onchange="DeDocketInstructionChanged();"/>
                        <label for="DeDocketInstructionOnly">@Localizer["Only list with De-Docket Instructions"]</label>

                        <br />
                    }
                    @if (isDelegationOn)
                    {
                        <input class="disable-ams-only" asp-for="DelegatedActionsOnly" type="checkbox" />
                        <label for="DelegatedActionsOnly">@Localizer["Delegated Actions Only"]</label>

                        <br />
                    }
                </div>
                <div class="col-md-auto">
                    <label class="form-check-label"><strong>@Localizer["Includes"]</strong></label><br />
                    <input id="PrintImage" class="CalendarDependence disable-ams-only" asp-for="PrintImage" type="checkbox" onchange="OptionChanged();" />
                    <label for="PrintImage">@Localizer["Documents"]</label><br />
                    @if (!isUserDMSInventor && !isUserDMSReviewer)
                    {
                        <input id="PrintImageDetail" class="CalendarDependence" asp-for="PrintImageDetail" type="checkbox" onchange="PrintImageDetailChanged();" />
                        <label for="PrintImageDetail">@Localizer["Show Image"]</label>
                        <br />
                        <input class="CalendarDependence disable-ams-only" asp-for="PrintPastReminders" type="checkbox" />
                        <label for="PrintPastReminders">@Localizer["Past Reminders"]</label>
                        <br />
                    }
                    @if (!isCorporation && isSoftDocketOn)
                    {
                        <input id="PrintSoftDocket" asp-for="PrintSoftDocket" type="checkbox" />
                        <label for="PrintSoftDocket">@Localizer["Include Soft Dockets"]</label>
                        <br />
                    }
                    @if (User.IsInSystem(SystemType.Patent) || (User.IsInRoles(SystemType.DMS, CPiPermissions.DMSDueDateList) && isDMSActionOn))
                    {
                        <input class="CalendarDependence PatentDependence" asp-for="PrintInventors" type="checkbox" />
                        <label for="PrintInventors">@Localizer["Inventors"]</label><br />
                    }
                    <input id = "PrintShowCriteria" asp-for="PrintShowCriteria" type="checkbox" onchange="PrintCriteriaChanged();" checked />
                    <label for="PrintShowCriteria">@Localizer["Selection Criteria"]</label><br />
                    <input class="CriteriaDependence" asp-for="PrintShowCriteriaOnFirstPage" type="checkbox" />
                    <label for="PrintShowCriteriaOnFirstPage">@Localizer["Print Criteria On First Page"]</label><br />
                </div>


                @if (User.IsInSystem(SystemType.Trademark))
                {
                    <div class="col-md-auto">
                        <label class="form-check-label"><strong>@Localizer["Class/Goods"]</strong></label><br />
                        <input id="PrintClassOnly" class="CalendarDependence TrademarkDependence" asp-for="PrintGoods" type="radio" value="1">
                        <label for="PrintClassOnly">@Localizer["Classes Only"]</label><br />
                        <input id="PrintGoodsOnly" class="CalendarDependence TrademarkDependence" asp-for="PrintGoods" type="radio" value="2">
                        <label for="PrintGoodsOnly">@Localizer["Goods Only"]</label><br />
                        <input id="PrintClassesAndGoods" class="CalendarDependence TrademarkDependence" asp-for="PrintGoods" type="radio" value="3">
                        <label for="PrintClassesAndGoods">@Localizer["Classes and Goods"]</label><br />
                        <input id="DoNotPrintClassesAndGoods" class="CalendarDependence TrademarkDependence" asp-for="PrintGoods" type="radio" value="0" checked>
                        <label for="DoNotPrintClassesAndGoods">@Localizer["Don't Print"]</label><br />
                    </div>
                }
                <div class="col-md-auto systems">
                    <label class="form-check-label"><strong>@Localizer["Systems"]</strong></label>
                    <div class="form-group">
                        @if (User.IsInSystem(SystemType.Patent))
                        {
                            @if (Model.PrintSystems.Contains("P"))
                            {
                                <input id="PrintSystemsP" name="PrintSystemsP" class="PrintSystemCheckBox" type="checkbox" checked value="P" />
                            }
                            else
                            {
                                <input id="PrintSystemsP" name="PrintSystemsP" class="PrintSystemCheckBox" type="checkbox" value="P" />
                            }
                            <label for="PrintSystemsP">@Localizer["Patent"]</label><br />
                        }
                        else
                        {
                            <input hidden id="PrintSystemsP" name="PrintSystemsP" class="PrintSystemCheckBox" type="checkbox" value="P" />
                        }
                        @if (User.IsInSystem(SystemType.Patent) && ViewBag.IsRTSOn)
                        {
                            @if (Model.PrintSystems.Contains("L"))
                            {
                                <input id="PrintSystemsL" name="PrintSystemsL" class="PrintSystemCheckBox" type="checkbox" checked value="L" />
                            }
                            else
                            {
                                <input id="PrintSystemsL" name="PrintSystemsL" class="PrintSystemCheckBox" type="checkbox" value="L" />
                            }
                            <label for="PrintSystemsL">@Localizer["Patent Office Actions"]</label><br />
                        }
                        else
                        {
                            <input hidden id="PrintSystemsL" name="PrintSystemsL" class="PrintSystemCheckBox" type="checkbox" value="L" />
                        }
                        @if (User.IsInSystem(SystemType.Trademark))
                        {
                            @if (Model.PrintSystems.Contains("T"))
                            {
                                <input id="PrintSystemsT" name="PrintSystemsT" class="PrintSystemCheckBox" type="checkbox" checked value="T" />
                            }
                            else
                            {
                                <input id="PrintSystemsT" name="PrintSystemsT" class="PrintSystemCheckBox" type="checkbox" value="T" />
                            }
                            <label for="PrintSystemsT">@Localizer["Trademark"]</label><br />
                        }
                        else
                        {
                            <input hidden id="PrintSystemsT" name="PrintSystemsT" class="PrintSystemCheckBox" type="checkbox" value="T" />
                        }
                        @if (User.IsInSystem(SystemType.Trademark) && ViewBag.IsTLOn)
                        {
                            @if (Model.PrintSystems.Contains("M"))
                            {
                                <input id="PrintSystemsM" name="PrintSystemsM" class="PrintSystemCheckBox" type="checkbox" checked value="M" />
                            }
                            else
                            {
                                <input id="PrintSystemsM" name="PrintSystemsM" class="PrintSystemCheckBox" type="checkbox" value="M" />
                            }
                            <label for="PrintSystemsM">@Localizer["Trademark Links Actions"]</label><br />
                        }
                        else
                        {
                            <input hidden id="PrintSystemsM" name="PrintSystemsM" class="PrintSystemCheckBox" type="checkbox" value="M" />
                        }
                        @if (User.IsInSystem(SystemType.GeneralMatter))
                        {
                            @if (Model.PrintSystems.Contains("G"))
                            {
                                <input id="PrintSystemsG" name="PrintSystemsG" class="PrintSystemCheckBox" type="checkbox" checked value="G" />
                            }
                            else
                            {
                                <input id="PrintSystemsG" name="PrintSystemsG" class="PrintSystemCheckBox" type="checkbox" value="G" />
                            }
                            <label for="PrintSystemsG">@Localizer["Gen. Matter"]</label><br />
                        }
                        else
                        {
                            <input hidden id="PrintSystemsG" name="PrintSystemsG" class="PrintSystemCheckBox" type="checkbox" value="G" />
                        }
                        @if (User.IsInRoles(SystemType.DMS, CPiPermissions.DMSDueDateList) && isDMSActionOn)
                        {
                            @if (Model.PrintSystems.Contains("D"))
                            {
                                <input id="PrintSystemsD" name="PrintSystemsD" class="PrintSystemCheckBox" type="checkbox" checked value="D" />
                            }
                            else
                            {
                                <input id="PrintSystemsD" name="PrintSystemsD" class="PrintSystemCheckBox" type="checkbox" value="D" />
                            }
                            <label for="PrintSystemsD">@Localizer["Invention Disclosure"]</label><br />
                        }
                        else
                        {
                            <input hidden id="PrintSystemsD" name="PrintSystemsD" class="PrintSystemCheckBox" type="checkbox" value="D" />
                        }
                        @if (User.IsInRoles(SystemType.AMS, CPiPermissions.RegularUser))
                        {
                            @if (Model.PrintSystems.Contains("A"))
                            {
                                <input id="PrintSystemsA" name="PrintSystemsA" class="PrintSystemCheckBox" type="checkbox" checked value="A" />
                            }
                            else
                            {
                                <input id="PrintSystemsA" name="PrintSystemsA" class="PrintSystemCheckBox" type="checkbox" value="A" />
                            }
                            <label for="PrintSystemsA">@Localizer["Annuity Management"]</label><br />
                        }
                        else
                        {
                            <input hidden id="PrintSystemsA" name="PrintSystemsA" class="PrintSystemCheckBox" type="checkbox" value="A" />
                        }
                        <input asp-for="PrintSystems" id="PrintSystems" type="text" hidden />
                    </div>
                </div>
            </div>

            <hr />

            <div class="container-fluid">
                <div class="form-row group justify-content-center">
                    <div class="form-group float-label col-xl-2 col-lg-3 col-md-4 col-6">
                        <label for="FromDate">@Localizer["From Due Date"]</label>
                        @await Component.InvokeAsync("DatePicker", new DatePickerOptions("FromDate"))
                    </div>

                    <div class="form-group float-label col-xl-2 col-lg-3 col-md-4 col-6">
                        <label for="ToDate">@Localizer["To Due Date"]</label>
                        @await Component.InvokeAsync("DatePicker", new DatePickerOptions("ToDate"))
                    </div>
                </div>
            </div>
            <hr />
            @if (isReportSchedulerOn && !isInIDSPermissionOnly)
            {
                <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" id="dueDateListTab" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="selectionCriteriaTab" data-toggle="tab" href="#selectionCriteriaTabContent" role="tab" aria-controls="selectionCriteriaTabContent" aria-selected="true">@Localizer["Selection Criteria"]</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" id="schedulesTab" href="#schedulesTabContent" role="tab" aria-controls="schedulesTabContent" aria-selected="false">@Localizer["Schedules"]</a>
                    </li>
                </ul>
            }
            
            <div class="tab-content detail pb-2">                
                <div class="tab-pane page-content show active" id="selectionCriteriaTabContent" role="tabpanel" aria-labelledby="selectionCriteriaTab" style="padding:0px 0px 0px 0px; margin:0px 0px 0px 0px">                    
                    <div class="container-fluid">                        
                        <div class="row">
                            @if (!isUserDMSInventor && !isUserDMSReviewer)
                            {
                                <div class="col-md-6">
                                    <div class="form-row group">
                                        <div class="form-group float-label col-xl-2 col-lg-3 col-4">
                                            @await Component.InvokeAsync("FilterOperatorList", new { name = "ActionTypeOp" })
                                        </div>
                                        <div class="form-group float-label col-xl-9 col-lg-8 col-7 ActionTypeMultiSelectClass" hidden>
                                            <label>@Localizer["Action Types"]</label>
                                            @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
                                        {
                                            Name = "ActionTypes_Options",
                                            DataTextProperty = "ActionType",
                                            Controller = partialViewModel.Controller,
                                            Area = partialViewModel.Area,
                                            Action = "GetActionTypeList",
                                        })
                                            <input asp-for="ActionTypes" id="ActionTypes" type="text" hidden value="" />
                                        </div>
                                        <div class="form-group float-label col-xl-9 col-lg-8 col-7 ActionTypeComboBoxClass">
                                            <label for="Area">@Localizer["Action Type"]</label>
                                            @await Component.InvokeAsync("ComboBox", new { name = "ActionType", controller = partialViewModel.Controller, action = "GetActionTypeList", area = partialViewModel.Area, screen = screen })
                                        </div>
                                        @await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "ActionTypeMultiSelectClass", SingleClass = "ActionTypeComboBoxClass" })
                                    </div>

                                    <div class="form-row group">
                                        <div class="form-group float-label col-xl-2 col-lg-3 col-4">
                                            @await Component.InvokeAsync("FilterOperatorList", new { name = "ActionDueOp" })
                                        </div>
                                        <div class="form-group float-label col-xl-9 col-lg-8 col-7 ActionDueMultiSelectClass" hidden>
                                            <label>@Localizer["Actions Due"]</label>
                                            @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
                                        {
                                            Name = "ActionDues_Options",
                                            DataTextProperty = "ActionDue",
                                            Controller = partialViewModel.Controller,
                                            Area = partialViewModel.Area,
                                            Action = "GetActionDueList",
                                        })
                                            <input asp-for="ActionDues" id="ActionDues" type="text" hidden value="" />
                                        </div>
                                        <div class="form-group float-label col-xl-9 col-lg-8 col-7 ActionDueComboBoxClass">
                                            <label>@Localizer["Action Due"]</label>
                                            @await Component.InvokeAsync("ComboBox", new { name = "ActionDue", controller = partialViewModel.Controller, action = "GetActionDueList", area = partialViewModel.Area, screen = screen })
                                        </div>
                                        @await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "ActionDueMultiSelectClass", SingleClass = "ActionDueComboBoxClass" })
                                    </div>

                                    <div class="form-row group">
                                        <div class="form-group float-label col-xl-2 col-lg-3 col-4">
                                            @await Component.InvokeAsync("FilterOperatorList", new { name = "IndicatorOp" })
                                        </div>
                                        <div class="form-group float-label col-xl-6 col-lg-7 col-8">
                                            <label>@Localizer["Indicators"]</label>
                                            @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
                                        {
                                            Name = "DueIndicators_Options",
                                            DataTextProperty = "Indicator",
                                            Controller = partialViewModel.Controller,
                                            Area = partialViewModel.Area,
                                            Action = "GetIndicatorList",
                                        })
                                            <input asp-for="DueIndicators" id="DueIndicators" type="text" hidden value="" />
                                        </div>
                                    </div>

                                    @if (isDelegationOn)
                                    {
                                        <div class="form-row group">
                                            <div class="form-group float-label col-12">
                                                <label>@Localizer["Delegated To"]</label>
                                                @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
                                        {
                                            Name = "DelegatedUserGroups_Options",
                                            DataValueProperty = "Id",
                                            DataTextProperty = "Name",
                                            Controller = partialViewModel.Controller,
                                            Area = partialViewModel.Area,
                                            Action = "GetUserGroupList",
                                        })
                                            </div>
                                            <input type="text" asp-for="DelegatedUserGroups" id="DelegatedUserGroups" hidden />
                                        </div>
                                    }                                

                                    <div class="form-row group">
                                        <div class="form-group float-label col-xl-2 col-lg-3 col-4">
                                            @await Component.InvokeAsync("FilterOperatorList", new { name = "ClientOp" })
                                        </div>
                                        <div class="form-group float-label col-xl-3 col-lg-3 col-3 ClientMultiSelectClass" hidden>
                                            <label>@Localizer[clientLabel + "s"]</label>
                                            @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
                                        {
                                            Controller = partialViewModel.Controller,
                                            Area = partialViewModel.Area,
                                            Action = "GetClientList",
                                            Name = "Clients_Options",
                                            DataTextProperty = "ClientCode",
                                            DataValueProperty = "ClientCode",
                                            ListWidth = 500,
                                            HeaderTemplate = ComboBoxHelper.GetHeaderTemplate(@Localizer[clientLabel], @Localizer[clientNameLabel]),
                                            ItemTemplate = ComboBoxHelper.GetItemTemplate("ClientCode", "ClientName"),
                                        })
                                        </div>
                                        <div class="form-group float-label col-xl-3 col-lg-3 col-3 ClientComboBoxClass">
                                            <label>@Localizer[clientLabel]</label>
                                            @await Component.InvokeAsync("ComboBox", ComboBoxHelper.ClientCode("Client", @Localizer[clientLabel], @Localizer[clientNameLabel], partialViewModel.Controller, "", partialViewModel.Area))
                                        </div>
                                        @await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "ClientMultiSelectClass", SingleClass = "ClientComboBoxClass" })
                                        <div class="form-group float-label col-xl-6 col-lg-5 col-4 ClientNameMultiSelectClass" hidden>
                                            <label>@Localizer[clientNameLabel + "s"]</label>
                                            @await Component.InvokeAsync("MultiSelect", new MultiSelectOptions
                                        {
                                            Controller = partialViewModel.Controller,
                                            Area = partialViewModel.Area,
                                            Action = "GetClientList",
                                            Name = "ClientNames_Options",
                                            DataTextProperty = "ClientName",
                                        })
                                        </div>
                                        <div class="form-group float-label col-xl-6 col-lg-5 col-4 ClientNameComboBoxClass">
                                            <label>@Localizer[clientNameLabel]</label>
                                            @await Component.InvokeAsync("ComboBox", new { name = "ClientName", controller = partialViewModel.Controller, action = "GetClientList", area = partialViewModel.Area })
                                        </div>
                                        @await Component.InvokeAsync("SingleMultiSwitcher", new { MultiClass = "ClientNameMultiSelectClass", SingleClass = "ClientNameComboBoxClass" })
                                        <input asp-for="Clients" id="Clients" type="text" hidden value="" />
                                        <input asp-for="ClientNames" id="ClientNames" type="text" hidden value="" />
                                    </div>

                                    <div class="form-row group">
                                        @await Component.InvokeAsync("RMultiSelectAgent", partialViewModel)
                                        <input asp-for="Agents" id="Agents" type="text" hidden value="" />
                                        <input asp-for="AgentNames" id="AgentNames" type="text" hidden value="" />
                                    </div>

                                    <div class="form-row group">
                                        @await Component.InvokeAsync("RMultiSelectOwner", partialViewModel)
                                        <input asp-for="Owners" id="Owners" type="text" hidden value="" />
                                        <input asp-for="OwnerNames" id="OwnerNames" type="text" hidden value="" />
                                    </div>

                                    <div class="form-row group">
                                        @await Component.InvokeAsync("RMultiSelectAttorney", partialViewModel)
