@model QuickDocketMassUpdateViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="modal fade" id="qdUpdateDateTakenDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" asp-action="UpdateDateTaken" asp-controller="QuickDocket">
                <div class="modal-header py-1">
                    <h4 class="modal-title">@Localizer["Populate Date Taken - Mass Update"]</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-1">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-12 mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="DateType" id="DateType_1" value="1" checked>
                                    <label class="form-check-label mt-0" for="DateType_1">
                                        @Localizer["Current Date"]
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="DateType" id="DateType_2" value="2">
                                    <label class="form-check-label mt-0" for="DateType_2">
                                        @Localizer["Due Date"]
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="DateType" id="DateType_3" value="3">
                                    <label class="form-check-label mt-0" for="DateType_3">
                                        @Localizer["Custom Date"]
                                    </label>
                                    <div class="custom-date d-none">
                                        @await Component.InvokeAsync("DatePicker", new DatePickerOptions("SpecificDate") {Value=DateTime.Now.Date,ValidationMessage=Localizer["Please enter a valid date"].Value})
                                    </div>
                                </div>
                                
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <div class="modal-footer-buttons">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                        <button type="submit" class="btn btn-primary"><i class="fa fa-check pr-2"></i>@Localizer["Update"]</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>






