<script>
    function getQDLabel(type) {

        switch (type) {
            case 'patentLabel': return '@patentLabel';
            case 'trademarkLabel': return '@trademarkLabel';
            case 'genMatterLabel': return '@genMatterLabel';
            case 'ptoActionsLabel': return '@ptoActionsLabel';
            case 'trademarkLinksLabel': return '@trademarkLinksLabel';
            case 'dmsLabel': return '@dmsLabel';
            case 'amsLabel': return '@amsLabel';

            case 'titleLabel': return '@titleLabel';
            case 'matterTitleLabel': return '@matterTitleLabel';
            case 'remarksLabel': return '@remarksLabel';

            case 'saveLabel': return '@saveLabel';
            case 'cancelLabel': return '@cancelLabel';
            case 'yesLabel': return '@yesLabel';
            case 'noLabel': return '@noLabel';

            case 'deDocketLabel': return '@deDocketLabel';
            case 'instructionLabel': return '@instructionLabel';
            case 'deDocketRemarksLabel': return '@deDocketRemarksLabel';
            case 'instructedByLabel': return '@instructedByLabel';
            case 'instructionDateLabel': return '@instructionDateLabel';
            case 'completedLabel': return '@completedLabel';

            case 'attachDocumentLabel': return '@attachDocumentLabel';
            case 'viewHistoryLabel': return '@viewHistoryLabel';
            case 'delegatedLabel': return '@delegatedLabel';
            case 'editRemarksLabel': return '@editRemarksLabel';
            case 'delegateLabel': return '@delegateLabel';
            case 'clientLabel': return '@clientLabel';
            case 'clientRefLabel': return '@clientRefLabel';
            case 'ownerLabel': return '@ownerLabel';
            case 'entitiesLabel': return '@entitiesLabel';
            case 'attorneysLabel': return '@attorneysLabel';
            case 'genRemarksLabel': return '@genRemarksLabel';
            case 'setCurrentDateLabel': return '@setCurrentDateLabel';
            case 'dueDateExtendedLabel': return '@dueDateExtendedLabel';
            case 'addSoftDocketLabel': return '@addSoftDocketLabel';
            case 'addDocketRequestLabel': return '@addDocketRequestLabel';


        }
        return "";
    }

    function girdDelegationIconCheck(DDId, hasDelegations, system) {
        var element = document.getElementById("delegate-icon" + system + DDId);
        if (hasDelegations) {
            if (element.classList.contains("fa-user")) {
                element.classList.remove("fa-user");
                element.classList.add("fa-users");
            }
        } else {
            if (element.classList.contains("fa-users")) {
                element.classList.remove("fa-users");
                element.classList.add("fa-user");
            }
        }
    }
</script>