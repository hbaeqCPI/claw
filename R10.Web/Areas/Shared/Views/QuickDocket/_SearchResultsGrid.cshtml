@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var deDocketOn = settings.IsDeDocketOn;
}
<div id="qdContentPage">
    <ul class="nav nav-tabs nav-tabs-horizontal flush-left" id="quickDocket-tab" role="tablist">
        <li class="nav-item">
            <a class="nav-link active" id="quickDocketMainInfo-tab" data-toggle="tab" role="tab" aria-controls="mainInfo" aria-selected="true" href="#mainInfo">@Localizer["Quick Docket"] </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="quickDocketCalendar-tab" data-toggle="tab" role="tab" aria-controls="qcalendar" aria-selected="false" href="#calendar">@Localizer["Calendar"]</a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="quickDocketDefaultSettings-tab" data-toggle="tab" role="tab" aria-controls="defaultSettings" aria-selected="false" href="#defaultSettings">@Localizer["Default Settings"]</a>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane page-content show active" id="mainInfo" role="tabpanel" aria-labelledby="mainInfo">
            @await Html.PartialAsync("_QuickDocket")
        </div>
        <div class="tab-pane page-content px-1" id="calendar" data-url="@Url.Action("Scheduler")" role="tabpanel" aria-labelledby="calendar">
        </div>
        <div class="tab-pane page-content px-1" id="defaultSettings" data-url="@Url.Action("DefaultSettings")" data-system="@Model.SystemType" role="tabpanel" aria-labelledby="defaultSettings">
        </div>
    </div>
</div>
    <script>
    quickDocket.initializeQuickDocket({ deDocketOn:@(deDocketOn ? "true":"false")});
    </script>
<style>
    #quickDocketSearchResults .page-header.page-crumbs {
        display: none;
    }
    #quickDocketSearchResults .page-header.cpiButtonsDetail,
    #quickDocketSearchResults .open-collapsed-sidebar {
        background-color: var(--bg-main);
        padding-bottom: 0;
    }

    #quickDocketSearchResults .page-header .nav-link {
        padding-bottom: 0;
    }
</style>

@await Html.PartialAsync("_IndicatorStyle")