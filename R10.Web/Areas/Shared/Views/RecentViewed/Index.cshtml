@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Recently Viewed Records"];
    ViewData["ActivePage"] = "recentViewedPage";

}
@section Scripts {
    <script>
        var @ViewBag.ActivePage = new ActivePage();
    </script>
}

@await Html.PartialPageAsync(Model.Page, Model)