@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var customFieldsLabel = settings.AuxCustomFieldsTabLabel;
}
<li class="nav-item">
    <a class="nav-link active" data-toggle="tab" id="attorneySearchMainTab" href="#attorneySearchMainTabContent" role="tab" aria-controls="attorneySearchMainTabContent" aria-selected="true">@SharedLocalizer["Attorney"]</a>
</li>
<li class="nav-item">
    <a class="nav-link" data-toggle="tab" id="attorneySearchAddressTab" href="#attorneySearchAddressTabContent" role="tab" aria-controls="attorneySearchAddressTabContent" aria-selected="false">@SharedLocalizer["Address"]</a>
</li>
<li class="nav-item">
    <a class="nav-link" data-toggle="tab" id="attorneySearchPOBoxTab" href="#attorneySearchPOBoxTabContent" role="tab" aria-controls="attorneySearchPOBoxTabContent" aria-selected="false">@SharedLocalizer["PO Box"]</a>
</li>
@if (User.IsAdmin())
{
    <li class="nav-item">
        <a id="attorneySearchPermissionsTab" href="#attorneySearchPermissionsTabContent" class="nav-link" data-toggle="tab" role="tab" aria-controls="attorneySearchPermissionsTabContent" title="@SharedLocalizer["Permissions"]">@SharedLocalizer["Permisssions"]</a>
    </li>
}
<li class="nav-item">
    <a class="nav-link" data-toggle="tab" id="attorneySearchOtherInfoTab" href="#attorneySearchOtherInfoTabContent" role="tab" aria-controls="attorneySearchOtherInfoTabContent" aria-selected="false">@SharedLocalizer["Other Info"]</a>
</li>
@if (settings.IsShowCustomFieldOn)
{
    <li class="nav-item">
        <a class="nav-link" data-toggle="tab" id="attorneySearchCustomFieldsTab" href="#attorneySearchCustomFieldsTabContent" role="tab" aria-controls="attorneySearchCustomFieldsTabContent" aria-selected="false">@SharedLocalizer[customFieldsLabel]</a>
    </li>
}