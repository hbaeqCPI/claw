@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Form IFW Action Settings"];
    ViewData["ActivePage"] = "formExtractIFWActionMap";
}

@section Scripts {
    <script>
        var @ViewBag.ActivePage = new ActivePage();
    </script>
}

@await Html.PartialPageAsync(Model.Page, Model)