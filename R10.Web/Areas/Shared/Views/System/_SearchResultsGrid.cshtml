@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<AppSystem>()
                .Name($"{Model.PageId}-Grid")
                .Columns(columns =>
                {
                    columns.Bound(m => m.SystemName).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: SystemId#", fromSearch = true }), "SystemName")).Width(200);
                    columns.Bound(m => m.SystemType).Width(200);
                })
                .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                .AutoBind(false)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                .Excel(excel => excel.FileName("SystemList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "System")))
                .DataSource(dataSource => dataSource
                .Ajax().Events(events => events.Error("cpiSystemPage.searchResultGridError"))
                .Events(events => events.RequestEnd("cpiSystemPage.searchResultGridRequestEnd"))
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                .Read(read => read.Action("PageRead", "System")
                .Data("cpiSystemPage.gridMainSearchFilters")
                )
                .Sort(sort => sort.Add(m => m.SystemName))
                )
                .HtmlAttributes(new { @class = "kendo-Grid" })
)
