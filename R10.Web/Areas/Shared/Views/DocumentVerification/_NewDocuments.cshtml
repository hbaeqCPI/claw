@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@inject IAuthorizationService AuthorizationService
@{
    var settings = await Settings.GetSetting();

    var caseNumberLabel = settings.IsClientMatterOn ? Localizer[settings.LabelClientMatter ?? "Client Matter"] : Localizer[settings.LabelCaseNumber ?? "Case Number"];
    var countryLabel = Localizer["Country"];

    var additionalData = "function() {return documentVerificationPage.getCriteria(documentVerificationPage.refineSearchContainer);}";

    var canModifyPatDoc = (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.CanUploadDocuments)).Succeeded;
    var canModifyTmkDoc = (await AuthorizationService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.CanUploadDocuments)).Succeeded;
    var canModifyGMDoc = (await AuthorizationService.AuthorizeAsync(User, GeneralMatterAuthorizationPolicy.CanUploadDocuments)).Succeeded;

    var canUploadDoc = canModifyPatDoc || canModifyTmkDoc || canModifyGMDoc;

    var documentStorageOptions = settings.DocumentStorage;
    var kendoUploadController = "DocDocuments";

    if (documentStorageOptions == DocumentStorageOptions.SharePoint)
        kendoUploadController = "SharePointGraph";
    else if (documentStorageOptions == DocumentStorageOptions.iManage)
        kendoUploadController = "iManageWork";
    else if (documentStorageOptions == DocumentStorageOptions.NetDocuments)
        kendoUploadController = "NetDocs";

    var isAdmin = User.IsAdmin();
}
<div class="page-header cpiButtonsDetail" id="newDocVerificationHeaderContainer">
    <nav class="nav nav-left pt-2 sidebar-link" style="align-items:center;">
        @if (canUploadDoc)
        {
            <a class="nav-link add-doc" href="#" role="button"><i class="fal fa-plus pr-1"></i><span>@Html.Raw(Localizer["Add"])</span></a>
            <a class="nav-link select-all-record" href="#" role="button"><i class="fal fa-check pr-1"></i><span>@Html.Raw(Localizer["Select all"])</span></a>
            <a class="nav-link link-doc" href="#" role="button"><i class="fal fa-link pr-1"></i><span>@Html.Raw(Localizer["Link Document"])</span></a>
            <a class="nav-link responsible-doc" href="#" role="button"><i class="fal fa-user-plus pr-1"></i><span>@Html.Raw(Localizer["Assign"])</span></a>
            <a class="nav-link delete-doc" href="#" role="button"><i class="fal fa-trash-alt pr-1"></i><span>@Html.Raw(Localizer["Delete"])</span></a>
        }
        <a class="nav-link print-record" href="#" role="button"><i class="fal fa-file-arrow-down pr-1"></i><span>@Html.Raw(Localizer["Print View"])</span></a>
        <a class="nav-link excel-export" href="#" role="button"><i class="fal fa-file-excel pr-1"></i><span>@Html.Raw(Localizer["Export to Excel"])</span></a>
        @if (isAdmin)
        {
            <a class="nav-link review-filters" href="#" role="button"><i class="fal fa-gear pr-1"></i><span class='badge badge-secondary'>@Html.Raw(Localizer["Global"])</span></a>
        }
    </nav>
    <form id="newDocExportToExcel" action="@Url.Action("ExportToExcel")" method="post">
        <input type="hidden" name="exportCriteria" id="newDocExportCriteria" value="" />
    </form>
</div>

<div id="newDocVerificationContainer">
    <div class="sidebar-link"></div>
    <div id="ndHeaderContainer_fake" style="position:fixed; top:0px; z-index:999">
        <table>
            <thead class="ndHeaderContainer">
                <tr>
                    <th style="width:28%">
                        <a data-id="NewDoc_DocName" href="#">@Html.Raw(Localizer["Document"])</a>
                    </th>
                    <th style="width:10%">
                        <a data-id="NewDoc_CaseNumber" href="#">@Html.Raw(caseNumberLabel)</a>
                    </th>
                    <th style="width:5%">
                        <a data-id="NewDoc_Country" href="#">@Html.Raw(countryLabel)</a>
                    </th>
                    <th style="width:6%">
                        <a data-id="NewDoc_SubCase" href="#">@Html.Raw(Localizer["Sub Case"])</a>
                    </th>
                    <th style="width:15%">
                        <a data-id="NewDoc_RespDocketing" href="#">@Html.Raw(Localizer["Responsible (Docketing)"])</a>
                    </th>
                    <th style="width:15%">
                        <a data-id="NewDoc_RespReporting" href="#">@Html.Raw(Localizer["Responsible (Reporting)"])</a>
                    </th>
                    <th style="width:5%">
                        <a data-id="NewDoc_DocLibrary" href="#">@Html.Raw(Localizer["System"])</a>
                    </th>
                    <th style="width:5%">
                        <a data-id="NewDoc_Source" href="#">@Html.Raw(Localizer["Source"])</a>
                    </th>
                    <th style="width:8%">
                        <a data-id="NewDoc_CreatedBy" href="#">@Html.Raw(Localizer["Uploaded By"])</a>
                    </th>
                    <th style="width:10%">
                        <a data-id="NewDoc_UploadedDate" href="#">@Html.Raw(Localizer["Uploaded Date"])</a>
                    </th>
                    <th style="width:7%">
                        <a href="#"></a>
                    </th>
                </tr>
            </thead>
        </table>
    </div>
    <table>
        <thead class="ndHeaderContainer" id="ndHeaderContainer_real">
            <tr>
                <th style="width:28%">
                    <a data-id="NewDoc_DocName" href="#">@Html.Raw(Localizer["Document"])</a>
                </th>                
                <th style="width:10%">
                    <a data-id="NewDoc_CaseNumber" href="#">@Html.Raw(caseNumberLabel)</a>
                </th>
                <th style="width:5%">
                    <a data-id="NewDoc_Country" href="#">@Html.Raw(countryLabel)</a>
                </th>
                <th style="width:6%">
                    <a data-id="NewDoc_SubCase" href="#">@Html.Raw(Localizer["Sub Case"])</a>
                </th>
                <th style="width:15%">
                    <a data-id="NewDoc_RespDocketing" href="#">@Html.Raw(Localizer["Responsible (Docketing)"])</a>
                </th>
                <th style="width:15%">
                    <a data-id="NewDoc_RespReporting" href="#">@Html.Raw(Localizer["Responsible (Reporting)"])</a>
                </th>
                <th style="width:5%">
                    <a data-id="NewDoc_DocLibrary" href="#">@Html.Raw(Localizer["System"])</a>
                </th>
                <th style="width:5%">
                    <a data-id="NewDoc_Source" href="#">@Html.Raw(Localizer["Source"])</a>
                </th>
                <th style="width:8%">
                    <a data-id="NewDoc_CreatedBy" href="#">@Html.Raw(Localizer["Uploaded By"])</a>
                </th>
                <th style="width:10%">
                    <a data-id="NewDoc_UploadedDate" href="#">@Html.Raw(Localizer["Uploaded Date"])</a>
                </th>
                <th style="width:7%">
                    <a href="#"></a>
                </th>
            </tr>
        </thead>
        @(Html.Kendo().ListView<DocumentVerificationNewDTO>()
            .Name("documentVerificationNewDocGrid")
            .TagName("tbody")
            .ContentElement("")
            .ClientTemplateId("ndTemplate")
            .AutoBind(false)
            .Events(e => e.DataBound("documentVerificationPage.newDocDataBound"))
            .DataSource(dataSource => dataSource
                .Ajax()
                .ServerOperation(false)
                .Read(read => read.Action("NewDocGrid_Read", "DocumentVerification")
                .Data(additionalData))
                .Sort(sort => sort.Add(c => c.UploadedDate).Descending())
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
            )
            .Pageable(pageable => pageable
                .Refresh(true)
                .ButtonCount(5)
                .PageSizes(settings.SearchResultsPageSizeOptions)
            )            
            .HtmlAttributes(new { @class = "kendo-listView" })
            )
    </table>
    <script type="text/x-kendo-tmpl" id="ndTemplate">
        <tr class="main item">
            <td style="width:28%">
                #if (CanUploadDocument) {#
                    @if (documentStorageOptions == DocumentStorageOptions.SharePoint) {
                        <input type="checkbox" class="click" name="chkNewDocLink" value="#:DriveItemId#" data-doc-id="#:DocId#" data-doc-name="#:DocName#" data-system-type="#:SystemType#"/>                        
                    }
                    else {
                        <input type="checkbox" class="click" name="chkNewDocLink" value="#:DocId#" data-doc-id="#:DocId#" data-drive-item-id="#:DriveItemId#" data-doc-name="#:DocName#" data-system-type="#:SystemType#"/>                                            
                    }
                #}#                
                @if (documentStorageOptions == DocumentStorageOptions.SharePoint)
                {
                    <span><a href="javascript:documentVerificationPage.viewSPDocument('#:DocLibrary#', '#:DriveItemId#')"><i class="fal fa-search-plus" title="@Html.Raw(Localizer["View"])"></i>#=DocName#</a></span>
                }
                else if (documentStorageOptions == DocumentStorageOptions.iManage || documentStorageOptions == DocumentStorageOptions.NetDocuments)
                {
                        <span><a href="@(Url.Action("Open", kendoUploadController, new { area = "", id = "" }))/#:DriveItemId#" target="_blank" rel="noopener" draggable="false"><i class="fal fa-search-plus" title="@Html.Raw(Localizer["View"])"></i>#=DocName#</a></span>
                }
                else
                {
                    <span><a href="javascript:documentVerificationPage.viewDocument('', '#:DocFileName#', #:ParentId#)"><i class="fal fa-search-plus" title="@Html.Raw(Localizer["View"])"></i>#=DocName#</a></span>
                }
            </td>           
            <td style="width:10%">
                #if(SystemType === 'P' || SystemType === 'G')
                {#
                    <span><a href="javascript:documentVerificationPage.redirectToRecordByCaseNumber('#:SystemType#', '#:CaseNumber#', #:ParentId#)"><i class='fal fa-search-plus'></i> #=(CaseNumber == null) ? '' : CaseNumber#</a></span>
                #} else {#
                    <span>#=(CaseNumber == null) ? '' : CaseNumber#</span>
                #}#
            </td>
            <td style="width:5%">
                #if(SystemType === 'P' || SystemType === 'T')
                {#
                    <span><a href="javascript:documentVerificationPage.redirectToRecordByCountry('#:SystemType#', #:ParentId#)"><i class='fal fa-search-plus'></i> #=(Country == null) ? '' : Country#</a></span>
                #} else {#
                    <span>#=(Country == null) ? '' : Country#</span>
                #}#                
            </td>
            <td style="width:6%">
                <span>#=(SubCase == null) ? '' : SubCase#</span>
            </td> 
             <td style="width:15%">
                <span>#=(RespDocketing == null) ? '' : RespDocketing#</span>
            </td>
            <td style="width:15%">
                <span>#=(RespReporting == null) ? '' : RespReporting#</span>
            </td>
            <td style="width:5%">
                #if(SystemType === 'P')
                {#
                <span>#=getDVLabel('patentLabel')#</span>
                #}
                else if(SystemType === 'T') {#
                <span>#=getDVLabel('trademarkLabel')#</span>
                #}
                else if (SystemType === 'G')
                {#
                <span>#=getDVLabel('genMatterLabel')#</span>
                #}
                else if (SystemType === 'O' || SystemType == null || SystemType === '')
                {#
                <span>#=getDVLabel('orphanageLabel')#</span>
                #}
                #
            </td>
            <td style="width:5%">
                <span>#=(Source == null) ? '' : Source#</span>
            </td>
            <td style="width:8%">
                <span>#=(CreatedBy == null) ? '' : CreatedBy#</span>
            </td>
            <td style="width:10%">
                <span>#= kendo.toString(UploadedDate,'dd-MMM-yyyy hh:mm:ss tt')#</span>
            </td>
            <td style="width:7%; text-align:right;">
            #if(CanUploadDocument) {#
                @if (documentStorageOptions == DocumentStorageOptions.SharePoint) {
                    <a href="javascript:documentVerificationPage.editSPDocument('#:DriveItemId#')"><i class="fal fa-pencil-alt pr-1" title="@Html.Raw(Localizer["Edit"])"></i></a>
                    <a href="javascript:documentVerificationPage.viewSPDocument('#:DocLibrary#', '#:DriveItemId#')"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                    <a class="#:(DocLibrary == null || DocLibrary == '@SharePointDocLibrary.Orphanage') ? '' : 'd-none'#" href="javascript:documentVerificationPage.linkRecord('#:DriveItemId#', '#:DocName#')"><i class="fal fa-link pr-1" title="@Html.Raw(Localizer["Link Document"])"></i></a>                     
                }
                else if (documentStorageOptions == DocumentStorageOptions.iManage || documentStorageOptions == DocumentStorageOptions.NetDocuments) {
                    <a href="javascript:documentVerificationPage.editIMDocument('#:SystemType#', '#:DriveItemId#', #:ParentId#, '#:DocName#')"><i class="fal fa-pencil-alt pr-1" title="@Html.Raw(Localizer["Edit"])"></i></a>
                    <a href="@(Url.Action("Open", kendoUploadController, new { area = "", id = "" }))/#:DriveItemId#" target="_blank" rel="noopener" draggable="false"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                    <a class="#:(DocLibrary == null || DocLibrary == '@SharePointDocLibrary.Orphanage') ? '' : 'd-none'#" href="javascript:documentVerificationPage.linkRecord('#:DocId#', '#:DocName#')"><i class="fal fa-link pr-1" title="@Html.Raw(Localizer["Link Document"])"></i></a>
                }
                else {
                    <a href="javascript:documentVerificationPage.editNewDocument(#:DocId#)"><i class="fal fa-pencil-alt pr-1" title="@Html.Raw(Localizer["Edit"])"></i></a>
                    <a href="javascript:documentVerificationPage.viewDocument('', '#:DocFileName#', #:ParentId#)"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                    <a class="#:(SystemType === '' || SystemType == null || SystemType === 'O') ? '' : 'd-none'#" href="javascript:documentVerificationPage.linkRecord(#:DocId#, '#:DocName#')"><i class="fal fa-link pr-1" title="@Html.Raw(Localizer["Link Document"])"></i></a>
                }
                
                @if (documentStorageOptions == DocumentStorageOptions.SharePoint || documentStorageOptions == DocumentStorageOptions.iManage || documentStorageOptions == DocumentStorageOptions.NetDocuments) {
                    <a href="javascript:documentVerificationPage.deleteNewDocument('#:DriveItemId#')"><i class="fal fa-trash-alt pr-1" title="@Html.Raw(Localizer["Delete"])"></i></a>
                }
                else {
                    <a href="javascript:documentVerificationPage.deleteNewDocument(#:DocId#)"><i class="fal fa-trash-alt pr-1" title="@Html.Raw(Localizer["Delete"])"></i></a>
                }

            #}
            else
            {#
                @if (documentStorageOptions == DocumentStorageOptions.SharePoint) {
                    <a href="javascript:documentVerificationPage.viewSPDocument('#:DocLibrary#', '#:DriveItemId#')"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                }
                else if (documentStorageOptions == DocumentStorageOptions.iManage || documentStorageOptions == DocumentStorageOptions.NetDocuments) {
                    <a href="@(Url.Action("Open", kendoUploadController, new { area = "", id = "" }))/#:DriveItemId#" target="_blank" rel="noopener" draggable="false"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                }
                else {
                    <a href="javascript:documentVerificationPage.viewDocument('', '#:DocFileName#', #:ParentId#)"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                }                    
            #}#
            </td>
        </tr>
    </script>
    <div class="cpiContainerPopup"></div>
</div>
@if (canUploadDoc)
{
    <div class="drop-zone">
        <div id="DropZone" data-save-email-url="@Url.Action("SaveDroppedAttachments", @kendoUploadController, new { Area = "Shared" })"
             data-drop-confirm="@Html.Raw(Localizer["Do you want to save the attachments in the email \"{subject}\" from {sender} for document verification?"])"
             data-drop-confirm-multiple="@Html.Raw(Localizer["Do you want to save the attachments from {count} emails for document verification?"])"
             data-drop-no-attachments="@Html.Raw(Localizer["Please select emails with attachment."])">
            <div class="dropZoneEl dropZoneElement_newDocVerification" ondrop="documentVerificationPage.dropMail(event)" ondragover="documentVerificationPage.allowDropMail(event)">
                <div class="textWrapper">
                    <p class="dropImageHereText">@Html.Raw(Localizer["Drop files here"])</p>
                </div>
            </div>
            <div id="UploadZone" style="display:none;">
                @(Html.Kendo().Upload()
                    .Name($"droppedFiles")
                    .Async(a => a
                    .Save("SaveDroppedDocVerification", @kendoUploadController, new { Area = documentStorageOptions == DocumentStorageOptions.iManage || documentStorageOptions == DocumentStorageOptions.NetDocuments ? "" : "Shared" })
                    .AutoUpload(true)
                    .Batch(true)
                    )
                    .DropZone($".dropZoneElement_newDocVerification")
                    .ShowFileList(false)
                    .Validation(validation => validation.AllowedExtensions(settings.ValidImageFileExtensions))
                    .Multiple(true)
                    .Events(e => e.Error($"documentVerificationPage.onNewDocUploadFail").Success($"documentVerificationPage.onNewDocUploadSuccess").Upload("function() {cpiLoadingSpinner.show();}"))
                    )
            </div>
        </div>
    </div>    
}
<style>
    .dropZoneEl {
        position: relative;
        display: inline-block;
        width: 100%;
        height: 70px;
        text-align: center;
        justify-content: center;
        background-color: var(--image-drop-zone-background);
        border: 1px solid var(--control-border);
    }

    .textWrapper {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 100%;
        font-size: 20px;
        line-height: 1.2em;
        font-family: Arial,Helvetica,sans-serif;
        color: var(--text-body);
    }

    .wrapper:after {
        content: ".";
        display: block;
        height: 0;
        clear: both;
        visibility: hidden;
    }

    #newDocVerificationContainer table {
        width: 100%;
        table-layout: fixed;
        font-size: .8rem;
    }

    /* Change #ndHeaderContainer to .ndHeaderContainer to target both headers */
    .ndHeaderContainer {
        vertical-align: bottom;
    }

    /* Ensure the fake container wrapper spans the full width of the parent */
    #ndHeaderContainer_fake {
        background-color: var(--bg-main); 
        display: none; 
    }

    /* Ensure the table inside the fake container matches the layout of the real table */
    #ndHeaderContainer_fake table {
        width: 100%;
        table-layout: fixed; /* Ensures column widths are respected */
        border-collapse: collapse;
    }

    .ndHeaderContainer td, .ndHeaderContainer th {
        border-bottom: 1px solid #ddd;
        padding: .5em .6em .4em .6em;
    }

    .ndHeaderContainer td, .ndHeaderContainer th, .item td {
        overflow: hidden;
        text-overflow: ellipsis;
        padding: .3em;
        border-spacing: 1px;
        font-weight: 400;
        text-align: left;
        outline: 0;
    }

    .ndHeaderContainer a, .ndHeaderContainer a:hover {
        color: var(--link-label);
        font-weight: 400;
        font-size: .9rem;
        text-decoration: none;
        display: block; /* Makes the entire header cell clickable */
    }

    .ndHeaderContainer th {
        color: var(--text-header);
        background-color: var(--bg-main);
        border-bottom: 1px solid var(--text-body);
    }

    /* Styling for the sort icons we are adding via JS */
    .ndHeaderContainer span.k-icon {
        margin-left: 5px;
        vertical-align: middle;
    }

    #ndHeaderContainer_fake {
        position: fixed;
        top: 0;
        z-index: 1000;
        background-color: var(--bg-main);
        overflow: hidden; /* Prevents internal rounding errors from showing */
    }

    /* Ensure the tables/grids inside them don't have extra margins */
    .ndHeaderContainer {
        margin-top: 0 !important;
    }
   
    #documentVerificationNewDocGrid tr.main:not(:first-child) {
        border-top: 1px solid var(--separator);
    }

    #documentVerificationNewDocGrid_pager .k-pager-info {
        display: block !important;
    }
</style>
