@model DocVerificationRequestDocZoomViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@inject IAuthorizationService AuthService
@{
    var settings = await Settings.GetSetting();
    var caseNumberLabel = settings.IsClientMatterOn ? Localizer[settings.LabelClientMatter ?? "Client Matter"] : Localizer[settings.LabelCaseNumber ?? "Case Number"];
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];    

    var viewerAction = ViewBag.FromTemp != null && (bool)ViewBag.FromTemp ? "GetTempFileDocumentViewer" : "GetDocumentViewer";
    var docUrl = Url.Action(viewerAction, "DocViewer", new { Area = "Shared", docFileName = Model.DocFileName, system = Model.System, screenCode = Model.ScreenCode, key = Model.ParentId, fileType = Model.FileType, sideBarView = GleamTech.DocumentUltimate.AspNet.UI.DocumentViewerSidebarView.None });

    var requestCompletedDateKey = string.Empty;
    var caseNumberUrl = string.Empty;
    var countryUrl = string.Empty;
    var systemLabel = string.Empty;
    var caseTypeLabel = Localizer["Case Type"];
    var filDateLabel = Localizer["Filing Date"];
    var actionDueUrl = string.Empty;
    var screenCode = string.Empty;
    var isActFullModify = false;
    var newActionLink = string.Empty;
    var documentLink = string.Empty;

    if (Model.System == SystemType.Patent)
    {
        requestCompletedDateKey = string.Format("{0}|{1}|{2}", SystemTypeCode.Patent, Model.DataKey, Model.DataKeyValue.ToString()) + ";";
        systemLabel = Localizer["Patent"].ToString();
        caseNumberUrl = Url.Action("Detail", "Invention", new { area = "Patent", id = Model.InvId, fromSearch = true });
        countryUrl = Url.Action("Detail", "CountryApplication", new { area = "Patent", id = Model.ParentId, fromSearch = true });
        actionDueUrl = Url.Action("Detail", "ActionDue", new { area = "Patent", id = Model.ActId, fromSearch = true });
        screenCode = ScreenCode.Application;
        isActFullModify = (await AuthService.AuthorizeAsync(User, PatentAuthorizationPolicy.FullModify)).Succeeded;
        newActionLink = Url.Action("DetailLink", "ActionDue", new { area = "Patent", id = 0, parentId = Model.ParentId, actionTypeId = "actualValue" });
        documentLink = string.Format("{0}|{1}|{2}|{3}", SystemTypeCode.Patent, ScreenCode.Application, "AppId", Model.ParentId.ToString());
    }
    else if (Model.System == SystemType.Trademark)
    {
        requestCompletedDateKey = string.Format("{0}|{1}|{2}", SystemTypeCode.Trademark, Model.DataKey, Model.DataKeyValue.ToString()) + ";";
        systemLabel = Localizer["Trademark"].ToString();
        countryUrl = Url.Action("Detail", "TmkTrademark", new { area = "Trademark", id = Model.ParentId, fromSearch = true });
        actionDueUrl = Url.Action("Detail", "ActionDue", new { area = "Trademark", id = Model.ActId, fromSearch = true });
        screenCode = ScreenCode.Trademark;
        isActFullModify = (await AuthService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.FullModify)).Succeeded;
        newActionLink = Url.Action("DetailLink", "ActionDue", new { area = "Trademark", id = 0, parentId = Model.ParentId, actionTypeId = "actualValue" });
        documentLink = string.Format("{0}|{1}|{2}|{3}", SystemTypeCode.Trademark, ScreenCode.Trademark, "TmkId", Model.ParentId.ToString());
    }
    else if (Model.System == SystemType.GeneralMatter)
    {
        requestCompletedDateKey = string.Format("{0}|{1}|{2}", SystemTypeCode.GeneralMatter, Model.DataKey, Model.DataKeyValue.ToString()) + ";";
        caseTypeLabel = Localizer["Matter Type"];
        filDateLabel = Localizer["Effective Open Date"];
        systemLabel = Localizer["Gen Matter"].ToString();
        caseNumberUrl = Url.Action("Detail", "Matter", new { area = "GeneralMatter", id = Model.ParentId, fromSearch = true });
        actionDueUrl = Url.Action("Detail", "ActionDue", new { area = "GeneralMatter", id = Model.ActId, fromSearch = true });
        screenCode = ScreenCode.GeneralMatter;
        isActFullModify = (await AuthService.AuthorizeAsync(User, GeneralMatterAuthorizationPolicy.FullModify)).Succeeded;
        newActionLink = Url.Action("DetailLink", "ActionDue", new { area = "GeneralMatter", id = 0, parentId = Model.ParentId, actionTypeId = "actualValue" });
        documentLink = string.Format("{0}|{1}|{2}|{3}", SystemTypeCode.GeneralMatter, ScreenCode.GeneralMatter, "MatId", Model.ParentId.ToString());
    }

    var popupTitle = Model.DocName;
    var remarksLabel = Localizer["Remarks"];

    if (string.IsNullOrEmpty(Model.DocFileName))
    {
        if ((Model.DataKey ?? "").ToLower() == "reqid")
        {
            popupTitle = Model.RequestType;
        }
        else if ((Model.DataKey ?? "").ToLower() == "dedocketid")
        {
            popupTitle = Model.ActionDue;
        }
        docUrl = "";
    }

    if ((Model.DataKey ?? "").ToLower() == "reqid")
    {
        remarksLabel = Localizer["Request Remarks"];
    }
    else if ((Model.DataKey ?? "").ToLower() == "dedocketid")
    {
        remarksLabel = Localizer["De-Docket Remarks"];
    }
    else if ((Model.DataKey ?? "").ToLower() == "docid")
    {
        remarksLabel = Localizer["Document Remarks"];
    }
}
<div id="docVerificationRequestDocZoomDialog" class="modal" data-backdrop="static" tabindex="-1" role="dialog" aria-labelledby="docVerificationRequestDocZoomDialogTitle" aria-hidden="true"
    data-cancel-message="@Localizer["Changes will not be saved. Do you want to continue?"]">
    <div class="modal-dialog" role="document" style="max-width:80%; max-height:92vh;">
        <div class="modal-content">
            @if ((Model.DataKey ?? "").ToLower() == "docid")
            {
                <script>
                    function docVerificationAfterSubmit(result) {
                        var requestZoomPopupSummary = $("#requestDocZoomPopupSummary");
                        if (requestZoomPopupSummary && result.message) {
                            $(requestZoomPopupSummary).removeClass("alert-danger");
                            $(requestZoomPopupSummary).addClass("alert-success");
                            requestZoomPopupSummary.find("span.message").html(result.message);
                            $(requestZoomPopupSummary).show(function () {
                                $(requestZoomPopupSummary).delay(3000).slideUp();
                            });
                        }
                        else if (requestZoomPopupSummary && result.errorMessage) {
                            $(requestZoomPopupSummary).addClass("alert-danger");
                            $(requestZoomPopupSummary).removeClass("alert-success");
                            requestZoomPopupSummary.find("span.message").html(pageHelper.getErrorMessage(result));
                            $(requestZoomPopupSummary).show();
                        }
                    }

                    $(document).ready(() => {
                        pageHelper.kendoGridDirtyTracking($(`#documentVerificationActGrid`), { name: 'documentVerificationActGrid', afterSubmit: docVerificationAfterSubmit });
                    });

                    function docActionTypeOnChange(e) {
                        if (e.dataItem) {
                            const row = $(`#${e.sender.element[0].id}`).closest("tr");
                            const keyId = e.dataItem["KeyId"];
                            const baseDate = e.dataItem["BaseDate"];

                            const grid = $("#documentVerificationActGrid").data("kendoGrid");
                            const dataItem = grid.dataItem(row);

                            if (keyId) {
                                var keyArr = keyId.split("|");
                                var dataKey = keyArr[0];
                                var dataKeyValue = keyArr[1];
                                if (dataKey.toLowerCase() == "actid") {
                                    dataItem.ActId = dataKeyValue;
                                    dataItem.ActionTypeID = 0;
                                }
                                else if (dataKey.toLowerCase() == "actiontypeid") {
                                    dataItem.ActionTypeID = dataKeyValue;
                                    dataItem.ActId = 0;
                                }
                            }
                            dataItem.BaseDate = e.dataItem["BaseDate"];
                            var baseDateField = $(row).find(".baseDate-field")
                            if (baseDateField) {
                                baseDateField.html(kendo.htmlEncode(baseDate));
                                if (dataItem.BaseDate) {
                                    baseDateField.removeClass("editable-cell");
                                }
                                else if (@isActFullModify.ToString().ToLower() && !dataItem.BaseDate) {
                                    baseDateField.addClass("editable-cell");
                                }
                            }
                        }
                    };

                    function docVerificationDataBinding(e) {
                        e.sender.tbody.find(".k-grid-delete").hide();
                        const grid = $("#" + e.sender.element[0].id).data("kendoGrid");
                        const data = grid.dataSource.view();
                        if (data) {
                            var filteredData = data.filter(function (el) { return el.VerifyId > 0; });
                            if (filteredData && filteredData.length > 1) {
                                for (var i = 0; i < filteredData.length; i++) {
                                    var trow = grid.tbody.find("tr[data-uid='" + filteredData[i].uid + "']");
                                    trow.find(".k-grid-delete").show();
                                    filteredData[i].CanDelete = true;
                                }
                            }
                            else if (filteredData && filteredData.length <= 1) {
                                for (var i = 0; i < filteredData.length; i++) {
                                    var trow = grid.tbody.find("tr[data-uid='" + filteredData[i].uid + "']");
                                    trow.find(".k-grid-delete").hide();
                                    filteredData[i].CanDelete = false;
                                }
                            }
                        }
                    };

                    function docVerificationDataBound(e) {
                        const gridId = e.sender.element[0].id;
                        const grid = $("#" + gridId).data("kendoGrid");
                        const data = grid.dataSource.view();
                        for (var i = 0; i < data.length; i++) {
                            const trow = grid.tbody.find("tr[data-uid='" + data[i].uid + "']");
                            if (@isActFullModify.ToString().ToLower() && !data[i].BaseDate || data[i].BaseDate == null) {
                                trow.children("td.baseDate-field").addClass("editable-cell");
                            }
                        }
                    }
                </script>
            }
            <form method="post">
                <input type="hidden" id="requestCompletedDateKey" value="@requestCompletedDateKey" />
                <input type="hidden" id="dataKey" value="@Model.DataKey" />
                <input type="hidden" id="dataKeyValue" value="@Model.DataKeyValue" />
                <div class="modal-header">
                    <h4 class="modal-title" id="docVerificationRequestDocZoomDialogTitle">@popupTitle</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="@Localizer["Close"]">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <div class="form-row">
                        <div class="col-6">
                            <div id="docVerificationRequestDocViewerContainer" data-viewer-url="@docUrl">                                                                
                            </div>
                            @if (string.IsNullOrEmpty(docUrl))
                            {
                                <div style="display: flex; justify-content: center; align-items: center; height: 100%;">
                                    <span>@Localizer["No document available"]</span>
                                </div>
                            }
                        </div>
                        <div class="col-6">
                            <div id="requestDocZoomPopupSummary" class="page-status alert alert-danger alert-dismissible boxy collapse" role="alert">
                                <button type="button" class="close" data-hide="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                                <span class="message"></span>
                            </div>
                            <div class="form-row">                            
                                <div class="col-4">
                                    <div class="form-group float-label">
                                        <label for="CaseNumber">@caseNumberLabel</label>
                                        @if (Model.System != SystemType.Trademark)
                                        {
                                            <div class="d-flex">
                                                <input type="text" class="form-control form-control-sm" asp-for="CaseNumber" asp-is-readonly="true" />
                                                <a href="@caseNumberUrl" target="_blank"><i cpi-button-link></i></a>
                                            </div>
                                        }
                                        else
                                        {
                                            <input type="text" class="form-control form-control-sm" asp-for="CaseNumber" asp-is-readonly="true" />
                                        }
                                    </div>
                                </div>
                                <div class="col-4">
                                    @if (Model.System != SystemType.GeneralMatter)
                                    {
                                        <div class="form-group float-label">
                                            <label asp-for="Country">@countryLabel</label>
                                            <div class="d-flex">
                                                <input type="text" class="form-control form-control-sm" asp-for="Country" asp-is-readonly="true" />
                                                <a href="@countryUrl" target="_blank"><i cpi-button-link></i></a>
                                            </div>
                                        </div>
                                    }                                
                                </div>
                                <div class="col-4">
                                    <div class="form-group float-label">
                                        <label asp-for="System">@Localizer["System"]</label>
                                        <input type="text" class="form-control form-control-sm" readonly value="@systemLabel" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-4">
                                    <div class="form-group float-label">
                                        <label asp-for="SubCase">@Localizer["Sub Case"]</label>
                                        <input type="text" class="form-control form-control-sm" asp-for="SubCase" asp-is-readonly="true" />
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group float-label">
                                        <label asp-for="CaseType">@caseTypeLabel</label>
                                        <input type="text" class="form-control form-control-sm" asp-for="CaseType" asp-is-readonly="true" />
                                    </div>
                                </div>
                                <div class="col-4">
                                    <div class="form-group float-label">
                                        <label asp-for="Status">@Localizer["Status"]</label>
                                        <input type="text" class="form-control form-control-sm" asp-for="Status" asp-is-readonly="true" />
                                    </div>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="col-4">
                                    @if(Model.System != SystemType.GeneralMatter)
                                    {
                                        <div class="form-group float-label">
                                            <label asp-for="AppNumber">@Localizer["Application No."]</label>
                                            <input type="text" class="form-control form-control-sm" asp-for="AppNumber" asp-is-readonly="true" />
                                        </div>
                                    }                                
                                </div>
                                <div class="col-4">

                                </div>
                                <div class="col-4">
                                    <div class="form-group float-label">
                                        <label asp-for="FilDate">@filDateLabel</label>
                                        <input type="text" class="form-control form-control-sm" asp-for="FilDate" asp-is-readonly="true" value="@(Model.FilDate.FormatToDisplay())" />
                                    </div>
                                </div>
                            </div>

                            @if ((Model.DataKey ?? "").ToLower() == "reqid")
                            {
                                <div class="form-row">
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="RequestType"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="RequestType" asp-is-readonly="true" />
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="CreatedBy"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="CreatedBy" asp-is-readonly="true" />
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="DateCreated"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="DateCreated" asp-is-readonly="true" value="@(((DateTime?)Model.DateCreated).FormatToDisplay())" />
                                        </div>
                                    </div>
                                </div>
                            }
                            else if ((Model.DataKey ?? "").ToLower() == "dedocketid")
                            {
                                <div class="form-row">
                                    <div class="col-8">
                                        <div class="form-group float-label">
                                            <label asp-for="ActionType"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="ActionType" asp-is-readonly="true" />
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="BaseDate"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="BaseDate" asp-is-readonly="true" value="@(((DateTime?)Model.BaseDate).FormatToDisplay())" />
                                        </div>
                                    </div>
                                </div>
                                <div class="form-row">                                    
                                    <div class="col-8">
                                        <div class="form-group float-label">
                                            <label asp-for="ActionDue"></label>
                                            <div class="d-flex">
                                                <input type="text" class="form-control form-control-sm" asp-for="ActionDue" asp-is-readonly="true" />
                                                <a href="@actionDueUrl" target="_blank"><i cpi-button-link></i></a>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="DueDate"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="DueDate" asp-is-readonly="true" value="@(((DateTime?)Model.DueDate).FormatToDisplay())" />
                                        </div>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="Instruction"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="Instruction" asp-is-readonly="true" />
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="InstructionDate"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="InstructionDate" asp-is-readonly="true" value="@(((DateTime?)Model.InstructionDate).FormatToDisplay())" />
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="Indicator"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="Indicator" asp-is-readonly="true" />
                                        </div>
                                    </div>
                                </div>
                            }
                            else if ((Model.DataKey ?? "").ToLower() == "docid")
                            {
                                <div class="form-row">
                                    <div class="col">
                                        <div class="form-group float-label">
                                            <label asp-for="DocName"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="DocName" asp-is-readonly="true" />
                                        </div>
                                    </div>                                    
                                </div>
                            }

                            @if ((Model.DataKey ?? "").ToLower() == "reqid" || (Model.DataKey ?? "").ToLower() == "dedocketid")
                            {
                                <div class="form-row">
                                    @if ((Model.DataKey ?? "").ToLower() == "dedocketid")
                                    {
                                        <div class="col-4">
                                            <div class="form-group float-label">
                                                <label asp-for="InstructedBy"></label>
                                                <input type="text" class="form-control form-control-sm" asp-for="InstructedBy" asp-is-readonly="true" />
                                            </div>
                                        </div>
                                    }
                                    <div class="col-4">
                                        <div class="form-group float-label">
                                            <label asp-for="CompletedBy"></label>
                                            <input type="text" class="form-control form-control-sm" asp-for="CompletedBy" asp-is-readonly="true" />
                                        </div>
                                    </div>
                                    @if (Model.CanSave)
                                    {
                                        <div class="col-4 d-flex completed-date">
                                            <div class="form-group float-label">
                                                <label asp-for="CompletedDate"></label>
                                                @await Component.InvokeAsync("DatePicker", new DatePickerOptions("CompletedDate") { Value = Model.CompletedDate })

                                            </div>
                                            <div class="pl-2" style="padding-top:15px;cursor:pointer;">
                                                <span class="completed-date-default" title="@Localizer["Set to current date"]"><i class="fal fa-calendar-check"></i></span>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="col-4">
                                            <div class="form-group float-label">
                                                <label asp-for="CompletedDate"></label>
                                                <input type="text" class="form-control form-control-sm" asp-for="CompletedDate" asp-is-readonly="true" value="@(((DateTime?)Model.CompletedDate).FormatToDisplay())" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            
                            <div class="form-row">
                                <div class="col">
                                    <div class="form-group float-label">
                                        <label for="Remarks">@remarksLabel</label>
                                        <textarea rows="3" class="form-control form-control-sm" asp-for="Remarks" asp-is-readonly="true"></textarea>
                                    </div>
                                </div>
                            </div>

                            @if ((Model.DataKey ?? "").ToLower() == "docid")
                            {
                                <div class="form-row">
                                    <div class="col-md-12">
                                        @(Html.Kendo().Grid<DocVerificationViewModel>()
                                            .Name("documentVerificationActGrid")
                                            .Columns(columns =>
                                            {
                                                columns.Bound(p => p.ActionType).Width("30%")
                                                .Title(Localizer["Action Type"])
                                                .EditorTemplateName("ComboBox")
                                                .EditorViewData(new
                                                {
                                                    action = "GetCorrespondingActList",
                                                    controller = "DocumentVerification",
                                                    dataValueField = "ActionType",
                                                    dataTextField = "ActionType",
                                                    onSelect = "docActionTypeOnChange",
                                                    limitToList = true,
                                                    serverFiltering = false,
                                                    valuePrimitive = true,
                                                    readData = $"function() {{return {{screenCode: '{screenCode}', parentId: {Model.ParentId} }} }}",
                                                    listWidth = 500,
                                                    columns = new List<ComboBoxColumn> {
                                                        new ComboBoxColumn { Name = "ActionType", Header = Localizer["Action Type"], Width = 400 },
                                                        new ComboBoxColumn { Name = "BaseDate", Header = Localizer["Base Date"], Width = 100 },
                                                        new ComboBoxColumn { Name = "Source", Header = Localizer["Source"], Width = 90 }
                                                    }
                                                })
                                                .HtmlAttributes(new { @class = "editable-cell actionType-field" });

                                                columns.Bound(a => a.BaseDate)
                                                .ClientTemplate("#= (BaseDate == null) ? '' : kendo.toString(BaseDate,'dd-MMM-yyyy')#")
                                                .EditorTemplateName("Date")
                                                .Editable($"function(e) {{ return ({isActFullModify.ToString().ToLower()} && (e.BaseDate == null || e.ActionTypeID > 0));}}")
                                                .HtmlAttributes(new { @class = "baseDate-field" })
                                                .Width("20%");

                                                columns.Bound(a => a.VerifiedBy).Title(Localizer["Verified By"]).Width("20%");
                                                columns.Bound(a => a.DateVerified).Title(Localizer["Verified Date"]).Format("{0:dd-MMM-yyyy}").Width("20%");

                                                columns.Bound(opt => opt.ActionTypeID).Hidden(true);
                                                columns.Bound(opt => opt.ActId).Hidden(true);

                                                columns.Command(command =>
                                                {
                                                    command.Custom("AddAction")
                                                .Click($"function(e) {{ var dataItem = this.dataItem($(e.currentTarget).closest('tr')); var url = '{newActionLink}'; url = url.replace('actualValue', dataItem.ActionTypeID); window.open(url, '_blank');}}")
                                                .IconClass("k-icon fal fa-search-plus")
                                                .Text($"<span class='grid-action-label'>{Localizer["Add"]}</span>")
                                                .HtmlAttributes(new { @class = "grid-action" })
                                                .Visible("function(dataItem) { return (dataItem.ActionTypeID > 0 && dataItem.ActId == 0);}");
                                                    command.Custom("Delete")
                                                .Click($"function(e) {{ const dataItem = this.dataItem($(e.currentTarget).closest('tr')); pageHelper.deleteGridRow(e,dataItem, docVerificationAfterSubmit); }}")
                                                .IconClass("k-icon fal fa-trash-alt")
                                                .Text($"<span class='grid-action-label'>{Localizer["Delete"]}</span>")
                                                .HtmlAttributes(new { @class = "grid-action" })
                                                .Visible("function(dataItem){ return dataItem.CanDelete; }");
                                                }).Width("10%");
                                            })
                                            .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
                                            .ToolBar(toolbar =>
                                            {
                                                toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"]).HtmlAttributes(new { @class = "grid-action" });
                                                toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                                                toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
                                            })
                                            .Editable(editable => editable
                                            .Enabled(Model.CanSave)
                                            .Mode(GridEditMode.InCell)
                                            .ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false)
                                            )
                                            .Pageable()
                                            .AutoBind(true)
                                            .DataSource(dataSource => dataSource
                                            .Ajax()
                                            .Batch(true)
                                            .PageSize(settings.SubFormPageSize)
                                            .ServerOperation(false)
                                            .Model(model =>
                                            {
                                                model.Id(opt => opt.VerifyId);
                                                model.Field(opt => opt.DocId).Editable(false).DefaultValue(Model.DataKeyValue);
                                                model.Field(opt => opt.ActionType).Editable(true);
                                                model.Field(opt => opt.BaseDate).Editable(isActFullModify);
                                                model.Field(opt => opt.VerifiedBy).Editable(false);
                                                model.Field(opt => opt.DateVerified).Editable(false);
                                                //model.Field(opt => opt.RandomGuid).Editable(false).DefaultValue(Model.RandomGuid);
                                                model.Field(opt => opt.WorkflowStatus).Editable(false).DefaultValue(DocVerificationWorkflowStatus.DoNotProcess);
                                            })
                                            .Read(read => read.Action("DocVerificationRead", "DocumentVerification", new { docId = Model.DataKeyValue, documentLink = documentLink }))
                                            .Update(update => update.Action("DocVerificationUpdate", "DocumentVerification", new { docId = Model.DataKeyValue, documentLink = documentLink }))
                                            .Destroy(destroy => destroy.Action("DocVerificationDelete", "DocumentVerification"))
                                            .Events(events =>
                                            {
                                                events.Error("pageHelper.onGridError");
                                            })
                                            )
                                            .Events(events =>
                                            {
                                                events.DataBound("docVerificationDataBound");
                                                events.DataBinding("docVerificationDataBinding");
                                            })
                                            .HtmlAttributes(new { @class = "k-grid-border" })
                                            )
                                    </div>
                                </div>
                            }

                        </div>
                    </div>                
                </div>
                <div class="modal-footer" style="display:block !important;">
                    <div class="row">
                        <div class="col-8" id="docVerificationRequestDocZoomDialogPager">
                            <div class="k-pager-wrap k-grid-pager k-widget k-floatwrap">
                                <a class="k-link k-pager-nav navigate" data-dir="top" tabindex="-1">
                                    <span class="k-icon k-i-seek-w"></span>
                                </a>
                                <a class="k-link k-pager-nav navigate" data-dir="prev" tabindex="-1">
                                    <span class="k-icon k-i-arrow-w"></span>
                                </a>
                                <a class="k-link k-pager-nav navigate" data-dir="next" tabindex="-1">
                                    <span class="k-icon k-i-arrow-e"></span>
                                </a>
                                <a class="k-link k-pager-nav navigate" data-dir="last" tabindex="-1">
                                    <span class="k-icon k-i-seek-e"></span>
                                </a>
                                <input type="text" style="border: 1px solid var(--control-border); width:80px;height: 80%; text-align:center;" class="currentRecPosition" />&nbsp;@Localizer["of"]&nbsp;<span class="navTotalRecs"></span>&nbsp;@Localizer["records"]
                            </div>
                        </div>
                        <div class="col-4">
                            @if (Model.CanSave)
                            {
                                <button type="button" class="btn btn-primary save-completed-date float-right" style="margin-left:.50rem !important;"><i class="fa fa-check pr-2"></i>@Localizer["Save"]</button>
                            }
                            <button id="cancel" type="button" class="btn btn-secondary float-right" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Close"]</button>                        
                        </div>
                    </div>                
                </div>
            </form>
        </div>       
    </div>
    
</div>
