@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@inject IAuthorizationService AuthorizationService
@{
    var settings = await Settings.GetSetting();

    var caseNumberLabel = settings.IsClientMatterOn ? Localizer[settings.LabelClientMatter ?? "Client Matter"] : Localizer[settings.LabelCaseNumber ?? "Case Number"];
    var deDocketLabel = Localizer["De-Docket"].ToString();
    var instructionLabel = Localizer["Instruction"].ToString();
    var deDocketRemarksLabel = Localizer["De-Docket Remarks"].ToString();
    var instructedByLabel = Localizer["Instructed By"].ToString();
    var instructionDateLabel = Localizer["Instruction Date"].ToString();
    var completedLabel = Localizer["Completed?"].ToString();

    var requestDocketLabel = Localizer["Request Docket"].ToString();
    var docketRequiredLabel = Localizer["Docket Required"].ToString();

    var additionalData = "function() {return documentVerificationPage.getCriteria(documentVerificationPage.refineSearchContainer);}";

    var canModifyPatDoc = (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.CanUploadDocuments)).Succeeded;
    var canModifyTmkDoc = (await AuthorizationService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.CanUploadDocuments)).Succeeded;
    var canModifyGMDoc = (await AuthorizationService.AuthorizeAsync(User, GeneralMatterAuthorizationPolicy.CanUploadDocuments)).Succeeded;
    var canUploadDoc = canModifyPatDoc || canModifyTmkDoc || canModifyGMDoc;

    var canAddPatAct = (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.FullModify)).Succeeded;
    var canAddTmkAct = (await AuthorizationService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.FullModify)).Succeeded;
    var canAddGMAct = (await AuthorizationService.AuthorizeAsync(User, GeneralMatterAuthorizationPolicy.FullModify)).Succeeded;

    var canAccessPatent = (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.CanAccessSystem)).Succeeded;
    var canAccessTrademark = (await AuthorizationService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.CanAccessSystem)).Succeeded;
    var canAccessGeneralMatter = (await AuthorizationService.AuthorizeAsync(User, GeneralMatterAuthorizationPolicy.CanAccessSystem)).Succeeded;
    var canAccessDueDateList = (await AuthorizationService.AuthorizeAsync(User, SharedAuthorizationPolicy.CanAccessDueDateList)).Succeeded 
                                && (canAccessPatent || canAccessTrademark || canAccessGeneralMatter);

    var isDocketRequestOn = settings.IsDocketRequestOn;
    var includeDeDocket = settings.IsDeDocketOn && settings.IncludeDeDocketInVerification;

    var docsStorageOption = ((int)(settings.DocumentStorage)).ToString();
    var docsSharePoint = ((int)DocumentStorageOptions.SharePoint).ToString();
    var docsIManage = ((int)DocumentStorageOptions.iManage).ToString();
    var docsNetDocs = ((int)DocumentStorageOptions.NetDocuments).ToString();
    var docsController = "DocDocuments";
    
    if (docsStorageOption == docsSharePoint) 
        docsController = "SharePointGraph"; 
    else if (docsStorageOption == docsIManage)
        docsController = "iManageWork";
    else if (docsStorageOption == docsNetDocs)
        docsController = "NetDocs";
}


<div class="page-header cpiButtonsDetail" id="docVerificationHeaderContainer">
    <nav class="nav nav-left pt-2 sidebar-link" style="align-items:center;">
        @if (canUploadDoc)
        {            
            <a class="nav-link select-all-record" href="#" role="button"><i class="fal fa-check pr-1"></i><span>@Html.Raw(Localizer["Select all"])</span></a>
            <a class="nav-link responsible-doc" href="#" role="button"><i class="fal fa-user pr-1"></i><span>@Html.Raw(Localizer["Delegate Task"])</span></a>
            <a class="nav-link delete-doc" href="#" role="button"><i class="fal fa-trash-alt pr-1"></i><span>@Html.Raw(Localizer["Delete"])</span></a>
        }
        <a class="nav-link print-record" href="#" role="button"><i class="fal fa-file-arrow-down pr-1"></i><span>@Html.Raw(Localizer["Print View"])</span></a>
        <a class="nav-link excel-export" href="#" role="button"><i class="fal fa-file-excel pr-1"></i><span>@Html.Raw(Localizer["Export to Excel"])</span></a>
        <a class="nav-link productivity-report" href="#" role="button"><i class="fal fa-file-chart-pie pr-1"></i><span>@Html.Raw(Localizer["Productivity Reports"])</span></a>
        @if (canAccessDueDateList)
        {
            <a class="nav-link quick-docket" href="#" role="button"><i class="fal fa-files pr-1"></i><span>@Html.Raw(Localizer["Quick Docket"])</span></a>
        }        
    </nav>
    <form id="dvExportToExcel" action="@Url.Action("ExportToExcel")" method="post">
        <input type="hidden" name="exportCriteria" id="dvExportCriteria" value="" />
    </form>
</div>

