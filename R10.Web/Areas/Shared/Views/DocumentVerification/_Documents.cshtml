        @(Html.Kendo().ListView<DocumentVerificationDTO>()
            .Name("documentVerificationSearchResults-Grid")
            .TagName("tbody")
            .ContentElement("")
            .ClientTemplateId("dvTemplate")
            .AutoBind(false)
            .Events(e => e.DataBound("documentVerificationPage.dataBound"))
            .DataSource(dataSource => dataSource
                .Ajax()
                .Read(read => read.Action("DocVerification_Read", "DocumentVerification")
                .Data(additionalData))
                .Sort(sort => sort.Add(c => c.UploadedDate))
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                .Events(e => {
                    e.RequestEnd("documentVerificationPage.requestListRequestEnd");
                })
            )
            .Pageable(pageable => pageable
            .Refresh(true)
            .ButtonCount(5)
            .PageSizes(settings.SearchResultsPageSizeOptions)
            )
            .HtmlAttributes(new { @class = "kendo-listView" })
            )
    </table>
    <script type="text/x-kendo-tmpl" id="dvTemplate">
        <tr class="main item">
            <td style="width:9%">
                #if(CanUploadDocument || CanViewDocketRequest || CanViewInstruction) {#
