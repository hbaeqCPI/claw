                        <a href="javascript:documentVerificationPage.editResponsible('#:System#', 'DocId|#:DocId#', '#:DocName#', @((int)DocRespLogType.Docketing))"><i class="fal #:((RespDocketing != '' && RespDocketing != null)) ? 'fa-users' : 'fa-user'# pr-1" title="@Html.Raw(Localizer["Delegate Task"])"></i></a>

