                else if (KeyId.startsWith('dedocketid') && CanViewInstruction) {#
                    <a href="javascript:documentVerificationPage.viewRequest('#:System#', #:ParentId#, '#:KeyId#')"><i class="fal fa-pencil-alt pr-1" title="@Html.Raw(Localizer["Edit Request"])"></i></a>

                    #if (DocFileName > '' || DriveItemId > '') {#
                        #if ("@docsStorageOption"==="@docsSharePoint") {#
                            <a href="javascript:documentVerificationPage.viewSPDocument('#:DocLibrary#', '#:DriveItemId#')"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                        #} else if ("@docsStorageOption"==="@docsIManage" || "@docsStorageOption"==="@docsNetDocs"){#
                            <a href="@(Url.Action("Open", docsController, new { area = "", id = "" }))/#:DriveItemId#" target="_blank" rel="noopener" draggable="false"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                        #} else {#
                            <a href="javascript:documentVerificationPage.viewDocument('#:System#', '#:DocFileName#', #:ParentId#, '#:KeyId#')"><i class="fal fa-file pr-1" title="@Html.Raw(Localizer["View"])"></i></a>
                        #}#
                    #}#

                    <a href="javascript:documentVerificationPage.editResponsible('#:System#', '#:KeyId#', '#:DocName ?? ActionDue#', @((int)DocRespLogType.Docketing))"><i class="fal #:((RespDocketing != '' && RespDocketing != null)) ? 'fa-users' : 'fa-user'# pr-1" title="@Html.Raw(Localizer["Delegate Task"])"></i></a>
                #}#

            </td>
        </tr>
        @if (includeDeDocket)
        {
            <tr class="item">
                <td class="pl-5" colspan="10">
                    #if(CanViewInstruction && (System == 'P' || System == 'T' || System == 'G' ))
                    {#
                    <div class="sub-field ddk-main # if(Instruction==null){ #d-none#}#">
                        <span class="ddk-container" style="cursor:pointer">
                            <i class="far fa-plus-square icon"></i>&nbsp;#=getDVLabel('deDocketLabel')#
                        </span>
                        <div class="d-none ddk row">
                        <div class="col-md-2">
                            <span>#=getDVLabel('instructionLabel')#:</span>
                            <span class="ddk-instruction">#=Instruction#</span>
                        </div>
                        <div class="col-md-2">
                            <span>#=getDVLabel('instructedByLabel')#:</span>
                            <span class="ddk-instructed-by">#=InstructedBy#</span>
                        </div>
                        <div class="col-md-2">
                            <span>#=getDVLabel('instructionDateLabel')#:</span>
                            <span class="ddk-instruction-date">#=pageHelper.cpiDateFormatToDisplay(InstructionDate)#</span>
                        </div>
                        <div class="col-md-2">
                            <span>#=getDVLabel('completedLabel')#:</span>
                            <span class="ddk-instruction-completed">
                                #: InstructionCompleted ? getDVLabel('yesLabel') : getDVLabel('noLabel')#
                            </span>
                        </div>                        
                        </div>
                        #if(CanViewRemarks && (System == 'P' || System == 'T' || System == 'G' ))
                        {#
                        <div class="d-none ddk">
                            <span>#=getDVLabel('deDocketRemarksLabel')#:</span>
                            <span class="ddk-remarks">#=DeDocketRemarks ?? ""#</span>
                        </div>
                        #}#
                    </div> 
                    #}#
                </td>
            </tr>
        }
        @if (isDocketRequestOn)
        {
            <tr class="item">
                <td class="pl-5" colspan="10">
                    #if(CanViewDocketRequest && (System == 'P' || System == 'T' || System == 'G' ))
                    {#
                    <div class="sub-field dkr-main # if(DocketRequest_CreatedBy==null){ #d-none#}#">
                        <span class="dkr-container" style="cursor:pointer">
                            <i class="far fa-plus-square icon"></i>&nbsp;#=getDVLabel('requestDocketLabel')#
                        </span>
                        <div class="d-none dkr row">                        
                        <div class="col-md-2">
                            <span>#=getDVLabel('requestDocketCreatedByLabel')#:</span>
                            <span class="dkr-request-by">#=DocketRequest_CreatedBy#</span>
                        </div>
                        <div class="col-md-2">
                            <span>#=getDVLabel('requestDocketDateCreatedLabel')#:</span>
                            <span class="dkr-request-date">#=pageHelper.cpiDateFormatToDisplay(DocketRequest_DateCreated)#</span>
                        </div>                                               
                        </div>
                        #if(CanViewRemarks && (System == 'P' || System == 'T' || System == 'G' ))
                        {#
                        <div class="d-none dkr">
                            <span>#=getDVLabel('requestDocketRemarksLabel')#:</span>
                            <span class="dkr-remarks">#=DocketRequest_Remarks ?? ""#</span>
                        </div>
                        #}#
                    </div> 
                    #}#
                </td>
            </tr>
        }
    </script>
    <div class="cpiContainerPopup"></div>
</div>
