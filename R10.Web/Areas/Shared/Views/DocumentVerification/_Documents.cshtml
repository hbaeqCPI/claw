<script>
    function getDataType(keyId) {
        if (keyId && keyId > "") {
            var keyArr = keyId.split("|");
            var dataKey = keyArr[0];
            var dataKeyValue = keyArr[1];

            if (dataKey && dataKey.toLowerCase() === 'verifyid') {
                return "@docketRequiredLabel";
            }
            else if (dataKey && dataKey.toLowerCase() === "reqid") {
                return "@requestDocketLabel";
            }
            else if (dataKey && dataKey.toLowerCase() === "dedocketid") {
                return "@deDocketLabel";
            }
            else {
                return "";
            }
        }
        return '';
    }    
    
    function canAddAct(System) {
        if ((System === "@SystemTypeCode.Patent" && "@canAddPatAct.ToString().ToLower()"==="true") ||
            (System === "@SystemTypeCode.Trademark" && "@canAddTmkAct.ToString().ToLower()"==="true") ||
            (System === "@SystemTypeCode.GeneralMatter" && "@canAddGMAct.ToString().ToLower()"==="true"))
        {
            return true;
        }
        else {
            return false;
        }
    }    

    function getActionDueDisplay(actionDue, dueDate, indicator) {
        var displayTemplate = "<span>[actiondue]</span> <span class='sub-field'>([duedate] - [indicator])</span>";
        if (actionDue) {
            return displayTemplate.replace("[actiondue]", actionDue).replace("[duedate]", pageHelper.cpiDateFormatToDisplay(dueDate)).replace("[indicator]", indicator);
        }
        else {
            return "";
        }
    }
</script>