                                <input type="radio" name="DocSentToClient" checked class="form-control" value="false" data-role="option"> @Localizer["No"]
                            </label>
                            <label class="btn btn-outline">
                                <input type="radio" name="DocSentToClient" class="form-control" value="" data-role="option"> @Localizer["All"]
                            </label>
                        </div>
                    </div>
