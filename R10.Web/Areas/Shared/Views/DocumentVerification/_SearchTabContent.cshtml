@model PageViewModel
@inject ISystemSettings<DefaultSetting> Settings
@inject ISystemSettings<PatSetting> PatSettings
@inject ISystemSettings<TmkSetting> TmkSettings
@inject IStringLocalizer<SharedResource> Localizer
@inject IAuthorizationService AuthorizationService
@{
    var settings = await Settings.GetSetting();
    var patSettings = await PatSettings.GetSetting();
    var tmkSettings = await TmkSettings.GetSetting();
    var attorneyLabel = Localizer["Attorney(s)"];
    var attorneyNameLabel = Localizer["Attorney Name"];
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];
    var clientLabel = Localizer[settings.LabelClient + "(s)"];
    var clientNameLabel = Localizer[settings.LabelClientName ?? "Client Name"];

    var isPatDocVerificationOn = (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.CanAccessDocumentVerification)).Succeeded;
    var isTmkDocVerificationOn = (await AuthorizationService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.CanAccessDocumentVerification)).Succeeded; ;
    var isGmDocVerificationOn = (await AuthorizationService.AuthorizeAsync(User, GeneralMatterAuthorizationPolicy.CanAccessDocumentVerification)).Succeeded; ;

    var enableComboPaging = settings.EnableComboBoxPaging;
    var comboPagingSize = settings.ComboBoxPagingSize;

    var additionalData = "function() {return documentVerificationPage.getSystems(documentVerificationPage.refineSearchContainer);}";

    var defaultResponsibleId = ViewData["DefaultResponsibleId"] == null ? "" : ((string)(ViewData["DefaultResponsibleId"] ?? ""));
    var inDocketingGroup = (bool)(ViewData["InDocketingGroup"] ?? false);
    var inReportingGroup = (bool)(ViewData["InReportingGroup"] ?? false);

    var includeDeDocket = settings.IsDeDocketOn && settings.IncludeDeDocketInVerification;
    var isDocketRequestOn = settings.IsDocketRequestOn;
    var canRequestDocket = false;
    if (isDocketRequestOn)
    {
        canRequestDocket = (await AuthorizationService.AuthorizeAsync(User, PatentAuthorizationPolicy.CanRequestDocket)).Succeeded ||
            (await AuthorizationService.AuthorizeAsync(User, TrademarkAuthorizationPolicy.CanRequestDocket)).Succeeded ||
            (await AuthorizationService.AuthorizeAsync(User, GeneralMatterAuthorizationPolicy.CanRequestDocket)).Succeeded;
    }
}


<div class="tab-content search page-content">
    <div class="tab-pane show active" id="documentVerificationSearchCaseInfoTabContent" role="tabpanel"
    aria-labelledby="documentVerificationSearchCaseInfoTab">        
        <div class="form-row">
            <div class="col">
                <input type="hidden" name="FromSystem" value="@Model.SystemType" />
                <input id="SortCol" type="text" hidden name="SortCol" value="" />
                <input id="SortOrder" type="text" hidden name="SortOrder" value="ASC" />
                <div class="system-types">
                    <div class="pb-1"><label>@Localizer["System"]</label></div>
                    <div class="border rounded px-2 py-2 d-flex">                        
                        @if (isPatDocVerificationOn)
                        {
                            <div class="form-check form-check-inline" style="width:40%">
                                <input class="form-check-input" type="checkbox" name="Patent" @(Model.SystemType != null && Model.SystemType.Contains("P") ? "checked" : "") value="P" onclick="documentVerificationPage.refreshCriteriaDS();">
                                <label class="form-check-label" for="Patent">@Localizer["Patent"]</label>
                            </div>
                        }
                        @if (isTmkDocVerificationOn)
                        {
                            <div class="form-check form-check-inline" style="width:40%">
                                <input class="form-check-input" type="checkbox" name="Trademark" @(Model.SystemType != null && Model.SystemType.Contains("T") ? "checked" : "") value="T" onclick="documentVerificationPage.refreshCriteriaDS();">
                                <label class="form-check-label" for="Trademark">@Localizer["Trademark"]</label>
                            </div>
                        }
                        @if (isGmDocVerificationOn)
                        {
                            <div class="form-check form-check-inline" style="width:40%">
                                <input class="form-check-input" type="checkbox" name="GeneralMatter" @(Model.SystemType != null && Model.SystemType.Contains("G") ? "checked" : "") value="G" onclick="documentVerificationPage.refreshCriteriaDS();">
                                <label class="form-check-label" for="GeneralMatter">@Localizer["General Matter"]</label>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        @if (isDocketRequestOn || includeDeDocket)
        {
            <div id="requestDocketFilter">
                <div class="form-row">
                    <div class="col grid-options">
                        <div class="form-group">
                            <label class="option-name" for="IncludeDocumentRequest">@Localizer["Include Document Verification"]</label>
                            <span>
                                <label class="toggle-switch active">
                                    <input name="IncludeDocumentRequest" checked type="checkbox" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </div>
                    </div>
                </div>
                @if (isDocketRequestOn && canRequestDocket)
                {
                    <div class="form-row">
                        <div class="col grid-options">
                            <div class="form-group">
                                <label class="option-name" for="IncludeRequestDocket">@Localizer["Include Request Docket"]</label>
                                <span>
                                    <label class="toggle-switch active">
                                        <input name="IncludeRequestDocket" checked type="checkbox" class="toggle-option">
                                        <span class="slider round"></span>
                                    </label>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="col">
                            <div class="form-group">
                                <label for="RequestDocketCompleted">@Localizer["Request Docket Completed?"]</label>
                                <div>
                                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                                        <label class="btn btn-outline">
                                            <input type="radio" name="RequestDocketCompleted" class="form-control" value="true" data-role="option"> @Localizer["Yes"]
                                        </label>
                                        <label class="btn btn-outline active">
                                            <input type="radio" name="RequestDocketCompleted" checked class="form-control" value="false" data-role="option"> @Localizer["No"]
                                        </label>
                                        <label class="btn btn-outline">
                                            <input type="radio" name="RequestDocketCompleted" class="form-control" value="" data-role="option"> @Localizer["All"]
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                @if (includeDeDocket)
                {
                    <div class="form-row">
                        <div class="col grid-options">
                            <div class="form-group">
                                <label class="option-name" for="IncludeDeDocket">@Localizer["Include De-Docket Instruction"]</label>
                                <span>
                                    <label class="toggle-switch active">
                                        <input name="IncludeDeDocket" checked type="checkbox" class="toggle-option">
                                        <span class="slider round"></span>
                                    </label>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="col">
                            <div class="form-group">
                                <label for="DeDocketCompleted">@Localizer["De-Docket Completed?"]</label>
                                <div>
                                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                                        <label class="btn btn-outline">
                                            <input type="radio" name="DeDocketCompleted" class="form-control" value="true" data-role="option"> @Localizer["Yes"]
                                        </label>
                                        <label class="btn btn-outline active">
                                            <input type="radio" name="DeDocketCompleted" checked class="form-control" value="false" data-role="option"> @Localizer["No"]
                                        </label>
                                        <label class="btn btn-outline">
                                            <input type="radio" name="DeDocketCompleted" class="form-control" value="" data-role="option"> @Localizer["All"]
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
