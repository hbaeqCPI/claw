    <div class="tab-pane" id="documentVerificationSearchEntitiesTabContent" role="tabpanel"
    aria-labelledby="documentVerificationSearchEntitiesTab">
        <div class="form-row">            
            <div class="col">
                <div class="form-group float-label">
                    <label>@clientLabel</label>
                    @(Html.Kendo().MultiSelect()
                            .Name("Clients")
                            .DataTextField("Client")
                            .DataValueField("Client")
                            .AutoBind(false)
                            .HeaderTemplate(ComboBoxHelper.GetHeaderTemplate(clientLabel, clientNameLabel))
                            .ItemTemplate(ComboBoxHelper.GetItemTemplate("Client", "ClientName"))
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                    read.Action("GetClientList", "DocumentVerification", new { Area = "Shared" }).Data(additionalData);
                                })
                                .ServerFiltering(false);
                            })
                            .AutoWidth(true)
                        )
                </div>
            </div>           
        </div>
        <div class="form-row">
            <div class="col">
                <div class="form-group float-label">
                    <label>@attorneyLabel</label>
                    @(Html.Kendo().MultiSelect()
                            .Name("Attorneys")
                            .DataTextField("Attorney")
                            .DataValueField("Attorney")
                            .AutoBind(false)
                            .DataSource(source =>
                            {
                                source.Read(read =>
                                {
                                    read.Action("GetAttorneyList", "QuickDocketLookup", new { Area = "Shared" }).Data(additionalData);
                                })
                                .ServerFiltering(false);
                            })
                            .HeaderTemplate(ComboBoxHelper.GetHeaderTemplate(new Dictionary<string, int>() { { attorneyLabel, 250 }, { attorneyNameLabel, 500 } }))
                            .ItemTemplate(ComboBoxHelper.GetItemTemplate(new Dictionary<string, int>() { { "Attorney", 250 }, { "AttorneyName", 500 } }))
                            .AutoWidth(true)
                            )
                </div>
            </div>
            <div class="col">
                <div class="form-check form-check-inline">
                    <label class="form-check-label mr-1" for="AttorneyFilter1">@Localizer["[1]"]</label>
                    <input class="form-check-input" type="checkbox" name="AttorneyFilter1" id="AttorneyFilter1" checked value="A1">
                </div>
                <div class="form-check form-check-inline">
                    <label class="form-check-label mr-1" for="AttorneyFilter2">@Localizer["[2]"]</label>
                    <input class="form-check-input" type="checkbox" name="AttorneyFilter2" id="AttorneyFilter2" checked value="A2">
                </div>
                <div class="form-check form-check-inline">
                    <label class="form-check-label mr-1" for="AttorneyFilter3">@Localizer["[3]"]</label>
                    <input class="form-check-input" type="checkbox" name="AttorneyFilter3" id="AttorneyFilter3" checked value="A3">
                </div>
                <div class="form-check form-check-inline">
                    <label class="form-check-label mr-1" for="AttorneyFilter4">@Localizer["[4]"]</label>
                    <input class="form-check-input" type="checkbox" name="AttorneyFilter4" id="AttorneyFilter4" checked value="A4">
                </div>
                <div class="form-check form-check-inline">
                    <label class="form-check-label mr-1" for="AttorneyFilter5">@Localizer["[5]"]</label>
                    <input class="form-check-input" type="checkbox" name="AttorneyFilter5" id="AttorneyFilter5" checked value="A5">
                </div>
                <div class="form-check form-check-inline d-none" id="attyFilterR">
                    <label class="form-check-label mr-1" for="AttorneyFilterR">@Localizer["[Responsible]"]</label>
                    <input class="form-check-input" type="checkbox" name="AttorneyFilterR" id="AttorneyFilterR" value="AR">
                </div>
                <div class="form-check form-check-inline d-none" id="attyFilterD">
                    <label class="form-check-label mr-1" for="AttorneyFilterD">@Localizer["[Due date]"]</label>
                    <input class="form-check-input" type="checkbox" name="AttorneyFilterD" id="AttorneyFilterD" value="AD">
                </div>
                @if (settings.IsDocketRequestOn)
                {
                    <div class="form-check form-check-inline" id="attyFilterRD">
                        <label class="form-check-label mr-1" for="AttorneyFilterRD">@Localizer["[Request Docket]"]</label>
                        <input class="form-check-input" type="checkbox" name="AttorneyFilterRD" id="AttorneyFilterRD" value="ARD">
                    </div>
                }                
            </div>
        </div>        
    </div>
</div>
<script>
    documentVerificationPage.defaultResponsibleId = "@defaultResponsibleId";
    documentVerificationPage.inDocketingGroup = @inDocketingGroup.ToString().ToLower();
    documentVerificationPage.inReportingGroup = @inReportingGroup.ToString().ToLower();
