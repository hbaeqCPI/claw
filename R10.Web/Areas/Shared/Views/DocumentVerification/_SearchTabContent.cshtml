                                            read.Action("GetDocVerificationActionType", "DocumentVerification", new { Area = "Shared" }).Data("function() {var data = documentVerificationPage.getSystems(documentVerificationPage.refineSearchContainer); data['getDistinctOnly'] = true; return data;}");
                                        })
                                        .ServerFiltering(false);
                                    })
                                    )
