                <div class="form-group float-label">
                    <label>@Localizer["Action Type"]</label>
                    @(Html.Kendo().MultiSelect()
                                    .Name("ActionTypes")
                                    .DataTextField("ActionType")
                                    .DataValueField("ActionType")
                                    .AutoBind(false)
                                    .DataSource(source =>
                                    {
                                        source.Read(read =>
