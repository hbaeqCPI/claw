@model DOCXPageViewModel
@inject IStringLocalizer<SharedResource> Localizer

@{
    var resultLabel = Localizer["Select the docx below that you want to view or modify."];
    var gridName = $"{Model.PageId}-Grid";
}


<div class="pl-2"  style="font-size:small; font-style:italic;">
    @resultLabel

</div>
@(Html.Kendo().Grid<DOCXSearchResultViewModel>()
    .Name(gridName)
    .Columns(columns =>
    {
        columns.Bound(l => l.DOCXId).Hidden();
        columns.Bound(l => l.DOCXName).Title(Localizer["DOCX"]);
    })
    .AutoBind(false)
    .Pageable(page => page.Responsive(false).Refresh(true))
    .Sortable(sort => sort.AllowUnsort(false))
    .DataSource(dataSource => dataSource
                    .Ajax()
                    .Model(model =>
                    {
                        model.Id(l => l.DOCXId);
                    })
                    .Events(events => events.Error("docxSetup.searchResultGridError"))
                    .Events(events => events.RequestEnd("docxSetup.searchResultGridRequestEnd"))

                    .PageSize(Model.GridPageSize)
                    .PageSize(10)
                    .Read(read => read.Action("PageRead", "DOCXSetup", new { sys = Model.SystemType })
                    .Data("docxSetup.gridMainSearchFilters"))
                    .Sort(sort => sort.Add(i => i.DOCXName))
                )
    .Selectable()
    .Scrollable()
    .Events(events => events
        .Change("docxSetup.gridDisplayDetail")
        .DataBound("docxSetup.searchGridSelectRow")
        )

    .HtmlAttributes(new { @class = "kendo-Grid" })
)


<style>
  #@gridName tr:hover {
        cursor:pointer;
    }
    #@(gridName) tr.k-state-selected {
        background-color: var(--grid-hover) !important;
    }

    #@(gridName) .k-grid-content {
        min-height: 100px;
        max-height: 450px;
    }

</style>
