@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<ProductGroup>()
                    .Name($"{Model.PageId}-Grid")
                    .Columns(columns =>
                    {
                        columns.Bound(m => m.ProductGroupName).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: ProductGroupId#", fromSearch = true }), "ProductGroupName")).Width(200);
                        columns.Bound(m => m.Description);
                    })
                    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                    .AutoBind(false)
                    .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                    .Sortable(sort => sort.AllowUnsort(false))
                    //.ColumnMenu()
                    .Excel(excel => excel.FileName("ProductGroupList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "Area")))
                    .DataSource(dataSource => dataSource
                    .Ajax().Events(events => events.Error("productGroupPage.searchResultGridError"))
                    .Events(events => events.RequestEnd("productGroupPage.searchResultGridRequestEnd"))
                    .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                    .Read(read => read.Action("PageRead", "ProductGroup")
                    .Data("productGroupPage.gridMainSearchFilters")
                    )
                    .Sort(sort => sort.Add(m => m.ProductGroupName))
                    )
                    .HtmlAttributes(new { @class = "kendo-Grid" })
)
