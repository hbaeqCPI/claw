                            <label for="RequestDocketTrademark" class="toggle-label">@Localizer[$"Allow Trademark Docket Request"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="RequestDocketTrademark" type="checkbox" checked="@Model.IsTrademarkRequestDocket" class="toggle-option is-request-docket" data-system="@SystemType.Trademark">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if(patSettings.IsExportControlOn && Model.HasPatent) 
        {
            <div class="card">
                <h5 class="">@Localizer["Export Control"]</h5>
                <ul class="list-group pb-2">
                    <li class="d-flex justify-content-between user-settings" data-group="@CPiSettings.UserAccountSettings">
                        <label for="RestrictExportControl">@Localizer["Restrict access to export control records"]</label>
                        <span>
                            <label class="toggle-switch">
                                <input id="RestrictExportControl" type="checkbox" checked="@Model.Settings.RestrictExportControl" data-setting="RestrictExportControl" class="toggle-option">
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                </ul>
            </div>
        }

        @if (Model.HasPatent || showPatTradeSecretSetting || showPatTradeSecretReportsSetting)
        {
            <div class="card">
                <h5 class="">@Localizer["Access Control"]</h5>
                <ul class="list-group pb-2">
                    @if (showPatTradeSecretSetting)
                    {
                        <li class="d-flex justify-content-between user-settings" data-group="@CPiSettings.UserAccountSettings">
                            <label for="RestrictPatTradeSecret">@Localizer["Restrict access to Patent trade secret"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="RestrictPatTradeSecret" type="checkbox" checked="@Model.Settings.RestrictPatTradeSecret" data-setting="RestrictPatTradeSecret" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (showPatTradeSecretReportsSetting)
                    {
                        <li class="d-flex justify-content-between user-settings" data-group="@CPiSettings.UserAccountSettings">
                            <label for="RestrictPatTradeSecretReports">@Localizer["Restrict access to Patent trade secret reports"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="RestrictPatTradeSecretReports" type="checkbox" checked="@Model.Settings.RestrictPatTradeSecretReports" data-setting="RestrictPatTradeSecretReports" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (Model.HasPatent)
                    {
                        <li class="d-flex justify-content-between user-settings" data-group="@CPiSettings.UserAccountSettings">
                            <label for="RestrictInventorInfo">@Localizer["Restrict access to inventor information"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="RestrictInventorInfo" type="checkbox" checked="@Model.Settings.RestrictInventorInfo" data-setting="RestrictInventorInfo" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (isPatModify || isTmkModify || isGMModify) 
        {
            <div class="card">
                <h5 class="">@Localizer["Actions"]</h5>
                <ul class="list-group pb-2">
                    <li class="d-flex justify-content-between user-settings" data-group="@CPiSettings.UserAccountSettings">
                        <label for="RestrictAdhocActions">@Localizer["Restrict adding adhoc actions"]</label>
                        <span>
                            <label class="toggle-switch">
                                <input id="RestrictAdhocActions" type="checkbox" checked="@Model.Settings.RestrictAdhocActions" data-setting="RestrictAdhocActions" class="toggle-option">
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                </ul>
            </div>
        }

        @if ((Model.UserType == CPiUserType.User || Model.IsAdmin) && (
             (User.IsSystemEnabled(SystemType.AMS) && Model.CanReceiveAMSNotifications) ||
             (User.IsSystemEnabled(SystemType.RMS) && Model.CanReceiveRMSNotifications) ||
             (User.IsSystemEnabled(SystemType.ForeignFiling) && Model.CanReceiveFFNotifications) ||
             ((User.IsModuleEnabled(CPiModule.PatDeDocket) || User.IsModuleEnabled(CPiModule.TmkDeDocket) || User.IsModuleEnabled(CPiModule.GMDeDocket)) && Model.CanReceiveDeDocketNotifications)))
        {
            <div class="card">
                <h5 class="">@Localizer["Receive instruction notification"]</h5>
                <ul class="list-group user-settings" data-group="@CPiSettings.UserNotificationSettings">
                    @if (User.IsSystemEnabled(SystemType.AMS) && Model.CanReceiveAMSNotifications)
                    {
                        <li class="d-flex justify-content-between">
                            <label for="ReceiveAMSInstructionNotification">@Localizer["Annuity Management"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="ReceiveAMSInstructionNotification" type="checkbox" checked="@Model.NotificationSettings.ReceiveAMSInstructionNotification" data-setting="ReceiveAMSInstructionNotification" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.ForeignFiling) && Model.CanReceiveFFNotifications)
                    {
                        <li class="d-flex justify-content-between">
                            <label for="ReceiveFFInstructionNotification">@Localizer["Foreign Filing"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="ReceiveFFInstructionNotification" type="checkbox" checked="@Model.NotificationSettings.ReceiveFFInstructionNotification" data-setting="ReceiveFFInstructionNotification" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.RMS) && Model.CanReceiveRMSNotifications)
                    {
                        <li class="d-flex justify-content-between">
                            <label for="ReceiveRMSInstructionNotification">@Localizer["Renewal Management"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="ReceiveRMSInstructionNotification" type="checkbox" checked="@Model.NotificationSettings.ReceiveRMSInstructionNotification" data-setting="ReceiveRMSInstructionNotification" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if ((User.IsModuleEnabled(CPiModule.PatDeDocket) || User.IsModuleEnabled(CPiModule.TmkDeDocket) || User.IsModuleEnabled(CPiModule.GMDeDocket)) && Model.CanReceiveDeDocketNotifications)
                   {
                        <li class="d-flex justify-content-between">
                            <label for="ReceiveDeDocketInstructionNotification">@Localizer["DeDocket Instructions"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="ReceiveDeDocketInstructionNotification" type="checkbox" checked="@Model.NotificationSettings.ReceiveDeDocketInstructionNotification" data-setting="ReceiveDeDocketInstructionNotification" class="toggle-option">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                   }
                </ul>
            </div>
        }
        @* Mailbox section removed during debloat (GraphSettings no longer available) *@
        @if (Model.IsAdmin)
        {
            <div class="card">
                <h5 class="">@Localizer["Administration"]</h5>
                <ul class="list-group user-settings" data-group="@CPiSettings.UserNotificationSettings">
                    <li class="d-flex justify-content-between">
                        <label for="ReceivePendingRegistrationNotification">@Localizer["Receive pending registration notification"]</label>
                        <span>
                            <label class="toggle-switch">
                                <input id="ReceivePendingRegistrationNotification" type="checkbox" checked="@Model.NotificationSettings.ReceivePendingRegistrationNotification" data-setting="ReceivePendingRegistrationNotification" class="toggle-option">
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                    <li class="d-flex justify-content-between">
                        <label for="ReceiveTaskSchedulerNotification">@Localizer["Receive Task Scheduler error notification"]</label>
                        <span>
                            <label class="toggle-switch">
                                <input id="ReceiveTaskSchedulerNotification" type="checkbox" checked="@Model.NotificationSettings.ReceiveTaskSchedulerNotification" data-setting="ReceiveTaskSchedulerNotification" class="toggle-option">
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                </ul>
            </div>
        }
        @if (dashboardAccess.Any())
        {
            <div class="card">
                <h5 class="">@Localizer["Dashboard"]</h5>
                <ul class="list-group">
                    @foreach (var system in dashboardAccess)
                    {
                        var elId = $"CanAccess{system.Key}Dashboard";
                        <li class="d-flex justify-content-between">
                            <label for="@elId">@Localizer[system.Value]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="@elId" type="checkbox" checked="@Model.Settings.DashboardAccess.Contains(system.Key)" class="toggle-option dashboard-access" data-system="@system.Key">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }
        @if (showDocumentStorageSettings)
        {
            <div class="card">
                <h5 class="">@Localizer[patSettings.DocumentStorage.GetDisplayName()]</h5>
                <ul class="list-group">
                    <li class="d-flex justify-content-between user-settings" data-group="@CPiSettings.UserAccountSettings">
                        <span>@Localizer["Account type"]</span>
                        <span>
                            @(Html.Kendo().DropDownList().AutoWidth(true)
                                .Name("DocumentStorageAccountType")
                                .BindTo(Html.GetEnumSelectList<DocumentStorageAccountType>())
                                .DataValueField("Value").DataTextField("Text")
                                .Value(((int)(Model.Settings.DocumentStorageAccountType)).ToString())
                                .HtmlAttributes(new { @data_setting = "DocumentStorageAccountType" })
                                .Events(e => e.Change($"function (e) {{ userSetupPage.saveDocumentStorageAccountType(e); }}"))
                                )
                        </span>
                    </li>
                </ul>
            </div>
        }
        @if (Model.HasPatent && (Model.UserType == CPiUserType.User || Model.IsAdmin) && epoMailboxSettings.IsAPIOn)
        {
            <div class="card">
                <h5 class="">@Localizer["MyEPO"]</h5>
                <ul class="list-group pb-2">
                    <li class="d-flex justify-content-between user-settings" data-group="@CPiSettings.UserAccountSettings">
                        <label for="AllowHandleMyEPOCommunications">@Localizer["Allow to handle MyEPO communications"]</label>
                        <span>
                            <label class="toggle-switch">
                                <input id="AllowHandleMyEPOCommunications" type="checkbox" checked="@Model.Settings.AllowHandleMyEPOCommunications" data-setting="AllowHandleMyEPOCommunications" class="toggle-option">
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                </ul>
            </div>
        }
    </div>
</form>
<style>    
    @@media (max-width: 991px) {
        .settings.card-columns {
            column-count: 1;
        }
    }
    @@media (min-width: 992px) {
        .settings.card-columns {
            column-count: 2;
        }
    }
    @@media (min-width: 1200px) {
        .settings.card-columns {
            column-count: 3;
        }
    }
    .settings.card-columns .card {
        border: none;
    }
</style>
<script>
    $(document).ready(function () {
        $("#AccountSettings .user-settings .toggle-option").on("click", function (e) {
            userSetupPage.saveSetting($(this));
        });
        $("#AccountSettings .is-reviewer").on("click", function (e) {
            userSetupPage.saveReviewerRole($(this));
        });
        $("#AccountSettings .is-previewer").on("click", function (e) {
            userSetupPage.savePreviewerRole($(this));
        });
        $("#AccountSettings .is-decision-maker").on("click", function (e) {
            userSetupPage.saveDecisionMakerRole($(this));
        });
        $("#AccountSettings .is-attorney").on("click", function (e) {
            userSetupPage.saveAttorneyRole($(this));
        });
        $("#AccountSettings .is-soft-docket").on("click", function (e) {
            userSetupPage.saveSoftDocketRole($(this));
        });
        $("#AccountSettings .is-request-docket").on("click", function (e) {
            userSetupPage.saveRequestDocketRole($(this));
        });
        $("#AccountSettings .can-upload").on("click", function (e) {
            userSetupPage.saveUploadRole($(this));
        });
        $("#AccountSettings .is-inventor").on("click", function (e) {
            userSetupPage.saveInventorRole($(this));
        });
        $("#AccountSettings .is-patent-score-modify").on("click", function (e) {
            userSetupPage.savePatentScoreRole($(this));
        });
        $("#AccountSettings .has-mails").on("click", function (e) {
            userSetupPage.saveMailsRole($(this));
        });
        $("#AccountSettings .dashboard-access").on("click", function (e) {
            userSetupPage.saveDashboardAccess($(this));
        });
        $("#AccountSettings .mailbox").on("click", function (e) {
            userSetupPage.saveMailboxAccess($(this));
        });
    });

    function refreshRecordStamp(el) {
        console.log("refreshRecordStamp", el);
        userSetupPage.updateRecordStamps();
        return true;
    }
</script>