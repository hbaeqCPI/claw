@using Microsoft.EntityFrameworkCore;
@using R10.Core.Interfaces;
@using R10.Core.Entities.Patent;
@using R10.Core.Entities.Trademark;
@using Microsoft.Extensions.Options;
@using R10.Web.Services;
@using R10.Web.Security;
@model AccountSettingsViewModel
@inject CPiUserManager UserManager
@inject ICPiUserPermissionManager PermissionManager
@inject ISystemSettings<PatSetting> PatSettings
@inject ISystemSettings<TmkSetting> TmkSettings
@inject IStringLocalizer<AdminResource> Localizer
@inject IOptions<EPOMailboxSettings> EPOMailboxSettings
@{
    //todo: toggle ExportControl based on Patent role

    var patSettings = await PatSettings.GetSetting();
    var tmkSettings = await TmkSettings.GetSetting();

    var epoMailboxSettings = EPOMailboxSettings.Value;

    var letterRoles = new List<CPiRole>();
    letterRoles.Add(new CPiRole() { Id = "", Name = "" });
    letterRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.Letters.Contains(r.Id.ToLower())).ToListAsync());

    var customQueryRoles = new List<CPiRole>();
    customQueryRoles.Add(new CPiRole() { Id = "", Name = "" });
    customQueryRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.CustomQuery.Contains(r.Id.ToLower())).ToListAsync());

    var auxiliaryRoles = new List<CPiRole>();
    auxiliaryRoles.Add(new CPiRole() { Id = "", Name = "" });
    auxiliaryRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.Auxiliary.Contains(r.Id.ToLower())).ToListAsync());

    var countryLawRoles = new List<CPiRole>();
    countryLawRoles.Add(new CPiRole() { Id = "", Name = "" });
    countryLawRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.CountryLaw.Contains(r.Id.ToLower())).ToListAsync());

    var actionTypeRoles = new List<CPiRole>();
    actionTypeRoles.Add(new CPiRole() { Id = "", Name = "" });
    actionTypeRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.ActionType.Contains(r.Id.ToLower())).ToListAsync());

    var productsRoles = new List<CPiRole>();
    productsRoles.Add(new CPiRole() { Id = "", Name = "" });
    productsRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.Products.Contains(r.Id.ToLower())).ToListAsync());

    var documentVerificationRoles = new List<CPiRole>();
    documentVerificationRoles.Add(new CPiRole() { Id = "", Name = "" });
    documentVerificationRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.DocumentVerification.Contains(r.Id.ToLower())).ToListAsync());

    var workflowRoles = new List<CPiRole>();
    workflowRoles.Add(new CPiRole() { Id = "", Name = "" });
    workflowRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.Workflow.Contains(r.Id.ToLower())).ToListAsync());

    var showPatentCostEstimator = (Model.UserType == CPiUserType.ContactPerson && patSettings.IsCostEstimatorOn);
    var showTrademarkCostEstimator = (Model.UserType == CPiUserType.ContactPerson && tmkSettings.IsCostEstimatorOn);

    var costEstimatorRoles = new List<CPiRole>();
    costEstimatorRoles.Add(new CPiRole() { Id = "", Name = "" });
    costEstimatorRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.CostEstimator.Contains(r.Id.ToLower())).ToListAsync());

    var isGermanRemunerationOn = patSettings.IsInventorRemunerationOn;
    var germanRemunerationRoles = new List<CPiRole>();
    germanRemunerationRoles.Add(new CPiRole() { Id = "", Name = "" });
    germanRemunerationRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.GermanRemuneration.Contains(r.Id.ToLower())).ToListAsync());

    var isFrenchRemunerationOn = patSettings.IsInventorFRRemunerationOn;
    var frenchRemunerationRoles = new List<CPiRole>();
    frenchRemunerationRoles.Add(new CPiRole() { Id = "", Name = "" });
    frenchRemunerationRoles.AddRange(await PermissionManager.CPiRoles.Where(r => CPiPermissions.FrenchRemuneration.Contains(r.Id.ToLower())).ToListAsync());

    var attorneyRole = await PermissionManager.GetAttorneyRole();
    var inventorRole = await PermissionManager.GetInventorRole();

    var isPatModify = Model.HasPatent && Model.IsPatentModify;
    var isTmkModify = Model.HasTrademark && Model.IsTrademarkModify;
    var isGMModify = Model.HasGeneralMatter && Model.IsGeneralMattersModify;

    //show dashboard access options
    var dashboardAccess = new Dictionary<string, string>();
    if (await UserManager.HasDashboardAccessOptions(new CPiUser() { Id = Model.UserId, UserType = Model.UserType }))
    {
        dashboardAccess = (await UserManager.GetSystems()).Where(s => SystemType.HasDashboardWidgets.Any(w => w.ToLower() == s.Id.ToLower())).ToDictionary(s => s.Id, s => s.Name);
    }

    var showDocumentStorageSettings = patSettings.DocumentStorage != DocumentStorageOptions.BlobOrFileSystem;

    var showPatTradeSecretSetting = patSettings.IsTradeSecretOn && CPiPermissions.CanHaveTSClearance.Contains(Model.UserType);
    var showPatTradeSecretReportsSetting = patSettings.IsTradeSecretOn && CPiPermissions.CanAccessTSReports.Contains(Model.UserType);

    var isSoftDocketOn = patSettings.IsSoftDocketOn || tmkSettings.IsSoftDocketOn;

    var isRequestDocketOn = patSettings.IsDocketRequestOn || tmkSettings.IsDocketRequestOn;

}

<form id="AccountSettings" method="post" data-on-close="refreshRecordStamp"
data-save-setting-url="@Url.Action("SaveSetting", "AccountSettings", new { Area = "Admin" })"
data-save-decision-maker-url="@Url.Action("SaveDecisionMakerRole", "AccountSettings", new { Area = "Admin" })" 
data-save-attorney-url="@Url.Action("SaveAttorneyRole", "AccountSettings", new { Area = "Admin" })" 
data-save-soft-docket-url="@(isSoftDocketOn ? Url.Action("SaveSoftDocketRole", "AccountSettings", new { Area = "Admin" }) : "")" 
data-save-request-docket-url="@(isRequestDocketOn ? Url.Action("SaveRequestDocketRole", "AccountSettings", new { Area = "Admin" }) : "")" 
data-save-upload-url="@Url.Action("SaveUploadRole", "AccountSettings", new { Area = "Admin" })" 
data-save-inventor-url="@Url.Action("SaveInventorRole", "AccountSettings", new { Area = "Admin" })" 
data-link-entity-url="@Url.Action("LinkEntity", "AccountSettings", new { Area = "Admin" })"
data-save-auxiliary-url="@Url.Action("SaveAuxiliaryRole", "AccountSettings", new { Area = "Admin" })"
data-save-country-law-url="@Url.Action("SaveCountryLawRole", "AccountSettings", new { Area = "Admin" })"
data-save-action-type-url="@Url.Action("SaveActionTypeRole", "AccountSettings", new { Area = "Admin" })"
data-save-letter-url="@Url.Action("SaveLetterRole", "AccountSettings", new { Area = "Admin" })"
data-save-custom-query-url="@Url.Action("SaveCustomQueryRole", "AccountSettings", new { Area = "Admin" })"
data-save-products-url="@Url.Action("SaveProductsRole", "AccountSettings", new { Area = "Admin" })"
data-save-cost-estimator-url="@Url.Action("SaveCostEstimatorRole", "AccountSettings", new { Area = "Admin" })" 
data-save-german-remuneration-url="@Url.Action("SaveGermanRemunerationRole", "AccountSettings", new { Area = "Admin" })" 
data-save-french-remuneration-url="@Url.Action("SaveFrenchRemunerationRole", "AccountSettings", new { Area = "Admin" })" 
data-save-patent-score-url="@Url.Action("SavePatentScoreRole", "AccountSettings", new { Area = "Admin" })"
data-save-mails-url="@Url.Action("SaveMailsRole", "AccountSettings", new { Area = "Admin" })"
data-save-document-verification-url="@Url.Action("SaveDocumentVerificationRole", "AccountSettings", new { Area = "Admin" })"
data-save-workflow-url="@Url.Action("SaveWorkflowRole", "AccountSettings", new { Area = "Admin" })"
data-save-dashboard-access-url="@Url.Action("SaveDashboardAccess", "AccountSettings", new { Area = "Admin" })"
data-save-mailbox-access-url="@Url.Action("SaveMailboxAccess", "AccountSettings", new { Area = "Admin" })">
    <input asp-for="UserId" class="form-control" hidden />
    <div class="modal-status page-status alert alert-danger collapse" role="alert" style="margin-top: -10px; margin-left: -10px;"><span class="message"></span></div>
    <div class="settings card-columns">
        @if (User.IsSystemEnabled(SystemType.DMS) && Model.UserType == CPiUserType.Inventor)
        {
            <div class="card">
                <h5 class="">@Localizer["Inventor Account"]</h5>
                <ul class="list-group pb-2">
                    <li class="d-flex justify-content-between">
                        <span>@Localizer["Inventor"]</span>
                        <span class="link-entity" data-entity-type="@((int)CPiEntityType.Inventor)">
                            @await Component.InvokeAsync("ComboBox", new { name = "Inventor", action = "GetInventorList", controller = "Inventor", area = "Patent", textProperty = "Inventor", valueProperty = "InventorID", defaultValue = (Model.EntityId == 0 ? "" : Model.EntityId.ToString()), defaultText = Model.EntityName, onChange = "function(e) { userSetupPage.linkEntity(e); }" })
                            <span class="field-validation-error" style="display:none;" data-valmsg-for="Inventor"></span>
                        </span>
                    </li>
                    <li class="d-flex justify-content-between">
                        <label for="IsDmsReviewer">@Localizer["Invention Disclosure Reviewer"]</label>
                        <span>
                            <label class="toggle-switch">
                                <input id="IsDmsReviewer" type="checkbox" checked="@Model.IsReviewer" class="toggle-option is-reviewer" data-save-reviewer-url="@Url.Action("SaveDMSReviewerRole", "AccountSettings", new { Area = "Admin" })">
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                    @if (User.IsSystemEnabled(SystemType.Patent))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="HasPatent">@Localizer[$"Patent {inventorRole.Name}"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="HasPatent" type="checkbox" checked="@Model.HasPatent" class="toggle-option is-inventor" data-system="@SystemType.Patent">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.PatClearance))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="IsPatClearanceReviewer">@Localizer["Patent Clearance Search Access"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="IsPatClearanceReviewer" type="checkbox" checked="@Model.IsPatClearanceReviewer" class="toggle-option is-reviewer" data-save-reviewer-url="@Url.Action("SavePatClearanceReviewerRole", "AccountSettings", new { Area = "Admin" })">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (Model.UserType == CPiUserType.Attorney)
        {
            <div class="card">
                <h5 class="">@Localizer["Attorney Account"]</h5>
                <ul class="list-group pb-2">
                    <li class="d-flex justify-content-between">
                        <span>@Localizer["Attorney"]</span>
                        <span class="link-entity" data-entity-type="@((int)CPiEntityType.Attorney)">
                            @await Component.InvokeAsync("ComboBox", R10.Web.Helpers.ComboBoxHelper.AttorneyNameID("Attorney", "Attorney", "Attorney Name", "Attorney", "Shared", "", Model.EntityId, Model.EntityName, "function(e) { userSetupPage.linkEntity(e); }"))
                            <span class="field-validation-error" style="display:none;" data-valmsg-for="Attorney"></span>
                        </span>
                    </li>
                    @if (User.IsSystemEnabled(SystemType.Patent))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="HasPatent">@Localizer[$"Patent {attorneyRole.Name}"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="HasPatent" type="checkbox" checked="@Model.HasPatent" class="toggle-option is-attorney" data-system="@SystemType.Patent">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.Trademark))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="HasTrademark">@Localizer[$"Trademark {attorneyRole.Name}"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="HasTrademark" type="checkbox" checked="@Model.HasTrademark" class="toggle-option is-attorney" data-system="@SystemType.Trademark">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.GeneralMatter))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="HasGeneralMatter">@Localizer[$"General Matter {attorneyRole.Name}"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="HasGeneralMatter" type="checkbox" checked="@Model.HasGeneralMatter" class="toggle-option is-attorney" data-system="@SystemType.GeneralMatter">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (User.IsSystemEnabled(SystemType.Patent) && patSettings.IsPatentScoreOn && CPiPermissions.CanHavePatentScoreRole.Contains(Model.UserType))
        {
            <div class="card">
                <h5 class="">@Localizer["Patent Score"]</h5>
                <ul class="list-group pb-2">
                    <li class="d-flex justify-content-between patent-score">
                        <label for="PatentScore" class="toggle-label @(Model.HasPatent ? "" : "text-muted")">@Localizer[$"Allow Patent Score update"]</label>
                        <span>
                            <label class="toggle-switch">
                                <input id="PatentScore" type="checkbox" checked="@Model.IsPatentScoreModify" class="toggle-option is-patent-score-modify" data-system="@SystemType.Patent" @(Model.HasPatent ? "" : "disabled")>
                                <span class="slider round"></span>
                            </label>
                        </span>
                    </li>
                </ul>
            </div>
        }

        @if (Model.UserType == CPiUserType.ContactPerson)
        {
            <div class="card">
                <h5 class="">@Localizer["Contact Person Account"]</h5>
                <ul class="list-group pb-2">
                    <li class="d-flex justify-content-between">
                        <span>@Localizer["Contact Person"]</span>
                        <span class="link-entity" data-entity-type="@((int)CPiEntityType.ContactPerson)">
                            @await Component.InvokeAsync("ComboBox", R10.Web.Helpers.ComboBoxHelper.ContactID("Contact", "Contact", "Contact Name", "ContactPerson", "Shared", "", Model.EntityId, Model.EntityName, "function(e) { userSetupPage.linkEntity(e); }"))
                            <span class="field-validation-error" style="display:none;" data-valmsg-for="Contact"></span>
                        </span>
                    </li>
                    @if (User.IsSystemEnabled(SystemType.DMS))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="IsContactDmsReviewer">@Localizer["Invention Disclosure Reviewer"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="IsContactDmsReviewer" type="checkbox" checked="@Model.IsReviewer" class="toggle-option is-reviewer" data-save-reviewer-url="@Url.Action("SaveDMSReviewerRole", "AccountSettings", new { Area = "Admin" })">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.AMS))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="IsContactAMSDecisionMaker">@Localizer["Annuity Management Decision Maker"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="IsContactAMSDecisionMaker" type="checkbox" checked="@Model.IsAMSDecisionMaker" class="toggle-option is-decision-maker" data-system="@SystemType.AMS">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.SearchRequest))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="IsContactClearanceReviewer">@Localizer["Trademark Search Request Reviewer"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="IsContactClearanceReviewer" type="checkbox" checked="@Model.IsClearanceReviewer" class="toggle-option is-reviewer" data-save-reviewer-url="@Url.Action("SaveClearanceReviewerRole", "AccountSettings", new { Area = "Admin" })">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.PatClearance))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="IsContactPatClearanceReviewer">@Localizer["Patent Clearance Search Reviewer"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="IsContactPatClearanceReviewer" type="checkbox" checked="@Model.IsPatClearanceReviewer" class="toggle-option is-reviewer" data-save-reviewer-url="@Url.Action("SavePatClearanceReviewerRole", "AccountSettings", new { Area = "Admin" })">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.RMS))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="IsContactRMSDecisionMaker">@Localizer["Renewal Management Decision Maker"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="IsContactRMSDecisionMaker" type="checkbox" checked="@Model.IsRMSDecisionMaker" class="toggle-option is-decision-maker" data-system="@SystemType.RMS">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                    @if (User.IsSystemEnabled(SystemType.ForeignFiling))
                    {
                        <li class="d-flex justify-content-between">
                            <label for="IsContactForeignFilingDecisionMaker">@Localizer["Foreign Filing Decision Maker"]</label>
                            <span>
                                <label class="toggle-switch">
                                    <input id="IsContactForeignFilingDecisionMaker" type="checkbox" checked="@Model.IsForeignFilingDecisionMaker" class="toggle-option is-decision-maker" data-system="@SystemType.ForeignFiling">
                                    <span class="slider round"></span>
                                </label>
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (Model.UserType.IsRegularUser() && (Model.HasAMS || Model.HasDMS || Model.HasPatent || Model.HasTrademark || Model.HasGeneralMatter || Model.HasClearance || Model.HasRMS || Model.HasForeignFiling || Model.HasPatClearance))
        {
            <div class="card">
                <h5 class="">@Localizer["Auxiliary Permissions"]</h5>
                <ul class="list-group pb-2">
                    @if (Model.HasAMS)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Annuity Management"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("AMSAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.AMSAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.AMS}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasPatent)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Patent"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("PatAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.PatentAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.Patent}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasPatClearance)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Clearance Search"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("PatClearanceAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.PatClearanceAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.PatClearance}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasForeignFiling)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Foreign Filing"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("ForeignFilingAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.ForeignFilingAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.ForeignFiling}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasDMS)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Invention Disclosure"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("DMSAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.DMSAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.DMS}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasTrademark)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Trademark"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("TmkAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.TrademarkAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.Trademark}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasClearance)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Search Request"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("ClearanceAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.ClearanceAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.SearchRequest}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasRMS)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Renewal Management"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("RMSAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.RMSAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.RMS}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                    @if (Model.HasGeneralMatter)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["General Matter"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                            .Name("GMAuxiliaryRole").BindTo(auxiliaryRoles).DataValueField("Id").DataTextField("Name")
                                            .Value(Model.GeneralMatterAuxiliaryRole)
                                            .Events(e => e.Change($"function (e) {{ userSetupPage.saveAuxiliaryRole(e, '{SystemType.GeneralMatter}'); }}"))
                                            )
                            </span>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (Model.UserType.IsRegularUser() && (Model.HasPatent || Model.HasTrademark))
        {
            <div class="card">
                <h5 class="">@Localizer["Country Law"]</h5>
                <ul class="list-group pb-2">
                    @if (Model.HasPatent)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Patent"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
                                        .Name("PatCountryLawRole")
                                        .BindTo(countryLawRoles)
                                        .DataValueField("Id")
                                        .DataTextField("Name")
                                        .Value(Model.PatentCountryLawRole)
                                        .Events(e => e.Change($"function (e) {{ userSetupPage.saveCountryLawRole(e, '{SystemType.Patent}'); }}"))
                                        )
                            </span>
                        </li>                    
                    }
                    @if (Model.HasTrademark)
                    {
                        <li class="d-flex justify-content-between pb-1">
                            <span>@Localizer["Trademark"]</span>
                            <span>
                                @(Html.Kendo().DropDownList().AutoWidth(true)
