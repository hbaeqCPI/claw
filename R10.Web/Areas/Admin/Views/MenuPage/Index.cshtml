@model SidebarPageViewModel
@inject IStringLocalizer<AdminResource> Localizer
@{    
    ViewData["Title"] = Model.PageTitle;
    ViewData["ActivePage"] = "menuPagePage";
}

@await Html.PartialAsync("_SidebarPage", Model)

@section Scripts {
    <script>
        var @ViewBag.ActivePage = new ActivePage();
    </script>
}
