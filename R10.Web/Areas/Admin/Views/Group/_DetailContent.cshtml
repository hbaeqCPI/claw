@model GroupDetailViewModel
@inject IStringLocalizer<AdminResource> Localizer
@{
    var addMode = Model.Id == 0;
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var screen = ViewData["PageId"];
}

<form cpi-detail-form action="Save">
    <input asp-for="Id" class="form-control" value="@Model.Id" hidden />
    <vc:detail-page-nav-links page-permission="detailPagePermission" title="" add-mode="addMode"></vc:detail-page-nav-links>
    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col col-12 col-md-8">
                <div class="form-group float-label">
                    <label asp-for="Name"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="Name" />
                    <span asp-validation-for="Name"></span>
                </div>
            </div>
            <div class="col col-6 col-md-3 mt-3 pt-md-1 ml-md-3 order-last order-md-2">
                <div class="form-group float-label">
                    <div class=" custom-control custom-checkbox">
                        <input asp-for="IsEnabled" class="custom-control-input" />
                        <label asp-for="IsEnabled" class="custom-control-label">
                        </label>
                    </div>
                    <span asp-validation-for="IsEnabled"></span>
                </div>
            </div>
            <div class="col col-12 order-md-last">
                <div class="form-group float-label">
                    <label asp-for="Description"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="Description" />
                    <span asp-validation-for="Description"></span>
                </div>
            </div>
        </div>
    </div>
    @if (!addMode)
    {
        <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" role="tablist">
            <li class="nav-item">
                <a id="groupUsersTab" href="#groupUsersTabContent" class="nav-link active" data-toggle="tab" role="tab" aria-controls="groupUsersTabContent" title="@Localizer["Users"]">@Localizer["Users"]</a>
            </li>
        </ul>
        <div class="tab-content detail">
            <div class="tab-pane active show" id="groupUsersTabContent" role="tabpanel" aria-labelledby="groupUsersTab">
                @await Html.PartialAsync("_GridUsers", Model.Id)
            </div>
        </div>
        <div class="content-stamp">
            <vc:record-stamps created-by="@Model.CreatedBy" date-created="@Model.DateCreated" updated-by="@Model.UpdatedBy" last-update="@Model.LastUpdate" t-stamp="@Model.tStamp"></vc:record-stamps>
        </div> 
    }
</form>

<script>
    @(ViewBag.ActivePage).editableGrids = [
        {
            name: 'groupUsers', isDirty: false, filter: { id: "@Model.Id"},
            afterSubmit: @(ViewBag.ActivePage).updateRecordStamps
        }
    ];
</script>

