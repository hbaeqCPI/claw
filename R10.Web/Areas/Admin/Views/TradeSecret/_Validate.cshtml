@model string
@inject IStringLocalizer<SharedResource> Localizer

<form id="tsTokenValidation" class="form-detail ts-validate" method="post" action="@Url.Action("Validate")">
    <input type="hidden" id="locator" name="locator" value="@Model" />
    <div class="mb-3">@Localizer["An access code was sent to your email address."]</div>
    <div class="form-group float-label">
        <label for="token" class="required">@Localizer["Access Code"]</label>
        <input type="text" id="token" name="token" class="form-control form-control-sm" required data-val="true" data-val-required="@Localizer["Access code is required"]" />
        <span class="field-validation-valid" data-valmsg-for="token" data-valmsg-replace="true"></span>
    </div>
</form>
<script>
    $(document).ready(function () {
        var form = $("#tsTokenValidation");
        form.submit(function (e) {
            e.preventDefault();
        });
        form.floatLabels();
        $.validator.unobtrusive.parse(form);
    });
</script>
