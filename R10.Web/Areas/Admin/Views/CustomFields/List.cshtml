@inject IStringLocalizer<SharedResource> Localizer
@{
    var title = ViewData["Title"].ToString();
    var container = ViewData["PageId"].ToString();
    var infoLabel = Localizer["Info"];
    var alertLabel = Localizer["Alert"];
}

<div id="notificationsEntry" class="mt-3">

    @(Html.Kendo().Grid<R10.Core.Entities.SysCustomFieldSetting>
            ()
            .Name("gridCustomFields")
            .Columns(columns =>
            {
                columns.Bound(t => t.TableName);
                columns.Bound(t => t.ColumnName);
                columns.Bound(t => t.DataType);
                columns.Bound(t => t.ColumnLabel).HtmlAttributes(new { @class = "editable-cell" });
                columns.Bound(t => t.EditorType).HtmlAttributes(new { @class = "editable-cell" })
                .EditorTemplateName("ComboBox")
                .EditorTemplateName("DropdownList")
                      .EditorViewData(new
                      {
                          //data = new string[] { "TextBox", "TextArea", "ComboBox", "DatePicker", "CheckBox" }
                          data = new string[] { "TextBox", "TextArea", "ComboBox"}
                      }).Width(150)
                .Editable($"function(data) {{ return !(data.DataType === 'Date' || data.DataType === 'Boolean'); }}");

                columns.Bound(t => t.OrderOfEntry).HtmlAttributes(new { @class = "editable-cell" });
                columns.Bound(t => t.Visible)
            .ClientTemplate("<i class='fa fal #: Visible ? 'fa-check' : ''#'></i>")
                    .EditorTemplateName("CheckBox").Width(10).HtmlAttributes(new { @class = "editable-cell", align = "center", style = "vertical-align:top; padding-top:0px !important" });
                columns.Bound(t => t.CountryAppSearch)
            .ClientTemplate("<i class='fa fal #: CountryAppSearch ? 'fa-check' : ''#'></i>")
                   .EditorTemplateName("CheckBox").Width(10).HtmlAttributes(new { @class = "editable-cell", align = "center", style = "vertical-align:top; padding-top:0px !important" })
            .Editable("isCountryAppSearchEditable");
            })
            .ToolBar(toolbar =>
            {
                toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
                toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
            })
            .Editable(editable => editable.Enabled(true)
            .Mode(GridEditMode.InCell).
            ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
            .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
            .Pageable()
            .Sortable(sort => sort.AllowUnsort(false))
            .PersistSelection()
            .AutoBind(true)
            .DataSource(dataSource => dataSource
            .Ajax()
            .Batch(true)
            //.ServerOperation(false)
            .Read(read => read.Action("PageRead", "CustomFields"))
            .Update(update => update.Action("Update", "CustomFields"))
            .Model(model =>
            {
                model.Id(t => t.SettingId);
                model.Field(t => t.TableName).Editable(false);
                model.Field(t => t.ColumnName).Editable(false);
                model.Field(t => t.DataType).Editable(false);
            })
            .Sort(sort => { sort.Add(t => t.TableName); sort.Add(t => t.ColumnName); })
            .PageSize(10)
            )
        .Events(events => events.DataBound($"function(e) {{customFieldsSetupGridDataBound(e);}}"))
    )
</div>
<script>
    $(document).ready(function () {
        const container = "#@container";
        const sidebar = pageHelper.initializeSidebarPage(`${container} .page-sidebar`, `${container} .page-main`);
        pageHelper.moveBreadcrumbs(container);
        window.cpiBreadCrumbs.addNode({
            name: container,
            label: "@title",
            url: "",
            updateHistory: true
        });

        const notifyGrid = $("#gridCustomFields");
        pageHelper.kendoGridDirtyTracking(notifyGrid, { name: "gridCustomFields" });
    });

    function isCountryAppSearchEditable(data) {
        return data.TableName == "tblPatInvention";
    }

    function customFieldsSetupGridDataBound(e) {
        var countryAppSearchIndex = e.sender.wrapper.find(".k-grid-header [data-field=" + "CountryAppSearch" + "]").index();

        var dataItems = e.sender.dataSource.view();
        for (var j = 0; j < dataItems.length; j++) {
            var tableName = dataItems[j].get("TableName");

            if (tableName.toLowerCase() != "tblpatinvention") {
                var row = e.sender.tbody.find("[data-uid='" + dataItems[j].uid + "']");
                var countryAppCell = row.children().eq(countryAppSearchIndex);
                countryAppCell.removeClass("editable-cell");
            }
        }
    }

</script>