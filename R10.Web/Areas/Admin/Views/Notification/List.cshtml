@inject IStringLocalizer<SharedResource> Localizer
@{
    var title = ViewData["Title"].ToString();
    var container = ViewData["PageId"].ToString();
    var infoLabel = Localizer["Info"];
    var alertLabel = Localizer["Alert"];
}

<div id="notificationsEntry">
    <div class="d-flex justify-content-end pr-3">
        <div>
            <input id="showViewed" type="checkbox" style="height:auto; margin-top: 10px;" />
            <label for="showViewed" style="padding-top: 5px; padding-left: 10px;">@Localizer["Show Viewed Alerts"]</label>
        </div>
    </div>
    @(Html.Kendo().Grid<R10.Core.Entities.Notification>
    ()
    .Name("gridNotifications")
    .Columns(columns =>
    {
        columns.Bound(t => t.Type).ClientTemplate($"<span>#=(Type==='A') ? '{alertLabel}': '{infoLabel}'#</span>");
        columns.Bound(t => t.Title).EditorTemplateName("TextArea").Width(200);
        columns.Bound(t => t.Message).EditorTemplateName("TextArea").Width(300);
        columns.Bound(t => t.UserName).EditorTemplateName("ComboBox")
                                      .EditorViewData(new { action = "GetUsers", controller = "Notification", dataValueField = "Email", serverFiltering = false, property = "Email" });
        columns.Bound(t => t.EffectiveFrom).Format("{0: dd-MMM-yyyy hh:mm tt}").Width(160);
        columns.Bound(t => t.EffectiveTo).Format("{0: dd-MMM-yyyy hh:mm tt}").Width(160);
        columns.Bound(t => t.NavigateToUrl).EditorTemplateName("TextArea").Width(200);
        columns.Bound(t => t.Viewed).ClientTemplate("<i class='fa fal #: Viewed ? ' fa-check' : '' #'></i>")
        .EditorTemplateName("CheckBox").Width(10).HtmlAttributes(new { align = "center", style = "vertical-align:top; padding-top:0px !important" });
        columns.Command(command =>
        {

            command.Custom("Delete")
            .Click("function(e) {deleteNotificationGridRow(e,this)}")
            .IconClass("k-icon fal fa-trash-alt")
            .Text($"<span class='grid-action-label'></span>")
            .HtmlAttributes(new { @class = "grid-action" });
        }).Width(10);
    })
    .ToolBar(toolbar =>
    {
        //toolbar.Create().IconClass("k-icon fal fa-plus").Text(Localizer["Add"]).HtmlAttributes(new { @class = "grid-action" });
        toolbar.Custom().Name("AddMessage").IconClass("k-icon fal fa-plus").Text(Localizer["Add"]);
        toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
        toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
    })
    .Editable(editable => editable.Enabled(true)
    .Mode(GridEditMode.InCell).
    ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
    .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
    .Pageable()
    .Sortable(sort => sort.AllowUnsort(false))
    .PersistSelection()
    .AutoBind(true)
    .DataSource(dataSource => dataSource
    .Ajax()
    .Batch(true)
    //.ServerOperation(false)
    .Read(read => read.Action("PageRead", "Notification").Data("notificationEntryCriteria"))
    .Update(update => update.Action("Update", "Notification"))
    .Destroy(delete => delete.Action("Delete", "Notification"))
    .Model(model =>
    {
        model.Id(t => t.MessageId);
    })
    .Sort(sort => sort.Add(t => t.MessageId).Descending())
    .PageSize(10)
    )
    )
</div>
<div class="cpiContainerPopup"></div>
<script>
    $(document).ready(function () {
        const notifyGrid = $("#gridNotifications");
        const container = "#@container";
        const sidebar = pageHelper.initializeSidebarPage(`${container} .page-sidebar`, `${container} .page-main`);
        pageHelper.moveBreadcrumbs(container);
        window.cpiBreadCrumbs.addNode({
            name: container,
            label: "@title",
            url: "",
            updateHistory: true
        });

        $("#notificationsEntry").on("click", "#showViewed", function () {
            const grid = notifyGrid.data("kendoGrid");
            grid.dataSource.read();
        });
        pageHelper.kendoGridDirtyTracking(notifyGrid, { name: "gridNotifications" });

        notifyGrid.find(".k-grid-toolbar").on("click",
            ".k-grid-AddMessage",
            () => {
                openNotificationMessageEntry(notifyGrid.data("kendoGrid"));
            });
    });

    function notificationEntryCriteria() {
        const showViewed = $("#notificationsEntry").find("#showViewed");
        return { showViewed: showViewed.prop("checked") };
    }
    function deleteNotificationGridRow(e, grid) {
        const dataItem = grid.dataItem($(e.currentTarget).closest("tr"));
        pageHelper.kendoGridDeleteRecord(e, dataItem, function () {});
    }

    function openNotificationMessageEntry(grid) {
        const baseUrl = $("body").data("base-url");
        const mainUrl = `${baseUrl}/Admin/Notification/GetMessageEntryScreen`;
        $.ajax({
            url: mainUrl,
            success: function (result) {
                const popupContainer = $(".cpiContainerPopup").last();
                popupContainer.html(result);
                const dialogContainer = $("#notificationEntryDialog");
                
                let entryForm = dialogContainer.find("form")[0];
                dialogContainer.modal("show");
                entryForm = $(entryForm);
                entryForm.cpiPopupEntryForm(
                    {
                        dialogContainer: dialogContainer,
                        beforeSubmit: function () {

                            var userNames = entryForm.find("select[name='UserNames']").val();
                            dialogContainer.find("#UserName").val(userNames.join());
                        },
                        afterSubmit: function () {
                            grid.dataSource.read();
                            dialogContainer.modal("hide");
                        }
                    }
                );
                entryForm.floatLabels();
            },
            error: function (error) {
                pageHelper.showErrors(error.responseText);
            }
        });
    }
</script>