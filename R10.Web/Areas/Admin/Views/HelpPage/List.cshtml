@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var title = ViewData["Title"].ToString();
    var container = ViewData["PageId"].ToString();
}

<div class="mt-3">
    @(Html.Kendo().Grid<R10.Core.Entities.Help>()
        .Name("gridHelpPages")
        .Columns(columns =>
        {
            columns.Bound(t => t.Page);
            columns.Bound(t => t.Path).HtmlAttributes(new { @class = "editable-cell" });
        })
        .ToolBar(toolbar =>
        {
            toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(Localizer["Save"]).HtmlAttributes(new { @class = "d-none" });
            toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(Localizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
        })
        .Editable(editable => editable
            .Enabled(true)
            .Mode(GridEditMode.InCell)
            .ConfirmDelete(@Localizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false)
        )
        .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
        .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
        .Sortable(sort => sort.AllowUnsort(false))
        .PersistSelection()
        .AutoBind(true)
        .DataSource(dataSource => dataSource
            .Ajax()
            .Batch(true)
            .Read(read => read.Action("PageRead", "HelpPage"))
            .Update(update => update.Action("Update", "HelpPage"))
            .Model(model =>
            {
                model.Id(t => t.HelpId);
                model.Field(t => t.Page).Editable(false);
            })
            .Sort(sort => sort.Add(t => t.Page))
            .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
        )
    )
</div>
<script>
    $(document).ready(function () {
        const container = "#@container";
        const sidebar = pageHelper.initializeSidebarPage(`${container} .page-sidebar`, `${container} .page-main`);
        pageHelper.moveBreadcrumbs(container);
        window.cpiBreadCrumbs.addNode({
            name: container,
            label: "@title",
            url: "",
            updateHistory: true
        });

        const helpPagesGrid = $("#gridHelpPages");
        pageHelper.kendoGridDirtyTracking(helpPagesGrid, { name: "gridHelpPages" });
    });

</script>