@model SystemSettingsViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var addLabel = Localizer["Add"].Value;
    var toolbarTemplate = $"<nav class='nav nav-left xxsidebar-link'><a class='k-button page-nav view-task' data-id='0' href='\\#'><i class='fal fa-plus pr-2'></i>{addLabel}</a></nav>";

    var detailsUrl = Url.Action("ViewTask", "ScheduledSystemStatus");
    var saveUrl = Url.Action("SaveTask", "ScheduledSystemStatus");
    var deleteUrl = Url.Action("DeleteTask", "ScheduledSystemStatus");
    var detailsLinkTemplate = $"<a href='' class='details-link view-task' data-id='#: TaskId#'>#: StatusType ?? ''#</a>";
}
<div class="col col-lg-8 col-xl-6">
    <ul class="list-group">
        <li class="d-flex justify-content-between">
            <span>Status</span>
            <span>
                @(Html.Kendo().DropDownList()
                                .Name("SystemStatus").AutoWidth(true)
                                .OptionLabel(" ")
                                .Value(((int)Model.SystemStatus.StatusType).ToString())
                                .DataTextField("Text")
                                .DataValueField("Value")
                                .BindTo(Html.GetEnumSelectList<SystemStatusType>().OrderBy(o => o.Text))
                                .HtmlAttributes(new { @class = "k-control" })
                )
            </span>
        </li>
        <li class="d-flex justify-content-between">
            <label for="ShowNotification">Show Notification</label>
            <span class="pl-4">
                <label class="toggle-switch">
                    <input id="ShowNotification" type="checkbox" checked="@Model.SystemStatus.Notification?.Active" class="toggle-option">
                    <span class="slider round"></span>
                </label>
            </span>
        </li>
        <li>
            <label asp-for="SystemStatus.Notification.Message">Message</label>
            <div style="width: 100%; padding-top: 5px;">
                <textarea class="form-control" style="width: 100%" rows="4" asp-for="SystemStatus.Notification.Message" data-val-required="Please enter a notification message."></textarea>
            </div>
        </li>
    </ul>
</div>
<div class="col col-12 mb-5">
    <button id="SaveStatus" class="btn btn-primary mt-2" data-confirm-title="@ViewData["Title"]" data-confirm-msg="@Localizer["System Status will be updated. Do you want to continue?"]" )>@Localizer["Update status"]</button>
</div>
<div class="col scheduled-tasks">
    <div>
        <ul class="nav nav-tabs nav-tabs-horizontal flush-left" id="schedules-tab" role="tablist">
            <li class="nav-item">
                <a class="nav-link active" id="schedules-tab" data-toggle="tab" role="tab" aria-controls="schedules" aria-selected="true" href="#schedules">@Localizer["Scheduled Updates"] </a>
            </li>
        </ul>
    </div>
    <div class="tab-content" id="costTracking-import-main">
        <div class="tab-pane page-content show active" id="schedules" role="tabpanel" aria-labelledby="schedules">
            <form method="post">
            @(Html.Kendo().Grid<ScheduledSystemStatusListViewModel>()
                .Name($"systemsStatusGrid")
                .Columns(columns =>
                {
                    columns.Bound(t => t.StatusType).ClientTemplate(detailsLinkTemplate).HtmlAttributes(new { @class="no-wrap" });
                    columns.Bound(t => t.ShowNotification).ClientTemplate($"<i class='#= ShowNotification ? 'fal fa-check' : ''#'>").HtmlAttributes(new { @class = "text-center" }).HeaderHtmlAttributes(new { @class = "ttext-center" }).MinScreenWidth(768);
                    columns.Bound(t => t.Message).MinScreenWidth(576);
                    columns.Bound(t => t.UpdateSecurityStamp).ClientTemplate($"<i class='#= UpdateSecurityStamp ? 'fal fa-check' : ''#'>").HtmlAttributes(new { @class = "text-center" }).HeaderHtmlAttributes(new { @class = "ttext-center" }).MinScreenWidth(768);
                    columns.Bound(t => t.IsEnabled).Title(Localizer["Enabled"].Value).ClientTemplate($"<i class='#= IsEnabled ? 'fal fa-check' : ''#'>").HtmlAttributes(new { @class = "text-center" }).HeaderHtmlAttributes(new { @class = "text-center" });
                    columns.Bound(t => t.Status).ClientTemplate("#= Status #").Title(Localizer["Task Status"].Value);
                    columns.Bound(t => t.NextRunTime).Format("{0:dd-MMM-yyyy h:mmtt}").HtmlAttributes(new { @class = "no-wrap" });
                    columns.Command(command =>                    
                                command.Custom("Delete")
                                        .Click("deleteTask")
                                        .IconClass("k-icon fal fa-trash-alt")
                                        .Text($"<span class='grid-action-label'>{Localizer["Delete"].Value}</span>")
                                        .HtmlAttributes(new { @class = "grid-action", title = Localizer["Delete"].Value })
                    );
                })
                .ToolBar(tools => tools.ClientTemplate(toolbarTemplate))
                .AutoBind(true)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                //.ColumnMenu()
                .Excel(excel => excel.FileName("ScheduledTaskList.xlsx").AllPages(true))
                .DataSource(dataSource => dataSource
                    .Ajax()
                    .Events(events => events.Error($"systemStatusGridError"))
                    .Events(events => events.RequestEnd($"systemStatusGridRequestEnd"))
                    .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                    .Read(read => read.Action("GetTasks", "ScheduledSystemStatus"))
                    .Sort(sort => sort.Add(p => p.NextRunTime))
                )
                .Events(e => e.DataBound("systemStatusGridDataBound"))
                .HtmlAttributes(new { @class = "kendo-Grid", data_details_url = detailsUrl, data_save_url = saveUrl, data_delete_url = deleteUrl, data_delete_title = Localizer["Confirm Delete"].Value, data_delete_message = Localizer["Are you sure you want to delete this record?"].Value })
                )
            </form>
        </div>
    </div>
</div>
<style>
    .row.system-settings {
        margin-left: -20px;
        margin-right: -20px;
    }

        .row.system-settings .col {
            padding-left: 20px;
        }

        .row.system-settings .col.scheduled-tasks {
            padding-left: 0;
            padding-right: 0;
        }

            .row.system-settings .col.scheduled-tasks .tab-pane {
                padding:0;
            }
</style>
<script>
    const systemStatusGridDataBound = (e) => {
        const grid = e.sender.element;

        grid.find(".view-task").off("click");
        grid.find(".view-task").on("click", (e) => {
            viewTaskDetail(e);
        });
    };

    const systemStatusGridRequestEnd = (e) => {
    };

    const systemStatusGridError = (e) => {
    };

    const deleteTask = (e) => {
        const el = $(e.currentTarget);
        const form = el.closest("form");
        const row = el.closest("tr");
        const grid = el.closest("#systemsStatusGrid").data("kendoGrid");
        const dataItem = grid.dataItem(row);
        const url = grid.element.data("delete-url");
        
        if (url){
            cpiConfirm.delete(grid.element.data("delete-title"), grid.element.data("delete-message"), () => {
                $.post(url, {
                    id: dataItem.TaskId,
                    __RequestVerificationToken: form.find("input[name=__RequestVerificationToken]").val()
                })
                    .done((response) => {
                        //showStatus(response);
                        grid.dataSource.read();
                    })
                    .fail((error) => {
                        cpiAlert.warning(pageHelper.getErrorMessage(error), () => {
                            grid.dataSource.read();
                        });
                    });
            });
        }
    };

    const viewTaskDetail = (e) => {
        const el = $(e.target);
        const taskId = el.data("id");
        const grid = el.closest("#systemsStatusGrid").data("kendoGrid");
        const url = grid.element.data("details-url");

        e.preventDefault();

        const showDetails = (view) => {
            const keepOpen = cpiConfirm.keepOpen;
            cpiConfirm.save(window.cpiBreadCrumbs.getTitle(), view,
                () => {
                    cpiConfirm.keepOpen = true;
                    hideError();
                    const data = pageHelper.formDataToJson($("form.task-scheduler"));

                    validateTask(data.payLoad);                    

                    $.post(grid.element.data("save-url"), {
                            updated: data.payLoad,
                            __RequestVerificationToken: data.verificationToken
                        })
                        .done((response) => {
                            //showStatus(response);
                            grid.dataSource.read();

                            cpiConfirm.keepOpen = keepOpen;
                            cpiConfirm.close();
                        })
                        .fail((error) => {
                            showError(pageHelper.getErrorMessage(error));
                            cpiConfirm.keepOpen = keepOpen;
                        });
                }, 
                true, null,true);
        }

        if (url) {
            $.get(url, { id: taskId })
                .done((response) => {
                    showDetails(response);
                })
                .fail((error) => {
                    cpiAlert.warning(pageHelper.getErrorMessage(error), () => {
                        grid.dataSource.read();
                    });
                });
        }
    };

    const validateTask = (task) => {
        // if (!task.Name)
        //     showError("Name is required.", false);   

        // if (!task.Password)
        //     showError("Please enter password.", false);   
    };

    const showError = (message) => {
        const alert = $(".task-scheduler").find(".page-status.alert");
        alert.find("span.message").html(message);
        alert.show();
        throw message;
    }

    const hideError = () => {
        const alert = $(".task-scheduler").find(".page-status.alert");
        alert.hide();
    }

    $(document).ready(function () {
    });
</script>