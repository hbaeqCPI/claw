@model Release
@inject IStringLocalizer<SharedResource> Localizer
@{
    var id = Model.ReleaseId;
    var addMode = id == 0;

    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;

    var systemsList = (List<string>)ViewData["SystemsList"] ?? new List<string>();
    var systemItems = systemsList.Select(s => new SelectListItem { Text = s, Value = s }).ToList();
}
<form id="detailForm" method="post" cpi-detail-form
      action="@Url.Action("Save", "Release", new { area = "Releases" })"
      data-error-message="@Localizer["An error occurred. No updates were made."]"
      data-save-message="@Localizer["Record has been saved successfully."]"
      data-cancel-title="@Localizer["Confirm Cancel Changes"]"
      data-cancel-message="@Localizer["Changes will not be saved. Do you want to continue?"]"
      data-delete-title="@Localizer["Confirm Delete"]"
      data-delete-message="@Localizer["You are about to delete this record. This operation cannot be undone."]"
      data-delete-success="@Localizer["Record has been deleted successfully."]">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ReleaseId" />
    @await Component.InvokeAsync("DetailPageNavLinks", new { pagePermission = detailPagePermission, title = "", addMode = addMode })

    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col-12 col-sm-8 col-md-6 col-lg-5 col-xl-4">
                <div class="form-group float-label">
                    <label asp-for="Name"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="Name" asp-is-readonly="@isReadOnly" asp-is-autofocus="@addMode" />
                    <span asp-validation-for="Name"></span>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-3 col-lg-2 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="Year"></label>
                    @if (isReadOnly)
                    {
                        <input type="number" class="form-control form-control-sm" asp-for="Year" readonly />
                    }
                    else
                    {
                        @(Html.Kendo().NumericTextBox<int>()
                            .Name("Year")
                            .Value(DateTime.Now.Year)
                            .Format("####")
                            .Decimals(0)
                            .Min(2000)
                            .Max(2100)
                            .HtmlAttributes(new { style = "width: 100%", placeholder = " " })
                        )
                    }
                    <span asp-validation-for="Year"></span>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-3 col-lg-2 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="Quarter"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="Quarter" readonly />
                    }
                    else
                    {
                        @(Html.Kendo().DropDownList()
                            .Name("Quarter")
                            .DataTextField("Text")
                            .DataValueField("Value")
                            .BindTo(new List<SelectListItem>
                            {
                                new SelectListItem { Text = "Q1", Value = "Q1" },
                                new SelectListItem { Text = "Q2", Value = "Q2" },
                                new SelectListItem { Text = "Q3", Value = "Q3" },
                                new SelectListItem { Text = "Q4", Value = "Q4" }
                            })
                            .Value(Model.Quarter ?? "Q1")
                            .HtmlAttributes(new { style = "width: 100%" })
                        )
                    }
                    <span asp-validation-for="Quarter"></span>
                </div>
            </div>
            <div class="col-6 col-sm-4 col-md-3 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label for="SystemType">@Localizer["System"]</label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="SystemType" readonly />
                    }
                    else
                    {
                        @(Html.Kendo().DropDownList()
                            .Name("SystemType")
                            .DataTextField("Text")
                            .DataValueField("Value")
                            .BindTo(systemItems)
                            .Value(Model.SystemType ?? systemItems.FirstOrDefault()?.Value)
                            .HtmlAttributes(new { style = "width: 100%" })
                        )
                    }
                    <span asp-validation-for="SystemType"></span>
                </div>
            </div>
        </div>
        @{
            var sysTypeForNotes = Model.SystemType ?? "";
            // Show Patent notes unless this release is trademark-only; show Trademark
            // notes unless it's patent-only. Matches the Generate MDB button logic.
            var showPatentNotes = !sysTypeForNotes.StartsWith("Tmk", StringComparison.OrdinalIgnoreCase);
            var showTmkNotes = !sysTypeForNotes.StartsWith("Pat", StringComparison.OrdinalIgnoreCase);
        }
        <div class="form-row">
            @if (showPatentNotes)
            {
                <div class="col-md-6">
                    <div class="form-group float-label">
                        <label asp-for="ReportNotesPatent"></label>
                        <textarea class="form-control form-control-sm" rows="3"
                                  asp-for="ReportNotesPatent" asp-is-readonly="@isReadOnly"
                                  placeholder="@Localizer["Rendered at the top of the Patent report PDF"]"></textarea>
                        <span asp-validation-for="ReportNotesPatent"></span>
                    </div>
                </div>
            }
            else
            {
                @* Preserve existing value on post when the field is hidden. *@
                <input type="hidden" asp-for="ReportNotesPatent" />
            }
            @if (showTmkNotes)
            {
                <div class="col-md-6">
                    <div class="form-group float-label">
                        <label asp-for="ReportNotesTrademark"></label>
                        <textarea class="form-control form-control-sm" rows="3"
                                  asp-for="ReportNotesTrademark" asp-is-readonly="@isReadOnly"
                                  placeholder="@Localizer["Rendered at the top of the Trademark report PDF"]"></textarea>
                        <span asp-validation-for="ReportNotesTrademark"></span>
                    </div>
                </div>
            }
            else
            {
                <input type="hidden" asp-for="ReportNotesTrademark" />
            }
        </div>
        @if (!addMode)
        {
            var sysType = Model.SystemType ?? "";
            var showPatentBtn = !sysType.StartsWith("Tmk", StringComparison.OrdinalIgnoreCase);
            var showTmkBtn = !sysType.StartsWith("Pat", StringComparison.OrdinalIgnoreCase);
            <div class="form-row">
                <div class="col-auto">
                    @if (showPatentBtn)
                    {
                        <button type="button" class="btn btn-primary btn-sm mr-2 btnGenerateMdb"
                                data-area="Patent"
                                data-url="@Url.Action("GenerateMdb", new { id = Model.ReleaseId, mdbArea = "Patent" })">
                            <i class="fal fa-database pr-1"></i> @Localizer["Generate Patent MDB"]
                        </button>
                    }
                    @if (showTmkBtn)
                    {
                        <button type="button" class="btn btn-primary btn-sm btnGenerateMdb"
                                data-area="Trademark"
                                data-url="@Url.Action("GenerateMdb", new { id = Model.ReleaseId, mdbArea = "Trademark" })">
                            <i class="fal fa-database pr-1"></i> @Localizer["Generate Trademark MDB"]
                        </button>
                    }
                </div>
            </div>
        }
    </div>

    @if (!addMode)
    {
        <ul class="nav nav-tabs detail cpiDetailInfoNav nav-tabs-horizontal" role="tablist">
            <li class="nav-item">
                <a id="releaseDetailDocumentsTab" href="#releaseDetailDocumentsTabContent" class="nav-link active" data-toggle="tab" role="tab" aria-controls="releaseDetailDocumentsTabContent" title="@Localizer["Documents"]">@Localizer["Documents"]</a>
            </li>
            <li class="nav-item">
                <a id="releaseDetailReportsTab" href="#releaseDetailReportsTabContent" class="nav-link" data-toggle="tab" role="tab" aria-controls="releaseDetailReportsTabContent" title="@Localizer["Reports"]">@Localizer["Reports"]</a>
            </li>
        </ul>
        <div class="tab-content detail">
            <div class="tab-pane active show" id="releaseDetailDocumentsTabContent" role="tabpanel" aria-labelledby="releaseDetailDocumentsTab">
                @await Html.PartialAsync("_DocumentTree", Model)
            </div>
            <div class="tab-pane" id="releaseDetailReportsTabContent" role="tabpanel" aria-labelledby="releaseDetailReportsTab">
                <div class="p-3">
                    <div id="reportMdbList_@id"><p class="text-muted">Loading...</p></div>
                    <div id="reportStatus_@id" class="mt-2" style="display:none;"></div>
                </div>
                <script>
                    $(document).ready(function () {
                        var releaseId = @id;
                        var mdbListDiv = $('#reportMdbList_' + releaseId);
                        var statusDiv = $('#reportStatus_' + releaseId);

                        // Load MDB files, group by Pat/Tmk, one section per type
                        function loadMdbFiles() {
                            $.get('@Url.Action("GetMdbFiles")', { releaseId: releaseId }, function (data) {
                                if (!data || data.length === 0) {
                                    mdbListDiv.html('<p class="text-muted">No MDB files found. Generate MDB files first.</p>');
                                    return;
                                }
                                // Group by Pat/Tmk — pick the latest (last) MDB per type as the current
                                var patDocs = [], tmkDocs = [];
                                $.each(data, function (i, doc) {
                                    if (doc.DocName.toLowerCase().indexOf('pat') >= 0) patDocs.push(doc);
                                    else tmkDocs.push(doc);
                                });

                                function renderSection(label, isPat, docs) {
                                    if (!docs.length) return '';
                                    var section = '<div class="mb-4 report-section" data-is-pat="' + isPat + '">';
                                    section += '<h6 class="font-weight-bold mb-2">' + label + '</h6>';
                                    section += '<div class="form-row align-items-end">';
                                    section += '<div class="col-md-4"><label class="small text-muted">Current MDB:</label>';
                                    section += '<select class="form-control form-control-sm currentMdbSelect">';
                                    // Newest first — most recent generation is likely the one the author wants.
                                    for (var i = docs.length - 1; i >= 0; i--) {
                                        var d = docs[i];
                                        var selected = i === docs.length - 1 ? ' selected' : '';
                                        section += '<option value="' + d.DocId + '"' + selected + '>' + d.DocName + '</option>';
                                    }
                                    section += '</select></div>';
                                    section += '<div class="col-md-5"><label class="small text-muted">Compare Against:</label>';
                                    section += '<select class="form-control form-control-sm compareMdbSelect"></select></div>';
                                    section += '<div class="col-auto"><button type="button" class="btn btn-sm btn-primary btnGenReport">';
                                    section += '<i class="fal fa-file-pdf pr-1"></i> Generate Report</button></div>';
                                    section += '</div></div>';
                                    return section;
                                }

                                var html = renderSection('Patent', 'true', patDocs)
                                         + renderSection('Trademark', 'false', tmkDocs);
                                mdbListDiv.html(html);

                                // Populate each compare dropdown with MDB files from other releases
                                mdbListDiv.find('.report-section').each(function () {
                                    var section = $(this);
                                    var isPat = section.data('is-pat');
                                    var sel = section.find('.compareMdbSelect');
                                    $.get('@Url.Action("GetCompareMdbFiles")', { releaseId: releaseId, isPat: isPat }, function (mdbFiles) {
                                        sel.empty().append('<option value="">-- Select an MDB --</option>');
                                        $.each(mdbFiles, function (j, f) {
                                            sel.append('<option value="' + f.DocId + '">' + f.Text + '</option>');
                                        });
                                    });
                                });
                            });
                        }
                        loadMdbFiles();

                        // Generate report
                        mdbListDiv.on('click', '.btnGenReport', function (e) {
                            e.preventDefault();
                            e.stopPropagation();
                            var section = $(this).closest('.report-section');
                            var docId = section.find('.currentMdbSelect').val();
                            var compareDocId = section.find('.compareMdbSelect').val();
                            if (!docId) {
                                pageHelper.showErrors('Please select the current MDB to generate the report from.');
                                return;
                            }
                            if (!compareDocId) {
                                pageHelper.showErrors('Please select an MDB file to compare against.');
                                return;
                            }
                            var btn = $(this);
                            btn.prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Generating...');
                            statusDiv.hide();

                            $.post('@Url.Action("GenerateReport")', {
                                releaseId: releaseId,
                                compareDocId: compareDocId,
                                docId: docId,
                                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                            }).done(function (result) {
                                btn.prop('disabled', false).html('<i class="fal fa-file-pdf pr-1"></i> Generate Report');
                                statusDiv.html('<div class="alert alert-success">' + (result.success || 'Report generated.') + '</div>').show();
                                // Switch to Documents tab and refresh
                                var docsTab = $('#releaseDetailDocumentsTab');
                                if (docsTab.length) docsTab.tab('show');
                                var treeEl = $('#documentTree_' + releaseId);
                                if (treeEl.length) {
                                    var tv = treeEl.data('kendoTreeView');
                                    if (tv) { tv.select($()); tv.dataSource.read(); }
                                    setTimeout(function() { releaseDocTree_@(id).fallbackFolderClick(); }, 500);
                                }
                            }).fail(function (e) {
                                btn.prop('disabled', false).html('<i class="fal fa-file-pdf pr-1"></i> Generate Report');
                                var msg = 'Error generating report.';
                                try { msg = JSON.parse(e.responseText); } catch (ex) { msg = e.responseText || msg; }
                                statusDiv.html('<div class="alert alert-danger">' + msg + '</div>').show();
                            });
                        });
                    });
                </script>
            </div>
        </div>
        <div class="content-stamp">
            @await Component.InvokeAsync("RecordStamps", new { createdBy = Model.CreatedBy, dateCreated = Model.DateCreated, updatedBy = Model.UpdatedBy, lastUpdate = Model.LastUpdate, tStamp = new byte[0] })
        </div>
    }
</form>

<script>
    $(document).ready(function() {
        $('.btnGenerateMdb').on('click', function() {
            var btn = $(this);
            var url = btn.data('url');
            var area = btn.data('area');
            cpiConfirm.confirm('Generate ' + area + ' MDB', 'Generate ' + area + ' MDB file for this release? This may take a moment.', function() {
                cpiLoadingSpinner.show();
                $.post(url).done(function(result) {
                    cpiLoadingSpinner.hide();
                    pageHelper.showSuccess(result.success || 'MDB files generated successfully.');
                    // Reload the detail page to show the new MDB in Documents
                    setTimeout(function() {
                        window.location.reload();
                    }, 1000);
                }).fail(function(e) {
                    cpiLoadingSpinner.hide();
                    pageHelper.showErrors(e);
                });
            });
        });
    });
</script>
