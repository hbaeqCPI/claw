@model int
@inject IStringLocalizer<SharedResource> SharedLocalizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
}

        @(Html.Kendo().Grid<TmkActionParameter>()
            .Name("tmkActionParametersGrid")
            .Columns(columns =>
            {
                columns.Bound(p => p.ActionDue)
                                    .Editable("tmkActionTypePage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
                columns.Bound(p => p.Yr).Width(100)
                                    .Editable("tmkActionTypePage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
                columns.Bound(p => p.Mo).Width(100)
                                    .Editable("tmkActionTypePage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
                columns.Bound(p => p.Dy).Width(100)
                                    .Editable("tmkActionTypePage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
                columns.Bound(p => p.Indicator).Width(175)
                                    .EditorTemplateName("ComboBox").Width(175)
                                    .EditorViewData(new { action = "GetPicklistData", controller = "Indicator", dataValueField = "Indicator" })
                                    .Editable("tmkActionTypePage.isGridColumnEditable")
                                    .HtmlAttributes(fullModify ? new { @class = "editable-cell" } : null);
                columns.Command(command =>
                {
                    if (detailPagePermission.CanDeleteRecord)
                        command.Custom("Delete")
                                .Click("function(e) {tmkActionTypePage.deleteGridRow(e,this)}")
                                .IconClass("k-icon fal fa-trash-alt")
                                .Text($"<span class='grid-action-label'>{SharedLocalizer["Delete"]}</span>")
                                .HtmlAttributes(new { @class = "grid-action" });
                }).Width(10);
            })
            .Selectable(selectable => selectable.Mode(GridSelectionMode.Single))
            .ToolBar(toolbar =>
            {
                if (detailPagePermission.CanAddRecord)
                {
                    toolbar.Create().IconClass("k-icon fal fa-plus").Text(SharedLocalizer["Add"])
                                    .HtmlAttributes(new { @class = "grid-action" });
                }
                if (detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
                {
                    toolbar.Custom().Name("Save").IconClass("k-icon fal fa-save").Text(SharedLocalizer["Save"]).HtmlAttributes(new {@class="d-none"});
                    toolbar.Custom().Name("Cancel").IconClass("k-icon fal fa-times").Text(SharedLocalizer["Cancel"]).HtmlAttributes(new { @class = "d-none" });
                }

            })
            .Editable(editable => editable.Enabled(detailPagePermission.CanEditRecord && !detailPagePermission.CanEditRemarksOnly)
                        .Mode(GridEditMode.InCell).
                        ConfirmDelete(@SharedLocalizer["Are you sure you want to delete this record?"]).DisplayDeleteConfirmation(false))
            .Sortable(sort => sort.AllowUnsort(false))
            .Pageable()
            .DataSource(dataSource => dataSource
            .Ajax()
            .Batch(true)
            .PageSize(settings.SubFormPageSize)
            .ServerOperation(false)
            .Model(model =>
            {
                model.Id(p => p.ActParamId);
                model.Field(p => p.Indicator).DefaultValue("Reminder");
            })
            .Read(create => create.Action("ActionParametersRead", "ActionType", new {actionTypeId = Model}))
            .Update(create => create.Action("ActionParametersUpdate", "ActionType"))
            .Destroy(create => create.Action("ActionParametersDelete", "ActionType"))
            .Events(events =>
            {
                events.Error("pageHelper.onGridError");
            })
            )
            .HtmlAttributes(new { @class = "kendo-Grid" })
        )