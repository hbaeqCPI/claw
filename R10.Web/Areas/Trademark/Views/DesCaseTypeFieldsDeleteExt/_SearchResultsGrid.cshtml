@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using R10.Core.Entities.Trademark

@(Html.Kendo().Grid<TmkDesCaseTypeFieldsDeleteExt>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.DesCaseType).Width(200);
        columns.Bound(m => m.FromField).Width(200);
        columns.Bound(m => m.ToField).Width(200);
        columns.Bound(m => m.DesCaseTypeNew).Width(200);
        columns.Bound(m => m.FromFieldNew).Width(200);
        columns.Bound(m => m.ToFieldNew).Width(200);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("DesCaseTypeFieldsDeleteExtList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DesCaseTypeFieldsDeleteExt")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("tmkDesCaseTypeFieldsDeleteExtPage.searchResultGridError"))
        .Events(events => events.RequestEnd("tmkDesCaseTypeFieldsDeleteExtPage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "DesCaseTypeFieldsDeleteExt").Data("tmkDesCaseTypeFieldsDeleteExtPage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
