@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer

@(Html.Kendo().Grid<dynamic>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound("DesCaseType").Title(Localizer["Des Case Type"].Value).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { desCaseType = "#: DesCaseType#", systems = "#: Systems#", fromSearch = true }), "DesCaseType")).Width(200);
        columns.Bound("Systems").Title(Localizer["Systems"].Value).Width(300);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("DesCaseTypeFieldsDeleteList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DesCaseTypeFieldsDelete")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("tmkDesCaseTypeFieldsDeletePage.searchResultGridError"))
        .Events(events => events.RequestEnd("tmkDesCaseTypeFieldsDeletePage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "DesCaseTypeFieldsDelete").Data("tmkDesCaseTypeFieldsDeletePage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
