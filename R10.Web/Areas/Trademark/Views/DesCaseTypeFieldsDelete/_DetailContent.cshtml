@model TmkDesCaseTypeFieldsDelete
@using R10.Core.Entities.Trademark
@inject IStringLocalizer<SharedResource> Localizer
@{
    var addMode = Model.IsNewRecord || (string.IsNullOrEmpty(Model.DesCaseType) && string.IsNullOrEmpty(Model.FromField) && string.IsNullOrEmpty(Model.ToField));
    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    var fullModify = detailPagePermission.CanEditRecord && (!detailPagePermission.CanEditRemarksOnly);
    bool isReadOnly = !fullModify;
}

<form cpi-detail-form action="Save">
    @if (addMode)
    {
        <input type="hidden" name="IsNewRecord" value="true" class="boolean" />
    }
    <input type="hidden" name="OriginalSystems" value="@(addMode ? "__NEW__" : (string.IsNullOrEmpty(Model.Systems) ? "__EMPTY__" : Model.Systems))" />
    <vc:detail-page-nav-links page-permission="detailPagePermission" title="" add-mode="addMode"></vc:detail-page-nav-links>

    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="DesCaseType"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="DesCaseType" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "DesCaseType", controller = "DesCaseType", area = "Trademark", action = "GetPicklistData", textProperty = "DesCaseType", defaultValue = Model.DesCaseType })
                        <span asp-validation-for="DesCaseType"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="FromField"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="FromField" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "FromField", controller = "DesCaseTypeFields", area = "Trademark", action = "GetPicklistData", defaultValue = Model.FromField })
                        <span asp-validation-for="FromField"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="ToField"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="ToField" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "ToField", controller = "DesCaseTypeFields", area = "Trademark", action = "GetPicklistData", defaultValue = Model.ToField })
                        <span asp-validation-for="ToField"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="DesCaseTypeNew"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="DesCaseTypeNew" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "DesCaseTypeNew", controller = "DesCaseType", area = "Trademark", action = "GetPicklistData", textProperty = "DesCaseType", defaultValue = Model.DesCaseTypeNew })
                        <span asp-validation-for="DesCaseTypeNew"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="FromFieldNew"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="FromFieldNew" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "FromFieldNew", controller = "DesCaseTypeFields", area = "Trademark", action = "GetPicklistData", defaultValue = Model.FromFieldNew })
                        <span asp-validation-for="FromFieldNew"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col col-sm-5 col-md-4 col-lg-3">
                <div class="form-group float-label">
                    <label asp-for="ToFieldNew"></label>
                    @if (isReadOnly)
                    {
                        <input type="text" class="form-control form-control-sm" asp-for="ToFieldNew" readonly />
                    }
                    else
                    {
                        @await Component.InvokeAsync("ComboBox", new { name = "ToFieldNew", controller = "DesCaseTypeFields", area = "Trademark", action = "GetPicklistData", defaultValue = Model.ToFieldNew })
                        <span asp-validation-for="ToFieldNew"></span>
                    }
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-6">
                <div class="form-group float-label">
                    <label asp-for="Systems"></label>
                    <input type="hidden" name="Systems" id="tmkDCTFDelSystemsHidden" value="@Model.Systems" />
                    <div class="border rounded p-2 position-relative" style="min-height: 60px; padding-top: 30px !important;">
                        @if (!isReadOnly)
                        {
                            <div class="position-absolute" style="top: 4px; right: 8px;">
                                <label class="small mb-0" style="cursor:pointer;"><input type="checkbox" id="tmkDCTFDelSystemsToggleAll" class="mr-1"/>Select All</label>
                            </div>
                        }
                        <div id="tmkDCTFDelSystemsCheckboxes"></div>
                    </div>
                    <script>
                        $(document).ready(function() {
                            var disabled = @(isReadOnly ? "true" : "false");
                            var selected = ($('#tmkDCTFDelSystemsHidden').val() || '').split(',').filter(function(s) { return s.length > 0; });
                            $.getJSON('@Url.Action("GetSystemList", "DesCaseTypeFieldsDelete")', function(data) {
                                var html = '';
                                $.each(data, function(i, name) {
                                    var checked = selected.indexOf(name) > -1 ? ' checked' : '';
                                    var dis = disabled ? ' disabled' : '';
                                    html += '<label class="mr-3" style="white-space:nowrap;"><input type="checkbox" class="tmkDCTFDelSystemChk mr-1" value="' + name + '"' + checked + dis + '/>' + name + '</label>';
                                });
                                $('#tmkDCTFDelSystemsCheckboxes').html(html);
                                var allCount = $('.tmkDCTFDelSystemChk').length;
                                var checkedCount = $('.tmkDCTFDelSystemChk:checked').length;
                                $('#tmkDCTFDelSystemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $(document).on('change', '.tmkDCTFDelSystemChk', function() {
                                var vals = [];
                                $('.tmkDCTFDelSystemChk:checked').each(function() { vals.push($(this).val()); });
                                $('#tmkDCTFDelSystemsHidden').val(vals.join(',')).trigger('change');
                                var allCount = $('.tmkDCTFDelSystemChk').length;
                                var checkedCount = $('.tmkDCTFDelSystemChk:checked').length;
                                $('#tmkDCTFDelSystemsToggleAll').prop('checked', allCount > 0 && allCount === checkedCount);
                            });
                            $('#tmkDCTFDelSystemsToggleAll').click(function() {
                                var isChecked = $(this).prop('checked');
                                $('.tmkDCTFDelSystemChk').prop('checked', isChecked).first().trigger('change');
                            });
                        });
                    </script>
                </div>
            </div>
        </div>
    </div>
</form>

<script>
    tmkDesCaseTypeFieldsDeletePage.afterInsert = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    tmkDesCaseTypeFieldsDeletePage.showDetails = function(result) {
        if (result && result.redirectUrl) {
            pageHelper.openLink(result.redirectUrl, true);
        }
    };
    $(document).ready(function() {
        $('.copy-record').off('click').on('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var url = $(this).data('url');
            if (url) pageHelper.openLink(url, true);
        });
    });
</script>
