@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<TmkIndicator>()
                .Name($"{Model.PageId}-Grid")
                .Columns(columns =>
                {
                    columns.Bound(m => m.Indicator).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: IndicatorId#", fromSearch = true }), "Indicator")).Width(200);
                    columns.Bound(m => m.Description);
                    columns.Bound(m => m.CPIIndicator).Width(120);
                    columns.Bound(m => m.RMSIndicator).Title("RMS Indicator").Width(120);
                })
                .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                .AutoBind(false)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                .Excel(excel => excel.FileName("TmkIndicatorList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "Indicator")))
                .DataSource(dataSource => dataSource
                .Ajax().Events(events => events.Error("tmkIndicatorPage.searchResultGridError"))
                .Events(events => events.RequestEnd("tmkIndicatorPage.searchResultGridRequestEnd"))
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                .Read(read => read.Action("PageRead", "Indicator")
                .Data("tmkIndicatorPage.gridMainSearchFilters")
                )
                .Sort(sort => sort.Add(m => m.Indicator))
                )
                .HtmlAttributes(new { @class = "kendo-Grid" })
)
