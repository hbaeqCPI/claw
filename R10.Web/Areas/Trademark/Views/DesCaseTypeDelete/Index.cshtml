@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Des Case Type Delete"];
    ViewData["ActivePage"] = "tmkDesCaseTypeDeletePage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof tmkDesCaseTypeDeletePage === 'undefined') { var tmkDesCaseTypeDeletePage = new ActivePage(); }
tmkDesCaseTypeDeletePage.mainSearchRecordIds = tmkDesCaseTypeDeletePage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)
