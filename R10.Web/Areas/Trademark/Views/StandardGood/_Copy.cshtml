@model StandardGoodCopyViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="modal fade" id="tmkStandardGoodCopyDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" asp-action="EditCopied">
                <div class="modal-header py-1">
                    <h4 class="modal-title">@Localizer["Copy Standard Good"]</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body pt-0">
                    <div class="container-fluid">
                        <input type="hidden" asp-for="ClassId" />
                        <div class="row">
                            <div class="col-md-12 px-0">
                                <div class="form-group float-label">
                                    <label asp-for="Class" class="required"></label>
                                    <input asp-for="Class" class="form-control form-control-sm" />
                                    <span asp-validation-for="Class"></span>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12 px-0">
                                <div class="form-group float-label">
                                    <label asp-for="ClassType" class="required"></label>
                                    <input asp-for="ClassType" class="form-control form-control-sm" />
                                    <span asp-validation-for="ClassType"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                    <button type="submit" class="btn btn-primary"><i class="fa fa-check pr-2"></i>@Localizer["Copy"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        tmkStandardGoodPage.showCopyScreen();
    });
</script>