@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
<div class="tab-content search page-content">
    <div class="tab-pane show active" id="areaCountrySearchMainTabContent" aria-labelledby="areaCountrySearchMainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Area">Area</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Area" })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="Country">Country</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Country" })
                </div>
            </div>
        </div>
    </div>
</div>
