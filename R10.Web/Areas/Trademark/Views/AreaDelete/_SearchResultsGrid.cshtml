@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using R10.Core.Entities.Trademark

@(Html.Kendo().Grid<TmkAreaDelete>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.Area).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { areaCode = "#: Area#", areaNewCode = "#: AreaNew#", systems = "#: Systems#", fromSearch = true }), "Area")).Width(200);
        columns.Bound(m => m.Description).Width(200);
        columns.Bound(m => m.AreaNew).Width(200);
        columns.Bound(m => m.Systems).Width(200);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("AreaDeleteList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "AreaDelete")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("tmkAreaDeletePage.searchResultGridError"))
        .Events(events => events.RequestEnd("tmkAreaDeletePage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "AreaDelete").Data("tmkAreaDeletePage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
