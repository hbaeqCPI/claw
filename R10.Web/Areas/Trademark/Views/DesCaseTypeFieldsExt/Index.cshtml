@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["DesCaseTypeFields Ext"];
    ViewData["ActivePage"] = "tmkDesCaseTypeFieldsExtPage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof tmkDesCaseTypeFieldsExtPage === 'undefined') { var tmkDesCaseTypeFieldsExtPage = new ActivePage(); }
tmkDesCaseTypeFieldsExtPage.mainSearchRecordIds = tmkDesCaseTypeFieldsExtPage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)
