@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<TmkDesCaseTypeFields>()
                .Name($"{Model.PageId}-Grid")
                .Columns(columns =>
                {
                    columns.Bound(m => m.DesCaseType).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { id = "#: KeyID#", fromSearch = true }), "DesCaseType")).Width(200);
                    columns.Bound(m => m.FromField);
                    columns.Bound(m => m.ToField);
                    columns.Bound(m => m.InUse).ClientTemplate("<i class='align-items-center small fa fal #: InUse ? 'fa-check' : ''#'></i>")
                        .HtmlAttributes(new { @class = "text-center" })
                        .HeaderHtmlAttributes(new { @class = "d-flex justify-content-center align-items-center" })
                        .Width(100);
                })
                .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                .AutoBind(false)
                .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                .Sortable(sort => sort.AllowUnsort(false))
                .Excel(excel => excel.FileName("DesCaseTypeFieldsList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DesCaseTypeFields")))
                .DataSource(dataSource => dataSource
                .Ajax().Events(events => events.Error("tmkDesCaseTypeFieldsPage.searchResultGridError"))
                .Events(events => events.RequestEnd("tmkDesCaseTypeFieldsPage.searchResultGridRequestEnd"))
                .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                .Read(read => read.Action("PageRead", "DesCaseTypeFields")
                .Data("tmkDesCaseTypeFieldsPage.gridMainSearchFilters")
                )
                .Sort(sort => sort.Add(m => m.DesCaseType))
                )
                .HtmlAttributes(new { @class = "kendo-Grid" })
)