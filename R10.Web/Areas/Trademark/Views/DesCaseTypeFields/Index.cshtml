@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Des Case Type Fields"];
    ViewData["ActivePage"] = "tmkDesCaseTypeFieldsPage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof tmkDesCaseTypeFieldsPage === 'undefined') { var tmkDesCaseTypeFieldsPage = new ActivePage(); }
tmkDesCaseTypeFieldsPage.mainSearchRecordIds = tmkDesCaseTypeFieldsPage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)
