@model PageViewModel
@inject IStringLocalizer<CountryLawResource> Localizer
@{
    var countryLabel = Localizer["Country"];
    var countryNameLabel = Localizer["Country Name"];
}

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="countryLawSearchMainTabContent" role="tabpanel" aria-labelledby="countryLawSearchMainTab">
        <div class="form-row">
            <div class="col-md-4 col-lg-4 col-xl-3">
                <div class="form-group float-label">
                    <label for="Country">@countryLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Country", controller = "CountryLaw", action = "GetCountryList", area = "Trademark", textProperty = "Country", multiSelect = true })
                </div>
            </div>
            <div class="col-md-8 col-lg-8 col-xl-4">
                <div class="form-group float-label">
                    <label for="CountryName">@countryNameLabel</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CountryName", controller = "CountryLaw", action = "GetCountryList", area = "Trademark", textProperty = "CountryName", multiSelect = true })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4 col-lg-4 col-xl-3">
                <div class="form-group float-label">
                    <label for="CaseType">@Localizer["Case Type"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CaseType", action = "GetCaseTypeList", multiSelect = true })
                </div>
            </div>
            <div class="col-md-4 col-lg-4 col-xl-3">
                <div class="form-group float-label">
                    <label for="SystemName">@Localizer["Systems"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "SystemName", controller = "System", area = "Shared", action = "GetPicklistData", multiSelect = true })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <label for="AutoGenDesCtry">@Localizer["Auto Gen Des Ctry"]</label>
                <div>
                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                        <label class="btn btn-outline">
                            <input type="radio" name="AutoGenDesCtry" class="form-control" value="true" data-role="option"> @Localizer["Yes"]
                        </label>
                        <label class="btn btn-outline">
                            <input type="radio" name="AutoGenDesCtry" class="form-control" value="false" data-role="option"> @Localizer["No"]
                        </label>
                        <label class="btn btn-outline active">
                            <input type="radio" name="AutoGenDesCtry" class="form-control" value="" data-role="option"> @Localizer["All"]
                        </label>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <label for="AutoUpdtDesTmkRecs">@Localizer["Auto Update Des Tmk Recs"]</label>
                <div>
                    <div class="btn-group btn-group-toggle" data-toggle="buttons">
                        <label class="btn btn-outline">
                            <input type="radio" name="AutoUpdtDesTmkRecs" class="form-control" value="true" data-role="option"> @Localizer["Yes"]
                        </label>
                        <label class="btn btn-outline">
                            <input type="radio" name="AutoUpdtDesTmkRecs" class="form-control" value="false" data-role="option"> @Localizer["No"]
                        </label>
                        <label class="btn btn-outline active">
                            <input type="radio" name="AutoUpdtDesTmkRecs" class="form-control" value="" data-role="option"> @Localizer["All"]
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
