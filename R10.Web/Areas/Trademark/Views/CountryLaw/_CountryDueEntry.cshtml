@using System.ComponentModel.DataAnnotations
@using System.Reflection
@model TmkCountryDue
@inject ISystemSettings<DefaultSetting> Settings
@inject ITmkCountryLawService CountryLawService
@inject IStringLocalizer<CountryLawResource> Localizer

@{
    var settings = await Settings.GetSetting();

    //var screen = "patCountryLaw";
    var caseNumberLabel = settings.LabelCaseNumber;

    var enableComboPaging = settings.EnableComboBoxPaging;
    var comboPagingSize = settings.ComboBoxPagingSize;

    var requiredValidationMessages = typeof(TmkCountryDue)
        .GetProperties()
        .Select(f => new { f.Name, RequiredValidation = f.GetCustomAttribute<RequiredAttribute>() })
        .Where(v => v.RequiredValidation != null)
        .Select(v => new { v.Name, v.RequiredValidation.ErrorMessage })
        .ToList();

    var labelCanGenerate = Localizer["Generate this Action?"];
    bool copyLawAction = ViewBag.CopyLawAction ?? false;
    // Allow full edit regardless of CPI Action status
    Model.CPIAction = false;
}

<div class="modal fade" id="tmkCountryDueEntryDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <form method="post" asp-action="CountryDueSave"
                  data-save-message="@Localizer["Record has been saved successfully."]">
                <div class="modal-header py-1">
                    <h4 class="modal-title">@Localizer[copyLawAction ? "Copy Law Action" : Model.CDueId == 0 ? "Add Law Action" : "Edit Law Action"]</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body py-1">
                    <div class="container-fluid">
                        <input type="hidden" asp-for="CDueId" value="@Model.CDueId" /> @* because of weird behavior (copy, non zero value)*@
                        @*<input type="hidden" asp-for="CPIAction" />*@
                        <input type="hidden" asp-for="Country" />
                        <input type="hidden" asp-for="CaseType" />
                        <input type="hidden" asp-for="OldFollowupAction" />
                        <input type="checkbox" asp-for="CPIAction" class="d-none" />

                        <div class="row">
                            <div class="col-12 col-md-6">
                                @if (Model.CPIAction)
                                {
                                    <div class="dymo-alert">@Localizer["CPI Action"]</div>
                                }
                            </div>
                            <div class="col-12 col-md-6">
                                @(Html.Kendo().CheckBoxFor(m => m.Calculate).Label(labelCanGenerate))
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label class="required" asp-for="ActionDue"></label>
                                    @await Component.InvokeAsync("ComboBox",
                                        new
                                             {
                                                 name = "ActionDue",
                                                 action = "GetActionDues",
                                                 controller = "CountryLaw",
                                                 defaultValue = Model.ActionDue,
                                                 textProperty = "Text",
                                            validationMessage = requiredValidationMessages.Where(v => v.Name == "ActionDue").Select(v => v.ErrorMessage).FirstOrDefault()
                                        })
                                    <span asp-validation-for="ActionDue"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label class="required" asp-for="ActionType"></label>
                                    @await Component.InvokeAsync("ComboBox",
                                        new { name = "ActionType", action = "GetActionTypes", controller = "CountryLaw", defaultValue = Model.ActionType, textProperty = "Text" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label class="required" asp-for="BasedOn"></label>
                                    @await Component.InvokeAsync("ComboBox",
                                        new
                                             {
                                                 name = "BasedOn",
                                                 action = "GetBasedOnList",
                                                 controller = "CountryLaw",
                                                 defaultValue = Model.BasedOn,
                                                 textProperty = "Text",
                                            validationMessage = requiredValidationMessages.Where(v => v.Name == "BasedOn").Select(v => v.ErrorMessage).FirstOrDefault()
                                        })
                                    <span asp-validation-for="BasedOn"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="Recurring"></label>
                                    @await Component.InvokeAsync("ComboBox",
                                        new { name = "Recurring", action = "GetRecurringOptions", controller = "CountryLaw", defaultValue = Model.Recurring.ToString(), defaultText = CountryLawService.GetRecurringDesc(Model.Recurring), valueProperty = "Value", textProperty = "Text" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <h6 class="ml-4">@Localizer["Terms"]</h6>
                        </div>
                        <div class="row">
                            <div class="col-md-6 d-flex">
                                <div class="pr-1">
                                    <div class="form-group float-label">
                                        <label asp-for="Yr"></label>
                                        <input type="number" class="form-control form-control-sm" name="Yr" id="Yr" value="@Model.Yr" min="0" style="width: 100%" />
                                    </div>
                                </div>
                                <div class="pr-1">
                                    <div class="form-group float-label">
                                        <label asp-for="Mo"></label>
                                        <input type="number" class="form-control form-control-sm" name="Mo" id="Mo" value="@Model.Mo" min="0" max="12" style="width: 100%" />
                                    </div>
                                </div>
                                <div>
                                    <div class="form-group float-label">
                                        <label asp-for="Dy"></label>
                                        <input type="number" class="form-control form-control-sm" name="Dy" id="Dy" value="@Model.Dy" min="0" max="31" style="width: 100%" />
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="Indicator"></label>
                                    @await Component.InvokeAsync("ComboBox",
                                        new
                                        {
                                            name = "Indicator",
                                                 action = "GetPicklistData",
                                                 controller = "Indicator",
                                                 defaultValue = Model.Indicator,
                                                 textProperty = "Indicator",
                                            validationMessage = requiredValidationMessages.Where(v => v.Name == "Indicator").Select(v => v.ErrorMessage).FirstOrDefault()
                                        })
                                    <span asp-validation-for="Indicator"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label class="required" asp-for="EffBasedOn"></label>
                                    @await Component.InvokeAsync("ComboBox",
                                        new { name = "EffBasedOn", action = "GetBasedOnList", controller = "CountryLaw", defaultValue = Model.EffBasedOn, textProperty = "Text", required = true, validationMessage = requiredValidationMessages.Where(v => v.Name == "EffBasedOn").Select(v => v.ErrorMessage).FirstOrDefault() ?? "The Eff Based On field is required." })
                                    <span asp-validation-for="EffBasedOn"></span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group float-label">
                                    <label asp-for="EffStartDate"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("EffStartDate") { Value = Model.EffStartDate })
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="form-group float-label">
                                    <label asp-for="EffEndDate"></label>
                                    @await Component.InvokeAsync("DatePicker", new DatePickerOptions("EffEndDate") { Value = Model.EffEndDate })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group float-label">
                                    <label asp-for="FollowupAction"></label>
                                    @await Component.InvokeAsync("ComboBox",
                                    new
                                    {
                                        name = "FollowupAction",
                                             action = "GetCountryLawFollowUpList",
                                             controller = "ActionType",
                                             defaultValue = Model.FollowupAction,
                                        textProperty = "ActionType",
                                             data = "tmkCountryLawPage.getCountry"
                                    })
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                @if (Model.CDueId > 0)
                {
                    <div class="content-stamp">
                        <vc:record-stamps created-by="@Model.UserID" date-created="@Model.DateCreated" updated-by="@Model.UserID" last-update="@Model.LastUpdate" t-stamp="null"></vc:record-stamps>
                    </div>
                }
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                    <button type="submit" class="btn btn-primary"><i class="fa fa-check pr-2"></i>@Localizer["Save"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
