@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="row mt-3">
    <div class="col">
        @if (ViewData["SuccessMessage"] == null)
        {
            <div class="card card-account border-secondary mx-auto">
                <h3 class="card-header bg-transparent border-0 mt-0 text-center">@ViewData["Title"]</h3>
                <div class="card-body">
                    <div class="card-title">Enter your email address and we'll send you a link to reset your password.</div>
                    <form id="forgotPassword" asp-action="ForgotPassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="list-unstyled alert alert-danger alert-dismissible mb-4" role="alert">
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                        </div>
                        <div class="form-group float-label">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" asp-is-autofocus="true" class="form-control form-control-sm" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="form-group pt-4">
                            <button type="submit" class="btn btn-primary btn-block-xs">Send</button>
                        </div>

                        <div class="form-group pt-2">
                            <p>
                                <a asp-area="" asp-controller="Account" asp-action="Login">Back to Log in</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="card card-account border-secondary mx-auto">
                <h3 class="card-header bg-transparent border-0 mt-0 text-center">@ViewData["Title"]</h3>
                <div class="card-body">
                    <p class="card-text">@Html.Raw(ViewData["SuccessMessage"])</p>
                    <p class="card-text text-center">
                        <a asp-area="" asp-controller="Account" asp-action="Login" class="btn btn-primary">Back to Log in</a>
                    </p>
                </div>
            </div>
        }
    </div>
</div>
@*@section Scripts {
            @await Html.PartialAsync("_ValidationScriptsPartial")
    }*@

@section Scripts {
    <script>
        $(document).ready(function () {
            $("#forgotPassword").floatLabels();
        })
    </script>
}