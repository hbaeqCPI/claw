@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<header>
    <h3 class="text-danger"><span class="far fa-exclamation-circle text-danger"></span> @ViewData["Title"]</h3>
    <p class="text-danger">An error occurred while processing your request.</p>
</header>

@if (Model.ShowRequestId)
{
    <code><label>Request ID:</label> @Model.RequestId</code>
}

