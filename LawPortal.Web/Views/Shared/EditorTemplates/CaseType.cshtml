@model CaseTypeLookupDTO
@{
    var headerTemplate = "<div class='row border-bottom'><div class='col-md-2 mt-2 mb-2'><span>&nbsp;&nbsp;Code</span></div><div class='col-md-5 mt-2 mb-2'><span>Description</span></div></div>";
    var template = "<div class='row'><div class='col-md-2'><span>#: data.CaseType #</span></div><div class='col-md-5'><span>#: data.CaseTypeName #</span></div></div>";
}

@(Html.Kendo().ComboBoxFor(m => m)
            .DataTextField("CaseType")
            .DataValueField("CaseType")
            .AutoWidth(true)
            .AutoBind(false)
                .DataSource(source =>
                {
                    source.Read(read =>
                    {
                        string parentFilter = ViewData["parentfilter"] != null ? ViewData["parentfilter"].ToString() : "";
                        read.Action(ViewData["action"].ToString(), ViewData["controller"].ToString(), new { area = ViewData["area"].ToString() }).Data(parentFilter);
                    })
                    .ServerFiltering(false);
                })
            .Filter(FilterType.Contains)
            .Template(template)
            .HeaderTemplate(headerTemplate)
            .HtmlAttributes(new { style = "width: 100%" })

)

