@using Microsoft.Extensions.Primitives
@using LawPortal.Web.Models.AuthorizationViewModels

@inject IStringLocalizer<SharedResource> Localizer
@model LogoutViewModel

@{
    ViewData["Title"] = Localizer["Sign Out"].Value;
    var logoutLabel = Localizer["Are you sure you want to sign out?"];
}

<div class="login-header">
    <div class="login-brand"></div>
</div>

<div class="row mt-3">
    <div class="col">
        <div class="card card-account border-secondary mx-auto">
            <h3 class="card-header bg-transparent border-0 mt-0 text-center">@ViewData["Title"]</h3>
            <div class="card-body pb-4">
                <div class="form-group">
                    @logoutLabel
                </div>
                <form asp-controller="Authorization" asp-action="Logout" method="post">
                    <input type="hidden" name="request_id" value="@Model.RequestId" />
                    <input type="hidden" name="post_logout_redirect_uri" value="@Model.PostLogoutRedirectUri" />
                    <div class="form-group p-3 k-centered">
                        <input class="btn btn-primary btn-block-xs text-white" name="Confirm" type="submit" value="Yes" />
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
