{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(local);Database=LawPortalCPiR10;Trusted_Connection=True;Max Pool Size = 300;Encrypt=false;MultipleActiveResultSets=true; Persist Security Info=true;",
    "CTMConnection": "Server=(local);Database=CTM_DB;Trusted_Connection=True;Encrypt=false;",
    "WebUpdatesConnection": "Server=(local);Database=WebUpdates;Trusted_Connection=True;Encrypt=false;MultipleActiveResultSets=true;"
  },

  "Logging": {
    "Console": {
      "IncludeScopes": false
    },
    "LogLevel": {
      "Default": "Error",
      "System": "Information",
      "Microsoft": "Information"
    }
  },

  "Report": {
    "ReportServiceUrl": "http://localhost/ReportServer/ReportExecution2005.asmx?wsdl",
    //ReportDeployServiceUrl seperate by '|' if there are multiple Report Server need to deploy
    "ReportDeployServiceUrls": "http://localhost/ReportServer/ReportService2005.asmx?wsdl",
    "UseNtlmAuthentication": false,
    "UserName": "",
    "Password": "",
    "Domain": "",
    "ClientFolder": "/CLIENTNAME/Reports/",
    "ClientApiUrl": "https://localhost/demo/api", //must use https otherwise OpenIddict 3.0 authentication fails
    "MaxFileSizeInMB": 25,
    "AllowedIPPrefix": "0.,10.,172.,192.,104.210.10.21",
    "ReportServerDomain": ".cpacki.com",
    "CloseTimeoutInMinutes": 3,
    "OpenTimeoutInMinutes": 3,
    "ReceiveTimeoutInMinutes": 3,
    "SendTimeoutInMinutes": 3
  },

  "UpdateService": {
    "UpdateServiceReportPath": "https://r9.computerpackages.com/rts/ReportLog"
  },

  "AMSSendToCPiService": {
    "EndpointUrl": "https://utility2.computerpackages.com/cpiWebServices/cpiEARSCommunication.asmx", //overrides url in tblPubOptions settings
    "TimeoutInSeconds": 180,
    "ErrorNotificationRecipients": "jdivinagracia@computerpackages.com",
    "DebugMode": false
  },

  "Cpi": {
    "Password": {
      "ExpireDays": 0, //number of days before password expires.
      "LastUnique": 0, //number of previous passwords that cannot be reused.
      "CanHavePartsOfName": false, //restrict parts of username in password.
      "MinimumCharsFromName": 0, //number of characters from username that is not allowed in password.
      "NamePartsSeparator": " -_." //list of possible characters that separate name parts.
    },
    "SignIn": {
      "InactiveDays": 0, //number of days without logging in before account is flagged inactive.
      "AllowSaveEmail": true, //show "Remember me" on login screen.
      "AllowStaySignedIn": true, //show "Keep me signed in" checkbox on login screen.
      "RequireTwoFactorAuthentication": false, //user needs to enable two-factor authentication from My Account
      "RequireExternalLoginTwoFactor": false, //SSO user needs to enable two-factor authentication from My Account
      "RequireSSODomains": [], //force domain users to login using sso
      "ActivationPeriodInDays": 0 //new accounts are disabled if not used within activation period.
    },
    "Lockout": {
      "DisableAccount": false //update status to disabled when account is locked out.
    },
    "Registration": {
      "Allowed": true, //allow self-registration
      "AllowedForExernalLogin": false, //allow SSO self-registration
      "ValidEmailDomains": [ "computerpackages.com", "cpi.email", "cpiip.com" ] //email domain validation
    },
    "ExternalLogin": {
      "AutoRegister": false, //automatically create new external login.
      "AutoLink": false, //automatically link external login with existing CPI account if emails match.
      "RoleAttributeName": "CpiRole", //claim type that contains Claim defined in tblCPiSSOClaimSystemRoles.
      "RequireRoleAttribute": false, //registration is only allowed if RoleAttributeName is passed.
      "NeedsApproval": false, //for user provisioning. true=sets status to CPiUserStatus.Pending, false=keep default status in CPiUser.NewExternalLogin
      "DisablePassword": false //for user provisioning. sets CannotChangePassword and ExternalLoginOnly to true so user cannot login using user/password and must use SSO
    },
    "Cookie": {
      "StaySignedInTimeSpan": "14.00:0:00.0000", //authentication cookie ExpireTimeSpan.
      "ValidationTimeSpan": "00:05:00" //defaults to 30 minutes. set to zero to enable immediate logout after updating the user profile.
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "LawPortal.Web.Controllers.MailsController": "Information",
        "LawPortal.Web.Controllers.AccountController": "Information",
        "LawPortal.Web.Services.BackgroundTaskService": "Information",
        "LawPortal.Web.Services.ScheduledTaskService": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Server=(local);Database=SQL_R10;Trusted_Connection=True;MultipleActiveResultSets=true;Encrypt=false",
          "tableName": "Logs"
        }
      }
    ]
  },

  "Identity": {
    "Password": {
      "RequireDigit": true, //password must contain a digit.
      "RequiredLength": 8, //minimum password length.
      "RequireNonAlphanumeric": false, //password must contain a non-alphanumeric character. 
      "RequireUppercase": "true", //password must contain a upper case ASCII character.
      "RequireLowercase": "true", //password must contain a lower case ASCII character.
      "RequiredUniqueChars": 6 //minimum number of unique characters which a password must contain.
    },
    "Lockout": {
      "DefaultLockoutTimeSpan": "0.00:30:00.0000", //lock out expiration before user is allowed to log back in.
      "MaxFailedAccessAttempts": 10, //number of failed login attempts before account is locked out.
      "AllowedForNewUsers": true //new users can be locked out
    },
    "User": {
      "RequireUniqueEmail": true, //email must be unique when creating new accounts.
      "AllowedUserNameCharacters": "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-._@+'`" //list of allowed characters in the username used to validate user names
    },
    "SignIn": {
      "RequireConfirmedEmail": false //email address confirmation is needed before user is allowed to login.
    }
  },

