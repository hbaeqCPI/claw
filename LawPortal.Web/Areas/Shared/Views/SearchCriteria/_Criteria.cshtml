@model SearchCriteria
@inject IStringLocalizer<SharedResource> Localizer
@{ 
    var load = ViewBag.Action == "Load";
}
    <div class="modal fade" id="saveSearchCriteriaDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <form id="saveSearchCriteria" method="post" asp-action="@ViewBag.Action">
                    <div class="modal-header py-1">
                        <h4 class="modal-title">@ViewBag.Title</h4>
                        <button type="button" class="close pt-3" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body py-1">
                        <div class="d-flex justify-content-between">
                            <div class="form-group float-label w-100 pr-2">
                                <label>@Localizer["Name"]</label>
                                @await Component.InvokeAsync("ComboBox", new
                           {
                               name = "CriteriaName",
                               textProperty = "CriteriaName",
                               valueProperty = "CriteriaName",
                               controller = "SearchCriteria",
                               action = "GetCriteriaNames",
                               validationMessage = Localizer["Criteria Name is required"].ToString(),
                               data = $"{{screen: '{Model.ScreenName}',loginName: '{Model.LoginName}'}}",
                               onSelect = "pageHelper.onSearchCriteriaNameChange",
                               screen = "save-criteria"
                           })
                            </div>
                            <div class='pt-2'>
                                <input class='k-checkbox k-valid' data-val='true' id='IsDefault' name='IsDefault' type='checkbox' value='true'><label class='k-checkbox-label' for='IsDefault'>@Localizer["Default?"]</label>
                                <input id='IsDefault' name='IsDefault' type='hidden' value='false' class='k-valid'>
                            </div>
                            <input type="hidden" name="ScreenName" value="@Model.ScreenName" />
                            <input type="hidden" name="CriteriaData" value="@Model.CriteriaData" />
                            <input type="hidden" name="LoadType" id="LoadType" />
                            <input type="hidden" name="OldCriteriaName" id="OldCriteriaName" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <div class="modal-footer-buttons">
                            <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                            @if (load)
                            {
                                <button type="submit" class="btn btn-danger btn-action btn-action-delete"><i class="pr-2 fa fa-trash-alt"></i><span>@Localizer["Delete"]</span></button>
                                <button type="submit" class="btn btn-primary btn-action btn-action-update"><i class="fal fa-pencil pr-2"></i>@Localizer["Update Settings"]</button>
                            }

                            <button type="submit" class="btn btn-primary btn-action btn-action-load"><i class="fa fa-check pr-2"></i>@Localizer[ViewBag.Action]</button>
                        </div>

                    </div>
                </form>
            </div>
        </div>
    </div>

<script>
    $(".btn-action-load").on("click",function() {
        if ($("#CriteriaName_save-criteria").val()=="" && $("[name='CriteriaName_input']").val() > "") {
            $("#CriteriaName_save-criteria").val($("[name='CriteriaName_input']").val());
        }
    });
</script>

