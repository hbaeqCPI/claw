@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="cpiSystemSearchMainTabContent" aria-labelledby="cpiSystemSearchMainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="SystemName">@Localizer["System Name"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "SystemName", multiSelect = true })
                </div>
            </div>
        </div>
    </div>
</div>
