@model AppSystem
@inject IStringLocalizer<SharedResource> SharedLocalizer
@{
    var id = Model.SystemId;
    var addMode = id == 0;

    var detailPagePermission = (DetailPagePermission)ViewData["PagePermission"];
    // Systems are preset — always read-only, no add/delete
    bool isReadOnly = true;
}

<form cpi-detail-form action="Save" delete-message="This system will be removed from all records. This operation cannot be undone.">
    <input type="hidden" asp-for="SystemId" />
    @await Component.InvokeAsync("DetailPageNavLinks", new { pagePermission = detailPagePermission, title = "", addMode = addMode })

    <div class="page-content detail cpiMainEntry">
        <div class="form-row">
            <div class="col-6 col-sm-4 col-md-4 col-lg-3 col-xl-2">
                <div class="form-group float-label">
                    <label asp-for="SystemName"></label>
                    <input type="text" class="form-control form-control-sm" asp-for="SystemName" asp-is-readonly="true" />
                    <span asp-validation-for="SystemName"></span>
                </div>
            </div>
        </div>
    </div>
    @if (!addMode)
    {
        <div class="content-stamp">
            @await Component.InvokeAsync("RecordStamps", new { createdBy = Model.CreatedBy, dateCreated = Model.DateCreated, updatedBy = Model.UpdatedBy, lastUpdate = Model.LastUpdate })
        </div>
    }
</form>
