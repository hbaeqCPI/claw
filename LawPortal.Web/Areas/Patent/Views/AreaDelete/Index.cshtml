@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Area Delete"];
    ViewData["ActivePage"] = "patAreaDeletePage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof patAreaDeletePage === 'undefined') { var patAreaDeletePage = new ActivePage(); }
patAreaDeletePage.mainSearchRecordIds = patAreaDeletePage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)
