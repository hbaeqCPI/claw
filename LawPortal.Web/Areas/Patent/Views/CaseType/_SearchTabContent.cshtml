@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer

<div class="tab-content search page-content">
    <div class="tab-pane show active" id="caseTypeSearchMainTabContent" aria-labelledby="caseTypeSearchMainTab" role="tabpanel">
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="CaseType">@Localizer["Case Type"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "CaseType", multiSelect = true })
                </div>
            </div>
            <div class="col-md-8">
                <div class="form-group float-label">
                    <label for="Description">@Localizer["Description"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "Description", multiSelect = true })
                </div>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="SystemName">@Localizer["Systems"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "SystemName", controller = "System", area = "Shared", action = "GetPicklistData", multiSelect = true })
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group float-label">
                    <label for="UserID">@Localizer["User ID"]</label>
                    @await Component.InvokeAsync("ComboBox", new { name = "UserID", multiSelect = true })
                </div>
            </div>
        </div>
    </div>
</div>
