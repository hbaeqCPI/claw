@inject IStringLocalizer<SharedResource> Localizer
@{
    var sourceArea = ViewBag.SourceArea as string ?? "";
    var sourceCountry = ViewBag.SourceCountry as string ?? "";
    var sourceSystems = ViewBag.SourceSystems as string ?? "";
}

<div class="modal fade" id="patAreaCountryCopyDialog" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <form method="post" asp-action="EditCopied">
                <div class="modal-header py-1">
                    <h4 class="modal-title">@Localizer["Copy Area Country"]</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body pt-0">
                    <input type="hidden" name="SourceArea" value="@sourceArea" />
                    <input type="hidden" name="SourceCountry" value="@sourceCountry" />
                    <input type="hidden" name="SourceSystems" value="@sourceSystems" />
                    <p>@Localizer["This will create a copy of"] <strong>@sourceArea / @sourceCountry</strong>.</p>
                    <p>@Localizer["You can modify the values after copying."]</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fa fa-undo-alt pr-2"></i>@Localizer["Cancel"]</button>
                    <button type="submit" class="btn btn-primary"><i class="fa fa-check pr-2"></i>@Localizer["Copy"]</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    $(document).ready(function () {
        patAreaCountryPage.showCopyScreen();
    });
</script>
