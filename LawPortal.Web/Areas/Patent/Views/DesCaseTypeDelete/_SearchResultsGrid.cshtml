@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using LawPortal.Web.Areas.Shared.ViewModels

@{
    var baseDetailUrl = Url.Action("Detail", "DesCaseTypeDelete", new { intlCode = "__IC__", caseType = "__CT__", desCountry = "__DC__", desCaseType = "__DCT__", intlCodeNew = "__ICN__", caseTypeNew = "__CTN__", desCountryNew = "__DCN__", desCaseTypeNew = "__DCTN__", systems = "__SY__", fromSearch = true });
    var extDetailUrl = Url.Action("Detail", "DesCaseTypeDeleteExt", new { intlCode = "__IC__", caseType = "__CT__", desCountry = "__DC__", desCaseType = "__DCT__", intlCodeNew = "__ICN__", caseTypeNew = "__CTN__", desCountryNew = "__DCN__", desCaseTypeNew = "__DCTN__", systems = "__SY__", fromSearch = true });
    var detailTemplate = "<a href='#= (IsExt ? \""
        + extDetailUrl
        + "\" : \""
        + baseDetailUrl
        + "\").replace(\"__IC__\", encodeURIComponent(IntlCode||\"\")).replace(\"__CT__\", encodeURIComponent(CaseType||\"\")).replace(\"__DC__\", encodeURIComponent(DesCountry||\"\")).replace(\"__DCT__\", encodeURIComponent(DesCaseType||\"\")).replace(\"__ICN__\", encodeURIComponent(IntlCodeNew||\"\")).replace(\"__CTN__\", encodeURIComponent(CaseTypeNew||\"\")).replace(\"__DCN__\", encodeURIComponent(DesCountryNew||\"\")).replace(\"__DCTN__\", encodeURIComponent(DesCaseTypeNew||\"\")).replace(\"__SY__\", encodeURIComponent(Systems||\"\")) #' class='details-link'>#: IntlCode #</a>";
}

@(Html.Kendo().Grid<DesCaseTypeDeleteSearchItem>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.IntlCode).ClientTemplate(detailTemplate).Width(120);
        columns.Bound(m => m.CaseType).Width(100);
        columns.Bound(m => m.DesCountry).Width(120);
        columns.Bound(m => m.DesCaseType).Width(120);
        columns.Bound(m => m.Systems).Width(200);
        columns.Bound(m => m.IsExt).Title("_Ext").Width(80)
            .ClientTemplate("#: IsExt ? '\\u2713' : '' #");
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplateTwoAdd(
        Url.Action("Add", "DesCaseTypeDelete", new { fromSearch = true }), Localizer["Add"],
        Url.Action("Add", "DesCaseTypeDeleteExt", new { fromSearch = true }), Localizer["Add _Ext"],
        Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("DesCaseTypeDeleteList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DesCaseTypeDelete")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("patDesCaseTypeDeletePage.searchResultGridError"))
        .Events(events => events.RequestEnd("patDesCaseTypeDeletePage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "DesCaseTypeDelete").Data("patDesCaseTypeDeletePage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)
