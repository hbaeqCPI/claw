@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Des Case Type Delete"];
    ViewData["ActivePage"] = "patDesCaseTypeDeletePage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof patDesCaseTypeDeletePage === 'undefined') { var patDesCaseTypeDeletePage = new ActivePage(); }
patDesCaseTypeDeletePage.mainSearchRecordIds = patDesCaseTypeDeletePage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)
