@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["CountryExp Delete"];
    ViewData["ActivePage"] = "patCountryExpDeletePage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof patCountryExpDeletePage === 'undefined') { var patCountryExpDeletePage = new ActivePage(); }
patCountryExpDeletePage.mainSearchRecordIds = patCountryExpDeletePage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)
