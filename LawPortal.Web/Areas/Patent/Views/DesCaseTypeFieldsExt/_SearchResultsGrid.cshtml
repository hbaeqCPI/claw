@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@using LawPortal.Core.Entities.Patent

@(Html.Kendo().Grid<PatDesCaseTypeFieldsExt>()
    .Name($"{Model.PageId}-Grid")
    .Columns(columns =>
    {
        columns.Bound(m => m.DesCaseType).ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { desCaseType = "#: DesCaseType#", fromField = "#: FromField#", toField = "#: ToField#", systems = "#: Systems#", fromSearch = true }), "DesCaseType")).Width(150);
        columns.Bound(m => m.FromField).Width(200);
        columns.Bound(m => m.ToField).Width(200);
        columns.Bound(m => m.InUse).ClientTemplate("#: InUse ? '\\u2713' : '' #").Width(80);
        columns.Bound(m => m.Systems).Width(300);
    })
    .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
    .AutoBind(false)
    .Pageable(page => page.Refresh(true).PageSizes(new[] { 10, 25, 50 }))
    .Sortable(sort => sort.AllowUnsort(false))
    .Excel(excel => excel.FileName("DesCaseTypeFieldsExtList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "DesCaseTypeFieldsExt")))
    .DataSource(dataSource => dataSource.Ajax()
        .Events(events => events.Error("patDesCaseTypeFieldsExtPage.searchResultGridError"))
        .Events(events => events.RequestEnd("patDesCaseTypeFieldsExtPage.searchResultGridRequestEnd"))
        .PageSize(25)
        .Read(read => read.Action("PageRead", "DesCaseTypeFieldsExt").Data("patDesCaseTypeFieldsExtPage.gridMainSearchFilters")))
    .HtmlAttributes(new { @class = "kendo-Grid" })
)