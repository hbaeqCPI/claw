@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Des Case Type Fields Ext"];
    ViewData["ActivePage"] = "patDesCaseTypeFieldsExtPage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof patDesCaseTypeFieldsExtPage === 'undefined') { var patDesCaseTypeFieldsExtPage = new ActivePage(); }
patDesCaseTypeFieldsExtPage.mainSearchRecordIds = patDesCaseTypeFieldsExtPage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)