@model PageViewModel
@inject IStringLocalizer<SharedResource> Localizer
@{
    ViewData["Title"] = Localizer["Des Case Type Fields"];
    ViewData["ActivePage"] = "patDesCaseTypeFieldsPage";
}
@section Scripts {
    <script>var @ViewBag.ActivePage = new ActivePage();</script>
}
<script>
if (typeof patDesCaseTypeFieldsPage === 'undefined') { var patDesCaseTypeFieldsPage = new ActivePage(); }
patDesCaseTypeFieldsPage.mainSearchRecordIds = patDesCaseTypeFieldsPage.mainSearchRecordIds || [];
</script>
@await Html.PartialPageAsync(Model.Page, Model)