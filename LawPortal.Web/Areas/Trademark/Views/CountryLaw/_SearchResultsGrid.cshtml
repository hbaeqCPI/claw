@model PageViewModel
@inject IStringLocalizer<CountryLawResource> Localizer
@inject ISystemSettings<DefaultSetting> Settings
@{
    var settings = await Settings.GetSetting();
}

@(Html.Kendo().Grid<TmkCountryLawSearchViewModel>()
                                        .Name($"{Model.PageId}-Grid")
                                        .Columns(columns =>
                                        {
                                            columns.Bound(c => c.CountryName)
                                                .Width(420)
                                                .HtmlAttributes(new { style = "white-space: nowrap;" })
                                                .ClientTemplate(Model.DetailsLinkTemplate(Url.Action("Detail", new { country = "#: Country#", caseType = "#: CaseType#", systems = "#: Systems#", fromSearch = true }), "CountryName"));
                                            columns.Bound(c => c.Country).Title("Country Code").Width(130);
                                            columns.Bound(c => c.CaseType);
                                            columns.Bound(c => c.Systems);
                                            columns.Bound(c => c.UserID).Hidden();
                                            columns.Bound(c => c.DateCreated).Format("{0:dd-MMM-yyyy}").Hidden();
                                            columns.Bound(c => c.LastUpdate).Format("{0:dd-MMM-yyyy}").Hidden();
                                        })
                                        .ToolBar(tools => tools.ClientTemplate(Model.ToolbarTemplate(Url.Action("Add", new { fromSearch = true }), Localizer["Add"], Localizer["Export to Excel"])))
                                        .AutoBind(false)
                                        .Pageable(page => page.PageSizes(settings.SearchResultsPageSizeOptions).Refresh(true))
                                        .Sortable(sort => sort.AllowUnsort(false))
                                        .Excel(excel => excel.FileName("CountryLawList.xlsx").AllPages(true).ProxyURL(Url.Action("ExcelExportSave", "CountryLaw")))
                                        .DataSource(dataSource => dataSource
                                            .Ajax()
                                            .Events(events => events.Error("tmkCountryLawPage.searchResultGridError"))
                                            .Events(events => events.RequestEnd("tmkCountryLawPage.searchResultGridRequestEnd"))
                                            .PageSize(User.GetSearchResultsPageSize(settings.SearchResultsPageSize))
                                            .Read(read => read.Action("PageRead", "CountryLaw")
                                            .Data("tmkCountryLawPage.gridMainSearchFilters")
                                            )
                                        .Sort(sort => sort.Add(c => c.CountryName))
                                    )
                                    .HtmlAttributes(new { @class = "kendo-Grid" })
)
